    }

    .affiliate-header {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: var(--space-md);
    }

    .affiliate-header svg {
      width: 18px;
      height: 18px;
      color: #ff9900;
    }

    .affiliate-links {
      display: flex;
