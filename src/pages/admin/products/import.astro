---
export const prerender = false;

import AdminLayout from '@components/admin/AdminLayout.astro';
import siteConfig from '@data/site-config.json';

const affiliateTag = siteConfig.amazon.associates.en.tag;
const affiliateTagEs = siteConfig.amazon.associates.es.tag;
---

<AdminLayout title="Importar Producto">
  <div class="import-container">
    <!-- Header -->
    <div class="page-header">
      <div class="header-content">
        <h1>Importar Producto</h1>
        <p>Extrae datos de Amazon automaticamente o ingresa manualmente</p>
      </div>
      <div class="header-actions">
        <a href="/admin/products" class="btn-back">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          Volver
        </a>
      </div>
    </div>

    <!-- Main Grid -->
    <div class="import-grid">
      <!-- Left Column: Input -->
      <div class="input-column">
        <!-- URL/ASIN Input Card -->
        <div class="card input-card">
          <div class="card-header">
            <div class="card-icon amazon">
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M.045 18.02c.072-.116.187-.124.348-.022 3.636 2.11 7.594 3.166 11.87 3.166 2.852 0 5.668-.533 8.447-1.595l.315-.14c.138-.06.234-.1.293-.13.226-.088.39-.046.525.13.12.174.09.336-.12.48-.256.19-.6.41-1.006.654-1.244.743-2.64 1.316-4.185 1.726a17.617 17.617 0 01-4.803.623c-2.418 0-4.727-.45-6.932-1.352-2.19-.9-4.097-2.092-5.752-3.54zM10.165 15.3c-.15-.18-.227-.39-.227-.63 0-.232.068-.42.205-.566.136-.15.306-.225.51-.225.232 0 .44.09.624.27.186.18.278.39.278.63 0 .18-.06.338-.18.47-.118.13-.265.22-.44.27l-.77.17v1.31c0 .2-.07.375-.21.52-.14.147-.31.22-.51.22-.2 0-.37-.073-.51-.22-.14-.145-.21-.32-.21-.52v-1.7zm3.28 1.7c0 .2-.07.375-.21.52-.14.147-.31.22-.51.22-.2 0-.37-.073-.51-.22-.14-.145-.21-.32-.21-.52V15c0-.2.07-.375.21-.52.14-.147.31-.22.51-.22.2 0 .37.073.51.22.14.145.21.32.21.52v2z"/>
              </svg>
            </div>
            <div>
              <h2>Buscar Producto</h2>
              <p>Ingresa URL de Amazon, ASIN o enlace de SiteStripe</p>
            </div>
          </div>

          <div class="input-group">
            <div class="input-wrapper">
              <input
                type="text"
                id="amazonUrl"
                class="main-input"
                placeholder="amazon.com/dp/B0XXX o ASIN..."
                autocomplete="off"
                spellcheck="false"
              />
              <button type="button" id="clearInput" class="clear-btn" style="display: none;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
              </button>
            </div>
            <button type="button" id="parseBtn" class="btn-extract">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
              </svg>
              <span>Buscar</span>
            </button>
          </div>

          <!-- Quick Tips -->
          <div class="tips-inline">
            <span class="tip-item">
              <kbd>B0XXXXXXXXX</kbd> ASIN
            </span>
            <span class="tip-item">
              <kbd>amazon.com/dp/...</kbd> URL
            </span>
            <span class="tip-item">
              <kbd>amzn.to/...</kbd> Short
            </span>
          </div>
        </div>

        <!-- Status Messages -->
        <div id="statusMessage" class="status-message"></div>

        <!-- Product Preview Card (shows after extraction) -->
        <div id="productPreview" class="card product-preview-card" style="display: none;">
          <div class="preview-header">
            <span class="preview-badge">Vista Previa</span>
            <span class="preview-source" id="dataSource">-</span>
          </div>

          <div class="preview-content">
            <!-- Product Image -->
            <div class="preview-image-container">
              <img id="previewImage" src="" alt="Product" class="preview-image" />
              <div class="image-placeholder" id="imagePlaceholder">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <polyline points="21 15 16 10 5 21"/>
                </svg>
                <span>Sin imagen</span>
              </div>
            </div>

            <!-- Product Info -->
            <div class="preview-info">
              <h3 id="previewTitle" class="preview-title">-</h3>
              <p id="previewBrand" class="preview-brand">-</p>

              <div class="preview-meta">
                <div class="meta-item">
                  <span class="meta-label">ASIN</span>
                  <code id="previewAsin">-</code>
                </div>
                <div class="meta-item">
                  <span class="meta-label">Precio</span>
                  <span id="previewPrice" class="price-value">-</span>
                </div>
                <div class="meta-item" id="originalPriceItem" style="display: none;">
                  <span class="meta-label">Original</span>
                  <span id="previewOriginalPrice" class="price-original">-</span>
                </div>
                <div class="meta-item" id="discountItem" style="display: none;">
                  <span class="meta-label">Descuento</span>
                  <span id="previewDiscount" class="discount-badge">-</span>
                </div>
              </div>

              <!-- Keepa Price History -->
              <div id="keepaSection" class="keepa-section" style="display: none;">
                <div class="keepa-header">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                  </svg>
                  <span>Historial de Precios (Keepa)</span>
                </div>
                <div id="keepaChart" class="keepa-chart">
                  <img id="keepaImage" src="" alt="Keepa Price History" />
                </div>
                <div class="keepa-stats">
                  <div class="keepa-stat">
                    <span class="stat-label">Promedio 90d</span>
                    <span id="keepaAvg" class="stat-value">-</span>
                  </div>
                  <div class="keepa-stat">
                    <span class="stat-label">Minimo</span>
                    <span id="keepaMin" class="stat-value good">-</span>
                  </div>
                  <div class="keepa-stat">
                    <span class="stat-label">Maximo</span>
                    <span id="keepaMax" class="stat-value">-</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Affiliate Link Generator -->
          <div class="affiliate-section">
            <div class="affiliate-header">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
              </svg>
              <span>Enlace de Afiliado</span>
            </div>

            <div class="affiliate-links">
              <div class="link-row">
                <div class="link-marketplace">
                  <img src="https://flagcdn.com/w20/us.png" alt="US" />
                  <span>.com</span>
                </div>
                <input type="text" id="affiliateLinkUs" class="link-input" readonly />
                <button type="button" class="btn-copy" data-target="affiliateLinkUs" title="Copiar enlace">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                  </svg>
                </button>
              </div>
              <div class="link-row">
                <div class="link-marketplace">
                  <img src="https://flagcdn.com/w20/es.png" alt="ES" />
                  <span>.es</span>
                </div>
                <input type="text" id="affiliateLinkEs" class="link-input" readonly />
                <button type="button" class="btn-copy" data-target="affiliateLinkEs" title="Copiar enlace">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                  </svg>
                </button>
              </div>
            </div>

            <div class="affiliate-actions">
              <button type="button" id="openAmazonBtn" class="btn-amazon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                Abrir en Amazon
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column: Form -->
      <div class="form-column">
        <div class="card form-card" id="formCard">
          <div class="card-header">
            <div class="card-icon form">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
              </svg>
            </div>
            <div>
              <h2>Datos del Producto</h2>
              <p>Completa o edita la informacion</p>
            </div>
          </div>

          <form id="productForm" class="product-form">
            <input type="hidden" id="formAsin" name="asin" />
            <input type="hidden" id="formAffiliateUrl" name="affiliateUrl" />
            <input type="hidden" id="formLang" name="lang" value="en" />

            <div class="form-section">
              <h3 class="section-title">Informacion Basica</h3>

              <div class="form-group">
                <label for="formTitle">Titulo <span class="required">*</span></label>
                <input type="text" id="formTitle" name="title" class="form-input" required placeholder="Nombre del producto" />
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="formBrand">Marca <span class="required">*</span></label>
                  <input type="text" id="formBrand" name="brand" class="form-input" required placeholder="Ej: Samsung" />
                </div>
                <div class="form-group">
                  <label for="formModel">Modelo</label>
                  <input type="text" id="formModel" name="model" class="form-input" placeholder="Ej: Galaxy S24" />
                </div>
              </div>
            </div>

            <div class="form-section">
              <h3 class="section-title">Precios</h3>

              <div class="form-row">
                <div class="form-group">
                  <label for="formPrice">Precio Actual <span class="required">*</span></label>
                  <div class="input-with-prefix">
                    <span class="input-prefix">$</span>
                    <input type="number" id="formPrice" name="price" class="form-input" step="0.01" required placeholder="0.00" />
                  </div>
                </div>
                <div class="form-group">
                  <label for="formOriginalPrice">Precio Original</label>
                  <div class="input-with-prefix">
                    <span class="input-prefix">$</span>
                    <input type="number" id="formOriginalPrice" name="originalPrice" class="form-input" step="0.01" placeholder="Si tiene descuento" />
                  </div>
                </div>
              </div>
            </div>

            <div class="form-section">
              <h3 class="section-title">Clasificacion</h3>

              <div class="form-row">
                <div class="form-group">
                  <label for="formCategory">Categoria</label>
                  <select id="formCategory" name="category" class="form-select">
                    <option value="electronics">Electronica</option>
                    <option value="computers">Computadoras</option>
                    <option value="smartphones">Smartphones</option>
                    <option value="audio">Audio</option>
                    <option value="tv">TV & Video</option>
                    <option value="gaming">Gaming</option>
                    <option value="home">Hogar</option>
                    <option value="kitchen">Cocina</option>
                    <option value="sports">Deportes</option>
                    <option value="fashion">Moda</option>
                    <option value="beauty">Belleza</option>
                    <option value="other">Otro</option>
                  </select>
                </div>
                <div class="form-group">
                  <label for="formStatus">Estado</label>
                  <select id="formStatus" name="status" class="form-select">
                    <option value="draft">Borrador</option>
                    <option value="published">Publicado</option>
                  </select>
                </div>
              </div>
            </div>

            <div class="form-section">
              <h3 class="section-title">Contenido</h3>

              <div class="form-group">
                <label for="formShortDesc">Descripcion Corta</label>
                <textarea id="formShortDesc" name="shortDescription" class="form-textarea" placeholder="Breve descripcion del producto (1-2 oraciones)"></textarea>
              </div>

              <div class="form-group">
                <label for="formImage">URL de Imagen</label>
                <input type="url" id="formImage" name="featuredImage" class="form-input" placeholder="https://m.media-amazon.com/images/..." />
              </div>
            </div>

            <div class="form-actions">
              <button type="submit" class="btn-primary" id="submitBtn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                Crear Producto
              </button>
              <button type="button" id="resetBtn" class="btn-secondary">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
                  <path d="M3 3v5h5"/>
                </svg>
                Limpiar
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <style>
    .import-container {
      max-width: 1400px;
      margin: 0 auto;
    }

    /* Header */
    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: var(--space-md);
      margin-bottom: var(--space-lg);
      flex-wrap: wrap;
    }

    .header-content h1 {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 4px;
    }

    .header-content p {
      color: var(--text-muted);
      font-size: 0.875rem;
    }

    .btn-back {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 14px;
      background: var(--bg-surface);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-sm);
      color: var(--text-secondary);
      font-size: 0.8125rem;
      text-decoration: none;
      transition: all var(--duration) var(--ease);
    }

    .btn-back:hover {
      background: var(--bg-hover);
      color: var(--text-primary);
    }

    .btn-back svg {
      width: 16px;
      height: 16px;
    }

    /* Grid Layout */
    .import-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    @media (min-width: 1024px) {
      .import-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    /* Cards */
    .card {
      background: var(--bg-surface);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius);
      padding: var(--space-lg);
    }

    .card-header {
      display: flex;
      align-items: flex-start;
      gap: var(--space-md);
      margin-bottom: var(--space-lg);
    }

    .card-icon {
      width: 44px;
      height: 44px;
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .card-icon svg {
      width: 22px;
      height: 22px;
    }

    .card-icon.amazon {
      background: linear-gradient(135deg, #ff9900 0%, #ffad33 100%);
      color: #000;
    }

    .card-icon.form {
      background: linear-gradient(135deg, #6366f1 0%, #818cf8 100%);
      color: #fff;
    }

    .card-header h2 {
      font-size: 1rem;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 2px;
    }

    .card-header p {
      font-size: 0.8125rem;
      color: var(--text-muted);
    }

    /* Input Card */
    .input-group {
      display: flex;
      gap: var(--space-sm);
      margin-bottom: var(--space-md);
    }

    .input-wrapper {
      flex: 1;
      position: relative;
    }

    .main-input {
      width: 100%;
      background: var(--bg-base);
      border: 2px solid var(--border-default);
      border-radius: var(--radius-sm);
      padding: 14px 40px 14px 16px;
      color: var(--text-primary);
      font-size: 0.9375rem;
      font-family: 'JetBrains Mono', monospace;
      transition: all var(--duration) var(--ease);
    }

    .main-input:focus {
      outline: none;
      border-color: #ff9900;
      box-shadow: 0 0 0 4px rgba(255, 153, 0, 0.15);
    }

    .main-input::placeholder {
      font-family: 'Manrope', sans-serif;
      color: var(--text-muted);
    }

    .clear-btn {
      position: absolute;
      right: 10px;
      top: 50%;
      transform: translateY(-50%);
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--bg-hover);
      border: none;
      border-radius: 50%;
      color: var(--text-muted);
      cursor: pointer;
      transition: all var(--duration) var(--ease);
    }

    .clear-btn:hover {
      background: var(--bg-elevated);
      color: var(--text-primary);
    }

    .clear-btn svg {
      width: 14px;
      height: 14px;
    }

    .btn-extract {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 14px 24px;
      background: linear-gradient(135deg, #ff9900 0%, #ffad33 100%);
      color: #000;
      border: none;
      border-radius: var(--radius-sm);
      font-size: 0.9375rem;
      font-weight: 600;
      cursor: pointer;
      transition: all var(--duration) var(--ease);
      white-space: nowrap;
    }

    .btn-extract:hover:not(:disabled) {
      transform: translateY(-1px);
      box-shadow: 0 4px 20px rgba(255, 153, 0, 0.4);
    }

    .btn-extract:disabled {
      opacity: 0.7;
      cursor: not-allowed;
    }

    .btn-extract svg {
      width: 18px;
      height: 18px;
    }

    /* Tips */
    .tips-inline {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-sm);
    }

    .tip-item {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    .tip-item kbd {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6875rem;
      background: var(--bg-base);
      padding: 3px 8px;
      border-radius: 4px;
      border: 1px solid var(--border-subtle);
      color: var(--text-secondary);
    }

    /* Status Message */
    .status-message {
      padding: var(--space-sm) var(--space-md);
      border-radius: var(--radius-sm);
      margin-bottom: var(--space-md);
      display: none;
      align-items: center;
      gap: var(--space-sm);
      font-size: 0.8125rem;
      font-weight: 500;
    }

    .status-message.error {
      display: flex;
      background: var(--error-muted);
      border: 1px solid rgba(239, 68, 68, 0.3);
      color: var(--error);
    }

    .status-message.success {
      display: flex;
      background: var(--success-muted);
      border: 1px solid rgba(34, 197, 94, 0.3);
      color: var(--success);
    }

    .status-message.loading {
      display: flex;
      background: rgba(99, 102, 241, 0.1);
      border: 1px solid rgba(99, 102, 241, 0.3);
      color: #818cf8;
    }

    .status-message svg {
      width: 16px;
      height: 16px;
      flex-shrink: 0;
    }

    /* Product Preview Card */
    .product-preview-card {
      animation: slideUp 300ms var(--ease);
    }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .preview-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: var(--space-md);
      padding-bottom: var(--space-sm);
      border-bottom: 1px solid var(--border-subtle);
    }

    .preview-badge {
      font-size: 0.6875rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #818cf8;
      background: rgba(99, 102, 241, 0.1);
      padding: 4px 10px;
      border-radius: 20px;
    }

    .preview-source {
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    .preview-content {
      display: grid;
      grid-template-columns: 140px 1fr;
      gap: var(--space-md);
      margin-bottom: var(--space-lg);
    }

    @media (max-width: 480px) {
      .preview-content {
        grid-template-columns: 1fr;
      }
    }

    .preview-image-container {
      position: relative;
      aspect-ratio: 1;
      background: var(--bg-base);
      border-radius: var(--radius-sm);
      overflow: hidden;
    }

    .preview-image {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .image-placeholder {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 8px;
      color: var(--text-muted);
    }

    .image-placeholder svg {
      width: 32px;
      height: 32px;
      opacity: 0.5;
    }

    .image-placeholder span {
      font-size: 0.75rem;
    }

    .preview-info {
      display: flex;
      flex-direction: column;
      gap: var(--space-sm);
    }

    .preview-title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--text-primary);
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .preview-brand {
      font-size: 0.8125rem;
      color: var(--text-muted);
    }

    .preview-meta {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-sm);
      margin-top: auto;
    }

    .meta-item {
      display: flex;
      flex-direction: column;
      gap: 2px;
      background: var(--bg-base);
