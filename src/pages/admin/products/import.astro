    /* Keepa Section */
    .keepa-section {
      background: var(--bg-base);
      border-radius: var(--radius-sm);
      padding: var(--space-md);
      margin-top: var(--space-md);
    }

    .keepa-header {
      display: flex;
      align-items: center;
