---
export const prerender = false;

import AdminLayout from '@components/admin/AdminLayout.astro';
import { getAllCachedVideos, getCacheStats } from '@lib/video-cache';

// Get initial data
const initialFilter = 'all' as 'all' | 'visible' | 'hidden';
const { videos, total } = await getAllCachedVideos({ filter: initialFilter, limit: 50 });
const stats = await getCacheStats();

// Calculate video-specific stats
const videoStats = {
  total: stats.cache.withVideo,
  visible: videos.filter(v => !v.isHidden).length,
  hidden: videos.filter(v => v.isHidden).length,
  premium: videos.filter(v => v.isPremiumChannel).length,
  shorts: videos.filter(v => v.isShort).length,
};
---

<AdminLayout title="Videos">
  <style>
    .videos-page {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }

    /* Stats Grid */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-sm);
    }

    @media (min-width: 640px) {
      .stats-grid {
        grid-template-columns: repeat(5, 1fr);
        gap: var(--space-md);
      }
    }

    .stat-card {
      background: var(--bg-surface);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius);
      padding: var(--space-md);
      text-align: center;
    }

    .stat-value {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text-primary);
      font-feature-settings: 'tnum';
    }

    .stat-label {
      font-size: 0.75rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.03em;
      margin-top: 2px;
    }

    .stat-visible .stat-value {
      color: var(--success);
    }

    .stat-hidden .stat-value {
      color: var(--warning);
    }

    .stat-premium .stat-value {
      color: var(--accent);
    }

    /* Toolbar */
    .toolbar {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }

    @media (min-width: 768px) {
      .toolbar {
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
      }
    }

    .toolbar-left {
      display: flex;
      flex-direction: column;
      gap: var(--space-sm);
    }

    @media (min-width: 480px) {
      .toolbar-left {
        flex-direction: row;
        align-items: center;
        gap: var(--space-md);
      }
    }

    .filter-group {
      display: flex;
      gap: var(--space-sm);
    }

    .filter-btn {
      background: var(--bg-surface);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-sm);
      padding: 6px 12px;
      font-size: 0.8125rem;
      color: var(--text-muted);
      cursor: pointer;
      transition: all 0.15s;
    }

    .filter-btn:hover {
      border-color: var(--border-medium);
      color: var(--text-primary);
    }

    .filter-btn.active {
      background: var(--accent);
      border-color: var(--accent);
      color: white;
    }

    .video-count {
      font-size: 0.875rem;
      color: var(--text-muted);
    }

    .video-count strong {
      color: var(--text-primary);
      font-weight: 600;
    }

    /* Video Grid */
    .video-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    @media (min-width: 640px) {
      .video-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 1024px) {
      .video-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    /* Video Card */
    .video-card {
      background: var(--bg-surface);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius);
      overflow: hidden;
      transition: all 0.2s;
    }

    .video-card:hover {
      border-color: var(--border-medium);
    }

    .video-card.is-hidden {
      opacity: 0.6;
    }

    .video-card.is-hidden .video-thumbnail {
      filter: grayscale(0.5);
    }

    .video-thumbnail {
      position: relative;
      aspect-ratio: 16/9;
      background: var(--bg-subtle);
      overflow: hidden;
    }

    .video-thumbnail img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .video-badges {
      position: absolute;
      top: 8px;
      left: 8px;
      display: flex;
      gap: 4px;
      flex-wrap: wrap;
    }

    .video-badge {
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 0.625rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }

    .badge-premium {
      background: var(--accent);
      color: white;
    }

    .badge-short {
      background: #ff0000;
      color: white;
    }

    .badge-hidden {
      background: var(--warning);
      color: var(--bg);
    }

    .video-info {
      padding: var(--space-sm);
    }

    .video-title {
      font-size: 0.8125rem;
      font-weight: 500;
      color: var(--text-primary);
      margin-bottom: 4px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      line-height: 1.3;
    }

    .video-channel {
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-bottom: 8px;
    }

    .video-product {
      font-size: 0.6875rem;
      color: var(--text-muted);
      padding: 4px 8px;
      background: var(--bg-subtle);
      border-radius: var(--radius-sm);
      display: -webkit-box;
      -webkit-line-clamp: 1;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .video-actions {
      padding: var(--space-sm);
      padding-top: 0;
      display: flex;
      gap: var(--space-sm);
    }

    .action-btn {
      flex: 1;
      padding: 8px;
      border-radius: var(--radius-sm);
      font-size: 0.75rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.15s;
      text-align: center;
      border: 1px solid var(--border-subtle);
      background: var(--bg);
      color: var(--text-primary);
    }

    .action-btn:hover {
      border-color: var(--border-medium);
    }

    .action-btn.btn-hide {
      background: var(--warning);
      border-color: var(--warning);
      color: var(--bg);
    }

    .action-btn.btn-hide:hover {
      background: #d97706;
      border-color: #d97706;
    }

    .action-btn.btn-show {
      background: var(--success);
      border-color: var(--success);
      color: white;
    }

    .action-btn.btn-show:hover {
      background: #059669;
      border-color: #059669;
    }

    .action-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    /* Empty State */
    .empty-state {
      text-align: center;
      padding: var(--space-xl);
      color: var(--text-muted);
    }

    .empty-icon {
      font-size: 2rem;
      margin-bottom: var(--space-sm);
    }

    /* Loading state */
    .loading {
      pointer-events: none;
      opacity: 0.7;
    }
  </style>

  <div class="videos-page">
    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-value">{videoStats.total}</div>
        <div class="stat-label">Total</div>
      </div>
      <div class="stat-card stat-visible">
        <div class="stat-value" id="stat-visible">{videoStats.visible}</div>
        <div class="stat-label">Visibles</div>
      </div>
      <div class="stat-card stat-hidden">
        <div class="stat-value" id="stat-hidden">{videoStats.hidden}</div>
        <div class="stat-label">Ocultos</div>
      </div>
      <div class="stat-card stat-premium">
        <div class="stat-value">{videoStats.premium}</div>
        <div class="stat-label">Premium</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">{videoStats.shorts}</div>
        <div class="stat-label">Shorts</div>
      </div>
    </div>

    <!-- Toolbar -->
    <div class="toolbar">
      <div class="toolbar-left">
        <div class="filter-group">
          <button class="filter-btn active" data-filter="all">Todos</button>
          <button class="filter-btn" data-filter="visible">Visibles</button>
          <button class="filter-btn" data-filter="hidden">Ocultos</button>
        </div>
        <div class="video-count">
          Mostrando <strong id="showing-count">{videos.length}</strong> de <strong id="total-count">{total}</strong> videos
        </div>
      </div>
    </div>

    <!-- Video Grid -->
    <div class="video-grid" id="video-grid">
      {videos.length === 0 ? (
        <div class="empty-state">
          <div class="empty-icon">📹</div>
          <p>No hay videos en cache</p>
        </div>
      ) : (
        videos.map(video => (
          <div
            class={`video-card ${video.isHidden ? 'is-hidden' : ''}`}
            data-video-id={video.videoId}
            data-is-hidden={video.isHidden ? 'true' : 'false'}
          >
            <div class="video-thumbnail">
              {video.thumbnail ? (
                <img src={video.thumbnail} alt={video.videoTitle || 'Video thumbnail'} loading="lazy" />
              ) : (
                <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: var(--text-muted);">
                  Sin thumbnail
                </div>
              )}
              <div class="video-badges">
                {video.isPremiumChannel && <span class="video-badge badge-premium">Premium</span>}
                {video.isShort && <span class="video-badge badge-short">Short</span>}
                {video.isHidden && <span class="video-badge badge-hidden">Oculto</span>}
              </div>
            </div>
            <div class="video-info">
              <div class="video-title" title={video.videoTitle || ''}>
                {video.videoTitle || 'Sin título'}
              </div>
              <div class="video-channel">
                {video.channelTitle || 'Canal desconocido'}
              </div>
              <div class="video-product" title={video.productTitle}>
                {video.productTitle}
              </div>
            </div>
            <div class="video-actions">
              <a
                href={`https://www.youtube.com/watch?v=${video.videoId}`}
                target="_blank"
                rel="noopener noreferrer"
                class="action-btn"
              >
                Ver
              </a>
              <button
                class={`action-btn ${video.isHidden ? 'btn-show' : 'btn-hide'}`}
                data-action="toggle-visibility"
                data-video-id={video.videoId}
              >
                {video.isHidden ? 'Mostrar' : 'Ocultar'}
              </button>
            </div>
          </div>
        ))
      )}
    </div>
  </div>

  <script>
    // Filter functionality
    const filterBtns = document.querySelectorAll('.filter-btn');
    const videoGrid = document.getElementById('video-grid');
    const showingCount = document.getElementById('showing-count');
    const totalCount = document.getElementById('total-count');
    const statVisible = document.getElementById('stat-visible');
    const statHidden = document.getElementById('stat-hidden');

    let currentFilter = 'all';

    filterBtns.forEach(btn => {
      btn.addEventListener('click', async () => {
        const filter = btn.getAttribute('data-filter') as 'all' | 'visible' | 'hidden';
        if (filter === currentFilter) return;

        // Update active button
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentFilter = filter;

        // Fetch filtered data
        videoGrid?.classList.add('loading');
        try {
          const response = await fetch(`/api/admin/videos?filter=${filter}&limit=50`);
          const data = await response.json();

          if (data.success) {
            renderVideos(data.videos);
            if (showingCount) showingCount.textContent = data.videos.length;
            if (totalCount) totalCount.textContent = data.total;
          }
        } catch (error) {
          console.error('Error fetching videos:', error);
        } finally {
          videoGrid?.classList.remove('loading');
        }
      });
    });

    // Toggle visibility functionality
    document.addEventListener('click', async (e) => {
      const target = e.target as HTMLElement;
      if (target.getAttribute('data-action') !== 'toggle-visibility') return;

      const videoId = target.getAttribute('data-video-id');
      if (!videoId) return;

      const card = target.closest('.video-card') as HTMLElement;
      const isCurrentlyHidden = card?.getAttribute('data-is-hidden') === 'true';

      target.setAttribute('disabled', 'true');
      target.textContent = 'Guardando...';

      try {
        const response = await fetch('/api/admin/videos/hide', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ videoId, hide: !isCurrentlyHidden }),
        });

        const data = await response.json();

        if (data.success) {
          // Update card state
          if (card) {
            card.setAttribute('data-is-hidden', data.isHidden ? 'true' : 'false');

            if (data.isHidden) {
              card.classList.add('is-hidden');
              target.classList.remove('btn-hide');
              target.classList.add('btn-show');
              target.textContent = 'Mostrar';

              // Add hidden badge
              const badges = card.querySelector('.video-badges');
              if (badges && !badges.querySelector('.badge-hidden')) {
                const badge = document.createElement('span');
                badge.className = 'video-badge badge-hidden';
                badge.textContent = 'Oculto';
                badges.appendChild(badge);
              }
            } else {
              card.classList.remove('is-hidden');
              target.classList.remove('btn-show');
              target.classList.add('btn-hide');
              target.textContent = 'Ocultar';

              // Remove hidden badge
              const hiddenBadge = card.querySelector('.badge-hidden');
              hiddenBadge?.remove();
            }

            // Update stats
            const visibleVal = parseInt(statVisible?.textContent || '0');
            const hiddenVal = parseInt(statHidden?.textContent || '0');
            if (data.isHidden) {
              if (statVisible) statVisible.textContent = String(visibleVal - 1);
              if (statHidden) statHidden.textContent = String(hiddenVal + 1);
            } else {
              if (statVisible) statVisible.textContent = String(visibleVal + 1);
              if (statHidden) statHidden.textContent = String(hiddenVal - 1);
            }

            // If filtering, maybe hide the card
            if (currentFilter === 'visible' && data.isHidden) {
              card.style.display = 'none';
            } else if (currentFilter === 'hidden' && !data.isHidden) {
              card.style.display = 'none';
            }
          }
        } else {
          alert('Error: ' + (data.error || 'No se pudo actualizar'));
          target.textContent = isCurrentlyHidden ? 'Mostrar' : 'Ocultar';
        }
      } catch (error) {
        console.error('Error toggling visibility:', error);
        alert('Error de conexión');
        target.textContent = isCurrentlyHidden ? 'Mostrar' : 'Ocultar';
      } finally {
        target.removeAttribute('disabled');
      }
    });

    // Render videos helper
    function renderVideos(videos: any[]) {
      if (!videoGrid) return;

      if (videos.length === 0) {
        videoGrid.innerHTML = `
          <div class="empty-state">
            <div class="empty-icon">📹</div>
            <p>No hay videos con este filtro</p>
          </div>
        `;
        return;
      }

      videoGrid.innerHTML = videos.map(video => `
        <div
          class="video-card ${video.isHidden ? 'is-hidden' : ''}"
          data-video-id="${video.videoId}"
          data-is-hidden="${video.isHidden ? 'true' : 'false'}"
        >
          <div class="video-thumbnail">
            ${video.thumbnail ? `
              <img src="${video.thumbnail}" alt="${video.videoTitle || 'Video thumbnail'}" loading="lazy" />
            ` : `
              <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: var(--text-muted);">
                Sin thumbnail
              </div>
            `}
            <div class="video-badges">
              ${video.isPremiumChannel ? '<span class="video-badge badge-premium">Premium</span>' : ''}
              ${video.isShort ? '<span class="video-badge badge-short">Short</span>' : ''}
              ${video.isHidden ? '<span class="video-badge badge-hidden">Oculto</span>' : ''}
            </div>
          </div>
          <div class="video-info">
            <div class="video-title" title="${video.videoTitle || ''}">
              ${video.videoTitle || 'Sin título'}
            </div>
            <div class="video-channel">
              ${video.channelTitle || 'Canal desconocido'}
            </div>
            <div class="video-product" title="${video.productTitle}">
              ${video.productTitle}
            </div>
          </div>
          <div class="video-actions">
            <a
              href="https://www.youtube.com/watch?v=${video.videoId}"
              target="_blank"
              rel="noopener noreferrer"
              class="action-btn"
            >
              Ver
            </a>
            <button
              class="action-btn ${video.isHidden ? 'btn-show' : 'btn-hide'}"
              data-action="toggle-visibility"
              data-video-id="${video.videoId}"
            >
              ${video.isHidden ? 'Mostrar' : 'Ocultar'}
            </button>
          </div>
        </div>
      `).join('');
    }
  </script>
</AdminLayout>
