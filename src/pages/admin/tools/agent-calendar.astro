<script>
  // State
  let currentDate = new Date();
  let view: '3day' | 'week' = '3day';
  let calendarData: any = null;
  let complianceData: any = null;
  let draggedTask: HTMLElement | null = null;

  // DOM Elements
  const calendarGrid = document.getElementById('calendarGrid')!;
  const dateRange = document.getElementById('dateRange')!;
  const viewBtns = document.querySelectorAll('.view-btn');
  const prevBtn = document.getElementById('prevBtn')!;
  const nextBtn = document.getElementById('nextBtn')!;
  const todayBtn = document.getElementById('todayBtn')!;
  const scheduleModal = document.getElementById('scheduleModal')!;
  const scheduleForm = document.getElementById('scheduleForm') as HTMLFormElement;

  // Initialize
  async function init() {
    await Promise.all([
      loadCalendarData(),
      loadComplianceData(),
    ]);
    setupEventListeners();
  }

  // Load calendar data
  async function loadCalendarData() {
    try {
      const from = currentDate.toISOString().split('T')[0];
      const response = await fetch(`/api/admin/agents/calendar?view=${view}&from=${from}`);
      calendarData = await response.json();
      renderCalendar();
    } catch (error) {
      console.error('Error loading calendar:', error);
    }
  }

  // Load compliance data
  async function loadComplianceData() {
    try {
      const response = await fetch('/api/admin/agents/compliance?includeAlerts=true');
      complianceData = await response.json();
      renderCompliance();
      renderAlerts();
      renderTodayTasks();
      renderActiveShift();
    } catch (error) {
      console.error('Error loading compliance:', error);
    }
  }

  // Render calendar
  function renderCalendar() {
    if (!calendarData) return;

    const days = view === 'week' ? 7 : 3;
    calendarGrid.className = `calendar-grid ${view === 'week' ? 'week-view' : ''}`;

    // Remove old day columns
    const oldColumns = calendarGrid.querySelectorAll('.day-column');
    oldColumns.forEach(col => col.remove());

    // Update date range display
    const endDate = new Date(currentDate);
    endDate.setDate(endDate.getDate() + days - 1);
    dateRange.textContent = `${formatDate(currentDate)} - ${formatDate(endDate)}`;

    // Create day columns
    calendarData.days?.forEach((day: any, index: number) => {
      const column = createDayColumn(day, index);
      calendarGrid.appendChild(column);
    });
  }

  function createDayColumn(day: any, index: number): HTMLElement {
    const column = document.createElement('div');
    column.className = 'day-column';

    const date = new Date(day.date);
    const isToday = new Date().toDateString() === date.toDateString();

    // Header
    const header = document.createElement('div');
    header.className = `day-header ${isToday ? 'today' : ''}`;
    header.innerHTML = `
      <div class="day-name">${date.toLocaleDateString('es', { weekday: 'short' }).toUpperCase()}</div>
      <div class="day-date">${date.getDate()}</div>
    `;
    column.appendChild(header);

    // Hour slots
    for (let hour = 0; hour < 24; hour++) {
      const slot = document.createElement('div');
      slot.className = 'hour-slot';
      slot.dataset.hour = hour.toString();
      slot.dataset.date = day.date;

      // Add shift bars
      day.shifts?.forEach((shift: any) => {
        if (hour >= shift.startHour && hour < shift.endHour) {
          if (hour === shift.startHour) {
            const shiftBar = document.createElement('div');
            shiftBar.className = 'shift-bar';
            shiftBar.style.height = `${(shift.endHour - shift.startHour) * 60}px`;
            shiftBar.textContent = shift.name;
            slot.appendChild(shiftBar);
          }
        }
      });

      // Add tasks
      day.tasks?.filter((t: any) => t.hour === hour).forEach((task: any) => {
        const taskCard = createTaskCard(task);
        slot.appendChild(taskCard);
      });

      // Drag & drop handlers
      slot.addEventListener('dragover', handleDragOver);
      slot.addEventListener('drop', handleDrop);
      slot.addEventListener('dragleave', handleDragLeave);

      column.appendChild(slot);
    }

    return column;
  }

  function createTaskCard(task: any): HTMLElement {
    const card = document.createElement('div');
    card.className = `task-card ${task.agentType} ${task.status}`;
    card.draggable = true;
    card.dataset.taskId = task.id;
    card.innerHTML = `
      <div class="task-name">${task.name}</div>
      <div class="task-time">${task.hour.toString().padStart(2, '0')}:${task.minute.toString().padStart(2, '0')}</div>
    `;

    card.addEventListener('dragstart', handleDragStart);
    card.addEventListener('dragend', handleDragEnd);

    return card;
  }

  // Drag & Drop
  function handleDragStart(e: DragEvent) {
    draggedTask = e.target as HTMLElement;
    draggedTask.classList.add('dragging');
    e.dataTransfer!.effectAllowed = 'move';
  }

  function handleDragEnd(e: DragEvent) {
    if (draggedTask) {
      draggedTask.classList.remove('dragging');
      draggedTask = null;
    }
    document.querySelectorAll('.droppable-active').forEach(el => {
      el.classList.remove('droppable-active');
    });
  }

  function handleDragOver(e: DragEvent) {
    e.preventDefault();
    e.dataTransfer!.dropEffect = 'move';
    (e.currentTarget as HTMLElement).classList.add('droppable-active');
  }

  function handleDragLeave(e: DragEvent) {
    (e.currentTarget as HTMLElement).classList.remove('droppable-active');
  }

  async function handleDrop(e: DragEvent) {
    e.preventDefault();
    const slot = e.currentTarget as HTMLElement;
    slot.classList.remove('droppable-active');

    if (!draggedTask) return;

    const taskId = draggedTask.dataset.taskId;
    const newHour = parseInt(slot.dataset.hour!);
    const newDate = slot.dataset.date!;

    const newScheduledFor = new Date(newDate);
    newScheduledFor.setHours(newHour, 0, 0, 0);

    try {
      const response = await fetch('/api/admin/agents/tasks', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id: parseInt(taskId!),
          scheduledFor: newScheduledFor.toISOString(),
        }),
      });

      if (response.ok) {
        await loadCalendarData();
      } else {
        console.error('Failed to reschedule task');
      }
    } catch (error) {
      console.error('Error rescheduling task:', error);
    }
  }

  // Render compliance
  function renderCompliance() {
    if (!complianceData?.overall) return;

    const { onTimeRate, successRate, currentStreak } = complianceData.overall;

    // Update circles
    updateCircle('onTimeCircle', onTimeRate);
    updateCircle('successCircle', successRate);
    document.getElementById('onTimeValue')!.textContent = `${onTimeRate}%`;
    document.getElementById('successValue')!.textContent = `${successRate}%`;
    document.getElementById('streakValue')!.textContent = currentStreak.toString();
  }

  function updateCircle(id: string, value: number) {
    const circle = document.querySelector(`#${id} .circle-progress`) as SVGPathElement;
    if (circle) {
      circle.style.strokeDasharray = `${value}, 100`;
    }
  }

  // Render alerts
  function renderAlerts() {
    const alertsList = document.getElementById('alertsList')!;
    const alertBadge = document.getElementById('alertBadge')!;

    if (!complianceData?.alerts?.length) {
      alertsList.innerHTML = '<p class="no-alerts">Sin alertas recientes</p>';
      alertBadge.textContent = '0';
      return;
    }

    alertBadge.textContent = complianceData.unreadAlertCount?.toString() || '0';

    alertsList.innerHTML = complianceData.alerts.slice(0, 5).map((alert: any) => `
      <div class="alert-item ${alert.severity}">
        <strong>${alert.agentType}</strong>: ${alert.message}
        <div style="font-size: 0.7rem; color: var(--text-secondary);">
          ${new Date(alert.createdAt).toLocaleString('es')}
        </div>
      </div>
    `).join('');
  }

  // Render today's tasks
  function renderTodayTasks() {
    const tasksList = document.getElementById('tasksList')!;
    const today = new Date().toISOString().split('T')[0];
    const todayData = calendarData?.days?.find((d: any) => d.date === today);

    if (!todayData?.tasks?.length) {
      tasksList.innerHTML = '<p class="no-tasks">Sin tareas para hoy</p>';
      return;
    }

    tasksList.innerHTML = todayData.tasks
      .sort((a: any, b: any) => a.hour - b.hour)
      .map((task: any) => `
        <div class="task-item ${task.status}">
          <div class="task-dot ${task.agentType}"></div>
          <span>${task.hour.toString().padStart(2, '0')}:${task.minute.toString().padStart(2, '0')}</span>
          <span style="flex: 1;">${task.name}</span>
          <span style="font-size: 0.7rem; text-transform: uppercase;">${task.status}</span>
        </div>
      `).join('');
  }

  // Render active shift
  async function renderActiveShift() {
    const activeShiftEl = document.getElementById('activeShift')!;
    try {
      const response = await fetch('/api/admin/agents/shifts');
      const data = await response.json();

      if (data.activeShiftId) {
        const shift = data.shifts.find((s: any) => s.id === data.activeShiftId);
        activeShiftEl.innerHTML = `<span class="shift-name">${shift?.name || 'Turno Activo'}</span>`;
        activeShiftEl.classList.remove('inactive');
      } else {
        activeShiftEl.innerHTML = '<span class="shift-name">Sin turno activo</span>';
        activeShiftEl.classList.add('inactive');
      }
    } catch (error) {
      console.error('Error loading shift:', error);
    }
  }

  // Event Listeners
  function setupEventListeners() {
    viewBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        viewBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        view = btn.dataset.view as '3day' | 'week';
        loadCalendarData();
      });
    });

    prevBtn.addEventListener('click', () => {
      currentDate.setDate(currentDate.getDate() - (view === 'week' ? 7 : 3));
      loadCalendarData();
    });

    nextBtn.addEventListener('click', () => {
      currentDate.setDate(currentDate.getDate() + (view === 'week' ? 7 : 3));
      loadCalendarData();
    });

    todayBtn.addEventListener('click', () => {
      currentDate = new Date();
      loadCalendarData();
    });

    document.getElementById('addScheduleBtn')?.addEventListener('click', () => {
      scheduleModal.classList.add('open');
    });

    document.getElementById('closeModal')?.addEventListener('click', () => {
      scheduleModal.classList.remove('open');
    });

    document.getElementById('cancelSchedule')?.addEventListener('click', () => {
      scheduleModal.classList.remove('open');
    });

    scheduleModal.querySelector('.modal-backdrop')?.addEventListener('click', () => {
      scheduleModal.classList.remove('open');
    });

    scheduleForm.addEventListener('submit', handleScheduleSubmit);

    // AI Planning listeners
    setupAIPlanningListeners();
  }

  // AI Planning State
  let aiDaysAhead = 3;
  let aiPreviewData: any = null;
  let aiProgressInterval: number | null = null;

  function setupAIPlanningListeners() {
    const aiDrawer = document.getElementById('aiDrawer')!;
    const aiBackdrop = document.getElementById('aiDrawerBackdrop')!;

    // Helper to open drawer with backdrop
    function openDrawer() {
      aiDrawer.classList.add('open');
      aiBackdrop.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    // Helper to close drawer with backdrop
    function closeDrawer() {
      aiDrawer.classList.remove('open');
      aiBackdrop.classList.remove('open');
      document.body.style.overflow = '';
      stopAiProgress();
    }

    // Open drawer
    document.getElementById('aiPlanBtn')?.addEventListener('click', () => {
      openDrawer();
      showAiStep(1);
      resetAiProgress();
    });

    // Close drawer (X button)
    document.getElementById('closeAiDrawer')?.addEventListener('click', closeDrawer);

    // Close on backdrop click
    aiBackdrop.addEventListener('click', closeDrawer);

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && aiDrawer.classList.contains('open')) {
        closeDrawer();
      }
    });

    // Days selector (chips)
    document.querySelectorAll('.ai-chip').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.ai-chip').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        aiDaysAhead = parseInt((btn as HTMLElement).dataset.days || '3');
      });
    });

    // Preview/Generate button
    document.getElementById('previewAiPlan')?.addEventListener('click', async () => {
      showAiStep(2);
      startAiProgress();
      await generateAIPreview();
    });

    // Back button
    document.getElementById('backToConfig')?.addEventListener('click', () => {
      showAiStep(1);
      resetAiProgress();
    });

    // Apply button
    document.getElementById('applyAiPlan')?.addEventListener('click', async () => {
      showAiStep(2);
      updateThinkingStatus('Aplicando plan al calendario...');
      startAiProgress();
      await applyAIPlan();
    });

    // Success close
    document.getElementById('closeAiSuccess')?.addEventListener('click', () => {
      closeDrawer();
      loadCalendarData();
    });
  }

  function showAiStep(step: number) {
    document.querySelectorAll('.ai-step').forEach(el => el.classList.add('hidden'));
    document.getElementById(`aiStep${step}`)?.classList.remove('hidden');
  }

  // Progress bar animation
  function startAiProgress() {
    const progressFill = document.getElementById('aiProgressFill');
    if (!progressFill) return;

    let progress = 0;
    const thinkingStatuses = [
      'Revisando rendimiento histórico...',
      'Analizando patrones de éxito...',
      'Calculando horarios óptimos...',
      'Optimizando distribución de tareas...',
      'Generando plan personalizado...',
    ];
    let statusIndex = 0;

    progressFill.style.width = '0%';

    aiProgressInterval = window.setInterval(() => {
      progress += Math.random() * 15;
      if (progress > 90) progress = 90;
      progressFill.style.width = `${progress}%`;

      // Update status text every ~20% progress
      if (progress > (statusIndex + 1) * 18 && statusIndex < thinkingStatuses.length - 1) {
        statusIndex++;
        updateThinkingStatus(thinkingStatuses[statusIndex]);
      }
    }, 400);
  }

  function stopAiProgress() {
    if (aiProgressInterval) {
      clearInterval(aiProgressInterval);
      aiProgressInterval = null;
    }
    const progressFill = document.getElementById('aiProgressFill');
    if (progressFill) {
      progressFill.style.width = '100%';
    }
  }

  function resetAiProgress() {
    stopAiProgress();
    const progressFill = document.getElementById('aiProgressFill');
    if (progressFill) {
      progressFill.style.width = '0%';
    }
    updateThinkingStatus('Revisando rendimiento histórico...');
  }

  function updateThinkingStatus(text: string) {
    const statusEl = document.getElementById('aiThinkingStatus');
    if (statusEl) {
      statusEl.textContent = text;
    }
  }

  async function generateAIPreview() {
    try {
      const response = await fetch(`/api/admin/agents/ai-plan?days=${aiDaysAhead}`);
      const data = await response.json();

      stopAiProgress();

      if (!data.success) {
        alert(`Error: ${data.error}`);
        showAiStep(1);
        return;
      }

      aiPreviewData = data;
      renderAIPreview(data);
      showAiStep(3);
    } catch (error) {
      console.error('Error generating AI preview:', error);
      stopAiProgress();
      alert('Error al generar vista previa');
      showAiStep(1);
    }
  }

  function getAgentIcon(agentType: string): string {
    const icons: Record<string, string> = {
      deal_hunter: '🎯',
      content_creator: '✏️',
      price_monitor: '📊',
      channel_manager: '📢',
    };
    return icons[agentType] || '🤖';
  }

  function renderAIPreview(data: any) {
    // Reasoning
    const reasoningEl = document.getElementById('aiReasoning');
    if (reasoningEl) {
      reasoningEl.textContent = data.reasoning;
    }

    // Task count and tokens
    const taskCountEl = document.getElementById('aiTaskCount');
    if (taskCountEl) {
      taskCountEl.textContent = data.tasks.length.toString();
    }

    const tokensEl = document.getElementById('aiTokens');
    if (tokensEl && data.tokensUsed) {
      tokensEl.textContent = data.tokensUsed.toString();
    }

    // Tasks preview with new card design
    const tasksPreview = document.getElementById('aiTasksPreview');
    if (!tasksPreview) return;

    tasksPreview.innerHTML = data.tasks
      .sort((a: any, b: any) => new Date(a.scheduledFor).getTime() - new Date(b.scheduledFor).getTime())
      .map((task: any) => {
        const date = new Date(task.scheduledFor);
        const priorityClass = task.priority >= 70 ? 'high' : task.priority >= 40 ? 'medium' : 'low';
        const priorityLabel = task.priority >= 70 ? 'Alta' : task.priority >= 40 ? 'Media' : 'Baja';

        return `
          <div class="ai-task-card ${task.agentType}">
            <div class="ai-task-icon ${task.agentType}">
              ${getAgentIcon(task.agentType)}
            </div>
            <div class="ai-task-details">
              <p class="ai-task-title">${task.name}</p>
              <div class="ai-task-schedule">
                <span>${date.toLocaleDateString('es', { weekday: 'short', day: 'numeric', month: 'short' })}</span>
                <span>•</span>
                <span>${date.toLocaleTimeString('es', { hour: '2-digit', minute: '2-digit' })}</span>
                <span class="ai-task-badge ${priorityClass}">${priorityLabel}</span>
              </div>
            </div>
          </div>
        `;
      }).join('');
  }

  async function applyAIPlan() {
    try {
      const clearExisting = (document.getElementById('aiClearExisting') as HTMLInputElement)?.checked || false;
      const prioritiesText = (document.getElementById('aiPriorities') as HTMLTextAreaElement)?.value || '';
      const priorities = prioritiesText ? prioritiesText.split('\n').filter(p => p.trim()) : undefined;

      const response = await fetch('/api/admin/agents/ai-plan', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          daysAhead: aiDaysAhead,
          clearExisting,
          priorities,
        }),
      });

      const data = await response.json();
      stopAiProgress();

      if (!data.success) {
        alert(`Error: ${data.error}`);
        showAiStep(3);
        return;
      }

      const successMsgEl = document.getElementById('aiSuccessMessage');
      if (successMsgEl) {
        successMsgEl.textContent = `Se crearon ${data.tasksCreated} tareas para los próximos ${aiDaysAhead} días.`;
      }
      showAiStep(4);
    } catch (error) {
      console.error('Error applying AI plan:', error);
      stopAiProgress();
      alert('Error al aplicar el plan');
      showAiStep(3);
    }
  }

  async function handleScheduleSubmit(e: Event) {
    e.preventDefault();
    const formData = new FormData(scheduleForm);

    const daysCheckboxes = scheduleForm.querySelectorAll('input[name="days"]:checked');
    const daysOfWeek = Array.from(daysCheckboxes).map(cb => parseInt((cb as HTMLInputElement).value));

    const data = {
      agentType: formData.get('agentType'),
      name: formData.get('name'),
      hour: parseInt(formData.get('hour') as string),
      minute: parseInt(formData.get('minute') as string) || 0,
      daysOfWeek,
      taskType: formData.get('taskType'),
    };

    try {
      const response = await fetch('/api/admin/agents/schedules', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        scheduleModal.classList.remove('open');
        scheduleForm.reset();
        await loadCalendarData();
      } else {
        const error = await response.json();
        alert(error.error || 'Error al crear horario');
      }
    } catch (error) {
      console.error('Error creating schedule:', error);
    }
  }

  // Utilities
  function formatDate(date: Date): string {
    return date.toLocaleDateString('es', {
      day: 'numeric',
      month: 'short'
    });
  }

  // Initialize on load
  init();

  // Refresh every 30 seconds
  setInterval(() => {
    loadCalendarData();
    loadComplianceData();
  }, 30000);
</script>
