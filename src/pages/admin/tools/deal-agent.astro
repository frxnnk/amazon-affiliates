  <!-- Loading Overlay -->
  <div id="loadingOverlay" class="loading-overlay">
    <div class="loading-card">
      <div class="loading-spinner"></div>
      <div class="loading-text" id="loadingText">Buscando productos...</div>
    </div>
  </div>

  <script>
    // State
    let products: any[] = [];
    let selectedAsins: Set<string> = new Set();
    let analysisData: any = null;
    let currentPreviewProduct: any = null;

    // Elements - Search Tab
    const searchForm = document.getElementById('searchForm') as HTMLFormElement;
    const keywordsInput = document.getElementById('keywords') as HTMLInputElement;
    const filterCategory = document.getElementById('filterCategory') as HTMLSelectElement;
    const filterMinPrice = document.getElementById('filterMinPrice') as HTMLInputElement;
    const filterMaxPrice = document.getElementById('filterMaxPrice') as HTMLInputElement;
    const filterMinDiscount = document.getElementById('filterMinDiscount') as HTMLInputElement;
    const filterSort = document.getElementById('filterSort') as HTMLSelectElement;
    const btnSearch = document.getElementById('btnSearch') as HTMLButtonElement;
    
    // Elements - Link Tab
    const amazonLinkInput = document.getElementById('amazonLink') as HTMLInputElement;
    const btnFetch = document.getElementById('btnFetch') as HTMLButtonElement;
    const productPreview = document.getElementById('productPreview')!;
    const previewImage = document.getElementById('previewImage') as HTMLImageElement;
    const previewTitle = document.getElementById('previewTitle')!;
    const previewBrand = document.getElementById('previewBrand')!;
    const previewPrice = document.getElementById('previewPrice')!;
    const previewAsin = document.getElementById('previewAsin')!;
    const btnAddToSelection = document.getElementById('btnAddToSelection') as HTMLButtonElement;
    const btnImportDirect = document.getElementById('btnImportDirect') as HTMLButtonElement;

    // Elements - Common
    const btnAnalyze = document.getElementById('btnAnalyze') as HTMLButtonElement;
    const btnImport = document.getElementById('btnImport') as HTMLButtonElement;
    const resultsSection = document.getElementById('resultsSection')!;
    const productsGrid = document.getElementById('productsGrid')!;
    const resultsCount = document.getElementById('resultsCount')!;
    const resultsSource = document.getElementById('resultsSource')!;
    const analysisPanel = document.getElementById('analysisPanel')!;
    const analysisSummary = document.getElementById('analysisSummary')!;
    const analysisGrid = document.getElementById('analysisGrid')!;
    const loadingOverlay = document.getElementById('loadingOverlay')!;
    const loadingText = document.getElementById('loadingText')!;

    // Tab switching
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const tabId = btn.getAttribute('data-tab');
        
        // Update buttons
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        
        // Update content
        document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
        document.getElementById(`tab${tabId!.charAt(0).toUpperCase() + tabId!.slice(1)}`)?.classList.add('active');
      });
    });

    // Extract ASIN from Amazon URL
    function extractAsin(input: string): { asin: string; marketplace: string } | null {
      const trimmed = input.trim();
      
      // Direct ASIN
      if (/^[A-Z0-9]{10}$/i.test(trimmed)) {
        return { asin: trimmed.toUpperCase(), marketplace: 'com' };
      }
      
      try {
        const url = new URL(trimmed.startsWith('http') ? trimmed : `https://${trimmed}`);
        const hostname = url.hostname.toLowerCase();
        
        // Check if Amazon domain
        if (!hostname.includes('amazon.') && !hostname.includes('amzn.')) {
          return null;
        }
        
        // Detect marketplace
        let marketplace = 'com';
        if (hostname.includes('amazon.es')) marketplace = 'es';
        else if (hostname.includes('amazon.co.uk')) marketplace = 'co.uk';
        else if (hostname.includes('amazon.de')) marketplace = 'de';
        else if (hostname.includes('amazon.fr')) marketplace = 'fr';
        else if (hostname.includes('amazon.it')) marketplace = 'it';
        
        // Extract ASIN patterns
        const patterns = [
          /\/dp\/([A-Z0-9]{10})/i,
          /\/gp\/product\/([A-Z0-9]{10})/i,
          /\/gp\/aw\/d\/([A-Z0-9]{10})/i,
          /\/([A-Z0-9]{10})(?:\/|\?|$)/i,
        ];
        
        for (const pattern of patterns) {
          const match = url.pathname.match(pattern) || url.href.match(pattern);
          if (match) {
            return { asin: match[1].toUpperCase(), marketplace };
          }
        }
      } catch {
        // Invalid URL
      }
      
      return null;
    }

    // Fetch product by link
    async function fetchProductByLink() {
      const input = amazonLinkInput.value.trim();
      if (!input) {
        alert('Por favor ingresa un link de Amazon o ASIN');
        return;
      }

      const extracted = extractAsin(input);
      if (!extracted) {
        alert('No se pudo extraer el ASIN del link. Verifica que sea un link válido de Amazon.');
        return;
      }

      showLoading('Obteniendo datos del producto...');
      productPreview.classList.remove('visible');

      try {
        // Search by ASIN using our API
        const response = await fetch('/api/admin/deals/search', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            keywords: extracted.asin,
            marketplace: extracted.marketplace,
          }),
        });

        const result = await response.json();

        if (!result.success || !result.products?.length) {
          // Try alternative: direct lookup
          throw new Error('Producto no encontrado. Intenta con otro link.');
        }

        // Get the product (should be exact match or first result)
        const product = result.products.find((p: any) => p.asin === extracted.asin) || result.products[0];
        currentPreviewProduct = {
          ...product,
          marketplace: extracted.marketplace,
        };

        // Show preview
        previewImage.src = product.imageUrl || '';
        previewTitle.textContent = product.title || 'Sin título';
        previewBrand.textContent = product.brand || 'Sin marca';
        previewPrice.textContent = formatPrice(product.price, product.currency);
        previewAsin.textContent = extracted.asin;
        productPreview.classList.add('visible');

      } catch (error) {
        alert(`Error: ${error instanceof Error ? error.message : 'Error desconocido'}`);
      } finally {
        hideLoading();
      }
    }

    // Add preview product to selection
    function addToSelection() {
      if (!currentPreviewProduct) return;
      
      // Add to products array if not already there
      if (!products.find(p => p.asin === currentPreviewProduct.asin)) {
        products.push(currentPreviewProduct);
      }
      
      // Select it
      selectedAsins.add(currentPreviewProduct.asin);
      
      // Show results section and render
      resultsSection.classList.add('visible');
      resultsCount.textContent = `${products.length} productos`;
      resultsSource.textContent = 'Selección manual';
      renderProducts();
      updateSelectionButtons();
      
      // Clear preview
      productPreview.classList.remove('visible');
      amazonLinkInput.value = '';
      currentPreviewProduct = null;
      
      // Switch to search tab to see results
      document.querySelector('.tab-btn[data-tab="search"]')?.dispatchEvent(new Event('click'));
    }

    // Import product directly
    async function importDirect() {
      if (!currentPreviewProduct) return;

      if (!confirm(`¿Importar "${currentPreviewProduct.title.slice(0, 50)}..." como borrador?`)) return;

      showLoading('Importando producto...');

      try {
        const response = await fetch('/api/admin/deals/import-bulk', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            products: [currentPreviewProduct],
            lang: currentPreviewProduct.marketplace === 'es' ? 'es' : 'en',
            category: filterCategory.value !== 'all' ? filterCategory.value : 'electronics',
            status: 'draft',
          }),
        });

        const result = await response.json();

        if (result.imported > 0) {
          alert('✓ Producto importado exitosamente');
          productPreview.classList.remove('visible');
          amazonLinkInput.value = '';
          currentPreviewProduct = null;
        } else {
          throw new Error(result.error || 'No se pudo importar');
        }
      } catch (error) {
        alert(`Error: ${error instanceof Error ? error.message : 'Error desconocido'}`);
      } finally {
        hideLoading();
      }
    }

    // Event listeners for link tab
    btnFetch.addEventListener('click', fetchProductByLink);
    amazonLinkInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        fetchProductByLink();
      }
    });
    btnAddToSelection.addEventListener('click', addToSelection);
    btnImportDirect.addEventListener('click', importDirect);

    // Helpers
    function showLoading(text: string) {
      loadingText.textContent = text;
      loadingOverlay.classList.add('visible');
    }

    function hideLoading() {
      loadingOverlay.classList.remove('visible');
    }

    function formatPrice(price: number | null, currency: string): string {
      if (price === null) return '-';
      return new Intl.NumberFormat('es-ES', {
        style: 'currency',
        currency: currency === 'EUR' ? 'EUR' : 'USD',
      }).format(price);
    }

    function calculateDiscount(price: number | null, originalPrice: number | null): number {
      if (!price || !originalPrice || originalPrice <= price) return 0;
      return Math.round(((originalPrice - price) / originalPrice) * 100);
    }

    function getScoreClass(score: number): string {
      if (score >= 7) return 'high';
      if (score >= 5) return 'medium';
      return 'low';
    }

    // Update selection state
    function updateSelectionButtons() {
      const hasSelection = selectedAsins.size > 0;
      btnAnalyze.disabled = !hasSelection;
      btnImport.disabled = !hasSelection;
      btnImport.textContent = hasSelection 
        ? `Importar (${selectedAsins.size})` 
        : 'Importar Seleccionados';
    }

    // Render products
    function renderProducts() {
      if (products.length === 0) {
        productsGrid.innerHTML = `
          <div class="empty-state" style="grid-column: 1 / -1;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="11" cy="11" r="8"/>
              <path d="M21 21l-4.35-4.35"/>
            </svg>
            <div class="empty-title">No se encontraron productos</div>
            <p>Intenta con otros términos de búsqueda o ajusta los filtros</p>
          </div>
        `;
        return;
      }

      productsGrid.innerHTML = products.map(product => {
        const discount = calculateDiscount(product.price, product.originalPrice);
        const isSelected = selectedAsins.has(product.asin);
        const scoreClass = getScoreClass(product.quickScore || 5);

        return `
          <div class="product-card ${isSelected ? 'selected' : ''}" data-asin="${product.asin}">
            <div class="quick-score ${scoreClass}">${product.quickScore || '?'}</div>
            <div class="product-checkbox">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <img 
              src="${product.imageUrl || 'data:image/svg+xml,...'}" 
              alt="${product.title}" 
              class="product-image"
              onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22%3E%3Crect fill=%22%23333%22 width=%2224%22 height=%2224%22/%3E%3C/svg%3E'"
            />
            <div class="product-title">${product.title}</div>
            <div class="product-brand">${product.brand || 'Sin marca'}</div>
            <div class="product-meta">
              <div class="product-price">
                <span class="price-current">${formatPrice(product.price, product.currency)}</span>
                ${product.originalPrice ? `<span class="price-original">${formatPrice(product.originalPrice, product.currency)}</span>` : ''}
                ${discount > 0 ? `<span class="discount-badge">-${discount}%</span>` : ''}
              </div>
              <div class="product-rating">
                <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                ${product.rating?.toFixed(1) || '-'} (${product.totalReviews || 0})
              </div>
            </div>
          </div>
        `;
      }).join('');

      // Add click handlers
      document.querySelectorAll('.product-card').forEach(card => {
        card.addEventListener('click', () => {
          const asin = card.getAttribute('data-asin')!;
          if (selectedAsins.has(asin)) {
            selectedAsins.delete(asin);
            card.classList.remove('selected');
          } else {
            selectedAsins.add(asin);
            card.classList.add('selected');
          }
          updateSelectionButtons();
        });
      });
    }

    // Search products
    async function searchProducts() {
      const keywords = keywordsInput.value.trim();
      if (!keywords) return;

      showLoading('Buscando productos en Amazon...');
      analysisPanel.classList.remove('visible');
      analysisData = null;

      try {
        const response = await fetch('/api/admin/deals/search', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            keywords,
            category: filterCategory.value !== 'all' ? filterCategory.value : undefined,
            minPrice: filterMinPrice.value ? parseFloat(filterMinPrice.value) : undefined,
            maxPrice: filterMaxPrice.value ? parseFloat(filterMaxPrice.value) : undefined,
            minDiscount: filterMinDiscount.value ? parseInt(filterMinDiscount.value) : undefined,
            sortBy: filterSort.value,
          }),
        });

        const result = await response.json();

        if (!result.success) {
          throw new Error(result.error || 'Error en la búsqueda');
        }

        products = result.products || [];
        selectedAsins.clear();
        
        resultsCount.textContent = `${products.length} productos`;
        resultsSource.textContent = result.source === 'rainforest' ? 'Rainforest' : 'PA-API';
        
        resultsSection.classList.add('visible');
        renderProducts();
        updateSelectionButtons();

      } catch (error) {
        alert(`Error: ${error instanceof Error ? error.message : 'Error desconocido'}`);
      } finally {
        hideLoading();
      }
    }

    // Analyze products
    async function analyzeProducts() {
      if (selectedAsins.size === 0) return;

      const selectedProducts = products.filter(p => selectedAsins.has(p.asin));
      
      showLoading('Analizando productos con IA...');

      try {
        const response = await fetch('/api/admin/deals/analyze', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            products: selectedProducts,
            lang: 'es',
          }),
        });

        const result = await response.json();

        if (!result.success) {
          throw new Error(result.error || 'Error en el análisis');
        }

        analysisData = result;
        renderAnalysis();

      } catch (error) {
        alert(`Error: ${error instanceof Error ? error.message : 'Error desconocido'}`);
      } finally {
        hideLoading();
      }
    }

    // Render analysis
    function renderAnalysis() {
      if (!analysisData || !analysisData.analyses) return;

      analysisPanel.classList.add('visible');

      // Summary
      analysisSummary.innerHTML = `
        <div class="summary-stat">
          <div class="summary-value">${analysisData.summary?.totalProducts || 0}</div>
          <div class="summary-label">Analizados</div>
        </div>
        <div class="summary-stat">
          <div class="summary-value">${analysisData.summary?.recommendedCount || 0}</div>
          <div class="summary-label">Recomendados</div>
        </div>
        <div class="summary-stat">
          <div class="summary-value">${analysisData.summary?.averageScore || 0}</div>
          <div class="summary-label">Score Promedio</div>
        </div>
        <div class="summary-stat">
          <div class="summary-value">${analysisData.tokensUsed || '?'}</div>
          <div class="summary-label">Tokens Usados</div>
        </div>
      `;

      // Cards
      analysisGrid.innerHTML = analysisData.analyses.map((analysis: any) => {
        const product = products.find(p => p.asin === analysis.asin);
        const scoreClass = getScoreClass(analysis.revenueScore);

        const recommendLabels: Record<string, string> = {
          'import_now': '✓ Importar Ya',
          'consider': '? Considerar',
          'skip': '✗ Saltar',
        };

        return `
          <div class="analysis-card">
            <div class="analysis-card-header">
              <span class="analysis-product-title">${product?.title?.slice(0, 40) || analysis.asin}...</span>
              <span class="revenue-score ${scoreClass}">${analysis.revenueScore}/10</span>
            </div>
            <div class="analysis-recommendation ${analysis.recommendation}">
              ${recommendLabels[analysis.recommendation] || analysis.recommendation}
            </div>
            <p class="analysis-reasoning">${analysis.reasoning}</p>
            <div class="analysis-tags">
              ${(analysis.highlights || []).map((h: string) => `<span class="analysis-tag highlight">${h}</span>`).join('')}
              ${(analysis.risks || []).map((r: string) => `<span class="analysis-tag risk">${r}</span>`).join('')}
            </div>
          </div>
        `;
      }).join('');

      // Scroll to analysis
      analysisPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // Import products
    async function importProducts() {
      if (selectedAsins.size === 0) return;

      const selectedProducts = products.filter(p => selectedAsins.has(p.asin));
      
      if (!confirm(`¿Importar ${selectedProducts.length} productos como borradores?`)) return;

      showLoading('Importando productos...');

      try {
        const response = await fetch('/api/admin/deals/import-bulk', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            products: selectedProducts,
            lang: 'es',
            category: filterCategory.value !== 'all' ? filterCategory.value : 'electronics',
            status: 'draft',
          }),
        });

        const result = await response.json();

        if (result.imported > 0) {
          alert(`✓ ${result.imported} productos importados exitosamente${result.failed > 0 ? `\n✗ ${result.failed} fallaron` : ''}`);
          selectedAsins.clear();
          updateSelectionButtons();
          renderProducts();
        } else {
          throw new Error(result.error || 'No se pudo importar ningún producto');
        }

      } catch (error) {
        alert(`Error: ${error instanceof Error ? error.message : 'Error desconocido'}`);
      } finally {
        hideLoading();
      }
    }

    // Event listeners
    searchForm.addEventListener('submit', (e) => {
      e.preventDefault();
      searchProducts();
    });

    btnAnalyze.addEventListener('click', analyzeProducts);
    btnImport.addEventListener('click', importProducts);
  </script>
</AdminLayout>
