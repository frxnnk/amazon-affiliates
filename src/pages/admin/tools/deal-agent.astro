        </form>
      </div>

      <!-- Link Tab -->
      <div id="tabLink" class="tab-content">
        <div class="link-input-section">
          <div class="search-main">
            <div class="link-input-wrapper" style="flex: 1;">
              <svg class="link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
              </svg>
              <input
                type="text"
                id="amazonLink"
                class="search-input link-input"
                placeholder="Pegar link de Amazon o ASIN..."
              />
            </div>
            <button type="button" class="btn-fetch" id="btnFetch">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
