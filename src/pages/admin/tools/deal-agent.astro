---
export const prerender = false;

import AdminLayout from '@components/admin/AdminLayout.astro';

// Get categories for filter dropdown
const categories = [
  { id: 'all', name: 'Todas las categorías' },
  { id: 'electronics', name: 'Electrónica' },
  { id: 'computers', name: 'Computadoras' },
  { id: 'smartphones', name: 'Smartphones' },
  { id: 'audio', name: 'Audio' },
  { id: 'gaming', name: 'Gaming' },
  { id: 'home', name: 'Hogar' },
  { id: 'kitchen', name: 'Cocina' },
  { id: 'sports', name: 'Deportes' },
  { id: 'fashion', name: 'Moda' },
  { id: 'beauty', name: 'Belleza' },
];
---

<AdminLayout title="Deal Agent">
  <style>
    .deal-agent {
      display: flex;
      flex-direction: column;
      gap: var(--space-lg);
    }

    /* Header */
    .agent-header {
      display: flex;
      flex-direction: column;
      gap: var(--space-sm);
    }

    .agent-title {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text-primary);
      display: flex;
      align-items: center;
      gap: var(--space-sm);
    }

    .agent-title svg {
      width: 28px;
      height: 28px;
      color: #10b981;
    }

    .agent-subtitle {
      font-size: 0.875rem;
      color: var(--text-muted);
    }

    /* Tabs */
    .search-tabs {
      display: flex;
      gap: 4px;
      margin-bottom: var(--space-md);
      background: var(--bg-base);
      padding: 4px;
      border-radius: var(--radius-sm);
      width: fit-content;
    }

    .tab-btn {
      padding: 10px 20px;
      border: none;
      background: transparent;
      color: var(--text-muted);
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      border-radius: 6px;
      transition: all var(--duration) var(--ease);
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .tab-btn:hover {
      color: var(--text-primary);
    }

    .tab-btn.active {
      background: var(--bg-surface);
      color: var(--text-primary);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    }

    .tab-btn svg {
      width: 16px;
      height: 16px;
    }

    .tab-content {
      display: none;
    }

    .tab-content.active {
      display: block;
    }

    /* Search Card */
    .search-card {
      background: var(--bg-surface);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius);
      padding: var(--space-lg);
    }

    .search-form {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }

    .search-main {
      display: flex;
      gap: var(--space-md);
    }

    @media (max-width: 768px) {
      .search-main {
        flex-direction: column;
      }
    }

    /* Link Input */
    .link-input-section {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }

    .link-input-wrapper {
      position: relative;
    }

    .link-input {
      width: 100%;
      background: var(--bg-base);
      border: 1px solid var(--border-default);
      border-radius: var(--radius-sm);
      padding: 14px 16px;
      padding-left: 44px;
      color: var(--text-primary);
      font-size: 0.9375rem;
      font-family: 'JetBrains Mono', monospace;
    }

    .link-input:focus {
      outline: none;
      border-color: #f59e0b;
      box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.15);
    }

    .link-icon {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      width: 18px;
      height: 18px;
      color: var(--text-muted);
    }

    .btn-fetch {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-sm);
      background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%);
      color: #000;
      border: none;
      border-radius: var(--radius-sm);
      padding: 14px 28px;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: all var(--duration) var(--ease);
      white-space: nowrap;
    }

    .btn-fetch:hover:not(:disabled) {
      transform: translateY(-1px);
      box-shadow: 0 4px 16px rgba(245, 158, 11, 0.4);
    }

    .btn-fetch:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    .link-hints {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-sm);
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    .link-hint {
      background: var(--bg-base);
      padding: 4px 10px;
      border-radius: 4px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6875rem;
    }

    /* Product Preview */
    .product-preview {
      display: none;
      background: var(--bg-base);
      border-radius: var(--radius-sm);
      padding: var(--space-md);
      margin-top: var(--space-md);
    }

    .product-preview.visible {
      display: block;
      animation: slideIn 0.3s ease-out;
    }

    .preview-content {
      display: flex;
      gap: var(--space-md);
    }

    @media (max-width: 600px) {
      .preview-content {
        flex-direction: column;
      }
    }

    .preview-image {
      width: 120px;
      height: 120px;
      object-fit: contain;
      background: var(--bg-surface);
      border-radius: var(--radius-sm);
      flex-shrink: 0;
    }

    .preview-info {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: var(--space-xs);
    }

    .preview-title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--text-primary);
      line-height: 1.4;
    }

    .preview-brand {
      font-size: 0.8125rem;
      color: var(--text-muted);
    }

    .preview-meta {
      display: flex;
      align-items: center;
      gap: var(--space-md);
      margin-top: auto;
    }

    .preview-price {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--accent);
    }

    .preview-asin {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      background: var(--bg-surface);
      padding: 4px 8px;
      border-radius: 4px;
      color: var(--text-muted);
    }

    .preview-actions {
      display: flex;
      gap: var(--space-sm);
      margin-top: var(--space-md);
      padding-top: var(--space-md);
      border-top: 1px solid var(--border-subtle);
    }

    .btn-add-to-selection {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 10px 20px;
      background: #10b981;
      color: white;
      border: none;
      border-radius: var(--radius-sm);
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: all var(--duration) var(--ease);
    }

    .btn-add-to-selection:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
    }

    .btn-import-direct {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 10px 20px;
      background: var(--accent);
      color: #000;
      border: none;
      border-radius: var(--radius-sm);
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: all var(--duration) var(--ease);
    }

    .btn-import-direct:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(251, 191, 36, 0.3);
    }

    .search-input-wrapper {
      flex: 1;
      position: relative;
    }

    .search-input {
      width: 100%;
      background: var(--bg-base);
      border: 1px solid var(--border-default);
      border-radius: var(--radius-sm);
      padding: 14px 16px;
      padding-left: 44px;
      color: var(--text-primary);
      font-size: 0.9375rem;
    }

    .search-input:focus {
      outline: none;
      border-color: #10b981;
      box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.15);
    }

    .search-icon {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      width: 18px;
      height: 18px;
      color: var(--text-muted);
    }

    .btn-search {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-sm);
      background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
      color: white;
      border: none;
      border-radius: var(--radius-sm);
      padding: 14px 28px;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: all var(--duration) var(--ease);
      white-space: nowrap;
    }

    .btn-search:hover:not(:disabled) {
      transform: translateY(-1px);
      box-shadow: 0 4px 16px rgba(16, 185, 129, 0.4);
    }

    .btn-search:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    /* Filters */
    .filters-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: var(--space-md);
    }

    .filter-group {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .filter-label {
      font-size: 0.6875rem;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .filter-select,
    .filter-input {
      background: var(--bg-base);
      border: 1px solid var(--border-default);
      border-radius: var(--radius-sm);
      padding: 10px 12px;
      color: var(--text-primary);
      font-size: 0.8125rem;
    }

    .filter-select:focus,
    .filter-input:focus {
      outline: none;
      border-color: #10b981;
    }

    /* Results Section */
    .results-section {
      display: none;
    }

    .results-section.visible {
      display: block;
    }

    .results-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: var(--space-md);
      flex-wrap: wrap;
      gap: var(--space-sm);
    }

    .results-info {
      display: flex;
      align-items: center;
      gap: var(--space-md);
    }

    .results-count {
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .results-source {
      font-size: 0.6875rem;
      padding: 4px 8px;
      border-radius: 4px;
      background: rgba(16, 185, 129, 0.15);
      color: #10b981;
      font-weight: 600;
    }

    .results-actions {
      display: flex;
      gap: var(--space-sm);
    }

    .btn-analyze,
    .btn-import {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 16px;
      border-radius: var(--radius-sm);
      font-size: 0.8125rem;
      font-weight: 600;
      cursor: pointer;
      transition: all var(--duration) var(--ease);
      border: none;
    }

    .btn-analyze {
      background: rgba(139, 92, 246, 0.15);
      color: #8b5cf6;
    }

    .btn-analyze:hover:not(:disabled) {
      background: rgba(139, 92, 246, 0.25);
    }

    .btn-import {
      background: var(--accent);
      color: #000;
    }

    .btn-import:hover:not(:disabled) {
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(251, 191, 36, 0.3);
    }

    .btn-analyze:disabled,
    .btn-import:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .btn-3d {
      background: linear-gradient(135deg, #8b5cf6 0%, #a78bfa 100%);
      color: white;
    }

    .btn-3d:hover:not(:disabled) {
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(139, 92, 246, 0.4);
    }

    /* Import options */
    .import-options {
      display: none;
      background: var(--bg-base);
      border-radius: var(--radius-sm);
      padding: var(--space-md);
      margin-top: var(--space-md);
      gap: var(--space-md);
    }

    .import-options.visible {
      display: flex;
      flex-direction: column;
      animation: slideIn 0.2s ease-out;
    }

    .option-row {
      display: flex;
      align-items: center;
      gap: var(--space-md);
      flex-wrap: wrap;
    }

    .option-checkbox {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      cursor: pointer;
    }

    .option-checkbox input {
      width: 18px;
      height: 18px;
      accent-color: #8b5cf6;
    }

    .option-checkbox span {
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .option-info {
      font-size: 0.75rem;
      color: var(--text-muted);
      padding: var(--space-sm);
      background: var(--bg-surface);
      border-radius: 4px;
    }

    .option-info svg {
      display: inline;
      width: 14px;
      height: 14px;
      vertical-align: middle;
      margin-right: 4px;
    }

    /* 3D Progress */
    .gen3d-progress {
      display: none;
      background: var(--bg-surface);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius);
      padding: var(--space-lg);
      margin-top: var(--space-md);
    }

    .gen3d-progress.visible {
      display: block;
    }

    .gen3d-header {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      margin-bottom: var(--space-md);
    }

    .gen3d-header svg {
      width: 22px;
      height: 22px;
      color: #8b5cf6;
      animation: spin 2s linear infinite;
    }

    .gen3d-title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--text-primary);
    }

    .gen3d-list {
      display: flex;
      flex-direction: column;
      gap: var(--space-sm);
    }

    .gen3d-item {
      display: flex;
      align-items: center;
      gap: var(--space-md);
      padding: var(--space-sm);
      background: var(--bg-base);
      border-radius: var(--radius-sm);
    }

    .gen3d-item-title {
      flex: 1;
      font-size: 0.8125rem;
      color: var(--text-primary);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .gen3d-item-status {
      font-size: 0.75rem;
      font-weight: 600;
      padding: 2px 8px;
      border-radius: 4px;
    }

    .gen3d-item-status.pending { 
      background: rgba(255, 255, 255, 0.1); 
      color: var(--text-muted); 
    }
    .gen3d-item-status.running { 
      background: rgba(139, 92, 246, 0.2); 
      color: #a78bfa; 
    }
    .gen3d-item-status.success { 
      background: rgba(16, 185, 129, 0.2); 
      color: #10b981; 
    }
    .gen3d-item-status.failed { 
      background: rgba(239, 68, 68, 0.2); 
      color: #ef4444; 
    }

    /* Products Grid */
    .products-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: var(--space-md);
    }

    /* Product Card */
    .product-card {
      background: var(--bg-surface);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius);
      padding: var(--space-md);
      display: flex;
      flex-direction: column;
      gap: var(--space-sm);
      position: relative;
      cursor: pointer;
      transition: all var(--duration) var(--ease);
    }

    .product-card:hover {
      border-color: var(--border-default);
      transform: translateY(-2px);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    }

    .product-card.selected {
      border-color: #10b981;
      background: rgba(16, 185, 129, 0.05);
    }

    .product-checkbox {
      position: absolute;
      top: 12px;
      right: 12px;
      width: 20px;
      height: 20px;
      border: 2px solid var(--border-default);
      border-radius: 4px;
      background: var(--bg-base);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all var(--duration) var(--ease);
    }

    .product-card.selected .product-checkbox {
      background: #10b981;
      border-color: #10b981;
    }

    .product-checkbox svg {
      width: 12px;
      height: 12px;
      color: white;
      opacity: 0;
    }

    .product-card.selected .product-checkbox svg {
      opacity: 1;
    }

    .product-image {
      width: 100%;
      height: 140px;
      object-fit: contain;
      border-radius: var(--radius-sm);
      background: var(--bg-base);
    }

    .product-title {
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--text-primary);
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .product-brand {
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    .product-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-sm);
    }

    .product-price {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .price-current {
      font-size: 1rem;
      font-weight: 700;
      color: var(--text-primary);
    }

    .price-original {
      font-size: 0.75rem;
      color: var(--text-muted);
      text-decoration: line-through;
    }

    .discount-badge {
      font-size: 0.6875rem;
      font-weight: 700;
      padding: 2px 6px;
      border-radius: 4px;
      background: var(--error-muted);
      color: var(--error);
    }

    .product-rating {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 0.75rem;
      color: var(--text-secondary);
    }

    .product-rating svg {
      width: 12px;
      height: 12px;
      color: #fbbf24;
      fill: #fbbf24;
    }

    /* Quick Score */
    .quick-score {
      position: absolute;
      top: 12px;
      left: 12px;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.75rem;
      font-weight: 700;
      color: white;
    }

    .quick-score.high {
      background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
    }

    .quick-score.medium {
      background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%);
    }

    .quick-score.low {
      background: linear-gradient(135deg, #ef4444 0%, #f87171 100%);
    }

    /* Analysis Panel */
    .analysis-panel {
      display: none;
      background: var(--bg-surface);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius);
      padding: var(--space-lg);
      margin-top: var(--space-md);
    }

    .analysis-panel.visible {
      display: block;
      animation: slideIn 0.3s ease-out;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateY(-10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .analysis-header {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      margin-bottom: var(--space-md);
    }

    .analysis-header svg {
      width: 22px;
      height: 22px;
      color: #8b5cf6;
    }

    .analysis-title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--text-primary);
    }

    .analysis-summary {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
      gap: var(--space-md);
      padding: var(--space-md);
      background: var(--bg-base);
      border-radius: var(--radius-sm);
      margin-bottom: var(--space-md);
    }

    .summary-stat {
      text-align: center;
    }

    .summary-value {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text-primary);
    }

    .summary-label {
      font-size: 0.6875rem;
      color: var(--text-muted);
      text-transform: uppercase;
    }

    /* Analysis Cards */
    .analysis-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: var(--space-md);
    }

    .analysis-card {
      background: var(--bg-base);
      border-radius: var(--radius-sm);
      padding: var(--space-md);
      display: flex;
      flex-direction: column;
      gap: var(--space-sm);
    }

    .analysis-card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .analysis-product-title {
      font-size: 0.8125rem;
      font-weight: 600;
      color: var(--text-primary);
      flex: 1;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .revenue-score {
      font-size: 1.25rem;
      font-weight: 700;
    }

    .revenue-score.high { color: #10b981; }
    .revenue-score.medium { color: #f59e0b; }
    .revenue-score.low { color: #ef4444; }

    .analysis-recommendation {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 0.6875rem;
      font-weight: 600;
      width: fit-content;
    }

    .analysis-recommendation.import_now {
      background: rgba(16, 185, 129, 0.15);
      color: #10b981;
    }

    .analysis-recommendation.consider {
      background: rgba(245, 158, 11, 0.15);
      color: #f59e0b;
    }

    .analysis-recommendation.skip {
      background: rgba(239, 68, 68, 0.15);
      color: #ef4444;
    }

    .analysis-reasoning {
      font-size: 0.8125rem;
      color: var(--text-secondary);
      line-height: 1.5;
    }

    .analysis-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
    }

    .analysis-tag {
      font-size: 0.625rem;
      padding: 2px 6px;
      border-radius: 3px;
      background: var(--bg-hover);
      color: var(--text-muted);
    }

    .analysis-tag.highlight {
      background: rgba(16, 185, 129, 0.1);
      color: #10b981;
    }

    .analysis-tag.risk {
      background: rgba(239, 68, 68, 0.1);
      color: #ef4444;
    }

    /* Loading States */
    .loading-overlay {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.5);
      z-index: 1000;
      align-items: center;
      justify-content: center;
    }

    .loading-overlay.visible {
      display: flex;
    }

    .loading-card {
      background: var(--bg-surface);
      border-radius: var(--radius);
      padding: var(--space-xl);
      text-align: center;
      max-width: 300px;
    }

    .loading-spinner {
      width: 48px;
      height: 48px;
      border: 3px solid var(--border-subtle);
      border-top-color: #10b981;
      border-radius: 50%;
      animation: spin 1s linear infinite;
      margin: 0 auto var(--space-md);
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .loading-text {
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    /* Empty State */
    .empty-state {
      text-align: center;
      padding: var(--space-xl) var(--space-lg);
      color: var(--text-muted);
    }

    .empty-state svg {
      width: 64px;
      height: 64px;
      margin-bottom: var(--space-md);
      opacity: 0.3;
    }

    .empty-title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--text-secondary);
      margin-bottom: var(--space-sm);
    }
  </style>

