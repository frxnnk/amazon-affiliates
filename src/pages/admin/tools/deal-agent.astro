    <!-- Results Section -->
    <div id="resultsSection" class="results-section">
      <div class="results-header">
        <div class="results-info">
          <span class="results-count" id="resultsCount">0 productos</span>
          <span class="results-source" id="resultsSource">PA-API</span>
        </div>
        <div class="results-actions">
          <button type="button" class="btn-analyze" id="btnAnalyze" disabled>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
            Analizar con IA
          </button>
          <button type="button" class="btn-3d" id="btnGen3D" disabled>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
              <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
              <line x1="12" y1="22.08" x2="12" y2="12"/>
            </svg>
            Generar 3D
          </button>
          <button type="button" class="btn-import" id="btnImport" disabled>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 5v14M5 12h14"/>
