      }

      .agents-grid {
        grid-template-columns: 1fr;
      }

      .api-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 640px) {
      .page-header {
        flex-direction: column;
        align-items: flex-start;
      }

      .header-content {
        flex-direction: column;
        align-items: flex-start;
      }

      .stats-row {
        grid-template-columns: 1fr;
      }

      .api-grid {
        grid-template-columns: 1fr;
      }

      .history-table {
        font-size: 0.75rem;
      }

      .history-table th,
      .history-table td {
        padding: 0.5rem;
      }
    }
  </style>

  <script>
    // @ts-nocheck

    // API Status tracking
    const apiStatus = {
      rapidapi: { status: 'checking', quota: { used: 0, limit: 500 } },
      openai: { status: 'checking', quota: { used: 0, limit: 100 } },
      youtube: { status: 'checking', quota: { used: 0, limit: 10000 } },
      telegram: { status: 'checking', quota: { used: 0, limit: 0 } },
    };

    // Agent data
    const agents = {
      deal_hunter: { lastRun: null, itemsProcessed: 0, isRunning: false },
      content_creator: { lastRun: null, itemsProcessed: 0, isRunning: false },
      price_monitor: { lastRun: null, itemsProcessed: 0, isRunning: false },
      channel_manager: { lastRun: null, itemsProcessed: 0, isRunning: false },
    };

    // Run history
    let runHistory = [];

    // Initialize
    document.addEventListener('DOMContentLoaded', async () => {
      // Set up event listeners
      document.getElementById('runAllBtn')?.addEventListener('click', runAllAgents);
      document.getElementById('testConnectionsBtn')?.addEventListener('click', testConnections);
      document.getElementById('closeModal')?.addEventListener('click', closeModal);
      document.getElementById('clearHistoryBtn')?.addEventListener('click', clearHistory);

      // Set up agent card buttons
      document.querySelectorAll('.agent-card').forEach(card => {
        const agentType = card.dataset.agent;
        card.querySelector('[data-action="run"]')?.addEventListener('click', () => runAgent(agentType));
        card.querySelector('[data-action="config"]')?.addEventListener('click', () => showConfig(agentType));
      });

      // Load initial data
      await loadStats();
      await testConnections();
      loadHistory();
    });

    // Test API connections
    async function testConnections() {
      const btn = document.getElementById('testConnectionsBtn');
      if (btn) {
        btn.disabled = true;
        btn.classList.add('loading');
      }

      updateStatusBanner('loading', 'Verificando conexiones...');

      try {
        const response = await fetch('/api/admin/test-connections');
        const data = await response.json();

        let allOk = true;
        let errorCount = 0;

        // Update each API status
        for (const [api, result] of Object.entries(data)) {
          const card = document.querySelector(`[data-api="${api}"]`);
          if (!card) continue;

          const badge = card.querySelector('.api-badge');
          const quotaFill = card.querySelector('.quota-fill');
          const quotaText = card.querySelector('.quota-text');

          if (result.ok) {
            badge.className = 'api-badge connected';
            badge.textContent = 'Conectado';
          } else if (result.warning) {
            badge.className = 'api-badge warning';
            badge.textContent = result.message || 'Advertencia';
            allOk = false;
          } else {
            badge.className = 'api-badge error';
            badge.textContent = result.message || 'Error';
            allOk = false;
            errorCount++;
          }

          // Update quota
          if (result.quota) {
            const percent = (result.quota.used / result.quota.limit) * 100;
            quotaFill.style.width = `${Math.min(percent, 100)}%`;
            quotaFill.className = 'quota-fill' + (percent > 80 ? ' danger' : percent > 50 ? ' warning' : '');
            quotaText.textContent = `${result.quota.used}/${result.quota.limit}`;
          }
        }

        if (allOk) {
          updateStatusBanner('success', 'Todas las APIs conectadas correctamente');
        } else {
          updateStatusBanner('error', `${errorCount} API(s) con problemas - revisar configuración`);
        }
      } catch (error) {
        console.error('Error testing connections:', error);
        updateStatusBanner('error', 'Error al verificar conexiones');
        showToast('error', 'Error al verificar conexiones');
      } finally {
        if (btn) {
          btn.disabled = false;
          btn.classList.remove('loading');
        }
      }
    }

    // Update status banner
    function updateStatusBanner(status, message) {
      const banner = document.getElementById('statusBanner');
      if (!banner) return;

      banner.innerHTML = `
        <div class="status-indicator ${status}">
          <span class="status-dot"></span>
          <span class="status-text">${message}</span>
        </div>
      `;
    }

    // Load stats
    async function loadStats() {
      try {
        const response = await fetch('/api/admin/agents/stats');
        if (!response.ok) throw new Error('Failed to load stats');

        const data = await response.json();

        document.getElementById('keywordsCount').textContent = data.keywords || '0';
        document.getElementById('contentQueueCount').textContent = data.contentQueue || '0';
        document.getElementById('publishQueueCount').textContent = data.publishQueue || '0';
        document.getElementById('runsToday').textContent = data.runsToday || '0';
      } catch (error) {
        console.error('Error loading stats:', error);
        // Set defaults
        document.getElementById('keywordsCount').textContent = '0';
        document.getElementById('contentQueueCount').textContent = '0';
        document.getElementById('publishQueueCount').textContent = '0';
        document.getElementById('runsToday').textContent = '0';
      }
    }

    // Run all agents
    async function runAllAgents() {
      const btn = document.getElementById('runAllBtn');
      if (!btn || btn.disabled) return;

      btn.disabled = true;
      btn.classList.add('loading');
      btn.innerHTML = `
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12a9 9 0 11-6.219-8.56"/>
        </svg>
        Ejecutando...
      `;

      showToast('info', 'Iniciando ejecución de todos los agentes...');

      try {
        const response = await fetch('/api/cron/agent-orchestrator', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ dryRun: false }),
        });

        const result = await response.json();

        if (result.success) {
          showToast('success', `Completado: ${result.agentsRun || 0} agentes ejecutados`);

          // Update agent cards with results
          if (result.results) {
            for (const [agentType, agentResult] of Object.entries(result.results)) {
              updateAgentCard(agentType, agentResult);
              addToHistory(agentType, agentResult);
            }
          }
        } else {
          showToast('error', result.error || 'Error al ejecutar agentes');
        }

        await loadStats();
      } catch (error) {
        console.error('Error running agents:', error);
        showToast('error', 'Error de conexión al ejecutar agentes');
      } finally {
        btn.disabled = false;
        btn.classList.remove('loading');
        btn.innerHTML = `
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polygon points="5 3 19 12 5 21 5 3"/>
          </svg>
          Ejecutar Todos
        `;
      }
    }

    // Run single agent
    async function runAgent(agentType) {
      const card = document.querySelector(`[data-agent="${agentType}"]`);
      const btn = card?.querySelector('[data-action="run"]');

      if (!btn || btn.disabled) return;

      btn.disabled = true;
      btn.classList.add('loading');
      btn.innerHTML = `
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12a9 9 0 11-6.219-8.56"/>
        </svg>
        Ejecutando...
      `;

      const statusBadge = card?.querySelector('.status-badge');
      if (statusBadge) {
        statusBadge.className = 'status-badge running';
        statusBadge.textContent = 'Ejecutando';
      }

      try {
        const response = await fetch('/api/cron/agent-orchestrator', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ agents: [agentType], dryRun: false }),
        });

        const result = await response.json();
        const agentResult = result.results?.[agentType];

        if (result.success && agentResult) {
          showToast('success', `${getAgentName(agentType)} completado`);
          updateAgentCard(agentType, agentResult);
          addToHistory(agentType, agentResult);
        } else {
          showToast('error', result.error || `Error al ejecutar ${getAgentName(agentType)}`);
        }

        await loadStats();
      } catch (error) {
        console.error('Error running agent:', error);
        showToast('error', `Error de conexión: ${getAgentName(agentType)}`);
      } finally {
        btn.disabled = false;
        btn.classList.remove('loading');
        btn.innerHTML = `
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polygon points="5 3 19 12 5 21 5 3"/>
          </svg>
          Ejecutar
        `;

        if (statusBadge) {
          statusBadge.className = 'status-badge active';
          statusBadge.textContent = 'Activo';
        }
      }
    }

    // Update agent card with results
    function updateAgentCard(agentType, result) {
      const card = document.querySelector(`[data-agent="${agentType}"]`);
      if (!card) return;

      const lastRunEl = card.querySelector('[data-field="lastRun"]');
      const itemsEl = card.querySelector('[data-field="itemsProcessed"]');

      if (lastRunEl) {
        lastRunEl.textContent = new Date().toLocaleString('es');
      }

      if (itemsEl && result.metrics) {
        itemsEl.textContent = result.metrics.itemsProcessed || '0';
      }
    }

    // Add run to history
    function addToHistory(agentType, result) {
      const entry = {
        id: Date.now(),
        agentType,
        status: result.success ? 'completed' : 'failed',
        duration: result.metrics?.duration || '-',
        itemsProcessed: result.metrics?.itemsProcessed || 0,
        errors: result.errors?.length || 0,
        timestamp: new Date(),
        result,
      };

      runHistory.unshift(entry);
      if (runHistory.length > 20) runHistory.pop();

      renderHistory();
    }

    // Render history table
    function renderHistory() {
      const tbody = document.getElementById('historyBody');
      if (!tbody) return;

      if (runHistory.length === 0) {
        tbody.innerHTML = `
          <tr class="empty-row">
            <td colspan="7">
              <div class="empty-state">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 6v6l4 2"/>
                </svg>
                <p>Sin ejecuciones recientes</p>
                <span>Ejecuta un agente para ver el historial</span>
              </div>
            </td>
          </tr>
        `;
        return;
      }

      tbody.innerHTML = runHistory.map(entry => `
        <tr>
          <td>
            <span class="history-status ${entry.status}">
              <span class="history-status-dot"></span>
              ${entry.status === 'completed' ? 'OK' : entry.status === 'failed' ? 'Error' : 'En curso'}
            </span>
          </td>
          <td><strong>${getAgentName(entry.agentType)}</strong></td>
          <td>${typeof entry.duration === 'number' ? `${entry.duration}ms` : entry.duration}</td>
          <td>${entry.itemsProcessed}</td>
          <td>${entry.errors > 0 ? `<span style="color: var(--brutal-red)">${entry.errors}</span>` : '0'}</td>
          <td>${entry.timestamp.toLocaleString('es')}</td>
          <td>
            <button class="btn-view" onclick="showResult(${entry.id})">Ver</button>
          </td>
        </tr>
      `).join('');
    }

    // Load history from localStorage
    function loadHistory() {
      try {
        const saved = localStorage.getItem('agentRunHistory');
        if (saved) {
          runHistory = JSON.parse(saved).map(entry => ({
            ...entry,
            timestamp: new Date(entry.timestamp),
          }));
        }
      } catch (e) {
        console.error('Error loading history:', e);
      }
      renderHistory();
    }

    // Save history to localStorage
    function saveHistory() {
      try {
        localStorage.setItem('agentRunHistory', JSON.stringify(runHistory));
      } catch (e) {
        console.error('Error saving history:', e);
      }
    }

    // Clear history
    function clearHistory() {
      runHistory = [];
      saveHistory();
      renderHistory();
      showToast('info', 'Historial limpiado');
    }

    // Show result modal
    window.showResult = function(id) {
      const entry = runHistory.find(e => e.id === id);
      if (!entry) return;

      const modal = document.getElementById('resultModal');
      const body = document.getElementById('modalBody');

      if (body) {
        body.innerHTML = `<pre>${JSON.stringify(entry.result, null, 2)}</pre>`;
      }

      modal?.classList.add('active');
    };

    // Close modal
    function closeModal() {
      document.getElementById('resultModal')?.classList.remove('active');
    }

    // Show config (placeholder)
    function showConfig(agentType) {
      showToast('info', `Configuración de ${getAgentName(agentType)} - Próximamente`);
    }

    // Get agent display name
    function getAgentName(type) {
      const names = {
        deal_hunter: 'Deal Hunter',
        content_creator: 'Content Creator',
        price_monitor: 'Price Monitor',
        channel_manager: 'Channel Manager',
      };
      return names[type] || type;
    }

    // Show toast notification
    function showToast(type, message) {
      const container = document.getElementById('toastContainer');
      if (!container) return;

      const toast = document.createElement('div');
      toast.className = `toast ${type}`;
      toast.textContent = message;
      container.appendChild(toast);

      setTimeout(() => {
        toast.style.animation = 'slideIn 0.3s var(--ease-brutal) reverse';
        setTimeout(() => toast.remove(), 300);
      }, 4000);
    }

    // Close modal on overlay click
    document.getElementById('resultModal')?.addEventListener('click', (e) => {
      if (e.target.id === 'resultModal') closeModal();
    });

    // Save history when leaving
    window.addEventListener('beforeunload', saveHistory);
  </script>
</AdminLayout>
