---
export const prerender = false;

import AdminLayout from '@components/admin/AdminLayout.astro';
---

<AdminLayout title="Agentes 24/7">
  <div class="agents-page">
    <!-- Status Banner -->
    <div class="status-banner" id="statusBanner">
      <div class="status-indicator loading">
        <span class="status-dot"></span>
        <span class="status-text">Verificando conexiones...</span>
      </div>
    </div>

    <!-- Page Header -->
    <div class="page-header">
      <div class="header-content">
        <div class="header-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <circle cx="12" cy="12" r="3"/>
            <path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
          </svg>
        </div>
        <div>
          <h1 class="page-title">Agentes Autónomos</h1>
          <p class="page-subtitle">Sistema multi-agente 24/7 para deals, contenido y publicación</p>
        </div>
      </div>
      <div class="header-actions">
        <button class="btn btn-secondary" id="testConnectionsBtn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          Probar APIs
        </button>
        <button class="btn btn-primary" id="runAllBtn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polygon points="5 3 19 12 5 21 5 3"/>
          </svg>
          Ejecutar Todos
        </button>
      </div>
    </div>

    <!-- Stats Row -->
    <div class="stats-row">
      <div class="stat-card stat-yellow">
        <div class="stat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
            <line x1="7" y1="7" x2="7.01" y2="7"/>
          </svg>
        </div>
        <div class="stat-content">
          <span class="stat-value" id="keywordsCount">-</span>
          <span class="stat-label">Keywords Activas</span>
        </div>
      </div>
      <div class="stat-card stat-blue">
        <div class="stat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
          </svg>
        </div>
        <div class="stat-content">
          <span class="stat-value" id="contentQueueCount">-</span>
          <span class="stat-label">En Cola Contenido</span>
        </div>
      </div>
      <div class="stat-card stat-orange">
        <div class="stat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <div class="stat-content">
          <span class="stat-value" id="publishQueueCount">-</span>
          <span class="stat-label">Pendientes Publicar</span>
        </div>
      </div>
      <div class="stat-card stat-green">
        <div class="stat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
          </svg>
        </div>
        <div class="stat-content">
          <span class="stat-value" id="runsToday">-</span>
          <span class="stat-label">Ejecuciones Hoy</span>
        </div>
      </div>
    </div>

    <!-- Agent Cards Grid -->
    <div class="section-header">
      <h2 class="section-title">Agentes del Sistema</h2>
      <span class="section-badge">4 agentes</span>
    </div>

    <div class="agents-grid" id="agentsGrid">
      <!-- Deal Hunter -->
      <div class="agent-card agent-yellow" data-agent="deal_hunter">
        <div class="agent-header">
          <div class="agent-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <circle cx="11" cy="11" r="8"/>
              <path d="m21 21-4.35-4.35"/>
            </svg>
          </div>
          <div class="agent-status">
            <span class="status-badge active">Activo</span>
          </div>
        </div>
        <div class="agent-body">
          <h3 class="agent-name">Deal Hunter</h3>
          <p class="agent-type">deal_hunter</p>
          <p class="agent-desc">Busca ofertas y deals de productos automáticamente</p>
        </div>
        <div class="agent-stats">
          <div class="agent-stat">
            <span class="stat-label">Última ejecución</span>
            <span class="stat-value" data-field="lastRun">Nunca</span>
          </div>
          <div class="agent-stat">
            <span class="stat-label">Productos encontrados</span>
            <span class="stat-value" data-field="itemsProcessed">0</span>
          </div>
        </div>
        <div class="agent-actions">
          <button class="btn-agent btn-config" data-action="config">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="3"/>
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
            </svg>
          </button>
          <button class="btn-agent btn-run" data-action="run">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polygon points="5 3 19 12 5 21 5 3"/>
            </svg>
            Ejecutar
          </button>
        </div>
      </div>

      <!-- Content Creator -->
      <div class="agent-card agent-blue" data-agent="content_creator">
        <div class="agent-header">
          <div class="agent-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M12 19l7-7 3 3-7 7-3-3z"/>
              <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/>
              <path d="M2 2l7.586 7.586"/>
            </svg>
          </div>
          <div class="agent-status">
            <span class="status-badge active">Activo</span>
          </div>
        </div>
        <div class="agent-body">
          <h3 class="agent-name">Content Creator</h3>
          <p class="agent-type">content_creator</p>
          <p class="agent-desc">Genera descripciones y pros/cons con GPT-5</p>
        </div>
        <div class="agent-stats">
          <div class="agent-stat">
            <span class="stat-label">Última ejecución</span>
            <span class="stat-value" data-field="lastRun">Nunca</span>
          </div>
          <div class="agent-stat">
            <span class="stat-label">Contenido generado</span>
            <span class="stat-value" data-field="itemsProcessed">0</span>
          </div>
        </div>
        <div class="agent-actions">
          <button class="btn-agent btn-config" data-action="config">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="3"/>
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
            </svg>
          </button>
          <button class="btn-agent btn-run" data-action="run">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polygon points="5 3 19 12 5 21 5 3"/>
            </svg>
            Ejecutar
          </button>
        </div>
      </div>

      <!-- Price Monitor -->
      <div class="agent-card agent-green" data-agent="price_monitor">
        <div class="agent-header">
          <div class="agent-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
            </svg>
          </div>
          <div class="agent-status">
            <span class="status-badge active">Activo</span>
          </div>
        </div>
        <div class="agent-body">
          <h3 class="agent-name">Price Monitor</h3>
          <p class="agent-type">price_monitor</p>
          <p class="agent-desc">Monitorea precios y detecta bajadas importantes</p>
        </div>
        <div class="agent-stats">
          <div class="agent-stat">
            <span class="stat-label">Última ejecución</span>
            <span class="stat-value" data-field="lastRun">Nunca</span>
          </div>
          <div class="agent-stat">
            <span class="stat-label">Alertas creadas</span>
            <span class="stat-value" data-field="itemsProcessed">0</span>
          </div>
        </div>
        <div class="agent-actions">
          <button class="btn-agent btn-config" data-action="config">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="3"/>
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
            </svg>
          </button>
          <button class="btn-agent btn-run" data-action="run">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polygon points="5 3 19 12 5 21 5 3"/>
            </svg>
            Ejecutar
          </button>
        </div>
      </div>

      <!-- Channel Manager -->
      <div class="agent-card agent-orange" data-agent="channel_manager">
        <div class="agent-header">
          <div class="agent-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <div class="agent-status">
            <span class="status-badge active">Activo</span>
          </div>
        </div>
        <div class="agent-body">
          <h3 class="agent-name">Channel Manager</h3>
          <p class="agent-type">channel_manager</p>
          <p class="agent-desc">Publica en Telegram, Twitter y Discord</p>
        </div>
        <div class="agent-stats">
          <div class="agent-stat">
            <span class="stat-label">Última ejecución</span>
            <span class="stat-value" data-field="lastRun">Nunca</span>
          </div>
          <div class="agent-stat">
            <span class="stat-label">Posts publicados</span>
            <span class="stat-value" data-field="itemsProcessed">0</span>
          </div>
        </div>
        <div class="agent-actions">
          <button class="btn-agent btn-config" data-action="config">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="3"/>
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
            </svg>
          </button>
          <button class="btn-agent btn-run" data-action="run">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polygon points="5 3 19 12 5 21 5 3"/>
            </svg>
            Ejecutar
          </button>
        </div>
      </div>
    </div>

    <!-- API Status Section -->
    <div class="section-header">
      <h2 class="section-title">Estado de APIs</h2>
      <span class="section-badge">Conexiones</span>
    </div>

    <div class="api-grid" id="apiGrid">
      <div class="api-card" data-api="rapidapi">
        <div class="api-icon rapidapi">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2L2 7v10l10 5 10-5V7L12 2zm0 2.18l6.9 3.45L12 11.08 5.1 7.63 12 4.18zM4 8.82l7 3.5v7.36l-7-3.5V8.82zm9 10.86v-7.36l7-3.5v7.36l-7 3.5z"/>
          </svg>
        </div>
        <div class="api-info">
          <h4 class="api-name">RapidAPI</h4>
          <p class="api-desc">Datos de productos Amazon</p>
        </div>
        <div class="api-status">
          <span class="api-badge checking">Verificando...</span>
        </div>
        <div class="api-quota">
          <div class="quota-bar">
            <div class="quota-fill" style="width: 0%"></div>
          </div>
          <span class="quota-text">-/-</span>
        </div>
      </div>

      <div class="api-card" data-api="openai">
        <div class="api-icon openai">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.985 5.985 0 0 0-3.998 2.9 6.046 6.046 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.997-2.9 6.056 6.056 0 0 0-.747-7.073zM13.26 22.43a4.476 4.476 0 0 1-2.876-1.04l.141-.081 4.779-2.758a.795.795 0 0 0 .392-.681v-6.737l2.02 1.168a.071.071 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494zM3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.771.771 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.676l5.815 3.355-2.02 1.168a.076.076 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.855l-5.833-3.387L15.119 7.2a.076.076 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667zm2.01-3.023l-.141-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135l-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08-4.778 2.758a.795.795 0 0 0-.393.681zm1.097-2.365l2.602-1.5 2.607 1.5v2.999l-2.597 1.5-2.607-1.5z"/>
          </svg>
        </div>
        <div class="api-info">
          <h4 class="api-name">OpenAI</h4>
          <p class="api-desc">GPT-5 para contenido</p>
        </div>
        <div class="api-status">
          <span class="api-badge checking">Verificando...</span>
        </div>
        <div class="api-quota">
          <div class="quota-bar">
            <div class="quota-fill" style="width: 0%"></div>
          </div>
          <span class="quota-text">-/-</span>
        </div>
      </div>

      <div class="api-card" data-api="youtube">
        <div class="api-icon youtube">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </div>
        <div class="api-info">
          <h4 class="api-name">YouTube</h4>
          <p class="api-desc">Videos de productos</p>
        </div>
        <div class="api-status">
          <span class="api-badge checking">Verificando...</span>
        </div>
        <div class="api-quota">
          <div class="quota-bar">
            <div class="quota-fill" style="width: 0%"></div>
          </div>
          <span class="quota-text">-/-</span>
        </div>
      </div>

      <div class="api-card" data-api="telegram">
        <div class="api-icon telegram">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
          </svg>
        </div>
        <div class="api-info">
          <h4 class="api-name">Telegram</h4>
          <p class="api-desc">Bot de publicación</p>
        </div>
        <div class="api-status">
          <span class="api-badge checking">Verificando...</span>
        </div>
        <div class="api-quota">
          <div class="quota-bar">
            <div class="quota-fill" style="width: 0%"></div>
          </div>
