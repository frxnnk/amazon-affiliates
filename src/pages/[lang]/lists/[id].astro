---
import BaseLayout from '@layouts/BaseLayout.astro';
import ProductCard from '@components/products/ProductCard.astro';
import Badge from '@components/ui/Badge.astro';
import { getCollection, render } from 'astro:content';
import { type Lang, getTranslation, formatDate } from '@i18n/utils';

// Obtener parametros de la URL
const { lang, id } = Astro.params as { lang: Lang; id: string };

// Buscar la lista
const lists = await getCollection('lists');
const list = lists.find(l => l.data.listId === id && l.data.lang === lang);

// Si no existe, retornar 404
if (!list) {
  return Astro.redirect(`/${lang}/lists`);
}

const { data } = list;
const { Content } = await render(list);
const t = getTranslation(lang);

// Get all products to resolve references
const allProducts = await getCollection('products');

// Map list products with their full data
const listProducts = data.products
  .sort((a, b) => a.position - b.position)
  .map((listProduct) => {
    const fullProduct = allProducts.find(
      p => p.data.productId === listProduct.productId && p.data.lang === lang
    );
    return {
      ...listProduct,
      product: fullProduct ? {
        productId: fullProduct.data.productId,
        asin: fullProduct.data.asin,
        title: fullProduct.data.title,
        brand: fullProduct.data.brand,
        price: fullProduct.data.price,
        originalPrice: fullProduct.data.originalPrice,
        currency: fullProduct.data.currency,
        rating: fullProduct.data.rating,
        featuredImage: fullProduct.data.featuredImage,
        affiliateUrl: fullProduct.data.affiliateUrl,
        isOnSale: fullProduct.data.isOnSale,
        isFeatured: fullProduct.data.isFeatured,
      } : null
    };
  })
  .filter(item => item.product !== null);

const listTypeLabels = {
  'best-of': { es: 'Los Mejores', en: 'Best Of' },
  'comparison': { es: 'Comparativa', en: 'Comparison' },
  'guide': { es: 'Guia', en: 'Guide' },
  'top-picks': { es: 'Top Picks', en: 'Top Picks' }
};
---

<BaseLayout
  title={data.title}
  description={data.excerpt}
  lang={lang}
  image={data.featuredImage?.url}
>
  <article class="max-w-5xl mx-auto">
    <!-- Header -->
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <Badge variant="primary">
          {listTypeLabels[data.listType]?.[lang] || data.listType}
        </Badge>
        <span class="text-sm text-gray-500">
          {data.products.length} {lang === 'es' ? 'productos' : 'products'}
        </span>
      </div>

      <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
        {data.title}
      </h1>

      {data.subtitle && (
        <p class="text-xl text-gray-600 mb-4">{data.subtitle}</p>
      )}

      <p class="text-gray-600 mb-6">{data.excerpt}</p>

      <div class="flex items-center gap-4 text-sm text-gray-500">
        <div class="flex items-center gap-2">
          {data.author.avatar && (
            <img
              src={data.author.avatar}
              alt={data.author.name}
              class="w-8 h-8 rounded-full"
            />
          )}
          <span>{data.author.name}</span>
        </div>
        <span>•</span>
        <time datetime={data.publishedAt.toISOString()}>
          {formatDate(data.publishedAt, lang)}
        </time>
        {data.updatedAt > data.publishedAt && (
          <>
            <span>•</span>
            <span>
              {lang === 'es' ? 'Actualizado' : 'Updated'}: {formatDate(data.updatedAt, lang)}
            </span>
          </>
        )}
      </div>
    </header>

    <!-- Featured Image -->
    {data.featuredImage?.url && (
      <div class="mb-8 rounded-xl overflow-hidden">
        <img
          src={data.featuredImage.url}
          alt={data.featuredImage.alt}
          class="w-full h-64 lg:h-80 object-cover"
        />
      </div>
    )}

    <!-- Products List -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">
        {lang === 'es' ? 'Productos en esta lista' : 'Products in this list'}
      </h2>

      <div class="space-y-6">
        {listProducts.map((item, index) => (
          <div class="bg-white rounded-xl shadow-sm overflow-hidden border border-gray-100">
            <div class="flex flex-col lg:flex-row">
              <!-- Position Badge -->
              <div class="lg:w-16 bg-gray-50 flex items-center justify-center p-4 lg:p-0">
                <span class="text-2xl font-bold text-gray-400">#{index + 1}</span>
              </div>

              <!-- Product Card -->
              <div class="flex-1 p-4">
                <div class="flex flex-col md:flex-row gap-4">
                  <!-- Image -->
                  <a
                    href={`/${lang}/products/${item.product.productId}`}
                    class="block w-full md:w-48 aspect-square bg-gray-50 rounded-lg overflow-hidden flex-shrink-0"
                  >
                    <img
                      src={item.product.featuredImage.url}
                      alt={item.product.featuredImage.alt}
                      class="w-full h-full object-contain p-4"
                    />
                  </a>

                  <!-- Info -->
                  <div class="flex-1">
                    <div class="flex items-start justify-between gap-4 mb-2">
                      <div>
                        {item.badge && (
                          <Badge variant="success" class="mb-2">{item.badge}</Badge>
                        )}
                        <h3 class="text-lg font-semibold text-gray-900">
                          <a
                            href={`/${lang}/products/${item.product.productId}`}
                            class="hover:text-primary-600"
                          >
                            {item.product.title}
                          </a>
                        </h3>
                        <p class="text-sm text-gray-500">{item.product.brand}</p>
                      </div>

                      <div class="text-right">
                        <p class="text-xl font-bold text-gray-900">
                          {item.product.currency === 'EUR' ? '€' : '$'}{item.product.price.toFixed(2)}
                        </p>
                        {item.product.originalPrice && item.product.originalPrice > item.product.price && (
                          <p class="text-sm text-gray-400 line-through">
                            {item.product.currency === 'EUR' ? '€' : '$'}{item.product.originalPrice.toFixed(2)}
                          </p>
                        )}
                      </div>
                    </div>

                    {item.miniReview && (
                      <p class="text-gray-600 mb-4">{item.miniReview}</p>
                    )}

                    <div class="flex items-center gap-4">
                      <div class="flex items-center gap-1">
                        <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20">
                          <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                        </svg>
                        <span class="text-sm font-medium">{item.product.rating.toFixed(1)}</span>
                      </div>

                      <a
                        href={`/${lang}/products/${item.product.productId}`}
                        class="text-sm text-primary-600 hover:text-primary-700 font-medium"
                      >
                        {lang === 'es' ? 'Ver detalles' : 'View details'} →
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      {listProducts.length === 0 && (
        <div class="text-center py-12 text-gray-500">
          <p>{lang === 'es' ? 'No hay productos en esta lista' : 'No products in this list'}</p>
        </div>
      )}
    </section>

    <!-- Content -->
    {Content && (
      <section class="bg-white rounded-xl shadow-sm p-6 lg:p-8 mb-8">
        <div class="prose prose-gray max-w-none">
          <Content />
        </div>
      </section>
    )}

    <!-- Tags -->
    {data.tags && data.tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8">
        {data.tags.map((tag) => (
          <span class="px-3 py-1 bg-gray-100 text-gray-600 text-sm rounded-full">
            #{tag}
          </span>
        ))}
      </div>
    )}

    <!-- Back Link -->
    <div class="text-center">
      <a
        href={`/${lang}/lists`}
        class="inline-flex items-center gap-2 text-primary-600 hover:text-primary-700 font-medium"
      >
        ← {lang === 'es' ? 'Volver a listas' : 'Back to lists'}
      </a>
    </div>
  </article>
</BaseLayout>
