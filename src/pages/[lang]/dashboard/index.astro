---
export const prerender = false;

import BaseLayout from '@layouts/BaseLayout.astro';
import BalanceCard from '@components/dashboard/BalanceCard.astro';
import TransactionList from '@components/dashboard/TransactionList.astro';
import ClaimsList from '@components/dashboard/ClaimsList.astro';
import { getOrCreateUser, getUserTransactions, getUserPendingClaims, getPendingCashback, getUserPayoutRequests, PAYOUT_CONFIG, type UserTier } from '@lib/db';
import { type Lang } from '@i18n/utils';

const { lang } = Astro.params as { lang: Lang };

// Get authenticated user from Clerk
const auth = Astro.locals.auth();
if (!auth.userId) {
  return Astro.redirect(`/${lang}`);
}

// Get user data from database
const clerkUser = await Astro.locals.currentUser();
const user = await getOrCreateUser(auth.userId, clerkUser?.emailAddresses[0]?.emailAddress || '');

if (!user) {
  return Astro.redirect(`/${lang}`);
}

// Get user's data
const transactions = await getUserTransactions(auth.userId, 10);
const claims = await getUserPendingClaims(auth.userId);
const pendingCashback = await getPendingCashback(auth.userId);
const payoutRequests = await getUserPayoutRequests(auth.userId);
const hasPendingPayout = payoutRequests.some(p => p.status === 'pending' || p.status === 'processing');
const canRequestPayout = user.balance >= PAYOUT_CONFIG.minimumAmount && !hasPendingPayout;

const labels = {
  en: {
    title: 'Dashboard',
    welcome: 'Welcome back',
    description: 'Track your cashback earnings and manage your account.',
    quickActions: 'Quick Actions',
    submitClaim: 'Submit Claim',
    viewProducts: 'Browse Products',
    requestPayout: 'Request Payout',
    settings: 'Settings',
  },
  es: {
    title: 'Panel',
    welcome: 'Bienvenido de nuevo',
    description: 'Rastrea tus ganancias de cashback y administra tu cuenta.',
    quickActions: 'Acciones Rapidas',
    submitClaim: 'Enviar Reclamo',
    viewProducts: 'Ver Productos',
    requestPayout: 'Solicitar Retiro',
    settings: 'Configuracion',
  },
};

const t = labels[lang as keyof typeof labels] || labels.en;
const firstName = clerkUser?.firstName || 'User';
---

<BaseLayout title={t.title} lang={lang} noindex>
  <div class="dashboard-page">
    <!-- Header Section -->
    <header class="dashboard-header">
      <div class="header-content">
        <div class="header-greeting">
          <span class="greeting-emoji">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </span>
          <div>
            <h1 class="dashboard-title">{t.welcome}, {firstName}</h1>
            <p class="dashboard-subtitle">{t.description}</p>
          </div>
        </div>
        <div class="header-actions">
          <a href={`/${lang}/dashboard/settings`} class="action-btn" aria-label={t.settings}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="3" />
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="quick-actions">
        <a href={`/${lang}/dashboard/claim`} class="quick-action-card">
          <span class="quick-action-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 5v14M5 12h14"/>
            </svg>
          </span>
          <span class="quick-action-label">{t.submitClaim}</span>
        </a>
        <a href={`/${lang}/products`} class="quick-action-card">
          <span class="quick-action-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
            </svg>
          </span>
          <span class="quick-action-label">{t.viewProducts}</span>
        </a>
        <a href={`/${lang}/dashboard/payout`} class:list={['quick-action-card', { 'payout-ready': canRequestPayout }]}>
          <span class="quick-action-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
          </span>
          <span class="quick-action-label">{t.requestPayout}</span>
        </a>
      </div>
    </header>

    <!-- Main Content -->
    <div class="dashboard-grid">
      <div class="dashboard-main">
        <BalanceCard
          balance={user.balance}
          pendingCashback={pendingCashback}
          tier={user.tier as UserTier}
          lang={lang}
        />

        <ClaimsList claims={claims} lang={lang} />
      </div>

      <aside class="dashboard-sidebar">
        <TransactionList transactions={transactions} lang={lang} />
      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  .dashboard-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  /* Header */
  .dashboard-header {
    margin-bottom: 2rem;
  }

  .header-content {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }

  .header-greeting {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .greeting-emoji {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    background: var(--color-honey-muted, #E8D5C4);
    color: var(--color-honey-dark, #A67B5B);
    border-radius: 12px;
    flex-shrink: 0;
  }

  .dashboard-title {
    font-family: var(--font-display, 'Fraunces', Georgia, serif);
    font-size: 1.75rem;
    font-weight: 400;
    color: var(--color-ink, #1A1815);
    margin: 0 0 0.25rem;
    letter-spacing: -0.02em;
  }

  .dashboard-subtitle {
    font-size: 0.9375rem;
    color: var(--color-stone, #6B6560);
    margin: 0;
  }

  .header-actions {
    display: flex;
    gap: 0.5rem;
  }

  .action-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: var(--color-white, #FFFFFF);
    border: 1px solid var(--color-sand, #E8E4DD);
    border-radius: 10px;
    color: var(--color-stone, #6B6560);
    transition: all 0.2s;
  }

  .action-btn:hover {
    color: var(--color-ink, #1A1815);
    border-color: var(--color-sand-dark, #D4CFC6);
    background: var(--color-cream, #FDFBF7);
  }

  .action-btn svg {
    width: 1.125rem;
    height: 1.125rem;
  }

  /* Quick Actions */
  .quick-actions {
    display: flex;
    gap: 1rem;
  }

  .quick-action-card {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: var(--color-white, #FFFFFF);
    border: 1px solid var(--color-sand, #E8E4DD);
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .quick-action-card:hover {
    border-color: var(--color-honey, #C8956C);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(26, 24, 21, 0.06);
  }

  .quick-action-card.payout-ready {
    border-color: var(--color-forest, #2D5A47);
    background: linear-gradient(135deg, #F0FDF4 0%, #DCFCE7 100%);
  }

  .quick-action-card.payout-ready .quick-action-icon {
    background: var(--color-forest, #2D5A47);
    color: white;
  }

  .quick-action-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    background: var(--color-cream, #FDFBF7);
    border-radius: 8px;
    color: var(--color-honey, #C8956C);
  }

  .quick-action-icon svg {
    width: 1.125rem;
    height: 1.125rem;
  }

  .quick-action-label {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-ink, #1A1815);
  }

  /* Grid */
  .dashboard-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 1024px) {
    .dashboard-grid {
      grid-template-columns: 1.6fr 1fr;
    }
  }

  .dashboard-main {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .dashboard-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .dashboard-page {
      padding: 1.5rem 1rem 3rem;
    }

    .header-greeting {
      flex-direction: column;
      gap: 0.75rem;
    }

    .greeting-emoji {
      width: 2.5rem;
      height: 2.5rem;
    }

    .greeting-emoji svg {
      width: 20px;
      height: 20px;
    }

    .dashboard-title {
      font-size: 1.5rem;
    }

    .quick-actions {
      flex-direction: column;
    }
  }
</style>
