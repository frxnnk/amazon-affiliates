---
export const prerender = false;

import BaseLayout from '@layouts/BaseLayout.astro';
import { getOrCreateUser, formatCurrency, getUserPayoutRequests, PAYOUT_CONFIG } from '@lib/db';
import { type Lang } from '@i18n/utils';

const { lang } = Astro.params as { lang: Lang };

// Get authenticated user
const auth = Astro.locals.auth();
if (!auth.userId) {
  return Astro.redirect(`/${lang}`);
}

// Get user data
const clerkUser = await Astro.locals.currentUser();
const user = await getOrCreateUser(auth.userId, clerkUser?.emailAddresses[0]?.emailAddress || '');

if (!user) {
  return Astro.redirect(`/${lang}`);
}

// Get user's payout requests
const payoutRequests = await getUserPayoutRequests(auth.userId);
const hasPendingPayout = payoutRequests.some(p => p.status === 'pending' || p.status === 'processing');
const canRequestPayout = user.balance >= PAYOUT_CONFIG.minimumAmount && !hasPendingPayout;

const labels = {
  en: {
    title: 'Request Payout',
    subtitle: 'Withdraw your cashback earnings to PayPal or Crypto.',
    currentBalance: 'Available Balance',
    minimumNote: `Minimum payout: ${formatCurrency(PAYOUT_CONFIG.minimumAmount)}`,
    amountLabel: 'Payout Amount',
    amountPlaceholder: 'Enter amount',
    methodLabel: 'Payment Method',
    paypal: 'PayPal',
    crypto: 'Cryptocurrency (USDT/USDC)',
    paypalEmailLabel: 'PayPal Email',
    paypalEmailPlaceholder: 'your@email.com',
    cryptoAddressLabel: 'Wallet Address (TRC-20)',
    cryptoAddressPlaceholder: 'Enter your TRC-20 wallet address',
    submit: 'Request Payout',
    cancel: 'Cancel',
    success: 'Payout request submitted! We will process it within 3-5 business days.',
    error: 'Failed to submit payout request.',
    insufficientBalance: 'Insufficient balance for payout.',
    pendingPayout: 'You have a pending payout request.',
    recentPayouts: 'Recent Payout Requests',
    noPayouts: 'No payout history yet.',
    status: 'Status',
    amount: 'Amount',
    method: 'Method',
    date: 'Date',
    pending: 'Pending',
    processing: 'Processing',
    completed: 'Completed',
    failed: 'Failed',
  },
  es: {
    title: 'Solicitar Retiro',
    subtitle: 'Retira tus ganancias de cashback a PayPal o Crypto.',
    currentBalance: 'Saldo Disponible',
    minimumNote: `Retiro minimo: ${formatCurrency(PAYOUT_CONFIG.minimumAmount)}`,
    amountLabel: 'Monto de Retiro',
    amountPlaceholder: 'Ingresa el monto',
    methodLabel: 'Metodo de Pago',
    paypal: 'PayPal',
    crypto: 'Criptomoneda (USDT/USDC)',
    paypalEmailLabel: 'Email de PayPal',
    paypalEmailPlaceholder: 'tu@email.com',
    cryptoAddressLabel: 'Direccion de Wallet (TRC-20)',
    cryptoAddressPlaceholder: 'Ingresa tu direccion de wallet TRC-20',
    submit: 'Solicitar Retiro',
    cancel: 'Cancelar',
    success: 'Solicitud de retiro enviada! Lo procesaremos en 3-5 dias habiles.',
    error: 'Error al enviar la solicitud de retiro.',
    insufficientBalance: 'Saldo insuficiente para retiro.',
    pendingPayout: 'Ya tienes una solicitud de retiro pendiente.',
    recentPayouts: 'Solicitudes de Retiro Recientes',
    noPayouts: 'Sin historial de retiros aun.',
    status: 'Estado',
    amount: 'Monto',
    method: 'Metodo',
    date: 'Fecha',
    pending: 'Pendiente',
    processing: 'Procesando',
    completed: 'Completado',
    failed: 'Fallido',
  },
};

const t = labels[lang as keyof typeof labels] || labels.en;
const minAmountDollars = PAYOUT_CONFIG.minimumAmount / 100;
---

<BaseLayout title={t.title} lang={lang} noindex>
  <div class="payout-container">
    <div class="payout-card">
      <header class="payout-header">
        <h1 class="payout-title">{t.title}</h1>
        <p class="payout-subtitle">{t.subtitle}</p>
      </header>

      <!-- Balance Display -->
      <div class="balance-display">
        <span class="balance-label">{t.currentBalance}</span>
        <span class="balance-amount">{formatCurrency(user.balance)}</span>
        <span class="balance-note">{t.minimumNote}</span>
      </div>

      {!canRequestPayout && hasPendingPayout && (
        <div class="alert alert-warning">
          {t.pendingPayout}
        </div>
      )}

      {!canRequestPayout && user.balance < PAYOUT_CONFIG.minimumAmount && (
        <div class="alert alert-info">
          {t.insufficientBalance}
        </div>
      )}

      {canRequestPayout && (
        <form id="payout-form" class="payout-form">
          <div class="form-group">
            <label for="amount">{t.amountLabel} *</label>
            <div class="amount-input-wrapper">
              <span class="currency-symbol">$</span>
              <input
                type="number"
                id="amount"
                name="amount"
                min={minAmountDollars}
                max={user.balance / 100}
                step="0.01"
                placeholder={t.amountPlaceholder}
                required
              />
            </div>
            <button type="button" class="max-btn" id="max-amount-btn">
              Max: {formatCurrency(user.balance)}
            </button>
          </div>

          <div class="form-group">
            <label>{t.methodLabel} *</label>
            <div class="method-options">
              <label class="method-option">
                <input type="radio" name="method" value="paypal" checked />
                <span class="method-content">
                  <span class="method-icon">
                    <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
                      <path d="M7.076 21.337H2.47a.641.641 0 0 1-.633-.74L4.944.901C5.026.382 5.474 0 5.998 0h7.46c2.57 0 4.578.543 5.69 1.81 1.01 1.15 1.304 2.42 1.012 4.287-.023.143-.047.288-.077.437-.983 5.05-4.349 6.797-8.647 6.797h-2.19c-.524 0-.968.382-1.05.9l-1.12 7.106zm14.146-14.42a3.35 3.35 0 0 0-.607-.541c-.013.076-.026.175-.041.254-.93 4.778-4.005 7.201-9.138 7.201h-2.19a.563.563 0 0 0-.556.479l-1.187 7.527h-.506l-.24 1.516a.56.56 0 0 0 .554.647h3.882c.46 0 .85-.334.922-.788.06-.26.76-4.852.816-5.09a.932.932 0 0 1 .923-.788h.58c3.76 0 6.705-1.528 7.565-5.946.36-1.847.174-3.388-.777-4.471z"/>
                    </svg>
                  </span>
                  <span class="method-label">{t.paypal}</span>
                </span>
              </label>
              <label class="method-option">
                <input type="radio" name="method" value="crypto" />
                <span class="method-content">
                  <span class="method-icon">
                    <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
                      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.31-8.86c-1.77-.45-2.34-.94-2.34-1.67 0-.84.79-1.43 2.1-1.43 1.38 0 1.9.66 1.94 1.64h1.71c-.05-1.34-.87-2.57-2.49-2.97V5H10.9v1.69c-1.51.32-2.72 1.3-2.72 2.81 0 1.79 1.49 2.69 3.66 3.21 1.95.46 2.34 1.15 2.34 1.87 0 .53-.39 1.39-2.1 1.39-1.6 0-2.23-.72-2.32-1.64H8.04c.1 1.7 1.36 2.66 2.86 2.97V19h2.34v-1.67c1.52-.29 2.72-1.16 2.73-2.77-.01-2.2-1.9-2.96-3.66-3.42z"/>
                    </svg>
                  </span>
                  <span class="method-label">{t.crypto}</span>
                </span>
              </label>
            </div>
          </div>

          <div id="paypal-fields" class="method-fields">
            <div class="form-group">
              <label for="paypalEmail">{t.paypalEmailLabel} *</label>
              <input
                type="email"
                id="paypalEmail"
                name="paypalEmail"
                placeholder={t.paypalEmailPlaceholder}
                value={user.paypalEmail || ''}
              />
            </div>
          </div>

          <div id="crypto-fields" class="method-fields hidden">
            <div class="form-group">
              <label for="cryptoAddress">{t.cryptoAddressLabel} *</label>
              <input
                type="text"
                id="cryptoAddress"
                name="cryptoAddress"
                placeholder={t.cryptoAddressPlaceholder}
                value={user.cryptoAddress || ''}
              />
            </div>
          </div>

          <div id="form-message" class="form-message hidden"></div>

          <div class="form-actions">
            <a href={`/${lang}/dashboard`} class="btn btn-secondary">{t.cancel}</a>
            <button type="submit" class="btn btn-primary">{t.submit}</button>
          </div>
        </form>
      )}
    </div>

    <!-- Recent Payouts -->
    {payoutRequests.length > 0 && (
      <div class="payouts-card">
        <h2 class="payouts-title">{t.recentPayouts}</h2>
        <div class="payouts-list">
          {payoutRequests.slice(0, 5).map(payout => (
            <div class="payout-item">
              <div class="payout-info">
                <span class="payout-amount">{formatCurrency(payout.amount)}</span>
                <span class="payout-method">{payout.method === 'paypal' ? t.paypal : t.crypto}</span>
              </div>
              <div class="payout-meta">
                <span class={`payout-status status-${payout.status}`}>
                  {t[payout.status as keyof typeof t]}
                </span>
                <span class="payout-date">
                  {new Date(payout.createdAt).toLocaleDateString()}
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .payout-container {
    max-width: 40rem;
    margin: 0 auto;
    padding: 2rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .payout-card,
  .payouts-card {
    background: var(--color-white, #FFFFFF);
    border: 1px solid var(--color-sand, #E8E4DD);
    border-radius: 1rem;
    padding: 2rem;
  }

  .payout-header {
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .payout-title {
    font-family: var(--font-display, 'Fraunces', Georgia, serif);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-ink, #1A1815);
    margin-bottom: 0.5rem;
  }

  .payout-subtitle {
    color: var(--color-stone, #6B6560);
    font-size: 0.9375rem;
  }

  /* Balance Display */
  .balance-display {
    background: var(--color-cream, #FDFBF7);
    border-radius: 0.75rem;
    padding: 1.5rem;
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .balance-label {
    display: block;
    font-size: 0.875rem;
    color: var(--color-stone, #6B6560);
    margin-bottom: 0.5rem;
  }

  .balance-amount {
    display: block;
    font-family: var(--font-display, 'Fraunces', Georgia, serif);
    font-size: 2rem;
    font-weight: 600;
    color: var(--color-forest, #2D5A47);
    margin-bottom: 0.5rem;
  }

  .balance-note {
    font-size: 0.75rem;
    color: var(--color-stone, #6B6560);
  }

  /* Alerts */
  .alert {
    padding: 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
  }

  .alert-warning {
    background: #FEF3C7;
    color: #92400E;
  }

  .alert-info {
    background: #DBEAFE;
    color: #1E40AF;
  }

  /* Form */
  .payout-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-weight: 500;
    color: var(--color-ink, #1A1815);
    font-size: 0.9375rem;
  }

  .form-group input {
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-sand, #E8E4DD);
    border-radius: 0.5rem;
    font-size: 1rem;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--color-honey, #C8956C);
    box-shadow: 0 0 0 3px rgba(200, 149, 108, 0.1);
  }

  .amount-input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .currency-symbol {
    position: absolute;
    left: 1rem;
    color: var(--color-stone, #6B6560);
    font-weight: 500;
  }

  .amount-input-wrapper input {
    padding-left: 2rem;
    width: 100%;
  }

  .max-btn {
    align-self: flex-start;
    background: none;
    border: none;
    color: var(--color-honey, #C8956C);
    font-size: 0.75rem;
    cursor: pointer;
    padding: 0;
    text-decoration: underline;
  }

  .max-btn:hover {
    color: var(--color-honey-dark, #A67B5B);
  }

  /* Method Options */
  .method-options {
    display: flex;
    gap: 1rem;
  }

  .method-option {
    flex: 1;
    cursor: pointer;
  }

  .method-option input {
    display: none;
  }

  .method-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem;
    border: 2px solid var(--color-sand, #E8E4DD);
    border-radius: 0.75rem;
    transition: all 0.2s;
  }

  .method-option input:checked + .method-content {
    border-color: var(--color-honey, #C8956C);
    background: var(--color-cream, #FDFBF7);
  }

  .method-icon {
    color: var(--color-stone, #6B6560);
  }

  .method-option input:checked + .method-content .method-icon {
    color: var(--color-honey, #C8956C);
  }

  .method-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink, #1A1815);
    text-align: center;
  }

  .method-fields.hidden {
    display: none;
  }

  /* Form Message */
  .form-message {
    padding: 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
  }

  .form-message.success {
    background: #D1FAE5;
    color: #065F46;
  }

  .form-message.error {
    background: #FEE2E2;
    color: #991B1B;
  }

  .form-message.hidden {
    display: none;
  }

  /* Form Actions */
  .form-actions {
    display: flex;
    gap: 1rem;
    justify-content: flex-end;
    margin-top: 0.5rem;
  }

  .btn {
    padding: 0.75rem 1.5rem;
    font-weight: 500;
    border-radius: 0.5rem;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.15s;
    border: none;
    font-size: 1rem;
  }

  .btn-primary {
    background: var(--color-honey, #C8956C);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-honey-dark, #A67B5B);
  }

  .btn-primary:disabled {
    background: var(--color-sand, #E8E4DD);
    cursor: not-allowed;
  }

  .btn-secondary {
    background: var(--color-cream, #FDFBF7);
    color: var(--color-ink, #1A1815);
    border: 1px solid var(--color-sand, #E8E4DD);
  }

  .btn-secondary:hover {
    background: var(--color-sand, #E8E4DD);
  }

  /* Payouts List */
  .payouts-title {
    font-family: var(--font-display, 'Fraunces', Georgia, serif);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-ink, #1A1815);
    margin-bottom: 1rem;
  }

  .payouts-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .payout-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem;
    background: var(--color-cream, #FDFBF7);
    border-radius: 0.5rem;
  }

  .payout-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .payout-amount {
    font-weight: 600;
    color: var(--color-ink, #1A1815);
  }

  .payout-method {
    font-size: 0.75rem;
    color: var(--color-stone, #6B6560);
  }

  .payout-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
  }

  .payout-status {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25rem 0.5rem;
    border-radius: 9999px;
  }

  .status-pending {
    background: #FEF3C7;
    color: #92400E;
  }

  .status-processing {
    background: #DBEAFE;
    color: #1E40AF;
  }

  .status-completed {
    background: #D1FAE5;
    color: #065F46;
  }

  .status-failed {
    background: #FEE2E2;
    color: #991B1B;
  }

  .payout-date {
    font-size: 0.75rem;
    color: var(--color-stone, #6B6560);
  }

  @media (max-width: 640px) {
    .method-options {
      flex-direction: column;
    }

    .form-actions {
      flex-direction: column-reverse;
    }

    .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>

<script define:vars={{ lang, labels: labels, userBalance: user.balance }}>
  const form = document.getElementById('payout-form');
  const methodInputs = document.querySelectorAll('input[name="method"]');
  const paypalFields = document.getElementById('paypal-fields');
  const cryptoFields = document.getElementById('crypto-fields');
  const maxBtn = document.getElementById('max-amount-btn');
  const amountInput = document.getElementById('amount');
  const messageDiv = document.getElementById('form-message');
  const t = labels[lang] || labels.en;

  // Toggle payment method fields
  methodInputs.forEach(input => {
    input.addEventListener('change', (e) => {
      if (e.target.value === 'paypal') {
        paypalFields?.classList.remove('hidden');
        cryptoFields?.classList.add('hidden');
      } else {
        paypalFields?.classList.add('hidden');
        cryptoFields?.classList.remove('hidden');
      }
    });
  });

  // Max amount button
  maxBtn?.addEventListener('click', () => {
    if (amountInput) {
      amountInput.value = (userBalance / 100).toFixed(2);
    }
  });

  // Form submission
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const submitBtn = form.querySelector('button[type="submit"]');
    if (submitBtn) submitBtn.disabled = true;

    const formData = new FormData(form);
    const method = formData.get('method');
    const data = {
      amount: Math.round(parseFloat(formData.get('amount')) * 100), // Convert to cents
      method,
      paypalEmail: method === 'paypal' ? formData.get('paypalEmail') : undefined,
      cryptoAddress: method === 'crypto' ? formData.get('cryptoAddress') : undefined,
    };

    try {
      const response = await fetch('/api/user/payout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await response.json();

      if (response.ok) {
        messageDiv.textContent = t.success;
        messageDiv.className = 'form-message success';

        setTimeout(() => {
          window.location.href = `/${lang}/dashboard`;
        }, 2000);
      } else {
        messageDiv.textContent = result.error || t.error;
        messageDiv.className = 'form-message error';
      }
    } catch (error) {
      messageDiv.textContent = t.error;
      messageDiv.className = 'form-message error';
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>
