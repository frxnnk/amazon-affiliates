---
import InfiniteFeed from '@components/feed/InfiniteFeed.astro';
import LegalModal from '@components/modals/LegalModal.astro';
import { type Lang } from '@i18n/utils';
import siteConfig from '@data/site-config.json';
import { SignedIn, SignedOut, UserButton } from '@clerk/astro/components';
import '../../styles/global.css';

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } }
  ];
}

const { lang } = Astro.params as { lang: Lang };

const validLangs = ['es', 'en'];
if (!validLangs.includes(lang)) {
  return Astro.redirect('/es/', 302);
}

const siteTitle = siteConfig.site.name;
const pageTitle = siteConfig.site.tagline[lang];
const metaDescription = lang === 'es' 
  ? 'Descubre los mejores productos de Amazon con ofertas exclusivas y cashback.'
  : 'Discover the best Amazon products with exclusive deals and cashback.';

const trendingSearches = lang === 'es' 
  ? ['iPhone 15', 'AirPods Pro', 'PS5', 'MacBook', 'Samsung Galaxy', 'Xiaomi']
  : ['iPhone 15', 'AirPods Pro', 'PS5', 'MacBook', 'Samsung Galaxy', 'Nintendo Switch'];

const texts = {
  es: {
    discover: 'Descubrir',
    search: 'Buscar',
    searchPlaceholder: '¿Qué estás buscando?',
    noResults: 'No se encontraron resultados',
    profile: 'Perfil',
    likes: 'Favoritos',
    saved: 'Guardados',
    loading: 'Cargando...',
    noLikes: 'No tienes favoritos aún',
    noSaved: 'No tienes productos guardados',
    signIn: 'Iniciar Sesión',
    signInPrompt: 'Para guardar productos y recibir cashback',
    terms: 'Términos y Condiciones',
    privacy: 'Política de Privacidad',
    about: 'Sobre Nosotros',
    trendingSearches: 'Búsquedas populares',
    recentSearches: 'Búsquedas recientes',
    clearHistory: 'Limpiar',
    quickCategories: 'Categorías',
    reviews: 'opiniones',
    tryDifferent: 'Prueba con otras palabras clave',
  },
  en: {
    discover: 'Discover',
    search: 'Search',
    searchPlaceholder: 'What are you looking for?',
    noResults: 'No results found',
    profile: 'Profile',
    likes: 'Favorites',
    saved: 'Saved',
    loading: 'Loading...',
    noLikes: 'No favorites yet',
    noSaved: 'No saved products',
    signIn: 'Sign In',
    signInPrompt: 'To save products and earn cashback',
    terms: 'Terms of Service',
    privacy: 'Privacy Policy',
    about: 'About Us',
    trendingSearches: 'Trending searches',
    recentSearches: 'Recent searches',
    clearHistory: 'Clear',
    quickCategories: 'Categories',
    reviews: 'reviews',
    tryDifferent: 'Try different keywords',
  }
};

const t = texts[lang];
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle} | {siteTitle}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <meta name="theme-color" content="#000000" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="feed-mode">
    
    <!-- Floating Header (only visible in search/profile) -->
    <header class="header hidden" id="app-header">
      <a href={`/${lang}`} class="brand-text">
        {siteTitle}
      </a>
      
      <div class="header-right">
        <!-- Language Dropdown -->
        <div class="lang-dropdown" id="lang-dropdown">
          <button class="lang-trigger" id="lang-trigger" type="button" aria-expanded="false" aria-haspopup="true">
            <span class="lang-flag">{lang === 'es' ? '🇪🇸' : '🇺🇸'}</span>
            <span class="lang-code">{lang.toUpperCase()}</span>
            <svg class="lang-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </button>
          <div class="lang-menu" role="menu">
            <a href="/es" class={`lang-option ${lang === 'es' ? 'active' : ''}`} role="menuitem">
              <span class="lang-option-flag">🇪🇸</span>
              <span class="lang-option-text">Español</span>
              {lang === 'es' && <span class="lang-check">✓</span>}
            </a>
            <a href="/en" class={`lang-option ${lang === 'en' ? 'active' : ''}`} role="menuitem">
              <span class="lang-option-flag">🇺🇸</span>
              <span class="lang-option-text">English</span>
              {lang === 'en' && <span class="lang-check">✓</span>}
            </a>
          </div>
        </div>
        <SignedOut>
          <a href={`/${lang}/login`} class="user-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="8" r="4"/>
              <path d="M4 20c0-4 4-6 8-6s8 2 8 6"/>
            </svg>
          </a>
        </SignedOut>
        <SignedIn>
          <UserButton />
        </SignedIn>
      </div>
    </header>

    <main class="main">
      
      <!-- FEED VIEW (Default/Primary) -->
      <section class="view feed-view active" id="feed-view">
        <InfiniteFeed lang={lang} category="all" />
      </section>

      <!-- SEARCH VIEW -->
      <section class="view" id="search-view">
        <div class="search-wrapper">
          
          <div class="search-header-fixed">
            <div class="search-bar" id="search-wrap">
              <div class="search-bar-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/>
                </svg>
              </div>
              <input 
                type="text" 
                id="search-input" 
                placeholder={t.searchPlaceholder} 
                autocomplete="off"
                spellcheck="false"
              />
              <button class="search-bar-clear" id="search-clear" type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 6L6 18M6 6l12 12"/>
                </svg>
              </button>
              <div class="search-bar-spinner" id="search-loading">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <circle cx="12" cy="12" r="10" stroke-opacity="0.2"/>
                  <path d="M12 2a10 10 0 0 1 10 10"/>
                </svg>
              </div>
            </div>
          </div>

          <div class="search-body" id="search-content">
            
            <!-- Initial State -->
            <div class="search-home" id="search-initial">
              
              <!-- Recent Searches -->
              <div class="search-block" id="recent-section" style="display: none;">
                <div class="search-block-head">
                  <span class="search-block-title">{t.recentSearches}</span>
                  <button class="search-block-action" id="clear-history">{t.clearHistory}</button>
                </div>
                <div class="search-tags" id="recent-chips"></div>
              </div>

              <!-- Trending -->
              <div class="search-block">
                <span class="search-block-title">{t.trendingSearches}</span>
                <div class="search-tags">
                  {trendingSearches.map((term, i) => (
                    <button class="search-tag" data-query={term}>
                      <span class="tag-number">{i + 1}</span>
                      <span class="tag-text">{term}</span>
                    </button>
                  ))}
                </div>
              </div>

              <!-- Quick Categories -->
              <div class="search-block">
                <span class="search-block-title">{t.quickCategories}</span>
                <div class="search-categories">
                  <button class="search-cat-btn" data-query={lang === 'es' ? 'auriculares' : 'headphones'}>
                    <div class="cat-btn-icon">🎧</div>
                    <span>Audio</span>
                  </button>
                  <button class="search-cat-btn" data-query={lang === 'es' ? 'smartphone' : 'smartphone'}>
                    <div class="cat-btn-icon">📱</div>
                    <span>{lang === 'es' ? 'Móviles' : 'Phones'}</span>
                  </button>
                  <button class="search-cat-btn" data-query={lang === 'es' ? 'laptop ordenador' : 'laptop computer'}>
                    <div class="cat-btn-icon">💻</div>
                    <span>PC</span>
                  </button>
                  <button class="search-cat-btn" data-query={lang === 'es' ? 'gaming consola' : 'gaming console'}>
                    <div class="cat-btn-icon">🎮</div>
                    <span>Gaming</span>
                  </button>
                  <button class="search-cat-btn" data-query={lang === 'es' ? 'smartwatch reloj' : 'smartwatch'}>
                    <div class="cat-btn-icon">⌚</div>
                    <span>Wearables</span>
                  </button>
                  <button class="search-cat-btn" data-query={lang === 'es' ? 'hogar electrodomestico' : 'home appliance'}>
                    <div class="cat-btn-icon">🏠</div>
                    <span>{lang === 'es' ? 'Hogar' : 'Home'}</span>
                  </button>
                </div>
              </div>
            </div>

            <!-- Loading Skeletons -->
            <div class="search-loading-state" id="search-skeleton" style="display: none;">
              <div class="search-results-grid">
                {[1, 2, 3, 4, 5, 6].map(() => (
                  <div class="result-skeleton">
                    <div class="skel-image"></div>
                    <div class="skel-content">
                      <div class="skel-text small"></div>
                      <div class="skel-text large"></div>
                      <div class="skel-text medium"></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Results Grid -->
            <div class="search-results-container" id="search-results" style="display: none;">
              <div class="search-results-grid" id="results-grid"></div>
            </div>

            <!-- Empty State -->
            <div class="search-empty-state" id="search-empty" style="display: none;">
              <div class="empty-illustration">
                <svg viewBox="0 0 120 120" fill="none">
                  <circle cx="60" cy="50" r="35" stroke="currentColor" stroke-width="3" opacity="0.15"/>
                  <circle cx="60" cy="50" r="25" stroke="currentColor" stroke-width="2" opacity="0.3"/>
                  <line x1="82" y1="72" x2="100" y2="90" stroke="currentColor" stroke-width="3" stroke-linecap="round" opacity="0.4"/>
                  <path d="M50 45 L70 55 M50 55 L70 45" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
                </svg>
              </div>
              <p class="empty-text">{t.noResults}</p>
              <p class="empty-hint">{t.tryDifferent}</p>
            </div>

          </div>
        </div>
      </section>

      <!-- PROFILE VIEW -->
      <section class="view" id="profile-view">
        <div class="profile-page">
          <SignedIn>
            <!-- Profile Hero -->
            <div class="profile-hero">
              <div class="hero-row">
                <div class="user-avatar-wrap">
                  <UserButton 
                    appearance={{
                      elements: {
                        avatarBox: "avatar-box",
                        userButtonTrigger: "avatar-trigger"
                      }
                    }}
                  />
                </div>
                <div class="user-info">
                  <span class="user-greeting">{lang === 'es' ? 'Bienvenido' : 'Welcome'}</span>
                  <h1 class="user-name" id="profile-user-name">...</h1>
                </div>
              </div>
            </div>

            <!-- Saved Section Header -->
            <div class="saved-section-header">
              <div class="saved-header-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0z"/>
                </svg>
              </div>
              <div class="saved-header-text">
                <span class="saved-header-title">{t.saved}</span>
                <span class="saved-header-count" id="profile-saved-count">0</span>
              </div>
            </div>

            <!-- Content Panels -->
            <div class="profile-content" id="profile-content">
              <div class="content-loading" id="profile-loading">
                <div class="dot-loader"><span></span><span></span><span></span></div>
                <p>{t.loading}</p>
              </div>
            </div>
          </SignedIn>
          <SignedOut>
            <div class="login-prompt-card">
              <div class="prompt-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <circle cx="12" cy="8" r="4"/>
                  <path d="M4 20c0-4 4-6 8-6s8 2 8 6"/>
                </svg>
              </div>
              <h2>{t.signIn}</h2>
              <p>{t.signInPrompt}</p>
              <a href={`/${lang}/login`} class="btn-login">{t.signIn}</a>
            </div>
          </SignedOut>
          <nav class="legal-links">
            <button type="button" class="legal-link" data-modal="terms">{t.terms}</button>
            <button type="button" class="legal-link" data-modal="privacy">{t.privacy}</button>
            <button type="button" class="legal-link" data-modal="about">{t.about}</button>
          </nav>
        </div>
      </section>

    </main>
    
    <!-- Legal Modals -->
    <LegalModal lang={lang} />

    <!-- Bottom Navigation (3 tabs) -->
    <nav class="bottom-nav" id="bottom-nav">
      <button class="nav-item active" data-view="feed">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>
        <span>{t.discover}</span>
      </button>
      <button class="nav-item" data-view="search">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/></svg>
        <span>{t.search}</span>
      </button>
      <button class="nav-item" data-view="profile">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6"/></svg>
        <span>{t.profile}</span>
      </button>
    </nav>

    <script define:vars={{ lang, t: texts[lang] }}>
      document.addEventListener('DOMContentLoaded', () => {
        // ============ NAVIGATION ============
        const nav = document.getElementById('bottom-nav');
        const header = document.getElementById('app-header');
        const views = document.querySelectorAll('.view');
        const tabs = nav?.querySelectorAll('.nav-item');

        function switchView(id) {
          views.forEach(v => v.classList.remove('active'));
          tabs?.forEach(t => t.classList.remove('active'));
          
          const view = document.getElementById(`${id}-view`);
          const tab = nav?.querySelector(`[data-view="${id}"]`);
          
          view?.classList.add('active');
          tab?.classList.add('active');
          
          // Feed mode: hide header, immersive experience
          if (id === 'feed') {
            header?.classList.add('hidden');
            document.body.classList.add('feed-mode');
            view?.dispatchEvent(new CustomEvent('feed:activated'));
          } else {
            header?.classList.remove('hidden');
            document.body.classList.remove('feed-mode');
          }

          // Focus search input when switching to search
          if (id === 'search') {
            setTimeout(() => document.getElementById('search-input')?.focus(), 100);
          }
        }

        tabs?.forEach(tab => tab.addEventListener('click', () => switchView(tab.dataset.view)));

        // ============ LANGUAGE DROPDOWN ============
        const langDropdown = document.getElementById('lang-dropdown');
        const langTrigger = document.getElementById('lang-trigger');

        langTrigger?.addEventListener('click', (e) => {
          e.stopPropagation();
          const isOpen = langDropdown?.classList.toggle('open');
          langTrigger?.setAttribute('aria-expanded', String(isOpen));
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', (e) => {
          if (langDropdown && !langDropdown.contains(e.target)) {
            langDropdown.classList.remove('open');
            langTrigger?.setAttribute('aria-expanded', 'false');
          }
        });

        // Close on escape key
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && langDropdown?.classList.contains('open')) {
            langDropdown.classList.remove('open');
            langTrigger?.setAttribute('aria-expanded', 'false');
          }
        });

        // ============ SEARCH FUNCTIONALITY ============
        const searchInput = document.getElementById('search-input');
        const searchWrap = document.getElementById('search-wrap');
        const searchClear = document.getElementById('search-clear');
        const searchInitial = document.getElementById('search-initial');
        const searchSkeleton = document.getElementById('search-skeleton');
        const searchResults = document.getElementById('search-results');
        const searchEmpty = document.getElementById('search-empty');
        const recentSection = document.getElementById('recent-section');
        const recentChips = document.getElementById('recent-chips');
        const clearHistory = document.getElementById('clear-history');
        
        let searchTimeout;
        const HISTORY_KEY = 'rewardHive_searchHistory';
        const MAX_HISTORY = 5;

        function getSearchHistory() {
          try {
            return JSON.parse(localStorage.getItem(HISTORY_KEY) || '[]');
          } catch { return []; }
        }

        function saveSearchHistory(query) {
          const history = getSearchHistory().filter(q => q !== query);
          history.unshift(query);
          localStorage.setItem(HISTORY_KEY, JSON.stringify(history.slice(0, MAX_HISTORY)));
          renderRecentSearches();
        }

        function clearSearchHistoryFn() {
          localStorage.removeItem(HISTORY_KEY);
          renderRecentSearches();
        }

        function renderRecentSearches() {
          const history = getSearchHistory();
          if (history.length === 0) {
            recentSection.style.display = 'none';
            return;
          }
          
          recentSection.style.display = 'block';
          recentChips.innerHTML = history.map(term => `
            <button class="search-tag recent-tag" data-query="${term}">
              <span class="tag-text">${term}</span>
              <span class="tag-remove" data-remove="${term}">×</span>
            </button>
          `).join('');

          recentChips.querySelectorAll('.recent-tag').forEach(chip => {
            chip.addEventListener('click', (e) => {
              if (e.target.classList.contains('tag-remove')) {
                e.stopPropagation();
                const toRemove = e.target.dataset.remove;
                const history = getSearchHistory().filter(q => q !== toRemove);
                localStorage.setItem(HISTORY_KEY, JSON.stringify(history));
                renderRecentSearches();
                return;
              }
              const query = chip.dataset.query;
              searchInput.value = query;
              performSearch(query);
            });
          });
        }

        function showState(state) {
          searchInitial.style.display = state === 'initial' ? 'block' : 'none';
          searchSkeleton.style.display = state === 'loading' ? 'flex' : 'none';
          searchResults.style.display = state === 'results' ? 'block' : 'none';
          searchEmpty.style.display = state === 'empty' ? 'flex' : 'none';
        }

        async function performSearch(query) {
          if (!query || query.length < 2) {
            showState('initial');
            searchWrap.classList.remove('has-value');
            return;
          }

          searchWrap.classList.add('has-value', 'is-loading');
          showState('loading');

          try {
            const res = await fetch(`/api/search?q=${encodeURIComponent(query)}&lang=${lang}`);
            const data = await res.json();

            searchWrap.classList.remove('is-loading');

            if (data.success && data.products?.length) {
              saveSearchHistory(query);
              renderResults(data.products);
              showState('results');
            } else {
              showState('empty');
            }
          } catch {
            searchWrap.classList.remove('is-loading');
            showState('empty');
          }
        }

        function renderResults(products) {
          const resultsGrid = document.getElementById('results-grid');
          if (!resultsGrid) return;
          
          resultsGrid.innerHTML = products.map(p => {
            const stars = p.rating ? renderStars(p.rating) : '';
            const reviewsText = p.totalReviews ? `<span class="result-reviews-count">(${formatNumber(p.totalReviews)})</span>` : '';
            const discount = p.discount > 0 ? `<span class="result-badge">-${p.discount}%</span>` : '';
            const prime = p.isPrime ? '<span class="result-prime-badge">Prime</span>' : '';
            const oldPrice = p.formattedOriginalPrice ? `<span class="result-item-old">${p.formattedOriginalPrice}</span>` : '';
            const imageUrl = p.image || 'data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><rect fill="%23f3f4f6" width="100" height="100"/></svg>';

            return `
              <a href="${p.affiliateUrl}" target="_blank" rel="noopener noreferrer nofollow" class="result-item">
                <div class="result-item-img">
                  ${discount}
                  <img src="${imageUrl}" alt="${p.title || ''}" loading="lazy" />
                </div>
                <div class="result-item-body">
                  ${p.brand ? `<span class="result-item-brand">${p.brand}</span>` : ''}
                  <h4 class="result-item-title">${p.title || 'Producto'}</h4>
                  ${stars || reviewsText ? `
                    <div class="result-item-meta">
                      ${stars}
                      ${reviewsText}
                    </div>
                  ` : ''}
                  <div class="result-item-pricing">
                    <span class="result-item-price">${p.formattedPrice || '---'}</span>
                    ${oldPrice}
                    ${prime}
                  </div>
                </div>
              </a>
            `;
          }).join('');
        }

        function formatNumber(num) {
          if (num >= 1000) return (num / 1000).toFixed(1).replace(/\.0$/, '') + 'k';
          return num.toString();
        }

        function renderStars(rating) {
          if (!rating) return '';
          const full = Math.floor(rating);
          const empty = 5 - full;
          
          let html = '<div class="result-stars">';
          for (let i = 0; i < full; i++) {
            html += '<svg class="result-star" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>';
          }
          for (let i = 0; i < empty; i++) {
            html += '<svg class="result-star empty" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>';
          }
          html += `<span class="result-rating-text">${rating.toFixed(1)}</span></div>`;
          return html;
        }

        searchInput?.addEventListener('input', (e) => {
          clearTimeout(searchTimeout);
          const q = e.target.value.trim();
          
          if (q.length > 0) {
            searchWrap.classList.add('has-value');
          } else {
            searchWrap.classList.remove('has-value');
            showState('initial');
            return;
          }

          if (q.length < 2) return;
          searchTimeout = setTimeout(() => performSearch(q), 400);
        });

        searchInput?.addEventListener('focus', () => searchWrap?.classList.add('focused'));
        searchInput?.addEventListener('blur', () => searchWrap?.classList.remove('focused'));

        searchClear?.addEventListener('click', () => {
          searchInput.value = '';
          searchWrap.classList.remove('has-value');
          showState('initial');
          searchInput.focus();
        });

        clearHistory?.addEventListener('click', clearSearchHistoryFn);

        document.querySelectorAll('.search-tag[data-query]').forEach(tag => {
          tag.addEventListener('click', () => {
            const query = tag.dataset.query;
            if (query) {
              searchInput.value = query;
              performSearch(query);
            }
          });
        });

        document.querySelectorAll('.search-cat-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            const query = btn.dataset.query;
            searchInput.value = query;
            performSearch(query);
          });
        });

        renderRecentSearches();

        // ============ LEGAL MODALS ============
        document.querySelectorAll('.legal-link[data-modal]').forEach(btn => {
          btn.addEventListener('click', () => {
            const modalType = btn.dataset.modal;
            if (modalType) {
              document.dispatchEvent(new CustomEvent('legal-modal:open', {
                detail: { type: modalType }
              }));
            }
          });
        });

        // ============ PROFILE ============
        const profileContent = document.getElementById('profile-content');
        const profileUserName = document.getElementById('profile-user-name');
        const profileSavedCount = document.getElementById('profile-saved-count');

        // Load user name from Clerk
        function loadProfileUserName() {
          const tryGetUser = () => {
            if (window.Clerk?.user) {
              const user = window.Clerk.user;
              const name = user.firstName || user.username || user.emailAddresses?.[0]?.emailAddress?.split('@')[0] || 'User';
              if (profileUserName) profileUserName.textContent = name;
            } else {
              setTimeout(tryGetUser, 100);
            }
          };
          tryGetUser();
        }

        // Update saved count
        function updateSavedCount() {
          const saved = JSON.parse(localStorage.getItem('savedProducts') || '[]');
          if (profileSavedCount) profileSavedCount.textContent = String(saved.length);
        }

        // Truncate title helper
        function truncateTitle(title, maxLen = 50) {
          if (!title) return '';
          return title.length > maxLen ? title.substring(0, maxLen) + '...' : title;
        }

        // Load saved products
        function loadSavedProducts() {
          if (!profileContent) return;
          
          const saved = JSON.parse(localStorage.getItem('savedProducts') || '[]');
          
          if (!saved.length) {
            profileContent.innerHTML = `
              <div class="empty-panel">
                <p class="empty-text">${t.noSaved}</p>
                <p class="empty-desc">${lang === 'es' ? 'Guarda productos desde el feed para verlos aquí' : 'Save products from the feed to see them here'}</p>
              </div>
            `;
          } else {
            const cardsHtml = saved.map(item => {
              const isOldFormat = typeof item === 'string';
              const asin = isOldFormat ? item : item.asin;
              const title = isOldFormat ? asin : (item.title || 'Producto');
              const brand = isOldFormat ? '' : (item.brand || '');
              const image = isOldFormat ? '' : (item.image || '');
              const price = isOldFormat ? '' : (item.price || '');
              const url = isOldFormat ? 'https://www.amazon.com/dp/' + asin + '?tag=rewardhive-20' : (item.affiliateUrl || '#');
              
              let imgHtml = '';
              if (image) {
                imgHtml = '<img src="' + image + '" alt="' + title + '" loading="lazy" />';
              } else {
                imgHtml = '<div class="saved-item-placeholder"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20"><path d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0z"/></svg></div>';
              }
              
              let priceHtml = price ? '<span class="saved-item-price">' + price + '</span>' : '<span class="saved-item-code">' + asin + '</span>';
              let brandHtml = brand ? '<span class="saved-item-brand">' + brand + '</span>' : '';
              
              return '<a href="' + url + '" target="_blank" rel="noopener noreferrer nofollow" class="saved-item" data-asin="' + asin + '">' +
                '<div class="saved-item-img">' + imgHtml + '</div>' +
                '<div class="saved-item-info">' + brandHtml + '<h4 class="saved-item-title">' + truncateTitle(title, 60) + '</h4>' + priceHtml + '</div>' +
                '<button class="saved-item-remove" data-asin="' + asin + '" title="' + (lang === 'es' ? 'Eliminar' : 'Remove') + '"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M6 18L18 6M6 6l12 12"/></svg></button>' +
              '</a>';
            }).join('');
            
            profileContent.innerHTML = '<div class="saved-list">' + cardsHtml + '</div>';
            
            // Add remove handlers
            profileContent.querySelectorAll('.saved-item-remove').forEach(btn => {
              btn.addEventListener('click', (e) => {
                e.stopPropagation();
                e.preventDefault();
                const asin = btn.dataset.asin;
                const items = JSON.parse(localStorage.getItem('savedProducts') || '[]');
                const newItems = items.filter(item => (typeof item === 'string' ? item : item.asin) !== asin);
                localStorage.setItem('savedProducts', JSON.stringify(newItems));
                btn.closest('.saved-item')?.remove();
                updateSavedCount();
                if (newItems.length === 0) loadSavedProducts();
              });
            });
          }
        }

        // Initialize profile
        loadProfileUserName();
        updateSavedCount();
        loadSavedProducts();
      });
    </script>
  </body>
</html>

