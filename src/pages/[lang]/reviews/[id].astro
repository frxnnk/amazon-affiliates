---
import BaseLayout from '@layouts/BaseLayout.astro';
import BuyButton from '@components/affiliate/BuyButton.astro';
import PriceDisplay from '@components/affiliate/PriceDisplay.astro';
import ProsConsList from '@components/products/ProsConsList.astro';
import Badge from '@components/ui/Badge.astro';
import { getCollection, render } from 'astro:content';
import { type Lang, getTranslation, formatDate } from '@i18n/utils';

// Obtener parametros de la URL
const { lang, id } = Astro.params as { lang: Lang; id: string };

// Buscar la review
const reviews = await getCollection('reviews');
const review = reviews.find(r => r.data.reviewId === id && r.data.lang === lang);

// Si no existe, retornar 404
if (!review) {
  return Astro.redirect(`/${lang}/reviews`);
}

const { data } = review;
const { Content } = await render(review);
const t = getTranslation(lang);

// Get the reviewed product
const allProducts = await getCollection('products');
const reviewedProduct = allProducts.find(
  p => p.data.productId === data.productId && p.data.lang === lang
);

const scoreLabels = {
  quality: { es: 'Calidad', en: 'Quality' },
  value: { es: 'Relacion Calidad-Precio', en: 'Value for Money' },
  features: { es: 'Caracteristicas', en: 'Features' },
  easeOfUse: { es: 'Facilidad de Uso', en: 'Ease of Use' }
};

function getScoreColor(score: number): string {
  if (score >= 9) return 'text-green-600 bg-green-50';
  if (score >= 7) return 'text-yellow-600 bg-yellow-50';
  if (score >= 5) return 'text-orange-600 bg-orange-50';
  return 'text-red-600 bg-red-50';
}
---

<BaseLayout
  title={data.title}
  description={data.excerpt}
  lang={lang}
  image={data.featuredImage?.url}
>
  <article class="max-w-4xl mx-auto">
    <!-- Header -->
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <Badge variant="primary">
          {lang === 'es' ? 'Review' : 'Review'}
        </Badge>
        <span class="text-sm text-gray-500">{data.category}</span>
      </div>

      <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
        {data.title}
      </h1>

      <p class="text-xl text-gray-600 mb-6">{data.excerpt}</p>

      <div class="flex items-center gap-4 text-sm text-gray-500">
        <div class="flex items-center gap-2">
          {data.author.avatar && (
            <img
              src={data.author.avatar}
              alt={data.author.name}
              class="w-8 h-8 rounded-full"
            />
          )}
          <span>{data.author.name}</span>
        </div>
        <span>•</span>
        <time datetime={data.publishedAt.toISOString()}>
          {formatDate(data.publishedAt, lang)}
        </time>
      </div>
    </header>

    <!-- Featured Image -->
    {data.featuredImage?.url && (
      <div class="mb-8 rounded-xl overflow-hidden">
        <img
          src={data.featuredImage.url}
          alt={data.featuredImage.alt}
          class="w-full h-64 lg:h-96 object-cover"
        />
      </div>
    )}

    <!-- Score Overview -->
    <section class="bg-white rounded-xl shadow-sm p-6 lg:p-8 mb-8">
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Overall Score -->
        <div class="text-center">
          <div class={`inline-flex items-center justify-center w-24 h-24 rounded-full ${getScoreColor(data.overallScore)}`}>
            <span class="text-4xl font-bold">{data.overallScore}</span>
          </div>
          <p class="text-lg font-medium text-gray-900 mt-2">
            {lang === 'es' ? 'Puntuacion General' : 'Overall Score'}
          </p>
          <p class="text-sm text-gray-500">{lang === 'es' ? 'de 10' : 'out of 10'}</p>
        </div>

        <!-- Individual Scores -->
        <div class="space-y-4">
          {Object.entries(data.scores).map(([key, score]) => (
            <div class="flex items-center gap-4">
              <span class="w-32 text-sm text-gray-600">
                {scoreLabels[key as keyof typeof scoreLabels]?.[lang] || key}
              </span>
              <div class="flex-1 bg-gray-100 rounded-full h-3">
                <div
                  class="h-3 rounded-full bg-primary-500"
                  style={`width: ${(score as number) * 10}%`}
                />
              </div>
              <span class="w-8 text-sm font-medium text-gray-900">{score}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Verdict -->
    <section class="bg-primary-50 rounded-xl p-6 lg:p-8 mb-8">
      <h2 class="text-xl font-bold text-gray-900 mb-4">
        {lang === 'es' ? 'Veredicto' : 'Verdict'}
      </h2>
      <p class="text-gray-700 text-lg">{data.verdict}</p>
    </section>

    <!-- Pros and Cons -->
    <section class="bg-white rounded-xl shadow-sm p-6 lg:p-8 mb-8">
      <ProsConsList pros={data.pros} cons={data.cons} lang={lang} />
    </section>

    <!-- Reviewed Product -->
    {reviewedProduct && (
      <section class="bg-white rounded-xl shadow-sm p-6 lg:p-8 mb-8">
        <h2 class="text-xl font-bold text-gray-900 mb-6">
          {lang === 'es' ? 'Producto Reseñado' : 'Reviewed Product'}
        </h2>

        <div class="flex flex-col md:flex-row gap-6">
          <a
            href={`/${lang}/products/${reviewedProduct.data.productId}`}
            class="block w-full md:w-48 aspect-square bg-gray-50 rounded-lg overflow-hidden flex-shrink-0"
          >
            <img
              src={reviewedProduct.data.featuredImage.url}
              alt={reviewedProduct.data.featuredImage.alt}
              class="w-full h-full object-contain p-4"
            />
          </a>

          <div class="flex-1">
            <p class="text-sm text-gray-500 mb-1">{reviewedProduct.data.brand}</p>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">
              <a
                href={`/${lang}/products/${reviewedProduct.data.productId}`}
                class="hover:text-primary-600"
              >
                {reviewedProduct.data.title}
              </a>
            </h3>

            <PriceDisplay
              price={reviewedProduct.data.price}
              originalPrice={reviewedProduct.data.originalPrice}
              currency={reviewedProduct.data.currency}
              lang={lang}
              size="md"
            />

            <div class="mt-4">
              <BuyButton
                productId={reviewedProduct.data.productId}
                asin={reviewedProduct.data.asin}
                affiliateUrl={reviewedProduct.data.affiliateUrl}
                lang={lang}
                size="md"
              />
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Content -->
    {Content && (
      <section class="bg-white rounded-xl shadow-sm p-6 lg:p-8 mb-8">
        <div class="prose prose-gray max-w-none">
          <Content />
        </div>
      </section>
    )}

    <!-- Tags -->
    {data.tags && data.tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8">
        {data.tags.map((tag) => (
          <span class="px-3 py-1 bg-gray-100 text-gray-600 text-sm rounded-full">
            #{tag}
          </span>
        ))}
      </div>
    )}

    <!-- Back Link -->
    <div class="text-center">
      <a
        href={`/${lang}/reviews`}
        class="inline-flex items-center gap-2 text-primary-600 hover:text-primary-700 font-medium"
      >
        ← {lang === 'es' ? 'Volver a reviews' : 'Back to reviews'}
      </a>
    </div>
  </article>
</BaseLayout>
