---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { type Lang, getTranslation, formatPrice } from '@i18n/utils';
import { calculateDiscount } from '@utils/affiliate';

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } }
  ];
}

const { lang } = Astro.params as { lang: Lang };
const t = getTranslation(lang);

const allDeals = await getCollection('deals');
const now = new Date();
const deals = allDeals
  .filter(d => d.data.lang === lang && d.data.status === 'published' && d.data.expiresAt > now)
  .sort((a, b) => a.data.expiresAt.getTime() - b.data.expiresAt.getTime());

function getTimeLeft(expiresAt: Date): string {
  const diff = expiresAt.getTime() - now.getTime();
  const days = Math.floor(diff / (1000 * 60 * 60 * 24));
  const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));

  if (days > 0) {
    return `${days} ${t('deal.daysLeft')}`;
  }
  return `${hours} ${t('deal.hoursLeft')}`;
}
---

<BaseLayout
  title={t('nav.deals')}
  description={lang === 'es' ? 'Las mejores ofertas y descuentos de Amazon' : 'The best Amazon deals and discounts'}
  lang={lang}
>
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        {t('nav.deals')}
      </h1>
      <p class="text-gray-600">
        {lang === 'es'
          ? 'Ofertas actualizadas diariamente'
          : 'Deals updated daily'}
      </p>
    </div>

    {deals.length > 0 ? (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {deals.map((deal) => {
          const discount = calculateDiscount(deal.data.originalPrice, deal.data.dealPrice);
          return (
            <article class="bg-white rounded-xl shadow-sm overflow-hidden hover:shadow-md transition-shadow relative">
              <div class="absolute top-3 left-3 z-10">
                <span class="px-3 py-1 bg-red-500 text-white text-sm font-bold rounded-full">
                  -{discount}%
                </span>
              </div>
              <a href={`/${lang}/deals/${deal.data.dealId}`}>
                <img
                  src={deal.data.featuredImage.url}
                  alt={deal.data.featuredImage.alt}
                  class="w-full h-48 object-contain bg-gray-50 p-4"
                />
              </a>
              <div class="p-6">
                <div class="flex items-center gap-2 mb-3">
                  <span class="px-2 py-1 bg-amber-100 text-amber-700 text-xs font-medium rounded">
                    {t('deal.limitedTime')}
                  </span>
                  <span class="text-xs text-gray-500">
                    {getTimeLeft(deal.data.expiresAt)}
                  </span>
                </div>
                <h2 class="font-semibold text-lg mb-3">
                  <a href={`/${lang}/deals/${deal.data.dealId}`} class="hover:text-primary-600">
                    {deal.data.title}
                  </a>
                </h2>
                <div class="flex items-baseline gap-2 mb-4">
                  <span class="text-2xl font-bold text-gray-900">
                    {formatPrice(deal.data.dealPrice, deal.data.currency, lang)}
                  </span>
                  <span class="text-gray-400 line-through">
                    {formatPrice(deal.data.originalPrice, deal.data.currency, lang)}
                  </span>
                </div>
                <p class="text-gray-600 text-sm line-clamp-2">{deal.data.description}</p>
              </div>
            </article>
          );
        })}
      </div>
    ) : (
      <div class="text-center py-16">
        <div class="text-gray-400 mb-4">
          <svg class="w-16 h-16 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h2 class="text-xl font-semibold text-gray-700 mb-2">
          {lang === 'es' ? 'Aun no hay ofertas' : 'No deals yet'}
        </h2>
        <p class="text-gray-500">
          {lang === 'es' ? 'Estamos buscando las mejores ofertas. Vuelve pronto!' : 'We are looking for the best deals. Come back soon!'}
        </p>
      </div>
    )}
  </div>
</BaseLayout>
