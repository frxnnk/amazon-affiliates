---
import BaseLayout from '@layouts/BaseLayout.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import { getCollection, render } from 'astro:content';
import { type Lang, formatDate } from '@i18n/utils';
import siteConfig from '@data/site-config.json';

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map((post) => ({
    params: {
      lang: post.data.lang,
      slug: post.data.articleId
    },
    props: { post }
  }));
}

const { post } = Astro.props;
const { data } = post;
const { Content } = await render(post);
const lang = data.lang as Lang;

// Get related articles
const allPosts = await getCollection('blog');
const relatedArticles = data.relatedArticles
  ? allPosts
      .filter(p => data.relatedArticles?.includes(p.data.articleId) && p.data.lang === lang)
      .slice(0, 3)
  : allPosts
      .filter(p => p.data.articleId !== data.articleId && p.data.lang === lang && p.data.category === data.category)
      .slice(0, 3);

// Build URLs for schema
const siteUrl = siteConfig.site.url;
const articleUrl = `${siteUrl}/${lang}/blog/${data.articleId}`;
const blogUrl = `${siteUrl}/${lang}/blog`;
const homeUrl = `${siteUrl}/${lang}`;

// Breadcrumb items
const breadcrumbItems = [
  { name: lang === 'es' ? 'Inicio' : 'Home', url: homeUrl },
  { name: 'Blog', url: blogUrl },
  { name: data.title, url: articleUrl },
];

const labels = {
  es: {
    backToBlog: 'Volver al blog',
    minRead: 'min de lectura',
    share: 'Compartir',
    relatedArticles: 'Articulos relacionados',
    writtenBy: 'Escrito por',
    publishedOn: 'Publicado el',
    updatedOn: 'Actualizado el',
  },
  en: {
    backToBlog: 'Back to blog',
    minRead: 'min read',
    share: 'Share',
    relatedArticles: 'Related articles',
    writtenBy: 'Written by',
    publishedOn: 'Published on',
    updatedOn: 'Updated on',
  },
};

const t = labels[lang];
---

<BreadcrumbSchema items={breadcrumbItems} />

<BaseLayout
  title={data.title}
  description={data.excerpt}
  lang={lang}
  image={data.featuredImage.url}
>
  <article class="article-page">
    <!-- Header -->
    <header class="article-header">
      <div class="header-content">
        <a href={`/${lang}/blog`} class="back-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          {t.backToBlog}
        </a>

        <div class="article-meta">
          <span class="article-category">{data.category}</span>
          <span class="article-date">{formatDate(data.publishedAt, lang)}</span>
          {data.readingTime && (
            <span class="article-reading-time">{data.readingTime} {t.minRead}</span>
          )}
        </div>

        <h1 class="article-title">{data.title}</h1>
        <p class="article-excerpt">{data.excerpt}</p>

        <div class="article-author">
          {data.author.avatar && (
            <img
              src={data.author.avatar}
              alt={data.author.name}
              class="author-avatar"
            />
          )}
          <div class="author-info">
            <span class="author-label">{t.writtenBy}</span>
            <span class="author-name">{data.author.name}</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Featured Image -->
    <div class="featured-image">
      <img
        src={data.featuredImage.url}
        alt={data.featuredImage.alt}
      />
    </div>

    <!-- Content -->
    <div class="article-content">
      <div class="prose">
        <Content />
      </div>

      <!-- Tags -->
      {data.tags && data.tags.length > 0 && (
        <div class="article-tags">
          {data.tags.map((tag) => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      )}

      <!-- Update info -->
      {data.updatedAt > data.publishedAt && (
        <p class="update-info">
          {t.updatedOn}: {formatDate(data.updatedAt, lang)}
        </p>
      )}
    </div>

    <!-- Related Articles -->
    {relatedArticles.length > 0 && (
      <section class="related-section">
        <h2 class="related-title">{t.relatedArticles}</h2>
        <div class="related-grid">
          {relatedArticles.map(article => (
            <article class="related-card">
              <a href={`/${lang}/blog/${article.data.articleId}`} class="related-image-link">
                <div class="related-image">
                  <img
                    src={article.data.featuredImage.url}
                    alt={article.data.featuredImage.alt}
                    loading="lazy"
                  />
                </div>
              </a>
              <div class="related-content">
                <span class="related-category">{article.data.category}</span>
                <h3 class="related-article-title">
                  <a href={`/${lang}/blog/${article.data.articleId}`}>
                    {article.data.title}
                  </a>
                </h3>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .article-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }

  /* Header */
  .article-header {
    padding: 2rem 0;
  }

  .header-content {
    max-width: 700px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-stone, #6B6560);
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-ink, #1A1815);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.75rem;
    color: var(--color-stone, #6B6560);
    margin-bottom: 1rem;
  }

  .article-category {
    color: var(--color-honey, #C8956C);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .article-date::before,
  .article-reading-time::before {
    content: '·';
    margin-right: 0.75rem;
  }

  .article-title {
    font-family: var(--font-display, 'Fraunces', Georgia, serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 400;
    line-height: 1.2;
    color: var(--color-ink, #1A1815);
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }

  .article-excerpt {
    font-size: 1.25rem;
    color: var(--color-stone, #6B6560);
    line-height: 1.6;
    margin: 0 0 2rem;
  }

  .article-author {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .author-avatar {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    object-fit: cover;
  }

  .author-info {
    display: flex;
    flex-direction: column;
  }

  .author-label {
    font-size: 0.75rem;
    color: var(--color-stone, #6B6560);
  }

  .author-name {
    font-weight: 600;
    color: var(--color-ink, #1A1815);
  }

  /* Featured Image */
  .featured-image {
    margin: 0 -1.5rem 2rem;
    border-radius: 1rem;
    overflow: hidden;
  }

  .featured-image img {
    width: 100%;
    aspect-ratio: 21/9;
    object-fit: cover;
  }

  /* Content */
  .article-content {
    max-width: 700px;
    margin: 0 auto;
  }

  .prose {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--color-ink, #1A1815);
  }

  .prose :global(h2) {
    font-family: var(--font-display, 'Fraunces', Georgia, serif);
    font-size: 1.75rem;
    font-weight: 500;
    margin: 2.5rem 0 1rem;
    letter-spacing: -0.01em;
  }

  .prose :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
  }

  .prose :global(p) {
    margin: 0 0 1.5rem;
  }

  .prose :global(a) {
    color: var(--color-honey, #C8956C);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(a:hover) {
    color: var(--color-honey-dark, #A67B5B);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.5rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin: 0.5rem 0;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-honey, #C8956C);
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: var(--color-stone, #6B6560);
  }

  .prose :global(img) {
    max-width: 100%;
    border-radius: 0.5rem;
    margin: 2rem 0;
  }

  .prose :global(pre) {
    background: var(--color-ink, #1A1815);
    color: var(--color-cream, #FDFBF7);
    padding: 1.5rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin: 2rem 0;
  }

  .prose :global(code) {
    font-family: ui-monospace, monospace;
    font-size: 0.9em;
  }

  /* Tags */
  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-sand, #E8E4DD);
  }

  .tag {
    padding: 0.375rem 0.75rem;
    background: var(--color-cream, #FDFBF7);
    color: var(--color-stone, #6B6560);
    font-size: 0.8125rem;
    border-radius: 100px;
  }

  .update-info {
    margin-top: 1.5rem;
    font-size: 0.875rem;
    color: var(--color-stone, #6B6560);
  }

  /* Related Section */
  .related-section {
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid var(--color-sand, #E8E4DD);
  }

  .related-title {
    font-family: var(--font-display, 'Fraunces', Georgia, serif);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-ink, #1A1815);
    margin: 0 0 1.5rem;
    text-align: center;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .related-card {
    background: var(--color-white, #FFFFFF);
    border: 1px solid var(--color-sand, #E8E4DD);
    border-radius: 0.75rem;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .related-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(26, 24, 21, 0.08);
  }

  .related-image-link {
    display: block;
  }

  .related-image {
    aspect-ratio: 16/10;
    overflow: hidden;
  }

  .related-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .related-card:hover .related-image img {
    transform: scale(1.05);
  }

  .related-content {
    padding: 1rem;
  }

  .related-category {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-honey, #C8956C);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .related-article-title {
    font-size: 0.9375rem;
    font-weight: 500;
    line-height: 1.4;
    margin: 0.375rem 0 0;
  }

  .related-article-title a {
    color: var(--color-ink, #1A1815);
    text-decoration: none;
    transition: color 0.2s;
  }

  .related-article-title a:hover {
    color: var(--color-honey-dark, #A67B5B);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .featured-image {
      margin: 0 -1.5rem 1.5rem;
      border-radius: 0;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
