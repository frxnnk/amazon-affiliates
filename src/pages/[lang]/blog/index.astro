---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { type Lang, formatDate } from '@i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } }
  ];
}

const { lang } = Astro.params as { lang: Lang };

// Get all published blog posts
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => post.data.lang === lang && post.data.status === 'published')
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

// Get featured posts
const featuredPosts = posts.filter(p => p.data.isFeatured).slice(0, 1);
const regularPosts = posts.filter(p => !featuredPosts.includes(p));

const labels = {
  es: {
    title: 'Blog',
    description: 'Consejos, guias y noticias sobre compras inteligentes y ahorro.',
    featured: 'Destacado',
    readMore: 'Leer mas',
    minRead: 'min de lectura',
    empty: 'Proximamente articulos',
    emptyDescription: 'Estamos trabajando en contenido increible para ti.',
  },
  en: {
    title: 'Blog',
    description: 'Tips, guides, and news about smart shopping and savings.',
    featured: 'Featured',
    readMore: 'Read more',
    minRead: 'min read',
    empty: 'Articles coming soon',
    emptyDescription: 'We are working on amazing content for you.',
  },
};

const t = labels[lang];
---

<BaseLayout title={t.title} description={t.description} lang={lang}>
  <div class="blog-page">
    <!-- Header -->
    <header class="blog-header">
      <div class="header-content">
        <span class="header-eyebrow">Blog</span>
        <h1 class="header-title">{t.title}</h1>
        <p class="header-description">{t.description}</p>
      </div>
    </header>

    {posts.length === 0 ? (
      <div class="empty-state">
        <div class="empty-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
          </svg>
        </div>
        <h2>{t.empty}</h2>
        <p>{t.emptyDescription}</p>
      </div>
    ) : (
      <div class="blog-content">
        <!-- Featured Post -->
        {featuredPosts.length > 0 && (
          <section class="featured-section">
            {featuredPosts.map(post => (
              <article class="featured-card">
                <a href={`/${lang}/blog/${post.data.articleId}`} class="featured-image-link">
                  <div class="featured-image">
                    <img
                      src={post.data.featuredImage.url}
                      alt={post.data.featuredImage.alt}
                      loading="eager"
                    />
                    <span class="featured-badge">{t.featured}</span>
                  </div>
                </a>
                <div class="featured-content">
                  <div class="post-meta">
                    <span class="post-category">{post.data.category}</span>
                    <span class="post-date">{formatDate(post.data.publishedAt, lang)}</span>
                    {post.data.readingTime && (
                      <span class="post-reading-time">{post.data.readingTime} {t.minRead}</span>
                    )}
                  </div>
                  <h2 class="featured-title">
                    <a href={`/${lang}/blog/${post.data.articleId}`}>
                      {post.data.title}
                    </a>
                  </h2>
                  <p class="featured-excerpt">{post.data.excerpt}</p>
                  <div class="post-author">
                    {post.data.author.avatar && (
                      <img
                        src={post.data.author.avatar}
                        alt={post.data.author.name}
                        class="author-avatar"
                      />
                    )}
                    <span class="author-name">{post.data.author.name}</span>
                  </div>
                </div>
              </article>
            ))}
          </section>
        )}

        <!-- Regular Posts Grid -->
        {regularPosts.length > 0 && (
          <section class="posts-section">
            <div class="posts-grid">
              {regularPosts.map(post => (
                <article class="post-card">
                  <a href={`/${lang}/blog/${post.data.articleId}`} class="post-image-link">
                    <div class="post-image">
                      <img
                        src={post.data.featuredImage.url}
                        alt={post.data.featuredImage.alt}
                        loading="lazy"
                      />
                    </div>
                  </a>
                  <div class="post-content">
                    <div class="post-meta">
                      <span class="post-category">{post.data.category}</span>
                      <span class="post-date">{formatDate(post.data.publishedAt, lang)}</span>
                    </div>
                    <h3 class="post-title">
                      <a href={`/${lang}/blog/${post.data.articleId}`}>
                        {post.data.title}
                      </a>
                    </h3>
                    <p class="post-excerpt">{post.data.excerpt}</p>
                    <div class="post-footer">
                      <div class="post-author-small">
                        {post.data.author.avatar && (
                          <img
                            src={post.data.author.avatar}
                            alt={post.data.author.name}
                            class="author-avatar-small"
                          />
                        )}
                        <span>{post.data.author.name}</span>
                      </div>
                      {post.data.readingTime && (
                        <span class="post-reading-time">{post.data.readingTime} {t.minRead}</span>
                      )}
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </section>
        )}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .blog-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Header */
  .blog-header {
    text-align: center;
    padding: 4rem 0 3rem;
  }

  .header-eyebrow {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-honey, #C8956C);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .header-title {
    font-family: var(--font-display, 'Fraunces', Georgia, serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 400;
    color: var(--color-ink, #1A1815);
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }

  .header-description {
    font-size: 1.125rem;
    color: var(--color-stone, #6B6560);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 6rem 2rem;
    color: var(--color-stone, #6B6560);
  }

  .empty-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 5rem;
    height: 5rem;
    margin-bottom: 1.5rem;
    color: var(--color-mist, #C4BFB8);
  }

  .empty-icon svg {
    width: 100%;
    height: 100%;
  }

  .empty-state h2 {
    font-family: var(--font-display, 'Fraunces', Georgia, serif);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-ink, #1A1815);
    margin: 0 0 0.5rem;
  }

  .empty-state p {
    margin: 0;
  }

  /* Blog Content */
  .blog-content {
    padding-bottom: 4rem;
  }

  /* Featured Section */
  .featured-section {
    margin-bottom: 3rem;
  }

  .featured-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    background: var(--color-white, #FFFFFF);
    border: 1px solid var(--color-sand, #E8E4DD);
    border-radius: 1rem;
    overflow: hidden;
  }

  .featured-image-link {
    display: block;
  }

  .featured-image {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
  }

  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .featured-card:hover .featured-image img {
    transform: scale(1.03);
  }

  .featured-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    padding: 0.375rem 0.75rem;
    background: var(--color-honey, #C8956C);
    color: white;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 4px;
  }

  .featured-content {
    padding: 2rem 2rem 2rem 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .featured-title {
    font-family: var(--font-display, 'Fraunces', Georgia, serif);
    font-size: 1.75rem;
    font-weight: 500;
    line-height: 1.3;
    margin: 0.75rem 0;
    letter-spacing: -0.01em;
  }

  .featured-title a {
    color: var(--color-ink, #1A1815);
    text-decoration: none;
    transition: color 0.2s;
  }

  .featured-title a:hover {
    color: var(--color-honey-dark, #A67B5B);
  }

  .featured-excerpt {
    font-size: 1rem;
    color: var(--color-stone, #6B6560);
    line-height: 1.6;
    margin: 0 0 1.5rem;
  }

  /* Post Meta */
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.75rem;
    color: var(--color-stone, #6B6560);
  }

  .post-category {
    color: var(--color-honey, #C8956C);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .post-date::before,
  .post-reading-time::before {
    content: '·';
    margin-right: 0.75rem;
  }

  /* Post Author */
  .post-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .author-avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    object-fit: cover;
  }

  .author-name {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink, #1A1815);
  }

  /* Posts Grid */
  .posts-section {
    margin-top: 2rem;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .post-card {
    background: var(--color-white, #FFFFFF);
    border: 1px solid var(--color-sand, #E8E4DD);
    border-radius: 1rem;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(26, 24, 21, 0.08);
  }

  .post-image-link {
    display: block;
  }

  .post-image {
    aspect-ratio: 16/10;
    overflow: hidden;
  }

  .post-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .post-card:hover .post-image img {
    transform: scale(1.05);
  }

  .post-content {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .post-title {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
    margin: 0.5rem 0;
  }

  .post-title a {
    color: var(--color-ink, #1A1815);
    text-decoration: none;
    transition: color 0.2s;
  }

  .post-title a:hover {
    color: var(--color-honey-dark, #A67B5B);
  }

  .post-excerpt {
    font-size: 0.875rem;
    color: var(--color-stone, #6B6560);
    line-height: 1.5;
    margin: 0 0 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--color-stone, #6B6560);
  }

  .post-author-small {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .author-avatar-small {
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    object-fit: cover;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .featured-card {
      grid-template-columns: 1fr;
    }

    .featured-content {
      padding: 1.5rem;
    }

    .featured-title {
      font-size: 1.5rem;
    }
  }

  @media (max-width: 640px) {
    .blog-header {
      padding: 3rem 0 2rem;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
