<script define:vars={{ lang, t: content[lang] }}>
class LegalModal {
  constructor() {
    this.overlay = document.getElementById('legal-modal-overlay');
    this.modal = document.getElementById('legal-modal');
    this.title = document.getElementById('modal-title');
    this.meta = document.getElementById('modal-meta');
    this.body = document.getElementById('modal-body');
    this.closeBtn = document.getElementById('modal-close');
    
    this.lang = lang;
    this.texts = t;
    this.isOpen = false;
    
    this.init();
  }
  
  init() {
    // Close button
    this.closeBtn?.addEventListener('click', () => this.close());
    
    // Click outside to close
    this.overlay?.addEventListener('click', (e) => {
      if (e.target === this.overlay) this.close();
    });
    
    // Escape key to close
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && this.isOpen) this.close();
    });
    
    // Listen for open events
    document.addEventListener('legal-modal:open', (e) => {
      this.open(e.detail.type);
    });
  }
  
  open(type) {
    if (!this.overlay || !this.modal) return;
    
    const typeInfo = this.texts[type];
    if (!typeInfo) return;
    
    // Set title and meta
    this.title.textContent = typeInfo.title;
    this.meta.textContent = `${this.texts.lastUpdated}: ${typeInfo.updated}`;
    
    // Load content from template
    const template = document.getElementById(`${type}-content-${this.lang}`);
    if (template) {
      this.body.innerHTML = template.innerHTML;
    }
    
    // Show modal
    this.overlay.classList.add('open');
    this.overlay.setAttribute('aria-hidden', 'false');
    this.isOpen = true;
    
    // Prevent body scroll
    document.body.style.overflow = 'hidden';
    
    // Focus close button for accessibility
    setTimeout(() => this.closeBtn?.focus(), 100);
  }
  
  close() {
    if (!this.overlay) return;
    
    this.overlay.classList.remove('open');
    this.overlay.setAttribute('aria-hidden', 'true');
    this.isOpen = false;
    
    // Restore body scroll
    document.body.style.overflow = '';
    
    // Clear content after animation
    setTimeout(() => {
      if (!this.isOpen) {
        this.body.innerHTML = '';
      }
    }, 300);
  }
}

// Initialize
document.addEventListener('DOMContentLoaded', () => {
  new LegalModal();
});

// Re-initialize on page navigation (Astro)
document.addEventListener('astro:page-load', () => {
  new LegalModal();
});
</script>

<style is:global>
  /* Modal Overlay */
  .legal-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    background: rgba(0, 0, 0, 0);
    visibility: hidden;
    transition: background 0.3s ease, visibility 0.3s ease;
  }
  
  .legal-modal-overlay.open {
    visibility: visible;
    background: rgba(0, 0, 0, 0.6);
  }
  
  /* Modal Container */
  .legal-modal {
    position: relative;
    width: 100%;
    max-width: 600px;
    max-height: 90dvh;
    background: var(--bg, #fff);
    border-radius: 20px 20px 0 0;
    display: flex;
    flex-direction: column;
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
    box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.2);
  }
  
  .legal-modal-overlay.open .legal-modal {
    transform: translateY(0);
  }
  
  /* Modal Header */
  .modal-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 20px 16px;
    border-bottom: 1px solid var(--border, #e5e7eb);
    flex-shrink: 0;
  }
  
  .modal-header::before {
    content: '';
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 36px;
    height: 4px;
    background: var(--border, #e5e7eb);
    border-radius: 2px;
  }
  
  .modal-header-content {
    flex: 1;
    padding-top: 8px;
  }
  
  .modal-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text, #111827);
    margin: 0 0 4px;
    line-height: 1.3;
  }
  
  .modal-meta {
    font-size: 0.75rem;
    color: var(--text-muted, #9ca3af);
    margin: 0;
  }
  
  .modal-close {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-secondary, #f9fafb);
    border: none;
    border-radius: 50%;
    color: var(--text-secondary, #6b7280);
