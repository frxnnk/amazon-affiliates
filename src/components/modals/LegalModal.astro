    color: var(--text, #111827);
  }
  
  .modal-close svg {
    width: 20px;
    height: 20px;
  }
  
  /* Modal Body */
  .modal-body {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
    -webkit-overflow-scrolling: touch;
  }
  
  /* Content Styles */
  .modal-body p {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--text, #111827);
    margin: 0 0 16px;
  }
  
  .modal-body h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text, #111827);
    margin: 28px 0 12px;
  }
  
  .modal-body h3:first-child {
    margin-top: 0;
  }
  
  .modal-body h4 {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text, #111827);
    margin: 20px 0 10px;
  }
  
  .modal-body ul,
  .modal-body ol {
    margin: 0 0 16px;
    padding-left: 20px;
  }
  
  .modal-body li {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--text, #111827);
    margin-bottom: 8px;
  }
  
  .modal-body strong {
    font-weight: 600;
    color: var(--text, #111827);
  }
  
  .modal-body blockquote {
    margin: 20px 0;
    padding: 16px 20px;
    background: var(--bg-secondary, #f9fafb);
    border-left: 3px solid var(--accent, #f59e0b);
    border-radius: 0 8px 8px 0;
    font-style: italic;
    color: var(--text-secondary, #6b7280);
  }
  
  .modal-body blockquote p {
    margin: 0;
  }
  
  /* Tier Table */
  .tier-table {
    margin: 16px 0 20px;
    border: 1px solid var(--border, #e5e7eb);
    border-radius: 10px;
    overflow: hidden;
  }
  
  .tier-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    padding: 12px 16px;
    font-size: 0.875rem;
    border-bottom: 1px solid var(--border, #e5e7eb);
  }
  
  .tier-row:last-child {
    border-bottom: none;
  }
  
  .tier-row.tier-header {
    background: var(--bg-secondary, #f9fafb);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--text-secondary, #6b7280);
  }
  
  /* Desktop */
  @media (min-width: 640px) {
    .legal-modal {
      max-height: 85dvh;
      border-radius: 20px;
      margin: auto;
    }
    
    .legal-modal-overlay {
      align-items: center;
      padding: 24px;
    }
    
    .legal-modal-overlay.open .legal-modal {
      transform: translateY(0);
    }
    
    .legal-modal {
      transform: translateY(20px) scale(0.98);
      opacity: 0;
      transition: transform 0.3s ease, opacity 0.3s ease;
    }
    
    .legal-modal-overlay.open .legal-modal {
      transform: translateY(0) scale(1);
      opacity: 1;
    }
    
    .modal-header::before {
      display: none;
    }
    
    .modal-header {
      padding: 24px 24px 20px;
    }
    
    .modal-header-content {
      padding-top: 0;
    }
    
    .modal-body {
      padding: 24px;
    }
    
    .modal-title {
      font-size: 1.375rem;
    }
  }
</style>
