---
/**
 * LegalModal - Professional modal for legal content (Terms, Privacy, About)
 *
 * Features:
 * - Smooth slide-up animation
 * - Scrollable content with proper header
 * - Keyboard accessible (Escape to close)
 * - Click outside to close
 * - Mobile-optimized full-screen on small devices
 */
import { type Lang } from '@i18n/utils';
import siteConfig from '@data/site-config.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const content = {
  es: {
    close: 'Cerrar',
    lastUpdated: 'Ultima actualizacion',
    terms: {
      title: 'Terminos de Servicio',
      updated: '15 de enero, 2025'
    },
    privacy: {
      title: 'Politica de Privacidad',
      updated: '15 de enero, 2025'
    },
    about: {
      title: 'Sobre Nosotros',
      updated: '15 de enero, 2025'
    }
  },
  en: {
    close: 'Close',
    lastUpdated: 'Last updated',
    terms: {
      title: 'Terms of Service',
      updated: 'January 15, 2025'
    },
    privacy: {
      title: 'Privacy Policy',
      updated: 'January 15, 2025'
    },
    about: {
      title: 'About Us',
      updated: 'January 15, 2025'
    }
  }
};

const t = content[lang];
const siteName = siteConfig.site.name;
---

<!-- Modal Overlay -->
<div class="legal-modal-overlay" id="legal-modal-overlay" role="dialog" aria-modal="true" aria-hidden="true">
  <div class="legal-modal" id="legal-modal">

    <!-- Modal Header -->
    <header class="modal-header">
      <div class="modal-header-content">
        <h2 class="modal-title" id="modal-title"></h2>
        <p class="modal-meta" id="modal-meta"></p>
      </div>
      <button class="modal-close" id="modal-close" aria-label={t.close}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    </header>

    <!-- Modal Body -->
    <div class="modal-body" id="modal-body">
      <!-- Content loaded dynamically -->
    </div>

  </div>
</div>

<!-- Modal Content Templates (hidden, used for JS injection) -->
