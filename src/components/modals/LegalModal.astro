<script define:vars={{ lang, t: content[lang] }}>
class LegalModal {
  constructor() {
    this.overlay = document.getElementById('legal-modal-overlay');
    this.modal = document.getElementById('legal-modal');
    this.title = document.getElementById('modal-title');
    this.meta = document.getElementById('modal-meta');
    this.body = document.getElementById('modal-body');
    this.closeBtn = document.getElementById('modal-close');

    this.lang = lang;
    this.texts = t;
    this.isOpen = false;

    this.init();
  }

  init() {
    // Close button
    this.closeBtn?.addEventListener('click', () => this.close());

    // Click outside to close
    this.overlay?.addEventListener('click', (e) => {
      if (e.target === this.overlay) this.close();
    });

    // Escape key to close
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && this.isOpen) this.close();
    });

    // Listen for open events
    document.addEventListener('legal-modal:open', (e) => {
      this.open(e.detail.type);
    });
  }

  open(type) {
    if (!this.overlay || !this.modal) return;

    const typeInfo = this.texts[type];
    if (!typeInfo) return;

    // Set title and meta
    this.title.textContent = typeInfo.title;
    this.meta.textContent = `${this.texts.lastUpdated}: ${typeInfo.updated}`;

    // Load content from template
    const template = document.getElementById(`${type}-content-${this.lang}`);
    if (template) {
      this.body.innerHTML = template.innerHTML;
    }

    // Show modal
    this.overlay.classList.add('open');
    this.overlay.setAttribute('aria-hidden', 'false');
    this.isOpen = true;

    // Prevent body scroll
    document.body.style.overflow = 'hidden';

    // Focus close button for accessibility
    setTimeout(() => this.closeBtn?.focus(), 100);
  }

  close() {
    if (!this.overlay) return;

    this.overlay.classList.remove('open');
    this.overlay.setAttribute('aria-hidden', 'true');
    this.isOpen = false;

    // Restore body scroll
    document.body.style.overflow = '';

    // Clear content after animation
    setTimeout(() => {
      if (!this.isOpen) {
        this.body.innerHTML = '';
      }
    }, 300);
  }
}

// Initialize
document.addEventListener('DOMContentLoaded', () => {
  new LegalModal();
});

// Re-initialize on page navigation (Astro)
document.addEventListener('astro:page-load', () => {
  new LegalModal();
});
</script>

<style is:global>
  /* Neo-Brutalist Legal Modal */
  .legal-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    background: rgba(26, 26, 26, 0);
    visibility: hidden;
    transition: background 200ms, visibility 200ms;
  }

  .legal-modal-overlay.open {
    visibility: visible;
    background: rgba(26, 26, 26, 0.85);
  }

  /* Modal Container */
  .legal-modal {
    position: relative;
    width: 100%;
    max-width: 600px;
    max-height: 90dvh;
    background: var(--color-cream, #FFFEF9);
    border: 4px solid var(--color-brutal-black, #1A1A1A);
    border-bottom: none;
    display: flex;
    flex-direction: column;
    transform: translateY(100%);
    transition: transform 250ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
    box-shadow: 0 -8px 0 var(--color-brutal-black, #1A1A1A);
  }

  .legal-modal-overlay.open .legal-modal {
    transform: translateY(0);
  }

  /* Modal Header */
  .modal-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 20px 16px;
    border-bottom: 3px solid var(--color-brutal-black, #1A1A1A);
    background: var(--color-brutal-yellow, #FFE14D);
    flex-shrink: 0;
  }

  .modal-header::before {
    content: '';
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 40px;
    height: 4px;
    background: var(--color-brutal-black, #1A1A1A);
  }

  .modal-header-content {
    flex: 1;
    padding-top: 8px;
  }

  .modal-title {
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 1.25rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-brutal-black, #1A1A1A);
    margin: 0 0 4px;
    line-height: 1.3;
  }

  .modal-meta {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--color-brutal-black, #1A1A1A);
    opacity: 0.7;
    margin: 0;
  }

  .modal-close {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-cream, #FFFEF9);
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-black, #1A1A1A);
    cursor: pointer;
    flex-shrink: 0;
    box-shadow: 3px 3px 0 var(--color-brutal-black, #1A1A1A);
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  .modal-close:hover {
    background: var(--color-brutal-orange, #FF6B35);
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 var(--color-brutal-black, #1A1A1A);
  }

  .modal-close:active {
    transform: translate(1px, 1px);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
  }

  .modal-close svg {
    width: 20px;
    height: 20px;
  }

  /* Modal Body */
  .modal-body {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
    -webkit-overflow-scrolling: touch;
    background: var(--color-cream, #FFFEF9);
  }

  /* Content Styles */
  .modal-body p {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-brutal-black, #1A1A1A);
    margin: 0 0 16px;
  }

  .modal-body h3 {
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-brutal-black, #1A1A1A);
    margin: 28px 0 12px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--color-brutal-black, #1A1A1A);
  }

  .modal-body h3:first-child {
    margin-top: 0;
  }

  .modal-body h4 {
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--color-brutal-black, #1A1A1A);
    margin: 20px 0 10px;
  }

  .modal-body ul,
  .modal-body ol {
    margin: 0 0 16px;
    padding-left: 20px;
  }

  .modal-body li {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-brutal-black, #1A1A1A);
    margin-bottom: 8px;
  }

  .modal-body strong {
    font-weight: 700;
    color: var(--color-brutal-black, #1A1A1A);
  }

  .modal-body blockquote {
    margin: 20px 0;
    padding: 16px 20px;
    background: var(--color-brutal-yellow, #FFE14D);
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 4px 4px 0 var(--color-brutal-black, #1A1A1A);
    font-style: normal;
    font-weight: 600;
    color: var(--color-brutal-black, #1A1A1A);
  }

  .modal-body blockquote p {
    margin: 0;
  }

  /* Desktop */
  @media (min-width: 640px) {
    .legal-modal {
      max-height: 85dvh;
      border: 4px solid var(--color-brutal-black, #1A1A1A);
      box-shadow: 12px 12px 0 var(--color-brutal-black, #1A1A1A);
      margin: auto;
    }

    .legal-modal-overlay {
      align-items: center;
      padding: 24px;
    }

    .legal-modal {
      transform: translateY(20px) rotate(-2deg);
      opacity: 0;
      transition: transform 250ms cubic-bezier(0.68, -0.6, 0.32, 1.6), opacity 200ms;
    }

    .legal-modal-overlay.open .legal-modal {
      transform: translateY(0) rotate(0deg);
      opacity: 1;
    }

    .modal-header::before {
      display: none;
    }

    .modal-header {
      padding: 24px 24px 20px;
    }

    .modal-header-content {
      padding-top: 0;
    }

    .modal-body {
      padding: 24px;
    }

    .modal-title {
      font-size: 1.375rem;
    }
  }
</style>
