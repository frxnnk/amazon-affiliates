---
/**
 * ProductModel3D Component
 * 
 * Displays a 3D model using Google's model-viewer web component.
 * Falls back to image if model is not available.
 */

interface Props {
  modelUrl?: string;
  imageUrl?: string;
  alt: string;
  autoRotate?: boolean;
  cameraControls?: boolean;
}

const { 
  modelUrl, 
  imageUrl, 
  alt,
  autoRotate = true,
  cameraControls = true,
} = Astro.props;

const hasModel = !!modelUrl;
---

<div class="model-3d-container" data-has-model={hasModel}>
  {hasModel ? (
    <model-viewer
      src={modelUrl}
      alt={alt}
      auto-rotate={autoRotate}
      camera-controls={cameraControls}
      shadow-intensity="1"
      exposure="0.8"
      environment-image="neutral"
      interaction-prompt="none"
      loading="eager"
      reveal="auto"
      class="product-model-viewer"
    >
      <!-- Loading indicator -->
      <div slot="poster" class="model-poster">
        {imageUrl && (
          <img src={imageUrl} alt={alt} class="poster-image" />
        )}
        <div class="loading-indicator">
          <div class="loading-spinner"></div>
          <span>Cargando 3D...</span>
        </div>
      </div>

      <!-- AR button for supported devices -->
      <button slot="ar-button" class="ar-button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        Ver en AR
      </button>
    </model-viewer>
  ) : imageUrl ? (
    <div class="fallback-image-container" data-3d-element>
      <div class="product-shadow"></div>
      <div class="product-image-wrapper">
        <img 
          src={imageUrl} 
          alt={alt} 
          class="fallback-image"
          loading="eager"
        />
      </div>
    </div>
  ) : (
    <div class="no-media">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="3" y="3" width="18" height="18" rx="2"/>
        <circle cx="8.5" cy="8.5" r="1.5"/>
        <path d="M21 15l-5-5L5 21"/>
      </svg>
    </div>
  )}
</div>

<style>
  .model-3d-container {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  /* Model Viewer Styles */
  .product-model-viewer {
    width: 100%;
    height: 100%;
    --poster-color: transparent;
    background: transparent;
  }

  .model-poster {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    position: relative;
  }

  .poster-image {
    max-width: 80%;
    max-height: 80%;
    object-fit: contain;
    opacity: 0.5;
    filter: blur(2px);
  }

  .loading-indicator {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.75rem;
    font-weight: 500;
  }

  .loading-spinner {
    width: 32px;
    height: 32px;
    border: 3px solid rgba(255, 255, 255, 0.2);
    border-top-color: #FF9900;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* AR Button */
  .ar-button {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 100px;
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease-out;
  }

  .ar-button:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: scale(1.05);
  }

  /* Hide AR button if not supported */
  .ar-button[slot="ar-button"]:not([ar-status="session-started"]) {
    display: none;
  }

  /* Fallback Image Container - mimics 3D effect */
  .fallback-image-container {
    position: relative;
    width: 100%;
    max-width: 320px;
    aspect-ratio: 1;
    perspective: 1000px;
    transform-style: preserve-3d;
  }

  .product-shadow {
    position: absolute;
    bottom: -20px;
    left: 50%;
    transform: translateX(-50%);
    width: 70%;
    height: 40px;
    background: radial-gradient(ellipse, rgba(0, 0, 0, 0.4) 0%, transparent 70%);
    filter: blur(15px);
    transition: all 0.15s ease-out;
  }

  .product-image-wrapper {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    transform-style: preserve-3d;
    transition: transform 0.15s ease-out;
    animation: float 4s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) rotateX(0) rotateY(0); }
    50% { transform: translateY(-12px) rotateX(2deg) rotateY(-2deg); }
  }

  .fallback-image {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.3));
    transition: transform 0.3s ease-out;
  }

  /* No media placeholder */
  .no-media {
    width: 150px;
    height: 150px;
    color: rgba(255, 255, 255, 0.2);
  }

  .no-media svg {
    width: 100%;
    height: 100%;
  }

  /* Responsive */
  @media (min-width: 768px) {
    .fallback-image-container {
      max-width: 400px;
    }
  }
</style>

<!-- Load model-viewer script -->
<script is:inline>
  // Only load if not already loaded
  if (!customElements.get('model-viewer')) {
    const script = document.createElement('script');
    script.type = 'module';
    script.src = 'https://ajax.googleapis.com/ajax/libs/model-viewer/3.3.0/model-viewer.min.js';
    document.head.appendChild(script);
  }
</script>
