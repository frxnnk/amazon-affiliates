---
/**
 * RegionSelector - Country/Language/Currency dropdown
 * Allows users to select their preferred region for product search
 */

interface Props {
  currentLang: string;
}

const { currentLang } = Astro.props;

const regions = [
  { code: 'ES', lang: 'es', currency: 'EUR', flag: '🇪🇸', label: 'España' },
  { code: 'US', lang: 'en', currency: 'USD', flag: '🇺🇸', label: 'United States' },
  { code: 'GB', lang: 'en', currency: 'GBP', flag: '🇬🇧', label: 'United Kingdom' },
  { code: 'DE', lang: 'de', currency: 'EUR', flag: '🇩🇪', label: 'Deutschland' },
  { code: 'FR', lang: 'fr', currency: 'EUR', flag: '🇫🇷', label: 'France' },
  { code: 'IT', lang: 'it', currency: 'EUR', flag: '🇮🇹', label: 'Italia' },
  { code: 'MX', lang: 'es', currency: 'MXN', flag: '🇲🇽', label: 'México' },
];

// Find current region
const currentRegion = regions.find(r => r.lang === currentLang) || regions[0];
---

<div class="region-selector" id="region-selector">
  <button type="button" class="region-toggle" id="region-toggle" aria-expanded="false" aria-haspopup="true">
    <span class="region-flag">{currentRegion.flag}</span>
    <span class="region-code">{currentRegion.code}</span>
    <svg viewBox="0 0 20 20" fill="currentColor" class="chevron-icon">
      <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
    </svg>
  </button>
  
  <div class="region-dropdown" id="region-dropdown" role="menu">
    <div class="dropdown-header">
      <span>{currentLang === 'es' ? 'Seleccionar región' : 'Select region'}</span>
    </div>
    <div class="region-list">
      {regions.map((region) => (
        <button 
          type="button"
          class={`region-option ${region.code === currentRegion.code ? 'active' : ''}`}
          data-code={region.code}
          data-lang={region.lang}
          data-currency={region.currency}
          role="menuitem"
        >
          <span class="option-flag">{region.flag}</span>
          <div class="option-info">
            <span class="option-label">{region.label}</span>
            <span class="option-currency">{region.currency}</span>
          </div>
          {region.code === currentRegion.code && (
            <svg viewBox="0 0 20 20" fill="currentColor" class="check-icon">
              <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
            </svg>
          )}
        </button>
      ))}
    </div>
  </div>
</div>

<script>
  const REGIONS = [
    { code: 'ES', lang: 'es', currency: 'EUR', flag: '🇪🇸', label: 'España' },
    { code: 'US', lang: 'en', currency: 'USD', flag: '🇺🇸', label: 'United States' },
    { code: 'GB', lang: 'en', currency: 'GBP', flag: '🇬🇧', label: 'United Kingdom' },
    { code: 'DE', lang: 'de', currency: 'EUR', flag: '🇩🇪', label: 'Deutschland' },
    { code: 'FR', lang: 'fr', currency: 'EUR', flag: '🇫🇷', label: 'France' },
    { code: 'IT', lang: 'it', currency: 'EUR', flag: '🇮🇹', label: 'Italia' },
    { code: 'MX', lang: 'es', currency: 'MXN', flag: '🇲🇽', label: 'México' },
  ];

  function initRegionSelector() {
    const selector = document.getElementById('region-selector');
    const toggle = document.getElementById('region-toggle');
    const dropdown = document.getElementById('region-dropdown');
    const options = document.querySelectorAll('.region-option');

    if (!toggle || !dropdown || !selector) return;

    // Update display from localStorage (client-side only)
    updateDisplayFromStorage();

    function updateDisplayFromStorage() {
      try {
        const saved = localStorage.getItem('preferredRegion');
        if (saved) {
          const { code } = JSON.parse(saved);
          const region = REGIONS.find(r => r.code === code);
          if (region) {
            // Update toggle display
            const flagEl = toggle.querySelector('.region-flag');
            const codeEl = toggle.querySelector('.region-code');
            if (flagEl) flagEl.textContent = region.flag;
            if (codeEl) codeEl.textContent = region.code;

            // Update active state in dropdown
            options.forEach(opt => {
              const isActive = opt.getAttribute('data-code') === code;
              opt.classList.toggle('active', isActive);
              // Update checkmark visibility
              const checkIcon = opt.querySelector('.check-icon');
              if (checkIcon) {
                checkIcon.style.display = isActive ? 'block' : 'none';
              }
            });
          }
        }
      } catch (e) {
        console.error('[RegionSelector] Error reading from localStorage:', e);
      }
    }

    // Toggle dropdown
    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = selector.classList.toggle('open');
      dropdown.classList.toggle('open', isOpen);
      toggle.setAttribute('aria-expanded', String(isOpen));
    });

    // Close on click outside
    document.addEventListener('click', (e) => {
      if (!selector.contains(e.target as Node)) {
        selector.classList.remove('open');
        dropdown.classList.remove('open');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });
    
    // Handle option selection
    options.forEach(option => {
      option.addEventListener('click', () => {
        const code = option.getAttribute('data-code');
        const lang = option.getAttribute('data-lang');
        const currency = option.getAttribute('data-currency');
        
        // Store in localStorage
        localStorage.setItem('preferredRegion', JSON.stringify({ code, lang, currency }));
        
        // Dispatch event
        window.dispatchEvent(new CustomEvent('region:change', {
          detail: { code, lang, currency }
        }));
        
        // Close dropdown
        selector.classList.remove('open');
        dropdown.classList.remove('open');
        toggle.setAttribute('aria-expanded', 'false');
        
        // Redirect to new language if different
        const currentPath = window.location.pathname;
        const currentLang = currentPath.split('/')[1];
        
        if (lang && lang !== currentLang && (lang === 'es' || lang === 'en')) {
          const newPath = currentPath.replace(`/${currentLang}`, `/${lang}`);
          window.location.href = newPath || `/${lang}/`;
        } else {
          // Just reload the feed with new region
          window.location.reload();
        }
      });
    });
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initRegionSelector);
  } else {
    initRegionSelector();
  }
  document.addEventListener('astro:page-load', initRegionSelector);
</script>

<style>
  /* NEO-BRUTALIST REGION SELECTOR */
  .region-selector {
    position: relative;
  }

  .region-toggle {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 10px 12px;
    background: var(--color-cream, #FFFEF9);
    border: none;
    border-left: 3px solid var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-black, #1A1A1A);
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background 0.1s ease;
  }

  .region-toggle:hover {
    background: var(--color-brutal-yellow, #FFE14D);
  }

  .region-selector.open .region-toggle {
    background: var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-yellow, #FFE14D);
  }

  .region-flag {
    font-size: 1rem;
  }

  .region-code {
    font-weight: 800;
    font-size: 0.625rem;
    letter-spacing: 0.05em;
  }

  .chevron-icon {
    width: 12px;
    height: 12px;
    transition: transform 0.15s ease;
  }

  .region-selector.open .chevron-icon {
    transform: rotate(180deg);
  }

  .region-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 180px;
    background: var(--color-cream, #FFFEF9);
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 4px 4px 0 var(--color-brutal-black, #1A1A1A);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: all 0.15s ease;
    z-index: 100;
  }

  .region-dropdown.open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-header {
    padding: 0.625rem 0.75rem;
    border-bottom: 2px solid var(--color-brutal-black, #1A1A1A);
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.5625rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-brutal-black, #1A1A1A);
    background: var(--color-brutal-yellow, #FFE14D);
  }

  .region-list {
    padding: 0.375rem;
    max-height: 280px;
    overflow-y: auto;
  }

  .region-option {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    width: 100%;
    padding: 0.5rem 0.625rem;
    background: transparent;
    border: 2px solid transparent;
    color: var(--color-brutal-black, #1A1A1A);
    cursor: pointer;
    transition: all 0.1s ease;
    text-align: left;
  }

  .region-option:hover {
    background: var(--color-brutal-yellow, #FFE14D);
    border-color: var(--color-brutal-black, #1A1A1A);
  }

  .region-option.active {
    background: var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-yellow, #FFE14D);
    border-color: var(--color-brutal-black, #1A1A1A);
  }

  .option-flag {
    font-size: 1.125rem;
  }

  .option-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .option-label {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.6875rem;
    font-weight: 700;
  }

  .option-currency {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.5625rem;
    font-weight: 600;
    opacity: 0.7;
  }

  .region-option.active .option-currency {
    opacity: 0.9;
  }

  .check-icon {
    width: 14px;
    height: 14px;
    color: var(--color-brutal-yellow, #FFE14D);
  }

  /* Mobile responsive */
  @media (max-width: 480px) {
    .region-toggle {
      padding: 6px 8px;
      border-left-width: 2px;
    }

    .region-flag {
      font-size: 0.875rem;
    }

    .region-code {
      display: none;
    }

    .chevron-icon {
      width: 10px;
      height: 10px;
    }

    .region-dropdown {
      min-width: 160px;
      border-width: 2px;
      box-shadow: 3px 3px 0 var(--color-brutal-black, #1A1A1A);
    }

    .dropdown-header {
      padding: 0.5rem 0.625rem;
      border-bottom-width: 2px;
      font-size: 0.5rem;
    }

    .region-option {
      padding: 0.4rem 0.5rem;
      gap: 0.5rem;
    }

    .option-flag {
      font-size: 1rem;
    }

    .option-label {
      font-size: 0.625rem;
    }

    .option-currency {
      font-size: 0.5rem;
    }
  }

  @media (max-width: 340px) {
    .region-toggle {
      padding: 5px 6px;
    }

    .region-flag {
      font-size: 0.8125rem;
    }
  }
</style>
