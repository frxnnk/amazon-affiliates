    id: 'all', 
    icon: 'sparkles',
    label: { es: 'Todo', en: 'All' }
  },
  { 
    id: 'electronics', 
    icon: 'cpu',
    label: { es: 'Electrónica', en: 'Electronics' }
  },
  { 
    id: 'audio', 
    icon: 'headphones',
    label: { es: 'Audio', en: 'Audio' }
  },
  { 
    id: 'gaming', 
    icon: 'gamepad',
    label: { es: 'Gaming', en: 'Gaming' }
  },
  { 
    id: 'smartphones', 
    icon: 'smartphone',
    label: { es: 'Móviles', en: 'Phones' }
  },
  { 
    id: 'home', 
    icon: 'home',
    label: { es: 'Hogar', en: 'Home' }
  },
  { 
    id: 'wearables', 
    icon: 'watch',
    label: { es: 'Wearables', en: 'Wearables' }
