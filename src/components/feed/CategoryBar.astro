---

<div class="category-bar" id="category-bar">
  <div class="category-scroll">
    {categories.map((cat) => (
      <button 
        type="button"
        class={`category-btn ${cat.id === activeCategory ? 'active' : ''}`}
        data-category={cat.id}
      >
        <svg 
          viewBox="0 0 24 24" 
          fill="none" 
          stroke="currentColor" 
          stroke-width="1.5"
          class="category-icon"
        >
          <Fragment set:html={icons[cat.icon]} />
        </svg>
        <span class="category-label">{cat.label[lang as 'es' | 'en'] || cat.label.en}</span>
      </button>
    ))}
  </div>
</div>

<script>
  function initCategoryBar() {
    const categoryBar = document.getElementById('category-bar');
    if (!categoryBar) return;

    const buttons = categoryBar.querySelectorAll('.category-btn');
    
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const category = btn.getAttribute('data-category');
        
        // Update active state
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        
        // Dispatch custom event for the feed to listen
        window.dispatchEvent(new CustomEvent('category:change', { 
          detail: { category } 
        }));
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCategoryBar);
  } else {
    initCategoryBar();
  }
  document.addEventListener('astro:page-load', initCategoryBar);
</script>

<style>
  .category-bar {
    position: relative;
    width: 100%;
    padding: 0.75rem 0;
    z-index: 10;
  }

  .category-scroll {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    padding: 0 1rem;
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-behavior: smooth;
    scroll-snap-type: x proximity;
  }

  .category-scroll::-webkit-scrollbar {
    display: none;
  }

  .category-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.9rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 100px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.8rem;
    font-weight: 500;
    white-space: nowrap;
    cursor: pointer;
    transition: all 0.2s ease;
    scroll-snap-align: start;
    flex-shrink: 0;
  }

  .category-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    color: white;
  }

  .category-btn.active {
    background: linear-gradient(135deg, #ff9500, #ff6b00);
    border-color: transparent;
    color: white;
    box-shadow: 0 4px 15px rgba(255, 149, 0, 0.3);
  }

  .category-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .category-label {
    font-family: var(--font-sans, 'DM Sans', sans-serif);
  }

  @media (min-width: 768px) {
    .category-scroll {
      justify-content: center;
      padding: 0 2rem;
    }

    .category-btn {
      padding: 0.6rem 1.1rem;
      font-size: 0.85rem;
    }

    .category-icon {
      width: 18px;
      height: 18px;
    }
  }
</style>
