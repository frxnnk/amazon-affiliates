---
import { type Lang, getTranslation } from '@i18n/utils';

interface Props {
  productId: string;
  affiliateUrl: string;
  lang: Lang;
}

const { productId, affiliateUrl, lang } = Astro.props;
const t = getTranslation(lang);
---

<div class="slide-actions">
  <!-- Like button -->
  <button 
    type="button" 
    class="action-btn" 
    data-action="like"
    data-product-id={productId}
    aria-label={lang === 'es' ? 'Me gusta' : 'Like'}
  >
    <svg viewBox="0 0 24 24" fill="none" class="action-icon heart-icon">
      <path 
        d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" 
        stroke="currentColor" 
        stroke-width="2"
        stroke-linejoin="round"
      />
    </svg>
    <span class="action-count" data-like-count>0</span>
  </button>

  <!-- Share button -->
  <button 
    type="button" 
    class="action-btn" 
    data-action="share"
    data-product-id={productId}
    data-share-url={`/${lang}/products/${productId}`}
    aria-label={lang === 'es' ? 'Compartir' : 'Share'}
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="action-icon">
      <path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8" stroke-linecap="round" stroke-linejoin="round"/>
      <polyline points="16,6 12,2 8,6" stroke-linecap="round" stroke-linejoin="round"/>
      <line x1="12" y1="2" x2="12" y2="15" stroke-linecap="round"/>
    </svg>
    <span class="action-label">{lang === 'es' ? 'Compartir' : 'Share'}</span>
  </button>

  <!-- Save/Bookmark button -->
  <button 
    type="button" 
    class="action-btn" 
    data-action="save"
    data-product-id={productId}
    aria-label={lang === 'es' ? 'Guardar' : 'Save'}
  >
    <svg viewBox="0 0 24 24" fill="none" class="action-icon bookmark-icon">
      <path 
        d="M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2v16z" 
        stroke="currentColor" 
        stroke-width="2"
        stroke-linecap="round" 
        stroke-linejoin="round"
      />
    </svg>
    <span class="action-label">{lang === 'es' ? 'Guardar' : 'Save'}</span>
  </button>

  <!-- Amazon link -->
  <a 
    href={affiliateUrl}
    target="_blank"
    rel="noopener noreferrer nofollow"
    class="action-btn action-amazon"
    data-product-id={productId}
    data-tracking="feed-sidebar"
    aria-label="Amazon"
  >
    <svg viewBox="0 0 24 24" fill="currentColor" class="action-icon amazon-icon">
      <path d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
    </svg>
    <span class="action-label">Amazon</span>
  </a>
</div>

<style>
  /* Neo-Brutalist Slide Actions - IMPROVED MOBILE */
  .slide-actions {
    position: absolute;
    right: 0.5rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.625rem;
  }

  .action-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.125rem;
    /* Minimum 44x44 for touch targets (WCAG) */
    min-width: 48px;
    min-height: 48px;
    padding: 0.5rem;
    background: var(--color-cream, #FFFEF9);
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 4px 4px 0 var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-black, #1A1A1A);
    cursor: pointer;
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
    /* Better touch feedback */
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  .action-btn:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-brutal-black, #1A1A1A);
  }

  .action-btn:active {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
  }

  .action-icon {
    width: 24px;
    height: 24px;
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  .action-count,
  .action-label {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.5rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1;
  }

  /* Heart animation */
  .heart-icon path {
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  .action-btn[data-action="like"].liked {
    background: #ef4444;
    color: white;
  }

  .action-btn[data-action="like"].liked .heart-icon path {
    fill: white;
    stroke: white;
  }

  .action-btn[data-action="like"]:hover .heart-icon path {
    stroke: #ef4444;
  }

  /* Bookmark animation */
  .bookmark-icon path {
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  .action-btn[data-action="save"].saved {
    background: var(--color-brutal-yellow, #FFE14D);
  }

  .action-btn[data-action="save"].saved .bookmark-icon path {
    fill: var(--color-brutal-black, #1A1A1A);
  }

  .action-btn[data-action="save"]:hover .bookmark-icon path {
    stroke: var(--color-brutal-yellow, #FFE14D);
  }

  /* Amazon button special - MEGA CTA */
  .action-amazon {
    text-decoration: none;
    background: #FF9900; /* Amazon orange */
    color: var(--color-brutal-black, #1A1A1A);
    border-color: var(--color-brutal-black, #1A1A1A);
    /* Make it bigger than other buttons */
    min-width: 52px;
    min-height: 52px;
    position: relative;
    /* Subtle glow effect */
    box-shadow:
      4px 4px 0 var(--color-brutal-black, #1A1A1A),
      0 0 20px rgba(255, 153, 0, 0.3);
  }

  .action-amazon:hover {
    background: var(--color-brutal-black, #1A1A1A);
    color: #FF9900;
    box-shadow:
      6px 6px 0 #FF9900,
      0 0 30px rgba(255, 153, 0, 0.5);
  }

  .action-amazon:active {
    box-shadow:
      2px 2px 0 var(--color-brutal-black, #1A1A1A),
      0 0 10px rgba(255, 153, 0, 0.2);
  }

  .action-amazon .action-label {
    color: inherit;
    font-weight: 900;
  }

  .amazon-icon {
    color: inherit;
    width: 26px;
    height: 26px;
  }

  /* Pulse animation for Amazon button to draw attention */
  @keyframes amazon-pulse {
    0%, 100% {
      box-shadow:
        4px 4px 0 var(--color-brutal-black, #1A1A1A),
        0 0 20px rgba(255, 153, 0, 0.3);
    }
    50% {
      box-shadow:
        4px 4px 0 var(--color-brutal-black, #1A1A1A),
        0 0 30px rgba(255, 153, 0, 0.5);
    }
  }

  .action-amazon {
    animation: amazon-pulse 3s ease-in-out infinite;
  }

  .action-amazon:hover {
    animation: none;
  }

  /* Responsive */
  @media (min-width: 768px) {
    .slide-actions {
      right: 1.5rem;
      gap: 0.875rem;
    }

    .action-btn {
      min-width: 52px;
      min-height: 52px;
      padding: 0.625rem;
      box-shadow: 5px 5px 0 var(--color-brutal-black, #1A1A1A);
    }

    .action-btn:hover {
      box-shadow: 7px 7px 0 var(--color-brutal-black, #1A1A1A);
    }

    .action-icon {
      width: 26px;
      height: 26px;
    }

    .action-count,
    .action-label {
      font-size: 0.5625rem;
    }

    .action-amazon {
      min-width: 56px;
      min-height: 56px;
    }

    .amazon-icon {
      width: 28px;
      height: 28px;
    }
  }

  @media (min-width: 1024px) {
    .slide-actions {
      right: 2rem;
    }
  }

  /* Hide labels on very small screens to keep buttons compact */
  @media (max-width: 360px) {
    .action-label {
      display: none;
    }

    .action-btn {
      min-width: 44px;
      min-height: 44px;
      padding: 0.375rem;
    }

    .action-amazon {
      min-width: 48px;
      min-height: 48px;
    }
  }

  /* Extra small screens (iPhone SE - 320px) */
  @media (max-width: 340px) {
    .slide-actions {
      right: 0.25rem;
      gap: 0.5rem;
    }

    .action-label,
    .action-count {
      display: none;
    }

    .action-btn {
      min-width: 36px;
      min-height: 36px;
      padding: 0.25rem;
      border-width: 2px;
      box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
    }

    .action-btn:hover {
      box-shadow: 3px 3px 0 var(--color-brutal-black, #1A1A1A);
    }

    .action-btn:active {
      box-shadow: 1px 1px 0 var(--color-brutal-black, #1A1A1A);
    }

    .action-icon {
      width: 18px;
      height: 18px;
    }

    .action-amazon {
      min-width: 40px;
      min-height: 40px;
      box-shadow:
        2px 2px 0 var(--color-brutal-black, #1A1A1A),
        0 0 12px rgba(255, 153, 0, 0.3);
    }

    .action-amazon:hover {
      box-shadow:
        3px 3px 0 #FF9900,
        0 0 20px rgba(255, 153, 0, 0.5);
    }

    .amazon-icon {
      width: 20px;
      height: 20px;
    }

    @keyframes amazon-pulse {
      0%, 100% {
        box-shadow:
          2px 2px 0 var(--color-brutal-black, #1A1A1A),
          0 0 12px rgba(255, 153, 0, 0.3);
      }
      50% {
        box-shadow:
          2px 2px 0 var(--color-brutal-black, #1A1A1A),
          0 0 18px rgba(255, 153, 0, 0.5);
      }
    }
  }
</style>

<script>
  // Handle action button interactions
  function initSlideActions() {
    // Like buttons
    document.querySelectorAll('[data-action="like"]').forEach((btn) => {
      btn.addEventListener('click', () => {
        btn.classList.toggle('liked');
        const countEl = btn.querySelector('[data-like-count]');
        if (countEl) {
          const current = parseInt(countEl.textContent || '0', 10);
          countEl.textContent = btn.classList.contains('liked') 
            ? String(current + 1) 
            : String(Math.max(0, current - 1));
        }
        // Add haptic feedback on supported devices
        if (navigator.vibrate) {
          navigator.vibrate(50);
        }
      });
    });

    // Save buttons
    document.querySelectorAll('[data-action="save"]').forEach((btn) => {
      btn.addEventListener('click', () => {
        btn.classList.toggle('saved');
        if (navigator.vibrate) {
          navigator.vibrate(50);
        }
      });
    });

    // Share buttons
    document.querySelectorAll('[data-action="share"]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const shareUrl = (btn as HTMLElement).dataset.shareUrl;
        const productId = (btn as HTMLElement).dataset.productId;
        
        if (navigator.share) {
          try {
            await navigator.share({
              title: document.title,
              url: window.location.origin + shareUrl,
            });
          } catch (err) {
            // User cancelled or share failed
            console.log('Share cancelled');
          }
        } else {
          // Fallback: copy to clipboard
          try {
            await navigator.clipboard.writeText(window.location.origin + shareUrl);
            // Show feedback (could be improved with a toast)
            const label = btn.querySelector('.action-label');
            if (label) {
              const original = label.textContent;
              label.textContent = '✓';
              setTimeout(() => {
                label.textContent = original;
              }, 1500);
            }
          } catch (err) {
            console.error('Could not copy to clipboard');
          }
        }
      });
    });
  }

  // Initialize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSlideActions);
  } else {
    initSlideActions();
  }

  // Re-init on Astro page transitions
  document.addEventListener('astro:page-load', initSlideActions);
</script>
