---
import ProductSlide from './ProductSlide.astro';
import { type Lang, getTranslation } from '@i18n/utils';

interface Product {
  productId: string;
  asin: string;
  title: string;
  brand: string;
  price: number;
  originalPrice?: number;
  currency: string;
  rating?: number;
  featuredImage: { url: string; alt: string };
  affiliateUrl: string;
  category?: string;
  shortDescription?: string;
  model3dUrl?: string;
  // Top reviews for feed display
  topReviews?: {
    reviews: Array<{
      title: string | null;
      content: string;
      rating: number;
      reviewerName: string | null;
      isVerifiedPurchase: boolean;
    }>;
    totalCount: number;
    averageRating: number;
  };
}

interface Props {
  products: Product[];
  lang: Lang;
}

const { products, lang } = Astro.props;
const t = getTranslation(lang);
---

<div class="product-feed" id="product-feed">
  <!-- Feed header (hidden but accessible) -->
  <h1 class="sr-only">
    {lang === 'es' ? 'Descubre productos' : 'Discover products'}
  </h1>

  <!-- Products container with scroll snap -->
  <div class="feed-container" id="feed-container">
    {products.map((product, index) => (
      <ProductSlide 
        product={product} 
        lang={lang} 
        index={index}
      />
    ))}

    <!-- End of feed message -->
    {products.length > 0 && (
      <div class="feed-end">
        <div class="feed-end-content">
          <div class="end-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h2 class="end-title">
            {lang === 'es' ? '¡Has visto todo!' : "You've seen it all!"}
          </h2>
          <p class="end-text">
            {lang === 'es' 
              ? 'Vuelve pronto para más productos' 
              : 'Come back soon for more products'}
          </p>
          <button type="button" class="end-button" id="scroll-to-top">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
              <path d="M12 19V5M5 12l7-7 7 7"/>
            </svg>
            {lang === 'es' ? 'Volver al inicio' : 'Back to top'}
          </button>
        </div>
      </div>
    )}
  </div>

  <!-- Progress indicator -->
  <div class="feed-progress" id="feed-progress">
    <div class="progress-bar" id="progress-bar"></div>
    <span class="progress-text" id="progress-text">1 / {products.length}</span>
  </div>

  <!-- Navigation hints -->
  <div class="nav-hints">
    <button type="button" class="nav-btn nav-prev" id="nav-prev" aria-label="Previous">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 19V5M5 12l7-7 7 7"/>
      </svg>
    </button>
    <button type="button" class="nav-btn nav-next" id="nav-next" aria-label="Next">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 5v14M5 12l7 7 7-7"/>
      </svg>
    </button>
  </div>
</div>

<!-- Load 3D effect script -->
<script src="../../scripts/slide-3d.ts"></script>

<script define:vars={{ totalProducts: products.length }}>
  function initFeed() {
    const container = document.getElementById('feed-container');
    const progressBar = document.getElementById('progress-bar');
    const progressText = document.getElementById('progress-text');
    const prevBtn = document.getElementById('nav-prev');
    const nextBtn = document.getElementById('nav-next');
    const scrollToTopBtn = document.getElementById('scroll-to-top');
    
    if (!container) return;

    let currentIndex = 0;
    const slides = container.querySelectorAll('.product-slide');
    const totalSlides = slides.length;

    // Update progress indicator
    function updateProgress() {
      const scrollTop = container.scrollTop;
      const scrollHeight = container.scrollHeight - container.clientHeight;
      const progress = scrollHeight > 0 ? (scrollTop / scrollHeight) * 100 : 0;
      
      if (progressBar) {
        progressBar.style.width = `${progress}%`;
      }

      // Calculate current slide
      const slideHeight = container.clientHeight;
      currentIndex = Math.round(scrollTop / slideHeight);
      
      if (progressText) {
        progressText.textContent = `${Math.min(currentIndex + 1, totalSlides)} / ${totalSlides}`;
      }

      // Update nav button states
      if (prevBtn) {
        prevBtn.classList.toggle('hidden', currentIndex === 0);
      }
      if (nextBtn) {
        nextBtn.classList.toggle('hidden', currentIndex >= totalSlides - 1);
      }
    }

    // Scroll to specific slide
    function scrollToSlide(index) {
      const targetSlide = slides[index];
      if (targetSlide) {
        targetSlide.scrollIntoView({ behavior: 'smooth' });
      }
    }

    // Event listeners
    container.addEventListener('scroll', updateProgress, { passive: true });

    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        if (currentIndex > 0) {
          scrollToSlide(currentIndex - 1);
        }
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        if (currentIndex < totalSlides - 1) {
          scrollToSlide(currentIndex + 1);
        }
      });
    }

    if (scrollToTopBtn) {
      scrollToTopBtn.addEventListener('click', () => {
        scrollToSlide(0);
      });
    }

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown' || e.key === 'j') {
        e.preventDefault();
        if (currentIndex < totalSlides - 1) {
          scrollToSlide(currentIndex + 1);
        }
      } else if (e.key === 'ArrowUp' || e.key === 'k') {
        e.preventDefault();
        if (currentIndex > 0) {
          scrollToSlide(currentIndex - 1);
        }
      }
    });

    // Initial state
    updateProgress();
  }

  // Initialize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFeed);
  } else {
    initFeed();
  }

  // Re-init on Astro page transitions
  document.addEventListener('astro:page-load', initFeed);
</script>

<style>
  .product-feed {
    position: relative;
    width: 100%;
    height: 100dvh;
    overflow: hidden;
    background: #0a0a0a;
  }

  .feed-container {
    width: 100%;
    height: 100%;
    overflow-y: scroll;
    overflow-x: hidden;
    scroll-snap-type: y mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    
    /* Hide scrollbar */
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .feed-container::-webkit-scrollbar {
    display: none;
  }

  /* Screen reader only */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* Progress indicator */
  .feed-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: 3px;
    background: rgba(255, 255, 255, 0.1);
  }

  .progress-bar {
    height: 100%;
    background: linear-gradient(90deg, #FF9900, #FFB84D);
    width: 0%;
    transition: width 0.2s ease-out;
  }

  .progress-text {
    position: absolute;
    top: 12px;
    right: 16px;
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.6);
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
    padding: 0.375rem 0.75rem;
    border-radius: 100px;
  }

  /* Navigation hints */
  .nav-hints {
    position: fixed;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 50;
    display: none;
    flex-direction: column;
    gap: 0.75rem;
  }

  @media (min-width: 1024px) {
    .nav-hints {
      display: flex;
    }
  }

  .nav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    color: white;
    cursor: pointer;
    transition: all 0.2s ease-out;
  }

  .nav-btn:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: scale(1.1);
  }

  .nav-btn.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .nav-btn svg {
    width: 20px;
    height: 20px;
  }

  /* Feed end screen */
  .feed-end {
    height: 100dvh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    scroll-snap-align: start;
    background: linear-gradient(180deg, #1a1a2e 0%, #0a0a0a 100%);
  }

  .feed-end-content {
    text-align: center;
    padding: 2rem;
    max-width: 400px;
  }

  .end-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 1.5rem;
    color: #22c55e;
  }

  .end-icon svg {
    width: 100%;
    height: 100%;
  }

  .end-title {
    font-family: var(--font-display, 'Fraunces', Georgia, serif);
    font-size: 1.75rem;
    font-weight: 400;
    color: white;
    margin: 0 0 0.75rem;
  }

  .end-text {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0 0 2rem;
  }

  .end-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.5rem;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 100px;
    color: white;
    font-family: var(--font-sans, 'DM Sans', sans-serif);
    font-size: 0.9375rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease-out;
  }

  .end-button:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
  }
</style>
