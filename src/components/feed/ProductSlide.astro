  }
</style>

<script>
  // Initialize carousels and see more buttons
  function initProductSlide() {
    const currentLang = document.documentElement.lang || 'es';

    // Carousel functionality
    document.querySelectorAll('[data-carousel]').forEach((carousel) => {
      const track = carousel.querySelector('[data-carousel-track]') as HTMLElement;
      const slides = carousel.querySelectorAll('[data-carousel-slide]');
      const dots = carousel.querySelectorAll('[data-carousel-dot]');
      const prevBtn = carousel.querySelector('[data-carousel-prev]');
      const nextBtn = carousel.querySelector('[data-carousel-next]');
      const statusRegion = carousel.querySelector('[data-carousel-status]');

      if (!track || slides.length === 0) return;

      let currentIndex = 0;
      const totalSlides = slides.length;

      // Announce slide change to screen readers
      function announceSlide(index: number) {
        if (statusRegion) {
          const message = currentLang === 'es'
            ? `Imagen ${index + 1} de ${totalSlides}`
            : `Image ${index + 1} of ${totalSlides}`;
          statusRegion.textContent = message;
        }
      }

      function goToSlide(index: number) {
        const previousIndex = currentIndex;
        currentIndex = Math.max(0, Math.min(index, totalSlides - 1));

        // Don't do anything if we're already at the target slide
        if (previousIndex === currentIndex && index !== currentIndex) return;

        // Pause any playing video in the previous slide
        if (previousIndex !== currentIndex) {
          const prevSlide = slides[previousIndex] as HTMLElement;
          if (prevSlide?.classList.contains('carousel-slide--video') && prevSlide.classList.contains('is-playing')) {
            const iframe = prevSlide.querySelector('.video-iframe') as HTMLIFrameElement;
            if (iframe) {
              iframe.src = '';
              prevSlide.classList.remove('is-playing');
            }
          }
        }

        track.style.transform = `translateX(-${currentIndex * 100}%)`;

        // Update ARIA attributes on slides
        slides.forEach((slide, i) => {
          slide.setAttribute('aria-hidden', i === currentIndex ? 'false' : 'true');
        });

        // Update dots with ARIA
        dots.forEach((dot, i) => {
          dot.classList.toggle('active', i === currentIndex);
          dot.setAttribute('aria-selected', i === currentIndex ? 'true' : 'false');
        });

        // Update count badge
        const countEl = carousel.querySelector('[data-current-index]');
        if (countEl) {
          countEl.textContent = String(currentIndex + 1);
        }

        // Announce the change
        announceSlide(currentIndex);
      }

      // Navigation buttons
      prevBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        goToSlide(currentIndex - 1);
      });

      nextBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        goToSlide(currentIndex + 1);
      });

      // Dot navigation
      dots.forEach((dot, index) => {
        dot.addEventListener('click', (e) => {
          e.stopPropagation();
          goToSlide(index);
        });
      });

      // Keyboard navigation within carousel
      carousel.addEventListener('keydown', (e: Event) => {
        const keyEvent = e as KeyboardEvent;
        if (keyEvent.key === 'ArrowLeft') {
          keyEvent.preventDefault();
          goToSlide(currentIndex - 1);
        } else if (keyEvent.key === 'ArrowRight') {
          keyEvent.preventDefault();
          goToSlide(currentIndex + 1);
        }
      });

      // Touch/swipe support
      let touchStartX = 0;
      let touchEndX = 0;

      carousel.addEventListener('touchstart', (e: Event) => {
        touchStartX = (e as TouchEvent).changedTouches[0].screenX;
      }, { passive: true });

      carousel.addEventListener('touchend', (e: Event) => {
        touchEndX = (e as TouchEvent).changedTouches[0].screenX;
        const diff = touchStartX - touchEndX;

        if (Math.abs(diff) > 50) {
          if (diff > 0) {
            goToSlide(currentIndex + 1);
          } else {
            goToSlide(currentIndex - 1);
          }
        }
      }, { passive: true });
    });

  }

  // See more functionality - use event delegation for dynamic content
  function initSeeMore() {
    // Remove existing listener to avoid duplicates
    document.removeEventListener('click', handleSeeMoreClick);
    document.addEventListener('click', handleSeeMoreClick);
  }

  function handleSeeMoreClick(e: Event) {
    const target = e.target as HTMLElement;
    if (!target.matches('[data-see-more]')) return;

    e.stopPropagation();
    e.preventDefault();

    const btn = target;
    const description = btn.closest('[data-description]') as HTMLElement;
    if (!description) return;

    const fullText = description.dataset.full || '';
    const truncatedText = description.dataset.truncated || '';
    const textSpan = description.querySelector('.description-text');
    const isSpanish = description.dataset.lang === 'es';

    if (!textSpan) return;

    const isExpanded = description.dataset.expanded === 'true';

    if (isExpanded) {
      textSpan.textContent = truncatedText;
      btn.textContent = isSpanish ? 'ver más' : 'see more';
      description.dataset.expanded = 'false';
    } else {
      textSpan.textContent = fullText;
      btn.textContent = isSpanish ? 'ver menos' : 'see less';
      description.dataset.expanded = 'true';
    }
  }

  // Video player functionality - load YouTube on play click
  function initVideoPlayers() {
    document.querySelectorAll('[data-video-player]').forEach((container) => {
      const videoContainer = container as HTMLElement;

      // Skip if already initialized
      if (videoContainer.dataset.videoInitialized) return;
      videoContainer.dataset.videoInitialized = 'true';

      const playBtn = videoContainer.querySelector('[data-play-btn]');
      const iframe = videoContainer.querySelector('.video-iframe') as HTMLIFrameElement;
      const embedUrl = videoContainer.dataset.embedUrl;

      if (!playBtn || !iframe || !embedUrl) return;

      playBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        e.preventDefault();

        // Add autoplay to the embed URL
        const autoplayUrl = embedUrl.includes('?')
          ? `${embedUrl}&autoplay=1`
          : `${embedUrl}?autoplay=1`;

        // Load and play the video
        iframe.src = autoplayUrl;
        videoContainer.classList.add('is-playing');
      });

      // Stop video when slide changes (if in a scroll container)
      const slideParent = videoContainer.closest('[data-slide-index]');
      if (slideParent) {
        // Use IntersectionObserver to pause when out of view
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting && videoContainer.classList.contains('is-playing')) {
                // Pause video by removing src
                iframe.src = '';
                videoContainer.classList.remove('is-playing');
              }
            });
          },
          { threshold: 0.5 }
        );
        observer.observe(videoContainer);
      }
    });
  }

  // Optional video modal functionality
  let videoModal: HTMLElement | null = null;

  function createVideoModal() {
    if (videoModal) return videoModal;

    const modal = document.createElement('div');
    modal.className = 'video-modal-overlay';
    modal.innerHTML = `
      <div class="video-modal-content">
        <button class="video-modal-close" aria-label="Close video">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>
        <iframe class="video-modal-iframe" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
        <div class="video-modal-channel">
          <svg viewBox="0 0 24 24" fill="#ff0000" width="16" height="16">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/>
            <polygon fill="#fff" points="9.545,15.568 15.818,12 9.545,8.432"/>
          </svg>
          <span class="channel-name"></span>
        </div>
      </div>
    `;

    document.body.appendChild(modal);
    videoModal = modal;

    // Close button handler
    const closeBtn = modal.querySelector('.video-modal-close');
    closeBtn?.addEventListener('click', closeVideoModal);

    // Close on overlay click
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeVideoModal();
    });

    // Close on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('is-open')) {
        closeVideoModal();
      }
    });

    return modal;
  }

  function openVideoModal(embedUrl: string, channelTitle: string) {
    const modal = createVideoModal();
    const iframe = modal.querySelector('.video-modal-iframe') as HTMLIFrameElement;
    const channelSpan = modal.querySelector('.channel-name');

    if (iframe) {
      // Add autoplay to the URL
      const autoplayUrl = embedUrl.includes('?')
        ? `${embedUrl}&autoplay=1`
        : `${embedUrl}?autoplay=1`;
      iframe.src = autoplayUrl;
    }

    if (channelSpan) {
      channelSpan.textContent = channelTitle;
    }

    modal.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeVideoModal() {
    if (!videoModal) return;

    const iframe = videoModal.querySelector('.video-modal-iframe') as HTMLIFrameElement;
    if (iframe) {
      iframe.src = ''; // Stop the video
    }

    videoModal.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  function initOptionalVideoButtons() {
    document.querySelectorAll('[data-optional-video-btn]').forEach((btn) => {
      const button = btn as HTMLElement;

      // Skip if already initialized
      if (button.dataset.optionalVideoInitialized) return;
      button.dataset.optionalVideoInitialized = 'true';

      button.addEventListener('click', (e) => {
        e.stopPropagation();
        e.preventDefault();

        const embedUrl = button.dataset.embedUrl;
        const channelTitle = button.dataset.channelTitle || '';

        if (embedUrl) {
          openVideoModal(embedUrl, channelTitle);
        }
      });
    });
  }

  // Toast notification system
  let toastContainer: HTMLElement | null = null;
  let toastTimeout: number | null = null;

  function createToastContainer() {
    if (toastContainer) return toastContainer;

    const container = document.createElement('div');
    container.id = 'cart-toast-container';
    container.innerHTML = `
      <style>
        #cart-toast-container {
          position: fixed;
          bottom: calc(env(safe-area-inset-bottom, 0px) + 100px);
          left: 50%;
          transform: translateX(-50%) translateY(100px);
          z-index: 9999;
          opacity: 0;
          transition: transform 0.3s cubic-bezier(0.68, -0.6, 0.32, 1.6), opacity 0.3s ease;
          pointer-events: none;
        }
        #cart-toast-container.visible {
          transform: translateX(-50%) translateY(0);
          opacity: 1;
          pointer-events: auto;
        }
        .cart-toast {
          display: flex;
          align-items: center;
          gap: 12px;
          padding: 12px 16px;
          background: var(--color-brutal-black, #1A1A1A);
          border: 3px solid var(--color-brutal-yellow, #FFE14D);
          box-shadow: 6px 6px 0 var(--color-brutal-yellow, #FFE14D);
          max-width: 340px;
        }
        .toast-image {
          width: 48px;
          height: 48px;
          object-fit: contain;
          background: white;
          border: 2px solid var(--color-brutal-black, #1A1A1A);
          flex-shrink: 0;
        }
        .toast-content {
          flex: 1;
          min-width: 0;
        }
        .toast-title {
          font-family: var(--font-display, 'Space Grotesk', sans-serif);
          font-size: 0.8125rem;
          font-weight: 700;
          color: white;
          margin: 0 0 2px;
          white-space: nowrap;
          overflow: hidden;
          text-overflow: ellipsis;
          max-width: 160px;
        }
        .toast-message {
          font-family: var(--font-mono, 'JetBrains Mono', monospace);
          font-size: 0.6875rem;
          color: var(--color-brutal-yellow, #FFE14D);
          text-transform: uppercase;
          letter-spacing: 0.05em;
          margin: 0;
        }
        .toast-action {
          display: flex;
          align-items: center;
          justify-content: center;
          padding: 8px 12px;
          background: var(--color-brutal-yellow, #FFE14D);
          border: 2px solid var(--color-brutal-black, #1A1A1A);
          color: var(--color-brutal-black, #1A1A1A);
          font-family: var(--font-mono, 'JetBrains Mono', monospace);
          font-size: 0.625rem;
          font-weight: 800;
          text-transform: uppercase;
          letter-spacing: 0.05em;
          cursor: pointer;
          transition: all 0.15s ease;
          flex-shrink: 0;
        }
        .toast-action:hover {
          background: var(--color-brutal-orange, #FF6B35);
        }
        @media (max-width: 380px) {
          #cart-toast-container {
            left: 8px;
            right: 8px;
            transform: translateX(0) translateY(100px);
          }
          #cart-toast-container.visible {
            transform: translateX(0) translateY(0);
          }
          .cart-toast {
            padding: 10px 12px;
            gap: 10px;
          }
          .toast-image {
            width: 40px;
            height: 40px;
          }
          .toast-title {
            font-size: 0.75rem;
            max-width: 120px;
          }
          .toast-action {
            padding: 6px 10px;
            font-size: 0.5625rem;
          }
        }
      </style>
      <div class="cart-toast">
        <img class="toast-image" src="" alt="" />
        <div class="toast-content">
          <p class="toast-title"></p>
          <p class="toast-message"></p>
        </div>
        <button type="button" class="toast-action"></button>
      </div>
    `;

    document.body.appendChild(container);
    toastContainer = container;

    // View cart action
    const actionBtn = container.querySelector('.toast-action');
    actionBtn?.addEventListener('click', () => {
      hideToast();
      window.dispatchEvent(new CustomEvent('cart:open'));
    });

    return container;
  }

  function showToast(product: { title: string; image: string }, lang: string = 'es') {
    const container = createToastContainer();
    const imgEl = container.querySelector('.toast-image') as HTMLImageElement;
    const titleEl = container.querySelector('.toast-title');
    const messageEl = container.querySelector('.toast-message');
    const actionEl = container.querySelector('.toast-action');

    if (imgEl) {
      imgEl.src = product.image || '';
      imgEl.alt = product.title;
    }
    if (titleEl) {
      titleEl.textContent = product.title;
    }
    if (messageEl) {
      messageEl.textContent = lang === 'es' ? 'Agregado al carrito' : 'Added to cart';
    }
    if (actionEl) {
      actionEl.textContent = lang === 'es' ? 'Ver carrito' : 'View cart';
    }

    // Clear existing timeout
    if (toastTimeout) {
      clearTimeout(toastTimeout);
    }

    // Show toast
    requestAnimationFrame(() => {
      container.classList.add('visible');
    });

    // Auto-hide after 3 seconds
    toastTimeout = window.setTimeout(() => {
      hideToast();
    }, 3000);
  }

  function hideToast() {
    if (toastContainer) {
      toastContainer.classList.remove('visible');
    }
    if (toastTimeout) {
      clearTimeout(toastTimeout);
      toastTimeout = null;
    }
  }

  // Add to Cart button functionality
  function initAddToCartButtons() {
    const currentLang = document.documentElement.lang || 'es';

    document.querySelectorAll('[data-add-to-cart]').forEach((btn) => {
      const button = btn as HTMLElement;

      // Skip if already initialized
      if (button.dataset.addToCartInitialized) return;
      button.dataset.addToCartInitialized = 'true';

      button.addEventListener('click', (e) => {
        e.stopPropagation();
        e.preventDefault();

        // Check if cart API is available
        if (!(window as any).cart) {
          console.warn('Cart API not available');
          return;
        }

        // Get product data from data attributes
        const product = {
          asin: button.dataset.asin || '',
          productId: button.dataset.productId || '',
          title: button.dataset.title || '',
          brand: button.dataset.brand || '',
          image: button.dataset.image || '',
          price: parseFloat(button.dataset.price || '0'),
          currency: button.dataset.currency || 'USD',
          affiliateUrl: button.dataset.affiliateUrl || '',
        };

        // Add to cart
        (window as any).cart.add(product);

        // Show toast notification
        showToast({ title: product.title, image: product.image }, currentLang);

        // Visual feedback - show "added" state
        button.classList.add('added');

        // Remove the "added" state after animation
        setTimeout(() => {
          button.classList.remove('added');
        }, 1500);
      });
    });
  }

  // Initialize price sparklines
  function initSparklines() {
    document.querySelectorAll('.price-sparkline').forEach((container) => {
      const sparklineEl = container as HTMLElement;

      // Skip if already initialized
      if (sparklineEl.dataset.sparklineInit) return;
      sparklineEl.dataset.sparklineInit = 'true';

      const pricesStr = sparklineEl.dataset.prices;
      if (!pricesStr) return;

      try {
        const prices = JSON.parse(pricesStr) as number[];
        if (prices.length < 2) return;

        const svg = sparklineEl.querySelector('.sparkline-svg');
        if (!svg) return;

        // Calculate min/max for normalization
        const min = Math.min(...prices);
        const max = Math.max(...prices);
        const range = max - min || 1;

        // Generate path points
        const width = 60;
        const height = 20;
        const padding = 2;
        const effectiveHeight = height - padding * 2;
        const effectiveWidth = width - padding * 2;

        const points = prices.map((price, i) => {
          const x = padding + (i / (prices.length - 1)) * effectiveWidth;
          const y = padding + effectiveHeight - ((price - min) / range) * effectiveHeight;
          return { x, y };
        });

        // Create line path
        const linePath = points.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x.toFixed(1)} ${p.y.toFixed(1)}`).join(' ');

        // Create area path (line + close to bottom)
        const areaPath = linePath +
          ` L ${points[points.length - 1].x.toFixed(1)} ${height - padding}` +
          ` L ${padding} ${height - padding} Z`;

        // Add paths to SVG
        svg.innerHTML = `
          <path class="sparkline-area" d="${areaPath}" />
          <path d="${linePath}" />
        `;

        // Color the line based on trend (last vs first price)
        const trend = prices[prices.length - 1] < prices[0] ? 'down' : 'up';
        const lineEl = svg.querySelector('path:not(.sparkline-area)') as SVGPathElement;
        const areaEl = svg.querySelector('.sparkline-area') as SVGPathElement;

        if (trend === 'down') {
          // Price went down - green (good for buyer)
          lineEl?.setAttribute('stroke', '#34D399');
          areaEl?.setAttribute('fill', 'rgba(52, 211, 153, 0.2)');
        } else {
          // Price went up - red (not ideal)
          lineEl?.setAttribute('stroke', '#F87171');
          areaEl?.setAttribute('fill', 'rgba(248, 113, 113, 0.15)');
        }
      } catch (e) {
        console.error('Error initializing sparkline:', e);
      }
    });
  }

  // Run on load and after Astro page transitions
  initProductSlide();
  initSeeMore();
  initVideoPlayers();
  initOptionalVideoButtons();
  initAddToCartButtons();
  initSparklines();
  document.addEventListener('astro:after-swap', () => {
    initProductSlide();
    initSeeMore();
    initVideoPlayers();
    initOptionalVideoButtons();
    initAddToCartButtons();
    initSparklines();
  });

  // Also re-init when new slides are dynamically added to the feed
  const feedObserver = new MutationObserver(() => {
    initVideoPlayers();
    initOptionalVideoButtons();
    initAddToCartButtons();
    initSparklines();
  });

  const feedContainer = document.getElementById('reel-slides');
  if (feedContainer) {
    feedObserver.observe(feedContainer, { childList: true, subtree: true });
  }
</script>
