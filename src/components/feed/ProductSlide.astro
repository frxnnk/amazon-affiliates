---
import { type Lang, getTranslation } from '@i18n/utils';
import SlideActions from './SlideActions.astro';
import ProductModel3D from './ProductModel3D.astro';

interface Props {
  product: {
    productId: string;
    asin: string;
    title: string;
    brand: string;
    price: number;
    originalPrice?: number;
    currency: string;
    rating?: number;
    featuredImage: { url: string; alt: string };
    images?: string[]; // All product images for carousel
    affiliateUrl: string;
    category?: string;
    shortDescription?: string;
    model3dUrl?: string;
    // YouTube video embed (if available)
    youtubeVideo?: {
      videoId: string;
      title: string;
      channelTitle: string;
      thumbnail: string;
      embedUrl: string;
      isShort: boolean;
      isPremiumChannel: boolean; // True if from a known quality tech review channel
      isHidden?: boolean; // Admin can hide specific videos
    } | null;
    // Extended MCP fields
    salesVolume?: string | null;
    isBestSeller?: boolean;
    isAmazonChoice?: boolean;
    couponText?: string | null;
    productBadge?: string | null;
    isPrime?: boolean;
    badges?: string[];
    // Keepa price context
    priceContext?: {
      isLowestIn30Days: boolean;
      percentBelowAvg: number;
      priceHistory?: number[]; // Last 30 days prices for sparkline
      priceDrop7Days?: number; // % price drop in last 7 days
    };
  };
  lang: Lang;
  index: number;
}

const { product, lang, index } = Astro.props;
const t = getTranslation(lang);

// Category-based gradient colors
const categoryGradients: Record<string, { from: string; to: string; accent: string }> = {
  electronics: { from: '#1a1a2e', to: '#16213e', accent: '#0f3460' },
  audio: { from: '#2d132c', to: '#1a0a1a', accent: '#801336' },
  phones: { from: '#0d1b2a', to: '#1b263b', accent: '#415a77' },
  books: { from: '#2c1810', to: '#1a0f09', accent: '#8b4513' },
  default: { from: '#1A1815', to: '#2D2926', accent: '#3d3a36' },
};

const category = product.category?.toLowerCase() || 'default';
const gradient = categoryGradients[category] || categoryGradients.default;

// Format price
const formattedPrice = new Intl.NumberFormat(lang === 'es' ? 'es-ES' : 'en-US', {
  style: 'currency',
  currency: product.currency || 'USD',
}).format(product.price);

const formattedOriginalPrice = product.originalPrice
  ? new Intl.NumberFormat(lang === 'es' ? 'es-ES' : 'en-US', {
      style: 'currency',
      currency: product.currency || 'USD',
    }).format(product.originalPrice)
  : null;

const discount = product.originalPrice
  ? Math.round(((product.originalPrice - product.price) / product.originalPrice) * 100)
  : 0;

// Keepa price context
const priceContext = product.priceContext;
const percentBelowAvg = priceContext?.percentBelowAvg || 0;
const isLowestIn30Days = priceContext?.isLowestIn30Days || false;
const priceDrop7Days = priceContext?.priceDrop7Days || 0;
const priceHistory = priceContext?.priceHistory || [];
const hasPriceDrop = priceDrop7Days >= 15; // 15%+ drop in 7 days
const hasGoodDeal = percentBelowAvg >= 10; // 10%+ below average

// Get all images for carousel (fallback to featured image)
const productImages = product.images && product.images.length > 0
  ? product.images
  : [product.featuredImage?.url].filter(Boolean) as string[];
const hasMultipleImages = productImages.length > 1;

// Video display logic - SIMPLIFIED:
// Video is always shown as the last slide in the carousel (if available and not hidden)
// No distinction between premium/non-premium - all videos are treated equally
const hasVideo = product.youtubeVideo && !product.youtubeVideo.isHidden;
const videoData = hasVideo ? product.youtubeVideo : null;

// Truncate description for "see more" functionality
const MAX_DESC_LENGTH = 20;
const fullDescription = product.shortDescription || '';
const shouldTruncate = fullDescription.length > MAX_DESC_LENGTH;
const truncatedDescription = shouldTruncate
  ? fullDescription.slice(0, MAX_DESC_LENGTH) + '...'
  : fullDescription;
---

<article 
  class="product-slide" 
  data-slide-index={index}
  style={`--gradient-from: ${gradient.from}; --gradient-to: ${gradient.to}; --gradient-accent: ${gradient.accent};`}
>
  <!-- Background -->
  <div class="slide-bg">
    <div class="bg-gradient"></div>
    <div class="bg-pattern"></div>
    <div class="bg-glow"></div>
  </div>

  <!-- Product Image Carousel (with optional video as last slide) -->
  <div class="product-container">
    {product.model3dUrl ? (
      <!-- 3D Model available - use model-viewer -->
      <div class="product-3d-model">
        <ProductModel3D
          modelUrl={product.model3dUrl}
          imageUrl={product.featuredImage?.url}
          alt={product.featuredImage?.alt || product.title}
        />
      </div>
    ) : (hasMultipleImages || hasVideo) ? (
      <!-- Image carousel (with video as last slide if available) -->
      <div
        class="product-carousel"
        data-carousel
        data-has-video={hasVideo ? 'true' : 'false'}
        role="region"
        aria-roledescription={lang === 'es' ? 'carrusel' : 'carousel'}
        aria-label={`${product.title} - ${lang === 'es' ? 'Galería' : 'Gallery'}`}
      >
        <!-- Slide count badge -->
        <div class="carousel-count" data-carousel-count>
          <span data-current-index>1</span>/{productImages.length + (hasVideo ? 1 : 0)}
        </div>

        <!-- Live region for carousel announcements -->
        <div class="sr-only" role="status" aria-live="polite" data-carousel-status></div>

        <div class="carousel-track" data-carousel-track aria-atomic="false">
          {/* Image slides */}
          {productImages.map((imgUrl, imgIndex) => (
            <div
              class="carousel-slide carousel-slide--image"
              data-carousel-slide
              data-slide-type="image"
              role="group"
              aria-roledescription={lang === 'es' ? 'diapositiva' : 'slide'}
              aria-label={`${imgIndex + 1} ${lang === 'es' ? 'de' : 'of'} ${productImages.length + (hasVideo ? 1 : 0)}`}
              aria-hidden={imgIndex !== 0 ? 'true' : 'false'}
            >
              <img
                src={imgUrl}
                alt={`${product.title} - ${lang === 'es' ? 'Imagen' : 'Image'} ${imgIndex + 1}`}
                loading={index < 2 && imgIndex === 0 ? 'eager' : 'lazy'}
                decoding="async"
                class="carousel-image"
              />
            </div>
          ))}
          {/* Video slide (last) */}
          {hasVideo && videoData && (
            <div
              class:list={[
                'carousel-slide',
                'carousel-slide--video',
                { 'is-short': videoData.isShort }
              ]}
              data-carousel-slide
              data-slide-type="video"
              data-video-player
              data-video-id={videoData.videoId}
              data-embed-url={videoData.embedUrl}
              data-is-short={videoData.isShort ? 'true' : 'false'}
              role="group"
              aria-roledescription={lang === 'es' ? 'diapositiva' : 'slide'}
              aria-label={`${lang === 'es' ? 'Video' : 'Video'}: ${videoData.channelTitle}`}
              aria-hidden="true"
            >
              {/* Video thumbnail */}
              <img
                src={videoData.thumbnail}
                alt={videoData.title}
                loading="lazy"
                class="video-thumbnail"
              />
              {/* Play button */}
              <button
                class="video-play-btn"
                data-play-btn
                aria-label={lang === 'es' ? 'Reproducir video' : 'Play video'}
              >
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </button>
              {/* Channel badge */}
              {videoData.channelTitle && (
                <div class="video-channel-badge">
                  <svg viewBox="0 0 24 24" fill="#ff0000" width="14" height="14" aria-hidden="true">
                    <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/>
                    <polygon fill="#fff" points="9.545,15.568 15.818,12 9.545,8.432"/>
                  </svg>
                  <span>{videoData.channelTitle}</span>
                </div>
              )}
              {/* Video iframe (loaded on play) */}
              <iframe
                class="video-iframe"
                title={videoData.title}
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>
          )}
        </div>

        <!-- Carousel indicators with video icon -->
        <div class="carousel-indicators" role="tablist" aria-label={lang === 'es' ? 'Indicadores' : 'Indicators'}>
          {productImages.map((_, imgIndex) => (
            <button
              class:list={['carousel-dot', { active: imgIndex === 0 }]}
              data-carousel-dot={imgIndex}
              role="tab"
              aria-selected={imgIndex === 0 ? 'true' : 'false'}
              aria-label={`${lang === 'es' ? 'Imagen' : 'Image'} ${imgIndex + 1}`}
              aria-controls={`carousel-slide-${index}-${imgIndex}`}
            />
          ))}
          {hasVideo && (
            <button
              class="carousel-dot carousel-dot--video"
              data-carousel-dot={productImages.length}
              role="tab"
              aria-selected="false"
              aria-label={lang === 'es' ? 'Ver video' : 'Watch video'}
            >
              <svg viewBox="0 0 24 24" fill="currentColor" width="10" height="10" aria-hidden="true">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </button>
          )}
        </div>

        <!-- Navigation arrows -->
        <button
          class="carousel-nav carousel-prev"
          data-carousel-prev
          aria-label={lang === 'es' ? 'Anterior' : 'Previous'}
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" aria-hidden="true">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </button>
        <button
          class="carousel-nav carousel-next"
          data-carousel-next
          aria-label={lang === 'es' ? 'Siguiente' : 'Next'}
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" aria-hidden="true">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </button>
      </div>
    ) : (
      <!-- Fallback to single image with 3D CSS effect -->
      <div class="product-3d" data-3d-element>
        <div class="product-shadow"></div>
        <div class="product-image-wrapper">
          {product.featuredImage?.url ? (
            <img
              src={product.featuredImage.url}
              alt={product.featuredImage.alt || product.title}
              loading={index < 2 ? 'eager' : 'lazy'}
              decoding="async"
              class="product-image"
            />
          ) : (
            <div class="image-placeholder">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                <rect x="3" y="3" width="18" height="18" rx="2" />
                <circle cx="8.5" cy="8.5" r="1.5" />
                <path d="M21 15l-5-5L5 21" />
              </svg>
            </div>
          )}
        </div>
      </div>
    )}
  </div>

  <!-- Actions sidebar -->
  <SlideActions 
    productId={product.productId}
    affiliateUrl={product.affiliateUrl}
    lang={lang}
  />

  <!-- Product Info - Compact Panel -->
  <div class="product-info">
    <div class="info-content">
      <!-- Top row: Brand + Key badge only -->
      <div class="info-top-row">
        <span class="brand-badge">{product.brand}</span>
        {product.isAmazonChoice && (
          <span class="mcp-badge amazon-choice">
            <svg viewBox="0 0 24 24" fill="currentColor" width="10" height="10">
              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
            </svg>
            Choice
          </span>
        )}
        {product.isBestSeller && !product.isAmazonChoice && (
          <span class="mcp-badge best-seller">#1 Best</span>
        )}
      </div>

      <!-- Title - 2 lines max -->
      <h2 class="product-title">{product.title}</h2>

      <!-- Rating + reviews in one clean row -->
      {product.rating && (
        <div class="rating-row">
          <div class="stars-mini">
            <svg viewBox="0 0 24 24" fill="#FF9900" width="13" height="13">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            <span class="rating-value">{product.rating.toFixed(1)}</span>
          </div>
          {product.reviewCount && (
            <span class="review-count">({product.reviewCount.toLocaleString()})</span>
          )}
          {product.salesVolume && (
            <span class="sales-tag">{product.salesVolume}</span>
          )}
        </div>
      )}

      <!-- Price section - clean and prominent -->
      <div class="price-section">
        <span class="current-price">{formattedPrice}</span>
        {formattedOriginalPrice && (
          <span class="original-price">{formattedOriginalPrice}</span>
        )}
        {discount > 0 && (
          <span class="discount-tag">-{discount}%</span>
        )}
      </div>

      <!-- Deal indicator - single consolidated line -->
      {(isLowestIn30Days || hasPriceDrop || hasGoodDeal || product.couponText) && (
        <div class="deal-line">
          {isLowestIn30Days ? (
            <span class="deal-tag lowest">
              <svg viewBox="0 0 24 24" fill="currentColor" width="11" height="11">
                <path d="M16 18l2.29-2.29-4.88-4.88-4 4L2 7.41 3.41 6l6 6 4-4 6.3 6.29L22 12v6h-6z"/>
              </svg>
              {lang === 'es' ? 'Mínimo 30d' : 'Lowest 30d'}
            </span>
          ) : hasPriceDrop ? (
            <span class="deal-tag drop">↓{Math.round(priceDrop7Days)}% {lang === 'es' ? 'esta semana' : 'this week'}</span>
          ) : hasGoodDeal ? (
            <span class="deal-tag below">{Math.round(percentBelowAvg)}% {lang === 'es' ? 'bajo avg' : 'below avg'}</span>
          ) : null}
          {product.couponText && (
            <span class="coupon-tag">
              <svg viewBox="0 0 24 24" fill="currentColor" width="10" height="10">
                <path d="M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.42l9 9c.36.36.86.58 1.41.58.55 0 1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41 0-.55-.23-1.06-.59-1.42z"/>
              </svg>
              {product.couponText}
            </span>
          )}
        </div>
      )}
    </div>
  </div>

  <!-- Floating CTA Buttons - Always Visible -->
  <div class="floating-cta">
    <div class="cta-buttons-row">
      <!-- Add to Cart Button -->
      <button
        type="button"
        class="add-to-cart-btn"
        data-add-to-cart
        data-asin={product.asin}
        data-product-id={product.productId}
        data-title={product.title}
        data-brand={product.brand}
        data-image={product.featuredImage?.url || ''}
        data-price={product.price}
        data-currency={product.currency}
        data-affiliate-url={product.affiliateUrl}
        aria-label={lang === 'es' ? 'Agregar al carrito' : 'Add to cart'}
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
          <line x1="3" y1="6" x2="21" y2="6" />
          <path d="M16 10a4 4 0 0 1-8 0" />
        </svg>
        <svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12" class="plus-icon">
          <path d="M12 4v16m-8-8h16"/>
        </svg>
      </button>

      <!-- Buy on Amazon Button -->
      <a
        href={product.affiliateUrl}
        target="_blank"
        rel="noopener noreferrer nofollow"
        class="buy-button-floating"
        data-product-id={product.productId}
        data-tracking="feed-cta-floating"
      >
        <div class="buy-button-content">
          <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22" class="amazon-icon">
            <path d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
          </svg>
          <span class="buy-text">{lang === 'es' ? 'Comprar en Amazon' : 'Buy on Amazon'}</span>
          <span class="buy-price">{formattedPrice}</span>
        </div>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" width="20" height="20" class="arrow-icon">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Scroll indicator (only on first slide) - Below Amazon button -->
    {index === 0 && (
      <div class="scroll-indicator">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
          <path d="M12 5v14M5 12l7 7 7-7"/>
        </svg>
        <span>{lang === 'es' ? 'Desliza para ver más' : 'Swipe for more'}</span>
      </div>
    )}
  </div>
</article>

<style>
  .product-slide {
    position: relative;
    height: 100dvh;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }

  /* Background layers */
  .slide-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .bg-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      var(--gradient-from) 0%,
      var(--gradient-to) 50%,
      var(--gradient-accent) 100%
    );
  }

  .bg-pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  .bg-glow {
    position: absolute;
    top: 20%;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 40%;
    background: radial-gradient(ellipse, var(--gradient-accent) 0%, transparent 70%);
    opacity: 0.3;
    filter: blur(60px);
  }

  /* Product container */
  .product-container {
    position: relative;
    z-index: 1;
    flex: 1 1 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 100vw;
    padding: 0.75rem;
    padding-top: calc(env(safe-area-inset-top, 0px) + 70px);
    overflow: hidden;
    min-height: 0; /* Allow flex shrinking */
  }

  /* 3D Model container (when using model-viewer) */
  .product-3d-model {
    position: relative;
    width: 100%;
    max-width: 400px;
    height: 350px;
  }

  /* YouTube Video container - BRUTALIST STYLE */
  .product-video-container {
    position: relative;
    width: clamp(240px, 85vw, 320px);
    height: auto;
    aspect-ratio: 16/9;
    background: var(--color-brutal-black, #1A1A1A);
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 8px 8px 0 var(--color-brutal-black, #1A1A1A);
    overflow: hidden;
    flex-shrink: 1;
    max-height: none; /* Let aspect-ratio control height */
  }

  /* YouTube Shorts - Vertical format (9:16) */
  .product-video-container.is-short {
    aspect-ratio: 9/16;
    width: clamp(140px, 45vw, 200px);
    height: auto;
    max-height: 45vh;
  }

  .video-thumbnail {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .product-video-container:hover .video-thumbnail {
    transform: scale(1.02);
  }

  /* Play Button - BRUTALIST */
  .video-play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 72px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-brutal-yellow, #FFE14D);
    border: 4px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 6px 6px 0 var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-black, #1A1A1A);
    cursor: pointer;
    transition: transform 0.15s cubic-bezier(0.68, -0.6, 0.32, 1.6), box-shadow 0.15s ease;
    z-index: 5;
  }

  .video-play-btn svg {
    width: 32px;
    height: 32px;
    margin-left: 4px; /* Visual centering for play icon */
  }

  .video-play-btn:hover {
    transform: translate(-50%, -50%) translate(-3px, -3px);
    box-shadow: 9px 9px 0 var(--color-brutal-black, #1A1A1A);
    background: var(--color-brutal-orange, #FF6B35);
  }

  .video-play-btn:active {
    transform: translate(-50%, -50%) translate(2px, 2px);
    box-shadow: 4px 4px 0 var(--color-brutal-black, #1A1A1A);
  }

  .video-play-btn:focus-visible {
    outline: 3px solid var(--color-brutal-orange, #FF6B35);
    outline-offset: 3px;
  }

  /* Channel Badge */
  .video-channel-badge {
    position: absolute;
    bottom: 12px;
    left: 12px;
    z-index: 4;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    background: var(--color-cream, #FFFEF9);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 3px 3px 0 var(--color-brutal-black, #1A1A1A);
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-brutal-black, #1A1A1A);
  }

  .video-channel-badge span {
    max-width: 100px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Video iframe - hidden until play */
  .video-iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
    opacity: 0;
    pointer-events: none;
    z-index: 10;
    transition: opacity 0.3s ease;
  }

  /* Playing state - show iframe, hide thumbnail/button */
  .product-video-container.is-playing .video-thumbnail,
  .product-video-container.is-playing .video-play-btn,
  .product-video-container.is-playing .video-channel-badge {
    opacity: 0;
    pointer-events: none;
  }

  .product-video-container.is-playing .video-iframe {
    opacity: 1;
    pointer-events: auto;
  }

  @media (min-width: 480px) {
    .product-video-container {
      width: clamp(300px, 75vw, 400px);
      border-width: 4px;
      box-shadow: 10px 10px 0 var(--color-brutal-black, #1A1A1A);
    }
    .product-video-container.is-short {
      width: clamp(160px, 40vw, 220px);
      max-height: 50vh;
    }
    .video-play-btn {
      width: 80px;
      height: 80px;
    }
    .video-play-btn svg {
      width: 36px;
      height: 36px;
    }
  }

  @media (min-width: 768px) {
    .product-video-container {
      width: clamp(360px, 60vw, 480px);
      border-width: 5px;
      box-shadow: 12px 12px 0 var(--color-brutal-black, #1A1A1A);
    }
    .product-video-container.is-short {
      width: clamp(200px, 35vw, 280px);
      max-height: 55vh;
    }
    .video-play-btn {
      width: 88px;
      height: 88px;
    }
    .video-play-btn svg {
      width: 40px;
      height: 40px;
    }
    .video-channel-badge {
      font-size: 0.6875rem;
    }
  }

  @media (min-width: 1024px) {
    .product-video-container {
      width: clamp(420px, 50vw, 560px);
    }
    .product-video-container.is-short {
      width: clamp(240px, 30vw, 320px);
      max-height: 65vh;
    }
    .video-play-btn {
      width: 96px;
      height: 96px;
    }
    .video-play-btn svg {
      width: 44px;
      height: 44px;
    }
  }

  /* Optional Video Button - for non-premium channel videos */
  .optional-video-btn {
    position: absolute;
    bottom: 12px;
    right: 12px;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    background: #FF0000;
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 4px 4px 0 var(--color-brutal-black, #1A1A1A);
    color: white;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.6875rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.15s cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  .optional-video-btn:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-brutal-black, #1A1A1A);
    background: #CC0000;
  }

  .optional-video-btn:active {
    transform: translate(1px, 1px);
    box-shadow: 3px 3px 0 var(--color-brutal-black, #1A1A1A);
  }

  .optional-video-btn:focus-visible {
    outline: 3px solid var(--color-brutal-yellow, #FFE14D);
    outline-offset: 2px;
  }

  .optional-video-btn svg {
    flex-shrink: 0;
  }

  /* Video Modal - for optional video playback */
  .video-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .video-modal-overlay.is-open {
    opacity: 1;
    visibility: visible;
  }

  .video-modal-content {
    position: relative;
    width: 100%;
    max-width: 800px;
    aspect-ratio: 16/9;
    background: var(--color-brutal-black, #1A1A1A);
    border: 5px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 12px 12px 0 var(--color-brutal-black, #1A1A1A);
  }

  .video-modal-iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  .video-modal-close {
    position: absolute;
    top: -50px;
    right: 0;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-cream, #FFFEF9);
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 4px 4px 0 var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-black, #1A1A1A);
    cursor: pointer;
    transition: all 0.15s cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  .video-modal-close:hover {
    background: var(--color-brutal-yellow, #FFE14D);
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-brutal-black, #1A1A1A);
  }

  .video-modal-channel {
    position: absolute;
    bottom: -40px;
    left: 0;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    background: var(--color-cream, #FFFEF9);
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 4px 4px 0 var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-black, #1A1A1A);
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.75rem;
    font-weight: 700;
  }

  /* Single Product Image - BRUTALIST FRAME */
  .product-3d {
    position: relative;
    width: 100%;
    max-width: 280px;
    max-height: 280px;
    aspect-ratio: 1;
    flex-shrink: 1;
  }

  .product-shadow {
    position: absolute;
    bottom: -12px;
    right: -12px;
    width: 100%;
    height: 100%;
    background: var(--color-brutal-black, #1A1A1A);
    z-index: 0;
  }

  .product-image-wrapper {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-cream, #FFFEF9);
    border: 4px solid var(--color-brutal-black, #1A1A1A);
    padding: 1rem;
    overflow: hidden;
    transition: transform 0.15s cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  .product-3d:hover .product-image-wrapper {
    transform: translate(-4px, -4px);
  }

  .product-3d:hover .product-shadow {
    transform: translate(4px, 4px);
  }

  .product-image {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    transition: transform 0.3s ease-out;
  }

  .product-3d:hover .product-image {
    transform: scale(1.02);
  }

  .image-placeholder {
    width: 120px;
    height: 120px;
    color: var(--color-mist, #CCCCCC);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .image-placeholder svg {
    width: 100%;
    height: 100%;
  }

  /* Image Carousel - BRUTALIST FRAME */
  .product-carousel {
    position: relative;
    width: 100%;
    max-width: 280px;
    max-height: 280px;
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--color-cream, #FFFEF9);
    border: 4px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 10px 10px 0 var(--color-brutal-black, #1A1A1A);
    flex-shrink: 1;
  }

  .carousel-track {
    display: flex;
    height: 100%;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .carousel-slide {
    flex: 0 0 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem;
    overflow: hidden;
    background: var(--color-cream, #FFFEF9);
  }

  .carousel-image {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .carousel-indicators {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 2;
    padding: 6px 10px;
    background: var(--color-cream, #FFFEF9);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 3px 3px 0 var(--color-brutal-black, #1A1A1A);
  }

  .carousel-dot {
    width: 10px;
    height: 10px;
    background: var(--color-mist, #CCCCCC);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    padding: 0;
    cursor: pointer;
    transition: all 0.15s cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  .carousel-dot.active {
    background: var(--color-brutal-yellow, #FFE14D);
    transform: scale(1.1);
  }

  .carousel-dot:hover:not(.active) {
    background: var(--color-brutal-orange, #FF6B35);
  }

  /* Video indicator dot */
  .carousel-dot--video {
    width: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #ff0000;
    border-color: var(--color-brutal-black, #1A1A1A);
  }

  .carousel-dot--video svg {
    fill: white;
  }

  .carousel-dot--video.active {
    background: #cc0000;
  }

  .carousel-dot--video:hover:not(.active) {
    background: #ff3333;
  }

  /* Video slide within carousel */
  .carousel-slide--video {
    position: relative;
    background: var(--color-brutal-black, #1A1A1A);
    padding: 0.5rem;
  }

  .carousel-slide--video .video-thumbnail {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.3s ease;
  }

  .carousel-slide--video .video-play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-brutal-yellow, #FFE14D);
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 4px 4px 0 var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-black, #1A1A1A);
    cursor: pointer;
    transition: transform 0.15s cubic-bezier(0.68, -0.6, 0.32, 1.6), box-shadow 0.15s ease;
    z-index: 5;
  }

  .carousel-slide--video .video-play-btn svg {
    width: 28px;
    height: 28px;
    margin-left: 3px;
  }

  .carousel-slide--video .video-play-btn:hover {
    transform: translate(-50%, -50%) translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-brutal-black, #1A1A1A);
    background: var(--color-brutal-orange, #FF6B35);
  }

  .carousel-slide--video .video-channel-badge {
    position: absolute;
    bottom: 12px;
    left: 12px;
    z-index: 4;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 5px 8px;
    background: var(--color-cream, #FFFEF9);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.5625rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-brutal-black, #1A1A1A);
  }

  .carousel-slide--video .video-channel-badge span {
    max-width: 80px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .carousel-slide--video .video-iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    pointer-events: none;
    z-index: 10;
  }

  .carousel-slide--video.is-playing .video-thumbnail,
  .carousel-slide--video.is-playing .video-play-btn,
  .carousel-slide--video.is-playing .video-channel-badge {
    opacity: 0;
    pointer-events: none;
  }

  .carousel-slide--video.is-playing .video-iframe {
    opacity: 1;
    pointer-events: auto;
  }

  /* Image count badge */
  .carousel-count {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 2;
    padding: 4px 8px;
    background: var(--color-cream, #FFFEF9);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.625rem;
    font-weight: 800;
    color: var(--color-brutal-black, #1A1A1A);
  }

  .carousel-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    background: var(--color-cream, #FFFEF9);
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 3px 3px 0 var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-black, #1A1A1A);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s cubic-bezier(0.68, -0.6, 0.32, 1.6);
    z-index: 3;
  }

  .carousel-nav:hover {
    background: var(--color-brutal-yellow, #FFE14D);
    transform: translateY(-50%) translate(-2px, -2px);
    box-shadow: 5px 5px 0 var(--color-brutal-black, #1A1A1A);
  }

  .carousel-nav:active {
    transform: translateY(-50%) translate(1px, 1px);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
  }

  .carousel-nav:focus-visible {
    outline: 3px solid var(--color-brutal-orange, #FF6B35);
    outline-offset: 2px;
  }

  .carousel-prev {
    left: 8px;
  }

  .carousel-next {
    right: 8px;
  }

  /* On small screens, make nav buttons smaller */
  @media (max-width: 380px) {
    .carousel-nav {
      width: 36px;
      height: 36px;
      border-width: 2px;
    }

    .carousel-nav svg {
      width: 16px;
      height: 16px;
    }
  }

  /* Actions sidebar */
  /* Positioned by SlideActions component */

  /* Product info - BRUTALIST COMPACT PANEL */
  .product-info {
    position: relative;
    z-index: 2;
    width: 100%;
    padding: 0.75rem 0.875rem 0.5rem;
    padding-right: 4rem; /* Space for sidebar actions */
    background: linear-gradient(to top, rgba(0, 0, 0, 0.92) 0%, rgba(0, 0, 0, 0.75) 70%, transparent 100%);
  }

  .info-content {
    max-width: 500px;
  }

  /* Top row with brand and rating */
  .info-top-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .brand-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.625rem;
    background: var(--color-brutal-yellow, #FFE14D);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.625rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-brutal-black, #1A1A1A);
  }

  .rating-compact {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.75rem;
    font-weight: 700;
    color: white;
  }

  /* MCP Badges - Best Seller, Amazon's Choice, Prime */
  .mcp-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.1875rem 0.5rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.5625rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
  }

  .mcp-badge.best-seller {
    background: #FF6B35;
    color: white;
  }

  .mcp-badge.amazon-choice {
    background: #232F3E;
    color: #FF9900;
  }

  .mcp-badge.prime {
    background: #00A8E1;
    color: white;
  }

  .mcp-badge.price-drop {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    background: #DC2626;
    color: white;
    animation: pulse-glow 2s ease-in-out infinite;
  }

  .mcp-badge.lowest-price {
    background: #059669;
    color: white;
  }

  @keyframes pulse-glow {
    0%, 100% { box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A); }
    50% { box-shadow: 2px 2px 8px rgba(220, 38, 38, 0.6), 2px 2px 0 var(--color-brutal-black, #1A1A1A); }
  }

  /* Product title */
  .product-title {
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: clamp(0.9rem, 3.5vw, 1.1rem);
    font-weight: 700;
    line-height: 1.25;
    color: white;
    margin: 0 0 0.375rem;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Rating row - clean horizontal layout */
  .rating-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.375rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.6875rem;
    color: rgba(255, 255, 255, 0.85);
  }

  .stars-mini {
    display: flex;
    align-items: center;
    gap: 0.2rem;
  }

  .rating-value {
    font-weight: 700;
    color: #FF9900;
  }

  .review-count {
    color: rgba(255, 255, 255, 0.6);
  }

  .sales-tag {
    padding: 0.125rem 0.375rem;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 2px;
    font-size: 0.6rem;
    color: rgba(255, 255, 255, 0.7);
  }

  /* Price section - prominent and clean */
  .price-section {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.375rem;
  }

  .current-price {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 1.25rem;
    font-weight: 800;
    background: var(--color-brutal-yellow, #FFE14D);
    color: var(--color-brutal-black, #1A1A1A);
    padding: 0.2rem 0.5rem;
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
  }

  .original-price {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: line-through;
    text-decoration-thickness: 2px;
  }

  .discount-tag {
    padding: 0.15rem 0.375rem;
    background: var(--color-brutal-orange, #FF6B35);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
    color: white;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.6875rem;
    font-weight: 900;
  }

  /* Deal line - consolidated deal indicators */
  .deal-line {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .deal-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.15rem 0.375rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.625rem;
    font-weight: 700;
    border-radius: 2px;
  }

  .deal-tag.lowest {
    background: #059669;
    color: white;
  }

  .deal-tag.drop {
    background: #DC2626;
    color: white;
  }

  .deal-tag.below {
    background: rgba(5, 150, 105, 0.2);
    color: #34D399;
  }

  .coupon-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.15rem 0.375rem;
    background: #00A661;
    color: white;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.625rem;
    font-weight: 700;
    border-radius: 2px;
  }

  .coupon-tag svg {
    flex-shrink: 0;
  }

  /* FLOATING CTA - Always visible at bottom */
  .floating-cta {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0.625rem 0.875rem;
    padding-bottom: calc(env(safe-area-inset-bottom, 0px) + 4.75rem); /* Space for bottom nav */
    background: linear-gradient(to top,
      rgba(0, 0, 0, 0.95) 0%,
      rgba(0, 0, 0, 0.85) 50%,
      transparent 100%);
  }

  .cta-buttons-row {
    display: flex;
    gap: 0.75rem;
    align-items: stretch;
  }

  /* Add to Cart Button - Brutalist Style */
  .add-to-cart-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    flex-shrink: 0;
    background: var(--color-cream, #FFFEF9);
    color: var(--color-brutal-black, #1A1A1A);
    border: 4px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 5px 5px 0 var(--color-brutal-black, #1A1A1A);
    cursor: pointer;
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
    -webkit-tap-highlight-color: transparent;
  }

  .add-to-cart-btn:hover {
    background: var(--color-brutal-yellow, #FFE14D);
    transform: translate(-2px, -2px);
