---
import { type Lang, getTranslation } from '@i18n/utils';
import SlideActions from './SlideActions.astro';
import ProductModel3D from './ProductModel3D.astro';

interface Props {
  product: {
    productId: string;
    asin: string;
    title: string;
    brand: string;
    price: number;
    originalPrice?: number;
    currency: string;
    rating?: number;
    featuredImage: { url: string; alt: string };
    images?: string[]; // All product images for carousel
    affiliateUrl: string;
    category?: string;
    shortDescription?: string;
    model3dUrl?: string;
    // YouTube video embed (if available)
    youtubeVideo?: {
      videoId: string;
      title: string;
      channelTitle: string;
      thumbnail: string;
      embedUrl: string;
      isShort: boolean;
    } | null;
    // Top reviews for feed display
    topReviews?: {
      reviews: Array<{
        title: string | null;
        content: string;
        rating: number;
        reviewerName: string | null;
        isVerifiedPurchase: boolean;
      }>;
      totalCount: number;
      averageRating: number;
    };
  };
  lang: Lang;
  index: number;
}

const { product, lang, index } = Astro.props;
const t = getTranslation(lang);

// Category-based gradient colors
const categoryGradients: Record<string, { from: string; to: string; accent: string }> = {
  electronics: { from: '#1a1a2e', to: '#16213e', accent: '#0f3460' },
  audio: { from: '#2d132c', to: '#1a0a1a', accent: '#801336' },
  phones: { from: '#0d1b2a', to: '#1b263b', accent: '#415a77' },
  books: { from: '#2c1810', to: '#1a0f09', accent: '#8b4513' },
  default: { from: '#1A1815', to: '#2D2926', accent: '#3d3a36' },
};

const category = product.category?.toLowerCase() || 'default';
const gradient = categoryGradients[category] || categoryGradients.default;

// Format price
const formattedPrice = new Intl.NumberFormat(lang === 'es' ? 'es-ES' : 'en-US', {
  style: 'currency',
  currency: product.currency || 'USD',
}).format(product.price);

const formattedOriginalPrice = product.originalPrice
  ? new Intl.NumberFormat(lang === 'es' ? 'es-ES' : 'en-US', {
      style: 'currency',
      currency: product.currency || 'USD',
    }).format(product.originalPrice)
  : null;

const discount = product.originalPrice
  ? Math.round(((product.originalPrice - product.price) / product.originalPrice) * 100)
  : 0;

// Get all images for carousel (fallback to featured image)
const productImages = product.images && product.images.length > 0
  ? product.images
  : [product.featuredImage?.url].filter(Boolean) as string[];
const hasMultipleImages = productImages.length > 1;

// Truncate description for "see more" functionality
const MAX_DESC_LENGTH = 20;
const fullDescription = product.shortDescription || '';
const shouldTruncate = fullDescription.length > MAX_DESC_LENGTH;
const truncatedDescription = shouldTruncate
  ? fullDescription.slice(0, MAX_DESC_LENGTH) + '...'
  : fullDescription;
---

<article 
  class="product-slide" 
  data-slide-index={index}
  style={`--gradient-from: ${gradient.from}; --gradient-to: ${gradient.to}; --gradient-accent: ${gradient.accent};`}
>
  <!-- Background -->
  <div class="slide-bg">
    <div class="bg-gradient"></div>
    <div class="bg-pattern"></div>
    <div class="bg-glow"></div>
  </div>

  <!-- Product Video/Image/3D Model -->
  <div class="product-container">
    {product.youtubeVideo ? (
      <!-- YouTube Video - Thumbnail + Play Button (loads on click) -->
      <div
        class="product-video-container"
        data-video-player
        data-video-id={product.youtubeVideo.videoId}
        data-embed-url={product.youtubeVideo.embedUrl}
      >
        <!-- Thumbnail -->
        <img
          src={product.youtubeVideo.thumbnail}
          alt={product.youtubeVideo.title}
          loading={index < 2 ? 'eager' : 'lazy'}
          class="video-thumbnail"
        />

        <!-- Play Button -->
        <button
          class="video-play-btn"
          data-play-btn
          aria-label={lang === 'es' ? 'Reproducir video' : 'Play video'}
        >
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M8 5v14l11-7z"/>
          </svg>
        </button>

        <!-- Channel Badge -->
        {product.youtubeVideo.channelTitle && (
          <div class="video-channel-badge">
            <svg viewBox="0 0 24 24" fill="#ff0000" width="14" height="14" aria-hidden="true">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/>
              <polygon fill="#fff" points="9.545,15.568 15.818,12 9.545,8.432"/>
            </svg>
            <span>{product.youtubeVideo.channelTitle}</span>
          </div>
        )}

        <!-- Video iframe (loaded on click) -->
        <iframe
          class="video-iframe"
          title={product.youtubeVideo.title}
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    ) : product.model3dUrl ? (
      <!-- 3D Model available - use model-viewer -->
      <div class="product-3d-model">
        <ProductModel3D
          modelUrl={product.model3dUrl}
          imageUrl={product.featuredImage?.url}
          alt={product.featuredImage?.alt || product.title}
        />
      </div>
    ) : hasMultipleImages ? (
      <!-- Image carousel when multiple images available -->
      <div
        class="product-carousel"
        data-carousel
        role="region"
        aria-roledescription={lang === 'es' ? 'carrusel' : 'carousel'}
        aria-label={`${product.title} - ${lang === 'es' ? 'Galería de imágenes' : 'Image gallery'}`}
      >
        <!-- Image count badge -->
        <div class="carousel-count" data-carousel-count>
          <span data-current-index>1</span>/{productImages.length}
        </div>

        <!-- Live region for carousel announcements -->
        <div class="sr-only" role="status" aria-live="polite" data-carousel-status></div>

        <div class="carousel-track" data-carousel-track aria-atomic="false">
          {productImages.map((imgUrl, imgIndex) => (
            <div
              class="carousel-slide"
              data-carousel-slide
              role="group"
              aria-roledescription={lang === 'es' ? 'diapositiva' : 'slide'}
              aria-label={`${imgIndex + 1} ${lang === 'es' ? 'de' : 'of'} ${productImages.length}`}
              aria-hidden={imgIndex !== 0 ? 'true' : 'false'}
            >
              <img
                src={imgUrl}
                alt={`${product.title} - ${lang === 'es' ? 'Imagen' : 'Image'} ${imgIndex + 1} ${lang === 'es' ? 'de' : 'of'} ${productImages.length}`}
                loading={index < 2 && imgIndex === 0 ? 'eager' : 'lazy'}
                decoding="async"
                class="carousel-image"
              />
            </div>
          ))}
        </div>
        <!-- Carousel indicators -->
        <div class="carousel-indicators" role="tablist" aria-label={lang === 'es' ? 'Indicadores de imagen' : 'Image indicators'}>
          {productImages.map((_, imgIndex) => (
            <button
              class:list={['carousel-dot', { active: imgIndex === 0 }]}
              data-carousel-dot={imgIndex}
              role="tab"
              aria-selected={imgIndex === 0 ? 'true' : 'false'}
              aria-label={`${lang === 'es' ? 'Ir a imagen' : 'Go to image'} ${imgIndex + 1} ${lang === 'es' ? 'de' : 'of'} ${productImages.length}`}
              aria-controls={`carousel-slide-${index}-${imgIndex}`}
            />
          ))}
        </div>
        <!-- Navigation arrows -->
        <button
          class="carousel-nav carousel-prev"
          data-carousel-prev
          aria-label={lang === 'es' ? 'Imagen anterior' : 'Previous image'}
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" aria-hidden="true">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </button>
        <button
          class="carousel-nav carousel-next"
          data-carousel-next
          aria-label={lang === 'es' ? 'Imagen siguiente' : 'Next image'}
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" aria-hidden="true">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </button>
      </div>
    ) : (
      <!-- Fallback to single image with 3D CSS effect -->
      <div class="product-3d" data-3d-element>
        <div class="product-shadow"></div>
        <div class="product-image-wrapper">
          {product.featuredImage?.url ? (
            <img
              src={product.featuredImage.url}
              alt={product.featuredImage.alt || product.title}
              loading={index < 2 ? 'eager' : 'lazy'}
              decoding="async"
              class="product-image"
            />
          ) : (
            <div class="image-placeholder">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                <rect x="3" y="3" width="18" height="18" rx="2" />
                <circle cx="8.5" cy="8.5" r="1.5" />
                <path d="M21 15l-5-5L5 21" />
              </svg>
            </div>
          )}
        </div>
      </div>
    )}
  </div>

  <!-- Actions sidebar -->
  <SlideActions 
    productId={product.productId}
    affiliateUrl={product.affiliateUrl}
    lang={lang}
  />

  <!-- Product Info - Compact Panel -->
  <div class="product-info">
    <div class="info-content">
      <!-- Top row: Brand + Rating -->
      <div class="info-top-row">
        <span class="brand-badge">{product.brand}</span>
        {product.rating && (
          <div class="rating-compact">
            <svg viewBox="0 0 24 24" fill="#FF9900" width="14" height="14">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            <span>{product.rating.toFixed(1)}</span>
          </div>
        )}
      </div>

      <!-- Title - 2 lines max, with tooltip for full title -->
      <h2 class="product-title" title={product.title}>{product.title}</h2>

      <!-- Price section - Prominent -->
      <div class="price-row">
        <div class="price-info">
          <span class="current-price">{formattedPrice}</span>
          {formattedOriginalPrice && (
            <span class="original-price">{formattedOriginalPrice}</span>
          )}
        </div>
        {discount > 0 && (
          <span class="discount-badge">-{discount}%</span>
        )}
      </div>

      <!-- Top Reviews Section -->
      {product.topReviews && product.topReviews.reviews.length > 0 && (
        <div class="top-reviews-section" data-reviews-section>
          <div class="reviews-header">
            <div class="reviews-summary">
              <svg viewBox="0 0 24 24" fill="#FF9900" width="14" height="14">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              <span class="avg-rating">{product.topReviews.averageRating.toFixed(1)}</span>
              <span class="review-count">({product.topReviews.totalCount} {lang === 'es' ? 'reseñas' : 'reviews'})</span>
            </div>
          </div>
          <div class="reviews-list">
            {product.topReviews.reviews.slice(0, 2).map((review, idx) => (
              <div class="review-card" data-review-idx={idx}>
                <div class="review-header">
                  <div class="review-stars">
                    {Array.from({ length: 5 }).map((_, i) => (
                      <svg viewBox="0 0 24 24" fill={i < review.rating ? "#FF9900" : "#4a4a4a"} width="10" height="10">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                    ))}
                  </div>
                  {review.isVerifiedPurchase && (
                    <span class="verified-badge">{lang === 'es' ? 'Verificado' : 'Verified'}</span>
                  )}
                </div>
                {review.title && <p class="review-title">{review.title}</p>}
                <div class="review-content-wrapper" data-expandable>
                  <p class="review-content">{review.content}</p>
                  {review.content && review.content.length > 100 && (
                    <>
                      <button type="button" class="btn-expand" data-expand-btn>
                        {lang === 'es' ? 'Leer más' : 'Read more'}
                      </button>
                      <button type="button" class="btn-collapse" data-collapse-btn>
                        {lang === 'es' ? 'Ver menos' : 'Show less'}
                      </button>
                    </>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>

  <!-- Floating CTA Buttons - Always Visible -->
  <div class="floating-cta">
    <div class="cta-row">
      <!-- Add to Cart Button -->
      <button
        type="button"
        class="add-to-cart-btn"
        data-add-to-cart
        data-asin={product.asin}
        data-product-id={product.productId}
        data-title={product.title}
        data-brand={product.brand}
        data-image={product.featuredImage?.url || ''}
        data-price={product.price}
        data-currency={product.currency}
        data-affiliate-url={product.affiliateUrl}
        data-marketplace={product.affiliateUrl?.includes('amazon.es') ? 'amazon.es' : 'amazon.com'}
        aria-label={lang === 'es' ? 'Agregar al carrito' : 'Add to cart'}
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" class="cart-icon">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
          <line x1="3" y1="6" x2="21" y2="6" />
          <path d="M16 10a4 4 0 0 1-8 0" />
        </svg>
        <span class="cart-label">{lang === 'es' ? 'Carrito' : 'Cart'}</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" width="10" height="10" class="plus-icon">
          <path d="M12 4v16m-8-8h16"/>
        </svg>
      </button>

      <!-- Buy on Amazon Button -->
      <a
        href={product.affiliateUrl}
        target="_blank"
        rel="noopener noreferrer nofollow"
        class="buy-button-floating"
        data-product-id={product.productId}
        data-tracking="feed-cta-floating"
      >
      <div class="buy-button-content">
        <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22" class="cart-icon">
          <path d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
        </svg>
        <span class="buy-text">{lang === 'es' ? 'Comprar en Amazon' : 'Buy on Amazon'}</span>
        <span class="buy-price">{formattedPrice}</span>
      </div>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" width="20" height="20" class="arrow-icon">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
    </div>

    <!-- Scroll indicator (only on first slide) - Below Amazon button -->
    {index === 0 && (
      <div class="scroll-indicator">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
          <path d="M12 5v14M5 12l7 7 7-7"/>
        </svg>
        <span>{lang === 'es' ? 'Desliza para ver más' : 'Swipe for more'}</span>
      </div>
    )}
  </div>
</article>

<style>
  .product-slide {
    position: relative;
    height: 100dvh;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }

  /* Background layers */
  .slide-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .bg-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      var(--gradient-from) 0%,
      var(--gradient-to) 50%,
      var(--gradient-accent) 100%
    );
  }

  .bg-pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  .bg-glow {
    position: absolute;
    top: 20%;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 40%;
    background: radial-gradient(ellipse, var(--gradient-accent) 0%, transparent 70%);
    opacity: 0.3;
    filter: blur(60px);
  }

  /* Product container */
  .product-container {
    position: relative;
    z-index: 1;
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 1rem;
    padding-top: calc(env(safe-area-inset-top, 0px) + 80px);
  }

  /* 3D Model container (when using model-viewer) */
  .product-3d-model {
    position: relative;
    width: 100%;
    max-width: 400px;
    height: 350px;
  }

  /* YouTube Video container - BRUTALIST STYLE */
  .product-video-container {
    position: relative;
    width: 100%;
    max-width: 320px;
    aspect-ratio: 16/9;
    background: var(--color-brutal-black, #1A1A1A);
    border: 4px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 10px 10px 0 var(--color-brutal-black, #1A1A1A);
    overflow: hidden;
  }

  .video-thumbnail {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .product-video-container:hover .video-thumbnail {
    transform: scale(1.02);
  }

  /* Play Button - BRUTALIST */
  .video-play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 72px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-brutal-yellow, #FFE14D);
    border: 4px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 6px 6px 0 var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-black, #1A1A1A);
    cursor: pointer;
    transition: transform 0.15s cubic-bezier(0.68, -0.6, 0.32, 1.6), box-shadow 0.15s ease;
    z-index: 5;
  }

  .video-play-btn svg {
    width: 32px;
    height: 32px;
    margin-left: 4px; /* Visual centering for play icon */
  }

  .video-play-btn:hover {
    transform: translate(-50%, -50%) translate(-3px, -3px);
    box-shadow: 9px 9px 0 var(--color-brutal-black, #1A1A1A);
    background: var(--color-brutal-orange, #FF6B35);
  }

  .video-play-btn:active {
    transform: translate(-50%, -50%) translate(2px, 2px);
    box-shadow: 4px 4px 0 var(--color-brutal-black, #1A1A1A);
  }

  .video-play-btn:focus-visible {
    outline: 3px solid var(--color-brutal-orange, #FF6B35);
    outline-offset: 3px;
  }

  /* Channel Badge */
  .video-channel-badge {
    position: absolute;
    bottom: 12px;
    left: 12px;
    z-index: 4;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    background: var(--color-cream, #FFFEF9);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 3px 3px 0 var(--color-brutal-black, #1A1A1A);
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-brutal-black, #1A1A1A);
  }

  .video-channel-badge span {
    max-width: 100px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Video iframe - hidden until play */
  .video-iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
    opacity: 0;
    pointer-events: none;
    z-index: 10;
    transition: opacity 0.3s ease;
  }

  /* Playing state - show iframe, hide thumbnail/button */
  .product-video-container.is-playing .video-thumbnail,
  .product-video-container.is-playing .video-play-btn,
  .product-video-container.is-playing .video-channel-badge {
    opacity: 0;
    pointer-events: none;
  }

  .product-video-container.is-playing .video-iframe {
    opacity: 1;
    pointer-events: auto;
  }

  @media (min-width: 480px) {
    .product-video-container {
      max-width: 380px;
    }
    .video-play-btn {
      width: 80px;
      height: 80px;
    }
    .video-play-btn svg {
      width: 36px;
      height: 36px;
    }
  }

  @media (min-width: 768px) {
    .product-video-container {
      max-width: 440px;
      border-width: 5px;
      box-shadow: 12px 12px 0 var(--color-brutal-black, #1A1A1A);
    }
    .video-play-btn {
      width: 88px;
      height: 88px;
    }
    .video-play-btn svg {
      width: 40px;
      height: 40px;
    }
    .video-channel-badge {
      font-size: 0.6875rem;
    }
  }

  @media (min-width: 1024px) {
    .product-video-container {
      max-width: 500px;
    }
    .video-play-btn {
      width: 96px;
      height: 96px;
    }
    .video-play-btn svg {
      width: 44px;
      height: 44px;
    }
  }

  /* Single Product Image - BRUTALIST FRAME */
  .product-3d {
    position: relative;
    width: 100%;
    max-width: 280px;
    max-height: 280px;
    aspect-ratio: 1;
    flex-shrink: 1;
  }

  .product-shadow {
    position: absolute;
    bottom: -12px;
    right: -12px;
    width: 100%;
    height: 100%;
    background: var(--color-brutal-black, #1A1A1A);
    z-index: 0;
  }

  .product-image-wrapper {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-cream, #FFFEF9);
    border: 4px solid var(--color-brutal-black, #1A1A1A);
    padding: 1rem;
    overflow: hidden;
    transition: transform 0.15s cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  .product-3d:hover .product-image-wrapper {
