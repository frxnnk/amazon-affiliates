<script>
  // Initialize carousels and see more buttons
  function initProductSlide() {
    const currentLang = document.documentElement.lang || 'es';

    // Carousel functionality
    document.querySelectorAll('[data-carousel]').forEach((carousel) => {
      const track = carousel.querySelector('[data-carousel-track]') as HTMLElement;
      const slides = carousel.querySelectorAll('[data-carousel-slide]');
      const dots = carousel.querySelectorAll('[data-carousel-dot]');
      const prevBtn = carousel.querySelector('[data-carousel-prev]');
      const nextBtn = carousel.querySelector('[data-carousel-next]');
      const statusRegion = carousel.querySelector('[data-carousel-status]');

      if (!track || slides.length === 0) return;

      let currentIndex = 0;
      const totalSlides = slides.length;

      // Announce slide change to screen readers
      function announceSlide(index: number) {
        if (statusRegion) {
          const message = currentLang === 'es'
            ? `Imagen ${index + 1} de ${totalSlides}`
            : `Image ${index + 1} of ${totalSlides}`;
          statusRegion.textContent = message;
        }
      }

      function goToSlide(index: number) {
        const previousIndex = currentIndex;
        currentIndex = Math.max(0, Math.min(index, totalSlides - 1));

        // Don't do anything if we're already at the target slide
        if (previousIndex === currentIndex && index !== currentIndex) return;

        track.style.transform = `translateX(-${currentIndex * 100}%)`;

        // Update ARIA attributes on slides
        slides.forEach((slide, i) => {
          slide.setAttribute('aria-hidden', i === currentIndex ? 'false' : 'true');
        });

        // Update dots with ARIA
        dots.forEach((dot, i) => {
          dot.classList.toggle('active', i === currentIndex);
          dot.setAttribute('aria-selected', i === currentIndex ? 'true' : 'false');
        });

        // Update count badge
        const countEl = carousel.querySelector('[data-current-index]');
        if (countEl) {
          countEl.textContent = String(currentIndex + 1);
        }

        // Announce the change
        announceSlide(currentIndex);
      }

      // Navigation buttons
      prevBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        goToSlide(currentIndex - 1);
      });

      nextBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        goToSlide(currentIndex + 1);
      });

      // Dot navigation
      dots.forEach((dot, index) => {
        dot.addEventListener('click', (e) => {
          e.stopPropagation();
          goToSlide(index);
        });
      });

      // Keyboard navigation within carousel
      carousel.addEventListener('keydown', (e: Event) => {
        const keyEvent = e as KeyboardEvent;
        if (keyEvent.key === 'ArrowLeft') {
          keyEvent.preventDefault();
          goToSlide(currentIndex - 1);
        } else if (keyEvent.key === 'ArrowRight') {
          keyEvent.preventDefault();
          goToSlide(currentIndex + 1);
        }
      });

      // Touch/swipe support
      let touchStartX = 0;
      let touchEndX = 0;

      carousel.addEventListener('touchstart', (e: Event) => {
        touchStartX = (e as TouchEvent).changedTouches[0].screenX;
      }, { passive: true });

      carousel.addEventListener('touchend', (e: Event) => {
        touchEndX = (e as TouchEvent).changedTouches[0].screenX;
        const diff = touchStartX - touchEndX;

        if (Math.abs(diff) > 50) {
          if (diff > 0) {
            goToSlide(currentIndex + 1);
          } else {
            goToSlide(currentIndex - 1);
          }
        }
      }, { passive: true });
    });

  }

  // See more functionality - use event delegation for dynamic content
  function initSeeMore() {
    // Remove existing listener to avoid duplicates
    document.removeEventListener('click', handleSeeMoreClick);
    document.addEventListener('click', handleSeeMoreClick);
  }

  function handleSeeMoreClick(e: Event) {
    const target = e.target as HTMLElement;
    if (!target.matches('[data-see-more]')) return;

    e.stopPropagation();
    e.preventDefault();

    const btn = target;
    const description = btn.closest('[data-description]') as HTMLElement;
    if (!description) return;

    const fullText = description.dataset.full || '';
    const truncatedText = description.dataset.truncated || '';
    const textSpan = description.querySelector('.description-text');
    const isSpanish = description.dataset.lang === 'es';

    if (!textSpan) return;

    const isExpanded = description.dataset.expanded === 'true';

    if (isExpanded) {
      textSpan.textContent = truncatedText;
      btn.textContent = isSpanish ? 'ver más' : 'see more';
      description.dataset.expanded = 'false';
    } else {
      textSpan.textContent = fullText;
      btn.textContent = isSpanish ? 'ver menos' : 'see less';
      description.dataset.expanded = 'true';
    }
  }

  // Video player functionality - load YouTube on play click
  function initVideoPlayers() {
    document.querySelectorAll('[data-video-player]').forEach((container) => {
      const videoContainer = container as HTMLElement;

      // Skip if already initialized
      if (videoContainer.dataset.videoInitialized) return;
      videoContainer.dataset.videoInitialized = 'true';

      const playBtn = videoContainer.querySelector('[data-play-btn]');
      const iframe = videoContainer.querySelector('.video-iframe') as HTMLIFrameElement;
      const embedUrl = videoContainer.dataset.embedUrl;

      if (!playBtn || !iframe || !embedUrl) return;

      playBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        e.preventDefault();

        // Add autoplay to the embed URL
        const autoplayUrl = embedUrl.includes('?')
          ? `${embedUrl}&autoplay=1`
          : `${embedUrl}?autoplay=1`;

        // Load and play the video
        iframe.src = autoplayUrl;
        videoContainer.classList.add('is-playing');
      });

      // Stop video when slide changes (if in a scroll container)
      const slideParent = videoContainer.closest('[data-slide-index]');
      if (slideParent) {
        // Use IntersectionObserver to pause when out of view
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting && videoContainer.classList.contains('is-playing')) {
                // Pause video by removing src
                iframe.src = '';
                videoContainer.classList.remove('is-playing');
              }
            });
          },
          { threshold: 0.5 }
        );
        observer.observe(videoContainer);
      }
    });
  }

  // Add to Cart button functionality
  function initAddToCartButtons() {
    const currentLang = document.documentElement.lang || 'es';

    document.querySelectorAll('[data-add-to-cart]').forEach((btn) => {
      const button = btn as HTMLElement;

      // Skip if already initialized
      if (button.dataset.addToCartInit) return;
      button.dataset.addToCartInit = 'true';

      button.addEventListener('click', (e) => {
        e.stopPropagation();
        e.preventDefault();

        // Check if cart API is available
        if (!(window as any).cart) {
          console.warn('Cart API not available');
          return;
        }

        // Get product data from data attributes
        const product = {
          asin: button.dataset.asin || '',
          productId: button.dataset.productId || '',
          title: button.dataset.title || '',
          brand: button.dataset.brand || '',
          image: button.dataset.image || '',
          price: parseFloat(button.dataset.price || '0'),
          currency: button.dataset.currency || 'USD',
          affiliateUrl: button.dataset.affiliateUrl || '',
          marketplace: button.dataset.marketplace || 'amazon.com',
        };

        // Add to cart
        (window as any).cart.add(product);

        // Visual feedback - show "added" state
        button.classList.add('added');

        // Haptic feedback
        if (navigator.vibrate) {
          navigator.vibrate(50);
        }

        // Remove the "added" state after animation
        setTimeout(() => {
          button.classList.remove('added');
        }, 1500);
      });
    });
  }

  // Review expand/collapse functionality
  function initReviewExpand() {
    document.querySelectorAll('[data-reviews-section]').forEach((section) => {
      // Handle expand buttons
      section.querySelectorAll('[data-expand-btn]').forEach((btn) => {
        const button = btn as HTMLElement;

        // Skip if already initialized
        if (button.dataset.expandInit) return;
        button.dataset.expandInit = 'true';

        button.addEventListener('click', (e) => {
          e.stopPropagation();
          e.preventDefault();

          const wrapper = button.closest('[data-expandable]');
          if (wrapper) {
            wrapper.classList.add('expanded');
          }
        });
      });

      // Handle collapse buttons
      section.querySelectorAll('[data-collapse-btn]').forEach((btn) => {
        const button = btn as HTMLElement;

        // Skip if already initialized
        if (button.dataset.collapseInit) return;
        button.dataset.collapseInit = 'true';

        button.addEventListener('click', (e) => {
          e.stopPropagation();
          e.preventDefault();

          const wrapper = button.closest('[data-expandable]');
          if (wrapper) {
            wrapper.classList.remove('expanded');
          }
        });
      });
    });
  }

  // Run on load and after Astro page transitions
  initProductSlide();
  initSeeMore();
  initVideoPlayers();
  initAddToCartButtons();
  initReviewExpand();
  document.addEventListener('astro:after-swap', () => {
    initProductSlide();
    initSeeMore();
    initVideoPlayers();
    initAddToCartButtons();
    initReviewExpand();
  });

  // Also re-init when new slides are dynamically added to the feed
  const feedObserver = new MutationObserver(() => {
    initVideoPlayers();
    initAddToCartButtons();
    initReviewExpand();
  });

  const feedContainer = document.getElementById('reel-slides');
  if (feedContainer) {
    feedObserver.observe(feedContainer, { childList: true, subtree: true });
  }
</script>
