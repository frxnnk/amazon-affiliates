---
/**
 * ProductInfoPanel - Expandable bottom panel with product details
 *
 * Features:
 * - Collapsed: Brand, title, price, CTA
 * - Expanded: Full description, specs, reviews, price history
 * - Swipe up to expand, down to collapse
 * - NEO-BRUTALIST styling
 */

interface Props {
  product: {
    asin: string;
    title: string;
    brand: string;
    price: number;
    originalPrice?: number;
    currency: string;
    rating?: number;
    totalReviews?: number;
    shortDescription?: string;
    affiliateUrl: string;
    discountPercent?: number;
    badges?: string[];
    priceContext?: {
      isLowestIn30Days: boolean;
      percentBelowAvg: number;
    };
  };
  lang: 'es' | 'en';
}

const { product, lang } = Astro.props;

// Format price
const formatPrice = (price: number) =>
  new Intl.NumberFormat(lang === 'es' ? 'es-ES' : 'en-US', {
    style: 'currency',
    currency: product.currency || 'EUR',
  }).format(price);

const formattedPrice = formatPrice(product.price);
const formattedOriginal = product.originalPrice ? formatPrice(product.originalPrice) : null;

// Texts
const texts = {
  es: {
    buy: 'Comprar',
    expand: 'Ver detalles',
    collapse: 'Menos',
    reviews: 'opiniones',
    lowestPrice: 'Precio m\u00e1s bajo en 30 d\u00edas',
    belowAvg: 'por debajo del promedio',
    description: 'Descripci\u00f3n',
    noDesc: 'Sin descripci\u00f3n disponible',
    verified: 'Verificado',
    forYou: 'Para ti',
    curated: 'Destacado',
    discount: 'Descuento',
    popular: 'Popular',
  },
  en: {
    buy: 'Buy',
    expand: 'See details',
    collapse: 'Less',
    reviews: 'reviews',
    lowestPrice: 'Lowest price in 30 days',
    belowAvg: 'below average',
    description: 'Description',
    noDesc: 'No description available',
    verified: 'Verified',
    forYou: 'For you',
    curated: 'Featured',
    discount: 'Discount',
    popular: 'Popular',
  },
};

const t = texts[lang];

// Build rating stars
const ratingStars = product.rating ? Math.round(product.rating) : 0;
const ratingDisplay = product.rating?.toFixed(1) || '0.0';

// Badge labels
const badgeLabels: Record<string, string> = {
  verified_deal: t.verified,
  for_you: t.forYou,
  curated: t.curated,
  great_discount: t.discount,
  popular: t.popular,
  lowest_price: t.lowestPrice,
};
---

<div class="product-panel" data-panel>
  <!-- Collapsed View -->
  <div class="panel-collapsed" data-collapsed>
    <!-- Expand Handle -->
    <button class="expand-handle" data-expand-btn aria-label={t.expand}>
      <span class="handle-bar"></span>
      <span class="handle-text">{t.expand}</span>
    </button>

    <!-- Brand Badge -->
    <span class="brand-tag">{product.brand}</span>

    <!-- Title -->
    <h2 class="product-title">{product.title}</h2>

    <!-- Rating (if available) -->
    {product.rating && (
      <div class="rating-row">
        <div class="stars" aria-label={`${ratingDisplay} ${lang === 'es' ? 'de 5' : 'out of 5'}`}>
          {[1, 2, 3, 4, 5].map(star => (
            <svg
              class={`star ${star <= ratingStars ? 'filled' : ''}`}
              viewBox="0 0 24 24"
              fill={star <= ratingStars ? 'currentColor' : 'none'}
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M12 2l2.4 7.4h7.6l-6 4.6 2.3 7-6.3-4.6-6.3 4.6 2.3-7-6-4.6h7.6z" />
            </svg>
          ))}
        </div>
        <span class="rating-text">{ratingDisplay}</span>
        {product.totalReviews && (
          <span class="reviews-count">({product.totalReviews.toLocaleString()} {t.reviews})</span>
        )}
      </div>
    )}

    <!-- Price Row -->
    <div class="price-row">
      <span class="current-price">{formattedPrice}</span>
      {formattedOriginal && (
        <span class="original-price">{formattedOriginal}</span>
      )}
      {product.discountPercent && product.discountPercent >= 10 && (
        <span class="discount-tag">-{product.discountPercent}%</span>
      )}
    </div>

    <!-- Price Context Badges -->
    {product.priceContext && (
      <div class="price-context">
        {product.priceContext.isLowestIn30Days && (
          <span class="context-badge lowest">
            <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14">
              <path d="M12 2l-1 9h-9l7 5-3 9 6-5 6 5-3-9 7-5h-9z"/>
            </svg>
            {t.lowestPrice}
          </span>
        )}
        {product.priceContext.percentBelowAvg > 0 && (
          <span class="context-badge below-avg">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
              <path d="M12 19V5M5 12l7-7 7 7"/>
            </svg>
            {product.priceContext.percentBelowAvg}% {t.belowAvg}
          </span>
        )}
      </div>
    )}

    <!-- CTA Button -->
    <a
      href={product.affiliateUrl}
      target="_blank"
      rel="noopener noreferrer nofollow"
      class="cta-button"
      data-asin={product.asin}
    >
      <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
        <path d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
      </svg>
      <span>{t.buy}</span>
      <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18" class="arrow">
        <path d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"/>
      </svg>
    </a>
  </div>

  <!-- Expanded View (hidden by default) -->
  <div class="panel-expanded" data-expanded>
    <!-- Collapse Handle -->
    <button class="collapse-handle" data-collapse-btn aria-label={t.collapse}>
      <span class="handle-bar"></span>
      <span class="handle-text">{t.collapse}</span>
    </button>

    <!-- Badges -->
    {product.badges && product.badges.length > 0 && (
      <div class="badges-row">
        {product.badges.map(badge => (
          <span class={`badge badge-${badge.replace('_', '-')}`}>
            {badgeLabels[badge] || badge}
          </span>
        ))}
      </div>
    )}

    <!-- Brand + Title -->
    <span class="brand-tag">{product.brand}</span>
    <h2 class="product-title-full">{product.title}</h2>

    <!-- Rating Section -->
    {product.rating && (
      <div class="rating-section">
        <div class="rating-big">
          <span class="rating-number">{ratingDisplay}</span>
          <div class="stars-big">
            {[1, 2, 3, 4, 5].map(star => (
              <svg
                class={`star ${star <= ratingStars ? 'filled' : ''}`}
                viewBox="0 0 24 24"
                fill={star <= ratingStars ? 'currentColor' : 'none'}
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path d="M12 2l2.4 7.4h7.6l-6 4.6 2.3 7-6.3-4.6-6.3 4.6 2.3-7-6-4.6h7.6z" />
              </svg>
            ))}
          </div>
        </div>
        {product.totalReviews && (
          <span class="reviews-total">{product.totalReviews.toLocaleString()} {t.reviews}</span>
        )}
      </div>
    )}

    <!-- Description -->
    <div class="description-section">
      <h3 class="section-title">{t.description}</h3>
      <p class="description-text">
        {product.shortDescription || t.noDesc}
      </p>
    </div>

    <!-- Price Section Expanded -->
    <div class="price-section">
      <div class="price-main">
        <span class="price-big">{formattedPrice}</span>
        {formattedOriginal && (
          <span class="price-original">{formattedOriginal}</span>
        )}
      </div>
      {product.discountPercent && product.discountPercent >= 10 && (
        <span class="discount-big">-{product.discountPercent}%</span>
      )}
    </div>

    <!-- Price Context -->
    {product.priceContext && (
      <div class="price-context-expanded">
        {product.priceContext.isLowestIn30Days && (
          <div class="context-item lowest">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span>{t.lowestPrice}</span>
          </div>
        )}
        {product.priceContext.percentBelowAvg > 0 && (
          <div class="context-item below">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
              <path d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6"/>
            </svg>
            <span>{product.priceContext.percentBelowAvg}% {t.belowAvg}</span>
          </div>
        )}
      </div>
    )}

    <!-- CTA Button (Expanded) -->
    <a
      href={product.affiliateUrl}
      target="_blank"
      rel="noopener noreferrer nofollow"
      class="cta-button cta-big"
      data-asin={product.asin}
    >
      <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
        <path d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
      </svg>
      <span>{t.buy}</span>
      <svg viewBox="0 0 20 20" fill="currentColor" width="20" height="20" class="arrow">
        <path d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"/>
      </svg>
    </a>
  </div>
</div>

<style>
  .product-panel {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: var(--color-cream, #FFFEF9);
    border-top: 4px solid var(--color-brutal-black, #1A1A1A);
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    max-height: 85dvh;
    overflow: hidden;
  }

  /* Collapsed State */
  .panel-collapsed {
    display: flex;
    flex-direction: column;
    padding: 16px 20px calc(env(safe-area-inset-bottom, 16px) + 16px);
    gap: 8px;
  }

  .product-panel.expanded .panel-collapsed {
    display: none;
  }

  /* Expanded State */
  .panel-expanded {
    display: none;
    flex-direction: column;
    padding: 16px 20px calc(env(safe-area-inset-bottom, 16px) + 16px);
    gap: 16px;
    max-height: 80dvh;
    overflow-y: auto;
    scrollbar-width: thin;
  }

  .product-panel.expanded .panel-expanded {
    display: flex;
  }

  /* Expand/Collapse Handle */
  .expand-handle,
  .collapse-handle {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 8px;
    margin: -8px -8px 4px;
    background: transparent;
    border: none;
    cursor: pointer;
    touch-action: manipulation;
  }

  .handle-bar {
    width: 40px;
    height: 4px;
    background: var(--color-brutal-black, #1A1A1A);
    border-radius: 2px;
  }

  .handle-text {
    font-family: var(--font-mono, monospace);
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-stone, #666);
  }

  /* Brand Tag */
  .brand-tag {
    display: inline-block;
    width: fit-content;
    padding: 4px 10px;
    background: var(--color-brutal-yellow, #FFE14D);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    font-family: var(--font-mono, monospace);
    font-size: 0.625rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-brutal-black, #1A1A1A);
  }

  /* Title */
  .product-title {
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-brutal-black, #1A1A1A);
    margin: 0;
    text-transform: uppercase;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .product-title-full {
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-brutal-black, #1A1A1A);
    margin: 0;
    text-transform: uppercase;
  }

  /* Rating */
  .rating-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .stars {
    display: flex;
    gap: 2px;
  }

  .star {
    width: 14px;
    height: 14px;
    color: var(--color-brutal-orange, #FF6B35);
  }

  .star.filled {
    fill: currentColor;
  }

  .rating-text {
    font-family: var(--font-mono, monospace);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-brutal-black, #1A1A1A);
  }

  .reviews-count {
    font-family: var(--font-mono, monospace);
    font-size: 0.75rem;
    color: var(--color-stone, #666);
  }

  /* Price Row */
  .price-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .current-price {
    font-family: var(--font-mono, monospace);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-brutal-black, #1A1A1A);
    background: var(--color-brutal-yellow, #FFE14D);
    padding: 6px 14px;
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 4px 4px 0 var(--color-brutal-black, #1A1A1A);
  }

  .original-price {
    font-family: var(--font-mono, monospace);
    font-size: 1rem;
    color: var(--color-stone, #666);
    text-decoration: line-through;
    text-decoration-thickness: 2px;
  }

  .discount-tag {
    font-family: var(--font-mono, monospace);
    font-size: 0.875rem;
    font-weight: 900;
    color: #fff;
    background: var(--color-brutal-orange, #FF6B35);
    padding: 4px 10px;
    border: 2px solid var(--color-brutal-black, #1A1A1A);
  }

  /* Price Context */
  .price-context {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .context-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 8px;
    font-family: var(--font-mono, monospace);
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    border: 2px solid var(--color-brutal-black, #1A1A1A);
  }

  .context-badge.lowest {
    background: var(--color-brutal-green, #2D9D4E);
    color: #fff;
  }

  .context-badge.below-avg {
    background: var(--color-brutal-blue, #4A90D9);
    color: #fff;
  }

  /* CTA Button */
  .cta-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 14px 24px;
    background: var(--color-brutal-orange, #FF6B35);
    color: var(--color-brutal-black, #1A1A1A);
    font-family: var(--font-mono, monospace);
    font-size: 0.875rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    border: 4px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 6px 6px 0 var(--color-brutal-black, #1A1A1A);
    transition: transform 0.1s, box-shadow 0.1s, background 0.1s;
    margin-top: 8px;
  }

  .cta-button:hover {
    background: var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-orange, #FF6B35);
    transform: translate(-4px, -4px);
    box-shadow: 10px 10px 0 var(--color-brutal-black, #1A1A1A);
  }

  .cta-button:active {
    transform: translate(4px, 4px);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
  }

  .cta-button .arrow {
    transition: transform 0.2s;
  }

  .cta-button:hover .arrow {
    transform: translateX(4px);
  }

  /* Expanded-only styles */
  .badges-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .badge {
    padding: 6px 12px;
    font-family: var(--font-mono, monospace);
    font-size: 0.625rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
  }

  .badge-curated {
    background: var(--color-brutal-yellow, #FFE14D);
    color: var(--color-brutal-black, #1A1A1A);
  }

  .badge-for-you {
    background: var(--color-brutal-blue, #4A90D9);
    color: #fff;
  }

  .badge-verified-deal {
    background: var(--color-brutal-green, #2D9D4E);
    color: #fff;
  }

  .badge-great-discount {
    background: var(--color-brutal-orange, #FF6B35);
    color: #fff;
  }

  .badge-popular {
    background: var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-yellow, #FFE14D);
  }

  .badge-lowest-price {
    background: var(--color-brutal-green, #2D9D4E);
    color: #fff;
  }

  /* Rating Section Expanded */
  .rating-section {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 12px;
    background: #fff;
    border: 2px solid var(--color-brutal-black, #1A1A1A);
  }

  .rating-big {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .rating-number {
    font-family: var(--font-mono, monospace);
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-brutal-black, #1A1A1A);
  }

  .stars-big {
    display: flex;
    gap: 2px;
  }

  .stars-big .star {
    width: 20px;
    height: 20px;
  }

  .reviews-total {
    font-family: var(--font-mono, monospace);
    font-size: 0.875rem;
    color: var(--color-stone, #666);
  }

  /* Description Section */
  .description-section {
    padding: 12px;
    background: #fff;
    border: 2px solid var(--color-brutal-black, #1A1A1A);
  }

  .section-title {
    font-family: var(--font-mono, monospace);
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-brutal-black, #1A1A1A);
    margin: 0 0 8px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--color-brutal-black, #1A1A1A);
  }

  .description-text {
    font-family: var(--font-sans, 'DM Sans', sans-serif);
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-stone, #444);
    margin: 0;
  }

  /* Price Section Expanded */
  .price-section {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .price-main {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .price-big {
    font-family: var(--font-mono, monospace);
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-brutal-black, #1A1A1A);
    background: var(--color-brutal-yellow, #FFE14D);
    padding: 8px 20px;
    border: 4px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 6px 6px 0 var(--color-brutal-black, #1A1A1A);
  }

  .price-original {
    font-family: var(--font-mono, monospace);
    font-size: 1.25rem;
    color: var(--color-stone, #666);
    text-decoration: line-through;
    text-decoration-thickness: 3px;
  }

  .discount-big {
    font-family: var(--font-mono, monospace);
    font-size: 1.5rem;
    font-weight: 900;
    color: #fff;
    background: var(--color-brutal-orange, #FF6B35);
    padding: 8px 16px;
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 4px 4px 0 var(--color-brutal-black, #1A1A1A);
  }

  /* Price Context Expanded */
  .price-context-expanded {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 12px;
    background: #fff;
    border: 2px solid var(--color-brutal-black, #1A1A1A);
  }

  .context-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono, monospace);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .context-item.lowest {
    color: var(--color-brutal-green, #2D9D4E);
  }

  .context-item.below {
    color: var(--color-brutal-blue, #4A90D9);
  }

  .cta-big {
    padding: 18px 28px;
    font-size: 1rem;
  }

  /* Responsive */
  @media (min-width: 640px) {
    .panel-collapsed,
    .panel-expanded {
      padding: 20px 32px calc(env(safe-area-inset-bottom, 20px) + 20px);
    }

    .product-title {
      font-size: 1.25rem;
    }

    .product-title-full {
      font-size: 1.5rem;
    }

    .current-price {
      font-size: 1.75rem;
    }

    .price-big {
      font-size: 2.5rem;
    }
  }

  @media (min-width: 768px) {
    .panel-collapsed,
    .panel-expanded {
      padding: 24px 40px calc(env(safe-area-inset-bottom, 24px) + 24px);
    }
  }
</style>

<script>
  function initPanels() {
    document.querySelectorAll('[data-panel]').forEach(panel => {
      if ((panel as HTMLElement).dataset.initialized) return;
      (panel as HTMLElement).dataset.initialized = 'true';

      const expandBtn = panel.querySelector('[data-expand-btn]');
      const collapseBtn = panel.querySelector('[data-collapse-btn]');

      let startY = 0;
      let isDragging = false;

      function expand() {
        panel.classList.add('expanded');
      }

      function collapse() {
        panel.classList.remove('expanded');
      }

      // Button clicks
      expandBtn?.addEventListener('click', expand);
      collapseBtn?.addEventListener('click', collapse);

      // Swipe gestures on the panel
      panel.addEventListener('touchstart', (e) => {
        const touch = (e as TouchEvent).touches[0];
        startY = touch.clientY;
        isDragging = true;
      }, { passive: true });

      panel.addEventListener('touchend', (e) => {
        if (!isDragging) return;
        isDragging = false;

        const touch = (e as TouchEvent).changedTouches[0];
        const diff = startY - touch.clientY;
        const threshold = 50;

        if (diff > threshold) {
          // Swipe up - expand
          expand();
        } else if (diff < -threshold) {
          // Swipe down - collapse
          collapse();
        }
      }, { passive: true });

      // Keyboard
      panel.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Escape') {
          collapse();
        }
      });
    });
  }

  initPanels();
  document.addEventListener('astro:page-load', initPanels);

  // Re-init when new slides are added
  const observer = new MutationObserver(() => {
    initPanels();
  });

  const feedScroll = document.getElementById('reel-slides');
  if (feedScroll) {
    observer.observe(feedScroll, { childList: true, subtree: true });
  }
</script>
