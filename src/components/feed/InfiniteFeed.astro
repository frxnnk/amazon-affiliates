---
/**
 * InfiniteFeed - NEO-BRUTALIST Product Feed
 *
 * Features:
 * - Bold borders, no blur, no shadows with blur
 * - Offset solid shadows
 * - Monospace typography for prices
 * - Uppercase text, high contrast
 * - Snappy transitions, no smooth fades
 * - Floating category selector with brutal dropdown
 * - Inline search bar with debounce
 * - Saveable sections (search + filter combinations)
 */
import { type Lang } from '@i18n/utils';
import '@styles/feed-brutal.css';
import FeedSearchBar from './FeedSearchBar.astro';
import FilterPanel from './FilterPanel.astro';

interface Props {
  lang: Lang;
  category?: string;
}

const { lang, category = 'all' } = Astro.props;

const texts = {
  es: {
    loading: 'Cargando...',
    noMore: 'No hay más productos',
    retry: 'Reintentar',
    error: 'Error al cargar',
    buy: 'Ver en Amazon',
    addToCart: 'Agregar al carrito',
    addedToCart: 'Agregado al carrito',
    viewCart: 'Ver carrito',
  },
  en: {
    loading: 'Loading...',
    noMore: 'No more products',
    retry: 'Retry',
    error: 'Failed to load',
    buy: 'View on Amazon',
    addToCart: 'Add to cart',
    addedToCart: 'Added to cart',
    viewCart: 'View cart',
  }
};

const t = texts[lang];

// Categories for the selector with SVG icons
const categories = [
  { 
    id: 'all', 
    label: { es: 'Todo', en: 'All' },
    // Grid/Apps icon (Lucide style)
    icon: '<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>'
  },
  { 
    id: 'electronics', 
    label: { es: 'Tech', en: 'Tech' },
    // Smartphone icon (Lucide style)
    icon: '<rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><path d="M12 18h.01"/>'
  },
  { 
    id: 'audio', 
    label: { es: 'Audio', en: 'Audio' },
    // Headphones icon (Lucide style)
    icon: '<path d="M3 18v-6a9 9 0 0118 0v6"/><path d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3v5z"/><path d="M3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3v5z"/>'
  },
  { 
    id: 'gaming', 
    label: { es: 'Gaming', en: 'Gaming' },
    // Gamepad icon (Lucide style)
    icon: '<path d="M6 12h4m-2-2v4m7-1h.01M18 11h.01"/><rect x="2" y="6" width="20" height="12" rx="2"/>'
  },
  { 
    id: 'home', 
    label: { es: 'Hogar', en: 'Home' },
    // Home icon (Lucide style)
    icon: '<path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><polyline points="9,22 9,12 15,12 15,22"/>'
  },
  { 
    id: 'wearables', 
    label: { es: 'Wearables', en: 'Wearables' },
    // Watch icon (Lucide style)
    icon: '<circle cx="12" cy="12" r="7"/><polyline points="12,9 12,12 14,14"/><path d="M9 2h6m-6 20h6"/>'
  },
];
---

<div class="feed" id="reel-feed" data-lang={lang} data-category={category}>
  
  <!-- Floating Top Controls Bar - Search, Sections, Filters, Category -->
  <div class="feed-controls" id="feed-controls">

    <!-- Full Controls: Search + Filters + Category + Cart -->
    <div class="controls-pill">

      <!-- Search Bar (inline, centered) -->
      <FeedSearchBar lang={lang} />

      <!-- Filter Panel -->
      <FilterPanel lang={lang} />

      <!-- Category Filter - Compact Dropdown -->
      <div class="category-ctrl" id="category-float">
        <button class="cat-trigger" id="category-toggle" type="button" data-category={category}>
          {categories.map((cat) => (
            <span class={`cat-active-icon ${cat.id === category ? 'show' : ''}`} data-category={cat.id}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <Fragment set:html={cat.icon} />
              </svg>
            </span>
          ))}
          <span class="cat-active-label">
            {categories.map((cat) => (
              <span class={cat.id === category ? 'show' : ''} data-category={cat.id}>{cat.label[lang]}</span>
            ))}
          </span>
          <svg class="cat-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </button>

        <!-- Dropdown Menu -->
        <div class="cat-menu" id="category-pills">
          <div class="cat-menu-inner">
            {categories.map((cat) => (
              <button
                type="button"
                class={`cat-option ${cat.id === category ? 'selected' : ''}`}
                data-category={cat.id}
              >
                <span class="cat-option-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <Fragment set:html={cat.icon} />
                  </svg>
                </span>
                <span class="cat-option-label">{cat.label[lang]}</span>
                <span class="cat-option-check">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </span>
              </button>
            ))}
          </div>
        </div>
      </div>

      <!-- Cart Button -->
      <button type="button" class="cart-ctrl" id="feed-cart-btn" aria-label={lang === 'es' ? 'Ver carrito' : 'View cart'}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
          <line x1="3" y1="6" x2="21" y2="6" />
          <path d="M16 10a4 4 0 0 1-8 0" />
        </svg>
        <span class="cart-badge" id="feed-cart-badge">0</span>
      </button>

    </div>

  </div>

  <div class="feed-scroll" id="reel-slides">
    
    <!-- Skeleton -->
    <div class="skeleton-wrap" id="skeleton-container">
      {[1, 2].map(() => (
        <article class="slide skeleton-slide">
          <div class="slide-main">
            <div class="skel-img"></div>
          </div>
          <div class="slide-sidebar">
            <div class="skel-btn"></div>
            <div class="skel-btn"></div>
            <div class="skel-btn"></div>
          </div>
          <div class="slide-footer">
            <div class="skel-line w-20"></div>
            <div class="skel-line w-80"></div>
            <div class="skel-line w-40"></div>
            <div class="skel-cta"></div>
          </div>
        </article>
      ))}
    </div>
    
    <!-- Scroll sentinel for infinite loading detection -->
    <div id="scroll-sentinel" style="height: 1px; width: 100%; pointer-events: none;"></div>

    <!-- Loader (Skeleton for loading more) -->
    <div class="feed-loader" id="reel-loader">
      <article class="slide skeleton-slide loader-skeleton">
        <div class="slide-main">
          <div class="skel-img"></div>
        </div>
        <div class="slide-sidebar">
          <div class="skel-btn"></div>
          <div class="skel-btn"></div>
        </div>
        <div class="slide-footer">
          <div class="skel-line w-20"></div>
          <div class="skel-line w-80"></div>
          <div class="skel-line w-40"></div>
          <div class="skel-cta"></div>
        </div>
      </article>
    </div>

    <!-- End -->
    <div class="feed-end" id="reel-end">{t.noMore}</div>
  </div>
  
  <!-- Error -->
  <div class="feed-error" id="reel-error">
    <p>{t.error}</p>
    <button id="retry-btn">{t.retry}</button>
  </div>
  
</div>

<script define:vars={{ lang, t: texts[lang] }}>
class Feed {
  constructor() {
    this.container = document.getElementById('reel-feed');
    this.scroll = document.getElementById('reel-slides');
    this.skeleton = document.getElementById('skeleton-container');
    this.loader = document.getElementById('reel-loader');
    this.sentinel = document.getElementById('scroll-sentinel');
    this.endEl = document.getElementById('reel-end');
    this.errorEl = document.getElementById('reel-error');
    
    // Top controls elements (simplified - category only)
    this.feedControls = document.getElementById('feed-controls');
    this.categoryFloat = document.getElementById('category-float');
    this.categoryPills = document.getElementById('category-pills');
    this.categoryToggle = document.getElementById('category-toggle');
    
    this.lang = this.container?.dataset.lang || 'es';
    this.category = this.container?.dataset.category || 'all';
    this.searchQuery = ''; // Current search query
    this.page = 1;
    this.products = [];
    this.seen = new Set();
    this.loading = false;
    this.hasMore = true;
    this.texts = t;
    
    // Video control state
    this.activeVideoSlide = null;
    this.globalMuted = false; // Start with sound ON - user preference
    this.videoObserver = null;

    // Category selector state
    this.categoryExpanded = false;

    // View tracking state
    this.viewObserver = null;
    this.viewedAsins = new Set(); // Track what we've already sent
    this.pendingViews = []; // Batch pending view tracking
    this.viewDebounceTimer = null;

    // Infinite scroll observer
    this.infiniteScrollObserver = null;

    // Filter state
    this.currentFilters = {};

    if (this.container) this.init();
  }
  
  async init() {
    this.setupEvents();
    this.setupVideoObserver();
    this.setupViewTrackingObserver();
    this.setupInfiniteScrollObserver();
    this.setupTopControls();
    await this.load();
  }

  // Setup IntersectionObserver for infinite scroll (more reliable than scroll events with snap)
  setupInfiniteScrollObserver() {
    console.log('[Feed] Setting up infinite scroll...', { sentinel: !!this.sentinel, scroll: !!this.scroll });

    if (!this.sentinel || !this.scroll) {
      console.warn('[Feed] Missing sentinel or scroll container!');
      return;
    }

    this.infiniteScrollObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        console.log('[Feed] Observer entry:', { isIntersecting: entry.isIntersecting, loading: this.loading, hasMore: this.hasMore });
        if (entry.isIntersecting && !this.loading && this.hasMore) {
          console.log('[Feed] Sentinel visible - triggering load');
          this.load();
        }
      });
    }, {
      root: this.scroll,
      rootMargin: '200% 0px', // Start loading when sentinel is within 2 screens
      threshold: 0
    });

    this.infiniteScrollObserver.observe(this.sentinel);
    console.log('[Feed] Infinite scroll observer initialized');
  }

  // Setup observer for tracking product views
  setupViewTrackingObserver() {
    if (!this.scroll) return;

    // Track when slides are visible for at least 1 second
    this.viewObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const slide = entry.target;
        const asin = slide.dataset.asin;

        if (!asin) return;

        if (entry.isIntersecting && entry.intersectionRatio >= 0.5) {
          // Slide is visible - start timing
          slide.dataset.viewStart = Date.now().toString();
        } else {
          // Slide left viewport - check if it was viewed long enough
          const viewStart = parseInt(slide.dataset.viewStart || '0');
          if (viewStart) {
            const timeSpent = Date.now() - viewStart;
            if (timeSpent >= 1000) { // At least 1 second
              this.queueViewTracking(asin, slide.dataset.category, timeSpent);
            }
            delete slide.dataset.viewStart;
          }
        }
      });
    }, {
      root: this.scroll,
      threshold: [0.5],
      rootMargin: '0px'
    });
  }

  // Queue a view for batch sending
  queueViewTracking(asin, category, timeSpentMs) {
    // Don't track the same product twice in this session
    if (this.viewedAsins.has(asin)) return;
    this.viewedAsins.add(asin);

    this.pendingViews.push({ asin, category, timeSpentMs });

    // Debounce: send batch after 2 seconds of inactivity
    if (this.viewDebounceTimer) clearTimeout(this.viewDebounceTimer);
    this.viewDebounceTimer = setTimeout(() => this.sendViewBatch(), 2000);

    // Or send immediately if we have 5+ pending
    if (this.pendingViews.length >= 5) {
      this.sendViewBatch();
    }
  }

  // Send batched views to the server
  async sendViewBatch() {
    if (this.pendingViews.length === 0) return;

    const views = [...this.pendingViews];
    this.pendingViews = [];

    if (this.viewDebounceTimer) {
      clearTimeout(this.viewDebounceTimer);
      this.viewDebounceTimer = null;
    }

    try {
      // Send individual views with engagement data
      for (const view of views) {
        await fetch('/api/user/view', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            asin: view.asin,
            category: view.category || this.category,
            timeSpentMs: view.timeSpentMs,
            interactionType: view.interactionType || 'view'
          })
        });
      }
      console.log(`[Feed] Tracked ${views.length} product views with engagement data`);
    } catch (error) {
      // Silently fail - view tracking is not critical
      console.warn('[Feed] Failed to track views:', error);
    }
  }

  // Track a specific engagement signal
  trackEngagement(asin, type, extraData = {}) {
    const signal = {
      asin,
      category: extraData.category || this.category,
      timeSpentMs: extraData.timeSpentMs,
      interactionType: type
    };

    // For high-value signals, send immediately
    if (['click', 'affiliate_click', 'save'].includes(type)) {
      fetch('/api/user/view', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(signal)
      }).catch(() => {}); // Silent fail
      console.log(`[Feed] Tracked ${type} for ${asin.slice(-6)}`);
    } else {
      // Queue low-value signals
      this.pendingViews.push(signal);
      if (this.viewDebounceTimer) clearTimeout(this.viewDebounceTimer);
      this.viewDebounceTimer = setTimeout(() => this.sendViewBatch(), 2000);
    }
  }

  // Toast notification for cart
  showCartToast(product) {
    // Create toast container if it doesn't exist
    let container = document.getElementById('cart-toast-container');
    if (!container) {
      container = document.createElement('div');
      container.id = 'cart-toast-container';
      container.innerHTML = `
        <div class="cart-toast">
          <img class="toast-image" src="" alt="" />
          <div class="toast-content">
            <p class="toast-title"></p>
            <p class="toast-message"></p>
          </div>
          <button type="button" class="toast-action"></button>
        </div>
      `;
      document.body.appendChild(container);

      // View cart action
      container.querySelector('.toast-action')?.addEventListener('click', () => {
        this.hideCartToast();
        window.dispatchEvent(new CustomEvent('cart:open'));
      });
    }

    // Update toast content
    const imgEl = container.querySelector('.toast-image');
    const titleEl = container.querySelector('.toast-title');
    const messageEl = container.querySelector('.toast-message');
    const actionEl = container.querySelector('.toast-action');

    if (imgEl) {
      imgEl.src = product.image || '';
      imgEl.alt = product.title;
    }
    if (titleEl) titleEl.textContent = product.title;
    if (messageEl) messageEl.textContent = this.texts.addedToCart;
    if (actionEl) actionEl.textContent = this.texts.viewCart;

    // Clear existing timeout
    if (this.toastTimeout) clearTimeout(this.toastTimeout);

    // Show toast
    requestAnimationFrame(() => {
      container.classList.add('visible');
    });

    // Auto-hide after 3 seconds
    this.toastTimeout = setTimeout(() => {
      this.hideCartToast();
    }, 3000);
  }

  hideCartToast() {
    const container = document.getElementById('cart-toast-container');
    if (container) container.classList.remove('visible');
    if (this.toastTimeout) {
      clearTimeout(this.toastTimeout);
      this.toastTimeout = null;
    }
  }

  // Observe a slide for view tracking
  observeSlideForViews(slide) {
    if (this.viewObserver && slide.dataset.asin) {
      this.viewObserver.observe(slide);
    }
  }
  
  // Top Controls Setup (simplified - category only)
  setupTopControls() {
    this.setupCategorySelector();
    this.setupCartButton();
  }

  // Cart Button Setup
  setupCartButton() {
    const cartBtn = document.getElementById('feed-cart-btn');
    const cartBadge = document.getElementById('feed-cart-badge');

    if (!cartBtn) return;

    // Open cart modal on click
    cartBtn.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('cart:open'));
    });

    // Update badge count
    const updateBadge = () => {
      const items = window.cart?.getItems() || [];
      const count = items.reduce((sum, item) => sum + item.quantity, 0);
      if (cartBadge) {
        cartBadge.textContent = count > 99 ? '99+' : String(count);
        cartBadge.classList.toggle('has-items', count > 0);
      }
    };

    // Initial update
    updateBadge();

    // Listen for cart updates
    window.addEventListener('cart:updated', updateBadge);
  }

  reloadFeed() {
    this.page = 1;
    this.products = [];
    this.seen.clear();
    this.hasMore = true;
    this.scroll?.querySelectorAll('.slide:not(.skeleton-slide)').forEach(s => s.remove());
    this.skeleton?.classList.remove('hide');
    this.endEl?.classList.remove('show');
    this.load();
  }

  // Category Selector Logic
  setupCategorySelector() {
    if (!this.categoryFloat) return;

    // Toggle expand/collapse
    this.categoryToggle?.addEventListener('click', (e) => {
      e.stopPropagation();
      this.toggleCategoryExpanded();
    });

    // Category option clicks
    this.categoryPills?.querySelectorAll('.cat-option').forEach(opt => {
      opt.addEventListener('click', (e) => {
        e.stopPropagation();
        const cat = opt.dataset.category;
        if (cat && cat !== this.category) {
          // Update selected state on options
          this.categoryPills.querySelectorAll('.cat-option').forEach(p => p.classList.remove('selected'));
          opt.classList.add('selected');

          // Update trigger button display
          this.updateCategoryToggleIcon(cat);

          // Change category
          this.changeCategory(cat);

          // Collapse after selection with smooth delay
          setTimeout(() => this.collapseCategorySelector(), 200);
        }
      });
    });

    // Close on click outside
    document.addEventListener('click', (e) => {
      if (this.categoryExpanded && !this.categoryFloat.contains(e.target)) {
        this.collapseCategorySelector();
      }
    });

    // Close on escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && this.categoryExpanded) {
        this.collapseCategorySelector();
      }
    });
  }

  toggleCategoryExpanded() {
    this.categoryExpanded = !this.categoryExpanded;
    this.categoryFloat?.classList.toggle('open', this.categoryExpanded);
  }

  collapseCategorySelector() {
    this.categoryExpanded = false;
    this.categoryFloat?.classList.remove('open');
  }

  updateCategoryToggleIcon(cat) {
    // Update icon visibility
    this.categoryToggle?.querySelectorAll('.cat-active-icon').forEach(icon => {
      icon.classList.toggle('show', icon.dataset.category === cat);
    });
    // Update label visibility
    this.categoryToggle?.querySelectorAll('.cat-active-label span').forEach(label => {
      label.classList.toggle('show', label.dataset.category === cat);
    });
  }
  
  // Setup IntersectionObserver for video slides
  setupVideoObserver() {
    if (!this.scroll) return;
    
    this.videoObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const slide = entry.target;
        const isVideoSlide = slide.classList.contains('slide-video');
        
        if (!isVideoSlide) return;
        
        const iframe = slide.querySelector('.video-iframe');
        if (!iframe) return;
        
        if (entry.isIntersecting && entry.intersectionRatio >= 0.5) {
          // Slide is now active - play video
          this.activateVideo(slide, iframe);
          // Preload adjacent videos
          this.preloadAdjacentVideos(slide);
        } else if (!entry.isIntersecting && this.activeVideoSlide === slide) {
          // Slide is leaving - pause video
          this.deactivateVideo(slide, iframe);
        }
      });
    }, {
      root: this.scroll,
      threshold: [0.1, 0.5, 0.9],
      rootMargin: '0px'
    });
  }
  
  // Preload next and previous video slides
  preloadAdjacentVideos(currentSlide) {
    const slides = Array.from(this.scroll?.querySelectorAll('.slide-video') || []);
    const currentIndex = slides.indexOf(currentSlide);
    
    // Preload next 2 slides
    [1, 2].forEach(offset => {
      const nextSlide = slides[currentIndex + offset];
      if (nextSlide && !nextSlide.dataset.preloaded) {
        this.preloadVideo(nextSlide);
      }
    });
  }
  
  // Preload a video (load thumbnail, prepare iframe)
  preloadVideo(slide) {
    slide.dataset.preloaded = 'true';
    const iframe = slide.querySelector('.video-iframe');
    const videoId = iframe?.dataset.videoId;
    if (!iframe || !videoId) return;
    
    // Preload the embed (paused, muted)
    iframe.src = `https://www.youtube.com/embed/${videoId}?rel=0&modestbranding=1&playsinline=1&mute=1`;
  }
  
  // Activate video when slide becomes visible
  activateVideo(slide, iframe) {
    if (this.activeVideoSlide === slide) return;

    // Deactivate previous video if any
    if (this.activeVideoSlide) {
      const prevIframe = this.activeVideoSlide.querySelector('.video-iframe');
      if (prevIframe) {
        this.deactivateVideo(this.activeVideoSlide, prevIframe);
      }
    }

    this.activeVideoSlide = slide;
    slide.dataset.playing = 'true';
    const videoId = iframe.dataset.videoId;

    // Show loading state
    slide.classList.add('video-loading-active');

    // Start playing - always muted initially for autoplay to work (browser policy)
    iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1&rel=0&modestbranding=1&playsinline=1&loop=1&playlist=${videoId}&enablejsapi=1`;

    // Hide loading when iframe loads
    iframe.onload = () => {
      setTimeout(() => {
        slide.classList.remove('video-loading-active');
        slide.classList.add('video-active');

        // Apply user's sound preference after video starts
        if (!this.globalMuted) {
          this.sendYouTubeCommand(iframe, 'unMute');
        }

        // Update sound button UI to match global state
        this.updateSoundButtonUI(slide, !this.globalMuted);
      }, 300);
    };

    // Update control buttons
    this.updateVideoControlUI(slide, true);
  }

  // Update sound button UI for a slide
  updateSoundButtonUI(slide, isUnmuted) {
    const soundBtn = slide.querySelector('.video-sound-btn');
    if (!soundBtn) return;

    const iconMuted = soundBtn.querySelector('.icon-muted');
    const iconUnmuted = soundBtn.querySelector('.icon-unmuted');

    soundBtn.dataset.muted = isUnmuted ? 'false' : 'true';
    soundBtn.title = isUnmuted
      ? (this.lang === 'es' ? 'Silenciar' : 'Mute')
      : (this.lang === 'es' ? 'Activar sonido' : 'Unmute');

    if (iconMuted) iconMuted.style.display = isUnmuted ? 'none' : 'block';
    if (iconUnmuted) iconUnmuted.style.display = isUnmuted ? 'block' : 'none';
  }
  
  // Deactivate video when slide leaves viewport
  deactivateVideo(slide, iframe) {
    // First pause the video
    this.sendYouTubeCommand(iframe, 'pauseVideo');
    
    slide.dataset.playing = 'false';
    slide.classList.remove('video-active', 'video-loading-active', 'video-paused');
    
    // Clear src to free resources when leaving viewport
    setTimeout(() => {
      if (slide.dataset.playing === 'false') {
        iframe.src = '';
      }
    }, 100);
    
    if (this.activeVideoSlide === slide) {
      this.activeVideoSlide = null;
    }

    this.updateVideoControlUI(slide, false);
  }

  // Toggle play/pause using YouTube IFrame API postMessage
  togglePlayPause(slide, iframe) {
    const isPlaying = slide.dataset.playing === 'true';
    const videoId = iframe.dataset.videoId;
    
    // Show brief tap feedback
    this.showTapFeedback(slide, isPlaying);
    
    if (isPlaying) {
      // PAUSE - send pause command to YouTube player
      slide.dataset.playing = 'false';
      slide.classList.remove('video-active');
      slide.classList.add('video-paused');
      this.sendYouTubeCommand(iframe, 'pauseVideo');
      this.updateVideoControlUI(slide, false);
    } else {
      // PLAY/RESUME
      slide.dataset.playing = 'true';
      slide.classList.remove('video-paused');
      
      // If iframe was cleared (deactivated), reload it
      if (!iframe.src || iframe.src === 'about:blank' || iframe.src === '') {
        slide.classList.add('video-loading-active');
        iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1&rel=0&modestbranding=1&playsinline=1&loop=1&playlist=${videoId}&enablejsapi=1`;
        iframe.onload = () => {
          setTimeout(() => {
            slide.classList.remove('video-loading-active');
            slide.classList.add('video-active');
            // Apply user's sound preference after reload
            if (!this.globalMuted) {
              this.sendYouTubeCommand(iframe, 'unMute');
            }
            this.updateSoundButtonUI(slide, !this.globalMuted);
          }, 300);
        };
      } else {
        // Send play command to resume
        this.sendYouTubeCommand(iframe, 'playVideo');
        slide.classList.add('video-active');
      }
      this.updateVideoControlUI(slide, true);
    }
  }
  
  // Send command to YouTube IFrame API via postMessage
  sendYouTubeCommand(iframe, command) {
    if (!iframe || !iframe.contentWindow) return;
    
    const message = JSON.stringify({
      event: 'command',
      func: command,
      args: []
    });
    
    iframe.contentWindow.postMessage(message, 'https://www.youtube.com');
  }
  
  // Show brief tap feedback animation
  showTapFeedback(slide, wasPlaying) {
    const indicator = slide.querySelector('.video-pause-indicator');
    if (!indicator) return;
    
    // Show play or pause icon briefly
    const svg = indicator.querySelector('svg');
    if (svg) {
      // Update icon based on action taken (opposite of current state)
      svg.innerHTML = wasPlaying 
        ? '<path d="M8 5v14l11-7z"/>' // Play icon (when pausing - shows what happens on next tap)
        : '<path d="M8 5v14l11-7z"/>'; // Play icon (when resuming)
    }
    
    // Animate in and out
    indicator.classList.add('show');
    setTimeout(() => {
      if (slide.dataset.playing === 'true') {
        indicator.classList.remove('show');
      }
    }, 600);
  }
  
  // Update play icon for paused videos
  updatePausedIcon(slide) {
    const indicator = slide.querySelector('.video-pause-indicator');
    if (!indicator) return;
    const svg = indicator.querySelector('svg');
    if (svg) {
      svg.innerHTML = '<path d="M8 5v14l11-7z"/>'; // Play icon
    }
  }
  
  // Update play/pause indicator UI
  updateVideoControlUI(slide, isPlaying) {
    const pauseIndicator = slide.querySelector('.video-pause-indicator');
    if (pauseIndicator) {
      pauseIndicator.classList.toggle('show', !isPlaying);
      // Always show play icon when paused
      if (!isPlaying) {
        this.updatePausedIcon(slide);
      }
    }
  }
  
  // Observe a new slide
  observeSlide(slide) {
    if (this.videoObserver && slide.classList.contains('slide-video')) {
      this.videoObserver.observe(slide);
    }
  }
  
  setupEvents() {
    document.getElementById('retry-btn')?.addEventListener('click', () => {
      this.errorEl?.classList.remove('show');
      this.load();
    });

    this.scroll?.addEventListener('scroll', () => {
      this.checkPreload();
    }, { passive: true });

    window.addEventListener('category:change', (e) => {
      if (e.detail?.category !== this.category) {
        this.changeCategory(e.detail.category);
      }
    });

    // Listen for search changes
    window.addEventListener('search:change', (e) => {
      const query = e.detail?.query || '';
      if (query !== this.searchQuery) {
        this.changeSearch(query);
      }
    });

    // Listen for search:apply from sections (sets input value too)
    window.addEventListener('search:apply', (e) => {
      const query = e.detail?.query || '';
      const searchInput = document.getElementById('feed-search-input');
      if (searchInput) {
        searchInput.value = query;
        // Trigger the clear button visibility update
        const clearBtn = document.getElementById('search-clear');
        clearBtn?.classList.toggle('visible', query.length > 0);
      }
      if (query !== this.searchQuery) {
        this.changeSearch(query);
      }
    });

    // Listen for filter changes
    window.addEventListener('filters:change', (e) => {
      this.currentFilters = e.detail || {};
      this.reloadFeed();
    });

    // Listen for Amazon product links pasted in search
    window.addEventListener('amazon:product', (e) => {
      if (e.detail?.product) {
        this.insertAmazonProduct(e.detail.product);
      }
    });

    // Send pending views when user leaves
    window.addEventListener('beforeunload', () => {
      this.sendViewBatch();
    });

    // Also send when tab becomes hidden
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'hidden') {
        this.sendViewBatch();
      }
    });
  }
  
  changeCategory(cat) {
    this.category = cat;
    this.page = 1;
    this.products = [];
    this.seen.clear();
    this.hasMore = true;
    this.scroll?.querySelectorAll('.slide:not(.skeleton-slide)').forEach(s => s.remove());
    this.skeleton?.classList.remove('hide');
    this.endEl?.classList.remove('show');
    this.load();
  }

  // Handle search query changes
  changeSearch(query) {
    this.searchQuery = query;
    this.page = 1;
    this.products = [];
    this.seen.clear();
    this.hasMore = true;
    this.scroll?.querySelectorAll('.slide:not(.skeleton-slide)').forEach(s => s.remove());
    this.skeleton?.classList.remove('hide');
    this.endEl?.classList.remove('show');
    this.load();
  }

  // Insert a product from Amazon link at the top of the feed
  insertAmazonProduct(product) {
    console.log('[Feed] Inserting Amazon product:', product.title);

    // Don't add if we've already seen this product
    if (this.seen.has(product.asin)) {
      // Scroll to the existing product
      const existingSlide = this.scroll?.querySelector(`[data-asin="${product.asin}"]`);
      if (existingSlide) {
        existingSlide.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
      return;
    }

    // Add to seen set
    this.seen.add(product.asin);
    this.products.unshift(product);

    // Create the slide
    const slide = this.createSlide(product);

    // Add a special class for pasted products
    slide.classList.add('slide-pasted');

    // Hide skeleton if visible
    this.skeleton?.classList.add('hide');

    // Insert at the top of the feed (after any skeleton)
    const firstSlide = this.scroll?.querySelector('.slide:not(.skeleton-slide)');
    if (firstSlide) {
      this.scroll?.insertBefore(slide, firstSlide);
    } else {
      // No slides yet, insert before sentinel
      this.scroll?.insertBefore(slide, this.sentinel);
    }

    // Observe the new slide
    this.observeSlide(slide);
    this.observeSlideForViews(slide);

    // Scroll to top to show the new product
    this.scroll?.scrollTo({ top: 0, behavior: 'smooth' });

    // Show a brief highlight animation
    setTimeout(() => {
      slide.classList.add('slide-highlight');
      setTimeout(() => slide.classList.remove('slide-highlight'), 1500);
    }, 100);
  }

  async load() {
    if (this.loading || !this.hasMore) return;
    
    this.loading = true;
    this.loader?.classList.add('show');
    this.errorEl?.classList.remove('show');
    
    try {
      const exclude = this.seen.size > 0 ? `&exclude=${[...this.seen].slice(-50).join(',')}` : '';
      const searchParam = this.searchQuery ? `&search=${encodeURIComponent(this.searchQuery)}` : '';
      const res = await fetch(`/api/feed/products?page=${this.page}&category=${this.category}&lang=${this.lang}&limit=5${exclude}${searchParam}`);
      const data = await res.json();
      
      if (!data.success) throw new Error(data.error);
      
      // Debug: Log video availability
      console.log('[Feed] ===== VIDEO DEBUG =====');
      console.log('[Feed] videoStats:', data.videoStats);
      console.log('[Feed] mediaMode:', this.mediaMode);
      const productsWithVideo = data.products.filter(p => p.youtubeVideo?.videoId);
      console.log(`[Feed] Total products: ${data.products.length}`);
      console.log(`[Feed] Products with video: ${productsWithVideo.length}`);
      if (productsWithVideo.length > 0) {
        console.log('[Feed] First video:', productsWithVideo[0].youtubeVideo);
      }
      console.log('[Feed] ========================');

      const newProducts = data.products.filter(p => !this.seen.has(p.asin));

      // Debug logging
      console.log(`[Feed] Loaded page ${this.page}: ${data.products.length} total, ${newProducts.length} new, hasMore=${data.hasMore}`);

      if (newProducts.length > 0) {
        newProducts.forEach(p => this.seen.add(p.asin));
        this.products.push(...newProducts);
        this.render(newProducts);
        this.page++;
        this.skeleton?.classList.add('hide');
      }

      // Always update hasMore from API response
      this.hasMore = data.hasMore && (newProducts.length > 0 || data.products.length > 0);

      // If no new products but API returned products (all duplicates), try next page
      if (newProducts.length === 0 && data.products.length > 0 && data.hasMore) {
        console.log('[Feed] All products were duplicates, loading next page...');
        this.page++;
        this.loading = false;
        this.loader?.classList.remove('show');
        return this.load();
      }

      if (!this.hasMore) {
        console.log('[Feed] No more products to load');
        this.endEl?.classList.add('show');
        this.skeleton?.classList.add('hide');
      }

      // Dispatch search results event to clear loading state
      window.dispatchEvent(new CustomEvent('search:results', { detail: { count: newProducts.length } }));
    } catch (e) {
      console.error(e);
      this.errorEl?.classList.add('show');
      this.skeleton?.classList.add('hide');
      // Still clear search loading on error
      window.dispatchEvent(new CustomEvent('search:results', { detail: { count: 0, error: true } }));
    } finally {
      this.loading = false;
      this.loader?.classList.remove('show');
    }
  }
  
  render(products) {
    products.forEach((p) => {
      const slide = this.createSlide(p);
      // Insert before sentinel to keep sentinel at the end for infinite scroll detection
      this.scroll?.insertBefore(slide, this.sentinel);
      // Start observing video slides for autoplay
      this.observeSlide(slide);
      // Start observing all slides for view tracking
      this.observeSlideForViews(slide);
    });
  }
  
  createSlide(p) {
