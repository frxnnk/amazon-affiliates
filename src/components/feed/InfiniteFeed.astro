---
/**
 * InfiniteFeed - Clean Product Feed
 * 
 * Features:
 * - Pure white background
 * - Large centered product image with subtle shadow
 * - Clean typography
 * - Minimal social actions
 * - Professional design
 * - Floating category selector with auto-hide
 */
import { type Lang } from '@i18n/utils';

interface Props {
  lang: Lang;
  category?: string;
}

const { lang, category = 'all' } = Astro.props;

const texts = {
  es: {
    loading: 'Cargando...',
    noMore: 'No hay más productos',
    retry: 'Reintentar',
    error: 'Error al cargar',
    buy: 'Ver en Amazon',
  },
  en: {
    loading: 'Loading...',
    noMore: 'No more products',
    retry: 'Retry',
    error: 'Failed to load',
    buy: 'View on Amazon',
  }
};

const t = texts[lang];

// Categories for the selector with SVG icons
const categories = [
  { 
    id: 'all', 
    label: { es: 'Todo', en: 'All' },
    // Grid/Apps icon (Lucide style)
    icon: '<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>'
  },
  { 
    id: 'electronics', 
    label: { es: 'Tech', en: 'Tech' },
    // Smartphone icon (Lucide style)
    icon: '<rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><path d="M12 18h.01"/>'
  },
  { 
    id: 'audio', 
    label: { es: 'Audio', en: 'Audio' },
    // Headphones icon (Lucide style)
    icon: '<path d="M3 18v-6a9 9 0 0118 0v6"/><path d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3v5z"/><path d="M3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3v5z"/>'
  },
  { 
    id: 'gaming', 
    label: { es: 'Gaming', en: 'Gaming' },
    // Gamepad icon (Lucide style)
    icon: '<path d="M6 12h4m-2-2v4m7-1h.01M18 11h.01"/><rect x="2" y="6" width="20" height="12" rx="2"/>'
  },
  { 
    id: 'home', 
    label: { es: 'Hogar', en: 'Home' },
    // Home icon (Lucide style)
    icon: '<path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><polyline points="9,22 9,12 15,12 15,22"/>'
  },
  { 
    id: 'wearables', 
    label: { es: 'Wearables', en: 'Wearables' },
    // Watch icon (Lucide style)
    icon: '<circle cx="12" cy="12" r="7"/><polyline points="12,9 12,12 14,14"/><path d="M9 2h6m-6 20h6"/>'
  },
];
---

<div class="feed" id="reel-feed" data-lang={lang} data-category={category}>
  
  <!-- Floating Top Controls Bar - Premium Glass Design -->
  <div class="feed-controls" id="feed-controls">

    <!-- Unified Control Pill -->
    <div class="controls-pill">

      <!-- Volume Toggle (only shown when video is playing) -->
      <button class="ctrl-btn volume-btn hidden" id="volume-toggle" type="button" data-muted="false" title={lang === 'es' ? 'Silenciar' : 'Mute'}>
        <span class="ctrl-icon">
          <svg class="icon-unmuted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" fill="currentColor"/>
            <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
            <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
          </svg>
          <svg class="icon-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" fill="currentColor"/>
            <line x1="22" y1="9" x2="16" y2="15"/>
            <line x1="16" y1="9" x2="22" y2="15"/>
          </svg>
        </span>
      </button>

      <!-- Divider (shown when volume is visible) -->
      <span class="ctrl-divider volume-divider hidden"></span>

      <!-- Media Mode Toggle - Segmented Pill -->
      <div class="media-toggle" id="mode-toggle" data-mode="video" role="tablist">
        <button class="media-opt" data-type="image" role="tab" aria-selected="false">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <circle cx="8.5" cy="8.5" r="1.5" fill="currentColor" stroke="none"/>
            <path d="m21 15-5-5L5 21"/>
          </svg>
          <span>{lang === 'es' ? 'Foto' : 'Photo'}</span>
        </button>
        <button class="media-opt active" data-type="video" role="tab" aria-selected="true">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M8 5.14v14l11-7-11-7z"/>
          </svg>
          <span>Video</span>
        </button>
        <span class="media-slider"></span>
      </div>

      <!-- Divider -->
      <span class="ctrl-divider"></span>

      <!-- Category Filter - Compact Dropdown -->
      <div class="category-ctrl" id="category-float">
        <button class="cat-trigger" id="category-toggle" type="button" data-category={category}>
          {categories.map((cat) => (
            <span class={`cat-active-icon ${cat.id === category ? 'show' : ''}`} data-category={cat.id}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <Fragment set:html={cat.icon} />
              </svg>
            </span>
          ))}
          <span class="cat-active-label">
            {categories.map((cat) => (
              <span class={cat.id === category ? 'show' : ''} data-category={cat.id}>{cat.label[lang]}</span>
            ))}
          </span>
          <svg class="cat-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </button>

        <!-- Dropdown Menu -->
        <div class="cat-menu" id="category-pills">
          <div class="cat-menu-inner">
            {categories.map((cat) => (
              <button
                type="button"
                class={`cat-option ${cat.id === category ? 'selected' : ''}`}
                data-category={cat.id}
              >
                <span class="cat-option-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <Fragment set:html={cat.icon} />
                  </svg>
                </span>
                <span class="cat-option-label">{cat.label[lang]}</span>
                <span class="cat-option-check">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </span>
              </button>
            ))}
          </div>
        </div>
      </div>

    </div>

  </div>
  
  <div class="feed-scroll" id="reel-slides">
    
    <!-- Skeleton -->
    <div class="skeleton-wrap" id="skeleton-container">
      {[1, 2].map(() => (
        <article class="slide skeleton-slide">
          <div class="slide-main">
            <div class="skel-img"></div>
          </div>
          <div class="slide-sidebar">
            <div class="skel-btn"></div>
            <div class="skel-btn"></div>
            <div class="skel-btn"></div>
          </div>
          <div class="slide-footer">
            <div class="skel-line w-20"></div>
            <div class="skel-line w-80"></div>
            <div class="skel-line w-40"></div>
            <div class="skel-cta"></div>
          </div>
        </article>
      ))}
    </div>
    
    <!-- Loader (Skeleton for loading more) -->
    <div class="feed-loader" id="reel-loader">
      <article class="slide skeleton-slide loader-skeleton">
        <div class="slide-main">
          <div class="skel-img"></div>
        </div>
        <div class="slide-sidebar">
          <div class="skel-btn"></div>
          <div class="skel-btn"></div>
        </div>
        <div class="slide-footer">
          <div class="skel-line w-20"></div>
          <div class="skel-line w-80"></div>
          <div class="skel-line w-40"></div>
          <div class="skel-cta"></div>
        </div>
      </article>
    </div>
    
    <!-- End -->
    <div class="feed-end" id="reel-end">{t.noMore}</div>
  </div>
  
  <!-- Error -->
  <div class="feed-error" id="reel-error">
    <p>{t.error}</p>
    <button id="retry-btn">{t.retry}</button>
  </div>
  
</div>

<script define:vars={{ lang, t: texts[lang] }}>
class Feed {
  constructor() {
    this.container = document.getElementById('reel-feed');
    this.scroll = document.getElementById('reel-slides');
    this.skeleton = document.getElementById('skeleton-container');
    this.loader = document.getElementById('reel-loader');
    this.endEl = document.getElementById('reel-end');
    this.errorEl = document.getElementById('reel-error');
    
    // Top controls elements
    this.feedControls = document.getElementById('feed-controls');
    this.categoryFloat = document.getElementById('category-float');
    this.categoryPills = document.getElementById('category-pills');
    this.categoryToggle = document.getElementById('category-toggle');
    this.modeToggle = document.getElementById('mode-toggle');
    this.volumeToggle = document.getElementById('volume-toggle');
    
    this.lang = this.container?.dataset.lang || 'es';
    this.category = this.container?.dataset.category || 'all';
    this.page = 1;
    this.products = [];
    this.seen = new Set();
    this.loading = false;
    this.hasMore = true;
    this.texts = t;
    
    // Video control state
    this.activeVideoSlide = null;
    this.globalMuted = false; // Start with sound ON
    this.videoObserver = null;
    
    // Media mode: 'video' or 'image'
    this.mediaMode = localStorage.getItem('feedMediaMode') || 'video';
    
    // Category selector state
    this.categoryExpanded = false;
    
    if (this.container) this.init();
  }
  
  async init() {
    this.setupEvents();
    this.setupVideoObserver();
    this.setupTopControls();
    await this.load();
  }
  
  // Top Controls Setup
  setupTopControls() {
    // Category selector
    this.setupCategorySelector();
    
    // Media mode toggle
    this.setupModeToggle();
    
    // Volume control
    this.setupVolumeControl();
  }
  
  // Media Mode Toggle
  setupModeToggle() {
    if (!this.modeToggle) return;

    // Set initial state from localStorage
    this.updateModeToggleUI();

    // Handle clicks on individual options
    const options = this.modeToggle.querySelectorAll('.media-opt');
    options.forEach(opt => {
      opt.addEventListener('click', (e) => {
        e.stopPropagation();
        const newMode = opt.dataset.type;
        if (newMode && newMode !== this.mediaMode) {
          this.mediaMode = newMode;
          localStorage.setItem('feedMediaMode', this.mediaMode);
          this.updateModeToggleUI();
          this.reloadFeed();
        }
      });
    });
  }

  updateModeToggleUI() {
    if (!this.modeToggle) return;
    const isVideo = this.mediaMode === 'video';
    this.modeToggle.dataset.mode = this.mediaMode;

    // Update active states on options
    const options = this.modeToggle.querySelectorAll('.media-opt');
    options.forEach(opt => {
      const isActive = opt.dataset.type === this.mediaMode;
      opt.classList.toggle('active', isActive);
      opt.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });
  }
  
  reloadFeed() {
    this.page = 1;
    this.products = [];
    this.seen.clear();
    this.hasMore = true;
    this.scroll?.querySelectorAll('.slide:not(.skeleton-slide)').forEach(s => s.remove());
    this.skeleton?.classList.remove('hide');
    this.endEl?.classList.remove('show');
    this.load();
  }
  
  // Volume Control - Simple mute/unmute toggle
  setupVolumeControl() {
    if (!this.volumeToggle) return;
    
    // Set initial UI state
    this.updateVolumeUI();
    
    // Toggle mute on button click
    this.volumeToggle.addEventListener('click', () => {
      this.globalMuted = !this.globalMuted;
      this.updateVolumeUI();
      this.applyVolumeToActiveVideo();
    });
  }
  
  updateVolumeUI() {
    if (!this.volumeToggle) return;
    
    const iconMuted = this.volumeToggle.querySelector('.icon-muted');
    const iconUnmuted = this.volumeToggle.querySelector('.icon-unmuted');
    
    if (iconMuted) iconMuted.style.display = this.globalMuted ? 'block' : 'none';
    if (iconUnmuted) iconUnmuted.style.display = this.globalMuted ? 'none' : 'block';
    
    this.volumeToggle.dataset.muted = this.globalMuted ? 'true' : 'false';
    this.volumeToggle.classList.toggle('active', !this.globalMuted);
    this.volumeToggle.title = this.globalMuted 
      ? (this.lang === 'es' ? 'Activar sonido' : 'Enable sound')
      : (this.lang === 'es' ? 'Silenciar' : 'Mute');
  }
  
  applyVolumeToActiveVideo() {
    if (!this.activeVideoSlide) return;
    const iframe = this.activeVideoSlide.querySelector('.video-iframe');
    if (!iframe) return;
    
    if (this.globalMuted) {
      this.sendYouTubeCommand(iframe, 'mute');
    } else {
      this.sendYouTubeCommand(iframe, 'unMute');
    }
  }
  
  // Category Selector Logic
  setupCategorySelector() {
    if (!this.categoryFloat) return;

    // Toggle expand/collapse
    this.categoryToggle?.addEventListener('click', (e) => {
      e.stopPropagation();
      this.toggleCategoryExpanded();
    });

    // Category option clicks
    this.categoryPills?.querySelectorAll('.cat-option').forEach(opt => {
      opt.addEventListener('click', (e) => {
        e.stopPropagation();
        const cat = opt.dataset.category;
        if (cat && cat !== this.category) {
          // Update selected state on options
          this.categoryPills.querySelectorAll('.cat-option').forEach(p => p.classList.remove('selected'));
          opt.classList.add('selected');

          // Update trigger button display
          this.updateCategoryToggleIcon(cat);

          // Change category
          this.changeCategory(cat);

          // Collapse after selection with smooth delay
          setTimeout(() => this.collapseCategorySelector(), 200);
        }
      });
    });

    // Close on click outside
    document.addEventListener('click', (e) => {
      if (this.categoryExpanded && !this.categoryFloat.contains(e.target)) {
        this.collapseCategorySelector();
      }
    });

    // Close on escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && this.categoryExpanded) {
        this.collapseCategorySelector();
      }
    });
  }

  toggleCategoryExpanded() {
    this.categoryExpanded = !this.categoryExpanded;
    this.categoryFloat?.classList.toggle('open', this.categoryExpanded);
  }

  collapseCategorySelector() {
    this.categoryExpanded = false;
    this.categoryFloat?.classList.remove('open');
  }

  updateCategoryToggleIcon(cat) {
    // Update icon visibility
    this.categoryToggle?.querySelectorAll('.cat-active-icon').forEach(icon => {
      icon.classList.toggle('show', icon.dataset.category === cat);
    });
    // Update label visibility
    this.categoryToggle?.querySelectorAll('.cat-active-label span').forEach(label => {
      label.classList.toggle('show', label.dataset.category === cat);
    });
  }
  
  // Setup IntersectionObserver for video slides
  setupVideoObserver() {
    if (!this.scroll) return;
    
    this.videoObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const slide = entry.target;
        const isVideoSlide = slide.classList.contains('slide-video');
        
        if (!isVideoSlide) return;
        
        const iframe = slide.querySelector('.video-iframe');
        if (!iframe) return;
        
        if (entry.isIntersecting && entry.intersectionRatio > 0.7) {
          // Slide is now active - play video
          this.activateVideo(slide, iframe);
          // Preload adjacent videos
          this.preloadAdjacentVideos(slide);
        } else if (this.activeVideoSlide === slide) {
          // Slide is leaving - pause video
          this.deactivateVideo(slide, iframe);
        }
      });
    }, {
      root: this.scroll,
      threshold: [0.3, 0.7, 1.0],
      rootMargin: '0px'
    });
  }
  
  // Preload next and previous video slides
  preloadAdjacentVideos(currentSlide) {
    const slides = Array.from(this.scroll?.querySelectorAll('.slide-video') || []);
    const currentIndex = slides.indexOf(currentSlide);
    
    // Preload next 2 slides
    [1, 2].forEach(offset => {
      const nextSlide = slides[currentIndex + offset];
      if (nextSlide && !nextSlide.dataset.preloaded) {
        this.preloadVideo(nextSlide);
      }
    });
  }
  
  // Preload a video (load thumbnail, prepare iframe)
  preloadVideo(slide) {
    slide.dataset.preloaded = 'true';
    const iframe = slide.querySelector('.video-iframe');
    const videoId = iframe?.dataset.videoId;
    if (!iframe || !videoId) return;
    
    // Preload the embed (paused, muted)
    iframe.src = `https://www.youtube.com/embed/${videoId}?rel=0&modestbranding=1&playsinline=1&mute=1`;
  }
  
  // Activate video when slide becomes visible
  activateVideo(slide, iframe) {
    if (this.activeVideoSlide === slide) return;

    // Deactivate previous video if any
    if (this.activeVideoSlide) {
      const prevIframe = this.activeVideoSlide.querySelector('.video-iframe');
      if (prevIframe) {
        this.deactivateVideo(this.activeVideoSlide, prevIframe);
      }
    }

    this.activeVideoSlide = slide;
    slide.dataset.playing = 'true';
    const videoId = iframe.dataset.videoId;
    
    // Show volume button
    this.showVolumeButton();

    // Show loading state
    slide.classList.add('video-loading-active');
    
    // Start playing (with current mute state)
    const muteParam = this.globalMuted ? '&mute=1' : '';
    iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1${muteParam}&rel=0&modestbranding=1&playsinline=1&loop=1&playlist=${videoId}&enablejsapi=1`;
    
    // Hide loading when iframe loads
    iframe.onload = () => {
      setTimeout(() => {
        slide.classList.remove('video-loading-active');
        slide.classList.add('video-active');
      }, 300);
    };
    
    // Update control buttons
    this.updateVideoControlUI(slide, true);
  }
  
  // Deactivate video when slide leaves viewport
  deactivateVideo(slide, iframe) {
    // First pause the video
    this.sendYouTubeCommand(iframe, 'pauseVideo');
    
    slide.dataset.playing = 'false';
    slide.classList.remove('video-active', 'video-loading-active', 'video-paused');
    
    // Clear src to free resources when leaving viewport
    setTimeout(() => {
      if (slide.dataset.playing === 'false') {
        iframe.src = '';
      }
    }, 100);
    
    if (this.activeVideoSlide === slide) {
      this.activeVideoSlide = null;
      // Hide volume button when no video is active
      this.hideVolumeButton();
    }
    
    this.updateVideoControlUI(slide, false);
  }
  
  showVolumeButton() {
    this.volumeToggle?.classList.remove('hidden');
    // Also show the divider
    const divider = document.querySelector('.ctrl-divider.volume-divider');
    divider?.classList.remove('hidden');
  }

  hideVolumeButton() {
    // Only hide if no video is currently active
    if (!this.activeVideoSlide) {
      this.volumeToggle?.classList.add('hidden');
      // Also hide the divider
      const divider = document.querySelector('.ctrl-divider.volume-divider');
      divider?.classList.add('hidden');
    }
  }
  
  // Toggle play/pause using YouTube IFrame API postMessage
  togglePlayPause(slide, iframe) {
    const isPlaying = slide.dataset.playing === 'true';
    const videoId = iframe.dataset.videoId;
    
    // Show brief tap feedback
    this.showTapFeedback(slide, isPlaying);
    
    if (isPlaying) {
      // PAUSE - send pause command to YouTube player
      slide.dataset.playing = 'false';
      slide.classList.remove('video-active');
      slide.classList.add('video-paused');
      this.sendYouTubeCommand(iframe, 'pauseVideo');
      this.updateVideoControlUI(slide, false);
    } else {
      // PLAY/RESUME
      slide.dataset.playing = 'true';
      slide.classList.remove('video-paused');
      
      // If iframe was cleared (deactivated), reload it
      if (!iframe.src || iframe.src === 'about:blank' || iframe.src === '') {
        slide.classList.add('video-loading-active');
        const muteParam = this.globalMuted ? '&mute=1' : '';
        iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1${muteParam}&rel=0&modestbranding=1&playsinline=1&loop=1&playlist=${videoId}&enablejsapi=1`;
        iframe.onload = () => {
          setTimeout(() => {
            slide.classList.remove('video-loading-active');
            slide.classList.add('video-active');
          }, 300);
        };
      } else {
        // Send play command to resume
        this.sendYouTubeCommand(iframe, 'playVideo');
        slide.classList.add('video-active');
      }
      this.updateVideoControlUI(slide, true);
    }
  }
  
  // Send command to YouTube IFrame API via postMessage
  sendYouTubeCommand(iframe, command) {
    if (!iframe || !iframe.contentWindow) return;
    
    const message = JSON.stringify({
      event: 'command',
      func: command,
      args: []
    });
    
    iframe.contentWindow.postMessage(message, 'https://www.youtube.com');
  }
  
  // Show brief tap feedback animation
  showTapFeedback(slide, wasPlaying) {
    const indicator = slide.querySelector('.video-pause-indicator');
    if (!indicator) return;
    
    // Show play or pause icon briefly
    const svg = indicator.querySelector('svg');
    if (svg) {
      // Update icon based on action taken (opposite of current state)
      svg.innerHTML = wasPlaying 
        ? '<path d="M8 5v14l11-7z"/>' // Play icon (when pausing - shows what happens on next tap)
        : '<path d="M8 5v14l11-7z"/>'; // Play icon (when resuming)
    }
    
    // Animate in and out
    indicator.classList.add('show');
    setTimeout(() => {
      if (slide.dataset.playing === 'true') {
        indicator.classList.remove('show');
      }
    }, 600);
  }
  
  // Update play icon for paused videos
  updatePausedIcon(slide) {
    const indicator = slide.querySelector('.video-pause-indicator');
    if (!indicator) return;
    const svg = indicator.querySelector('svg');
    if (svg) {
      svg.innerHTML = '<path d="M8 5v14l11-7z"/>'; // Play icon
    }
  }
  
  // Update play/pause indicator UI
  updateVideoControlUI(slide, isPlaying) {
    const pauseIndicator = slide.querySelector('.video-pause-indicator');
    if (pauseIndicator) {
      pauseIndicator.classList.toggle('show', !isPlaying);
      // Always show play icon when paused
      if (!isPlaying) {
        this.updatePausedIcon(slide);
      }
    }
  }
  
  // Observe a new slide
  observeSlide(slide) {
    if (this.videoObserver && slide.classList.contains('slide-video')) {
      this.videoObserver.observe(slide);
    }
  }
  
  setupEvents() {
    document.getElementById('retry-btn')?.addEventListener('click', () => {
      this.errorEl?.classList.remove('show');
      this.load();
    });
    
    this.scroll?.addEventListener('scroll', () => {
      this.checkPreload();
    }, { passive: true });
    
    window.addEventListener('category:change', (e) => {
      if (e.detail?.category !== this.category) {
        this.changeCategory(e.detail.category);
      }
    });
  }
  
  changeCategory(cat) {
    this.category = cat;
    this.page = 1;
    this.products = [];
    this.seen.clear();
    this.hasMore = true;
    this.scroll?.querySelectorAll('.slide:not(.skeleton-slide)').forEach(s => s.remove());
    this.skeleton?.classList.remove('hide');
    this.endEl?.classList.remove('show');
    this.load();
  }
  
  async load() {
    if (this.loading || !this.hasMore) return;
    
    this.loading = true;
    this.loader?.classList.add('show');
    this.errorEl?.classList.remove('show');
    
    try {
      const exclude = this.seen.size > 0 ? `&exclude=${[...this.seen].slice(-50).join(',')}` : '';
      const res = await fetch(`/api/feed/products?page=${this.page}&category=${this.category}&lang=${this.lang}&limit=5${exclude}`);
      const data = await res.json();
      
      if (!data.success) throw new Error(data.error);
      
      // Debug: Log video availability
      console.log('[Feed] ===== VIDEO DEBUG =====');
      console.log('[Feed] videoStats:', data.videoStats);
      console.log('[Feed] mediaMode:', this.mediaMode);
      const productsWithVideo = data.products.filter(p => p.youtubeVideo?.videoId);
      console.log(`[Feed] Total products: ${data.products.length}`);
      console.log(`[Feed] Products with video: ${productsWithVideo.length}`);
      if (productsWithVideo.length > 0) {
        console.log('[Feed] First video:', productsWithVideo[0].youtubeVideo);
      }
      console.log('[Feed] ========================');

      const newProducts = data.products.filter(p => !this.seen.has(p.asin));
      
      if (newProducts.length > 0) {
        newProducts.forEach(p => this.seen.add(p.asin));
        this.products.push(...newProducts);
        this.render(newProducts);
        this.page++;
        this.hasMore = data.hasMore;
        this.skeleton?.classList.add('hide');
      } else if (data.products.length === 0) {
        this.hasMore = false;
      }
      
      if (!this.hasMore) {
        this.endEl?.classList.add('show');
        this.skeleton?.classList.add('hide');
      }
    } catch (e) {
      console.error(e);
      this.errorEl?.classList.add('show');
      this.skeleton?.classList.add('hide');
    } finally {
      this.loading = false;
      this.loader?.classList.remove('show');
    }
  }
  
  render(products) {
    products.forEach((p) => {
      const slide = this.createSlide(p);
      this.scroll?.insertBefore(slide, this.loader);
      // Start observing video slides
      this.observeSlide(slide);
    });
  }
  
  createSlide(p) {
    const el = document.createElement('article');
    el.className = 'slide';
    el.dataset.asin = p.asin;
    
    const discount = p.discountPercent || (p.originalPrice 
      ? Math.round(((p.originalPrice - p.price) / p.originalPrice) * 100) 
      : 0);
    
    const price = new Intl.NumberFormat(this.lang === 'es' ? 'es-ES' : 'en-US', {
      style: 'currency', currency: p.currency || 'EUR'
    }).format(p.price);
    
    const oldPrice = p.originalPrice ? new Intl.NumberFormat(this.lang === 'es' ? 'es-ES' : 'en-US', {
      style: 'currency', currency: p.currency || 'EUR'
    }).format(p.originalPrice) : '';
    
    // Check if product has YouTube video
    const hasVideo = p.youtubeVideo && p.youtubeVideo.videoId;
    
    // Media content: video or image (respects mediaMode preference)
    const showVideo = hasVideo && this.mediaMode === 'video';
    const thumbUrl = p.youtubeVideo?.thumbnail || `https://i.ytimg.com/vi/${p.youtubeVideo?.videoId}/maxresdefault.jpg`;
    
    // Update slide class if showing video
    if (showVideo) {
      el.className = 'slide slide-video';
      el.dataset.videoId = p.youtubeVideo.videoId;
    }
    
    const mediaContent = showVideo 
      ? `<div class="video-fullscreen">
          <div class="video-loading">
            <img src="${thumbUrl}" alt="" class="video-thumb" />
            <div class="video-loader-overlay">
              <div class="video-spinner"></div>
            </div>
          </div>
          <iframe 
            src="" 
            title="${p.youtubeVideo.title}"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="video-iframe"
            data-video-id="${p.youtubeVideo.videoId}"
          ></iframe>
          <div class="video-tap-area" title="${this.lang === 'es' ? 'Tocar para pausar' : 'Tap to pause'}"></div>
          <div class="video-pause-indicator">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/>
            </svg>
          </div>
          <div class="video-channel">
            <svg viewBox="0 0 24 24" fill="#ff0000" width="16" height="16">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/>
              <polygon fill="#fff" points="9.545,15.568 15.818,12 9.545,8.432"/>
            </svg>
            <span>${p.youtubeVideo.channelTitle || 'YouTube'}</span>
          </div>
        </div>`
      : `<img src="${p.featuredImage?.url || ''}" alt="${p.title}" loading="lazy" class="product-img" />`;
    
    // Build badges HTML
    const badges = p.badges || [];
    const badgesHtml = badges.length > 0 ? `
      <div class="product-badges">
        ${badges.includes('curated') ? `<span class="badge badge-curated" title="${this.lang === 'es' ? 'Deal destacado' : 'Featured Deal'}">
          <svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12"><path d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
          ${this.lang === 'es' ? 'Destacado' : 'Featured'}
        </span>` : ''}
        ${badges.includes('for_you') ? `<span class="badge badge-foryou" title="${this.lang === 'es' ? 'Basado en tus preferencias' : 'Based on your preferences'}">
          <svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12"><path d="M12 2l2.09 6.26L21 9.27l-5.46 4.29 2.09 6.44-5.63-4.09-5.63 4.09 2.09-6.44L3 9.27l6.91-1.01L12 2z"/></svg>
          ${this.lang === 'es' ? 'Para ti' : 'For you'}
        </span>` : ''}
        ${badges.includes('verified_deal') ? `<span class="badge badge-verified" title="${this.lang === 'es' ? 'Precio verificado' : 'Verified price'}">
          <svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12"><path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          ${this.lang === 'es' ? 'Verificado' : 'Verified'}
        </span>` : ''}
      </div>
    ` : '';
    
    el.innerHTML = `
      <div class="slide-main">
        ${mediaContent}
        ${badgesHtml}
      </div>

      <div class="slide-sidebar">
        <button class="action share-btn" data-url="${p.affiliateUrl}">
          <svg viewBox="0 0 24 24"><path d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 9.316a3 3 0 105.367 2.684 3 3 0 00-5.367-2.684zm0-9.316a3 3 0 105.368-2.684 3 3 0 00-5.368 2.684z"/></svg>
        </button>
        <button class="action save-btn" data-asin="${p.asin}">
          <svg viewBox="0 0 24 24"><path d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0z"/></svg>
        </button>
      </div>
      
      <div class="slide-footer">
        <span class="brand">${p.brand || ''}</span>
        <h2 class="title">${this.truncateTitle(p.title)}</h2>
        ${this.getDescriptionHtml(p)}
        <div class="pricing">
          <span class="price">${price}</span>
          ${oldPrice ? `<span class="old-price">${oldPrice}</span>` : ''}
          ${discount >= 15 ? `<span class="badge-discount">-${discount}%</span>` : ''}
        </div>
        <a href="${p.affiliateUrl}" target="_blank" rel="noopener noreferrer nofollow" class="cta">
          ${this.texts.buy}
          <svg viewBox="0 0 20 20" fill="currentColor"><path d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"/></svg>
        </a>
      </div>
    `;
    
    // Setup image error handler only if showing image (not video)
    if (!showVideo) {
      const img = el.querySelector('.product-img');
      if (img) {
        img.onerror = () => {
          img.src = 'data:image/svg+xml,' + encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200"><rect fill="#f5f5f5" width="200" height="200"/><text fill="#ccc" font-family="system-ui" font-size="12" x="50%" y="50%" text-anchor="middle">No image</text></svg>');
        };
      }
    }
    
    // Setup video controls for video slides
    if (showVideo) {
      const tapArea = el.querySelector('.video-tap-area');
      const iframe = el.querySelector('.video-iframe');
      
      // Tap area for play/pause (tap anywhere on video)
      if (tapArea && iframe) {
        tapArea.addEventListener('click', (e) => {
          e.stopPropagation();
          this.togglePlayPause(el, iframe);
        });
      }
      
      // Don't load iframe yet - will be loaded when slide becomes visible
      el.dataset.playing = 'false';
    }
    
    this.setupSlide(el, p);
    return el;
  }
  
  setupSlide(el, p) {
    const shareBtn = el.querySelector('.share-btn');
    shareBtn?.addEventListener('click', async () => {
      const url = shareBtn.dataset.url;
      if (navigator.share) {
        try { await navigator.share({ url }); } catch (e) {}
      } else {
        try {
          await navigator.clipboard.writeText(url);
          // Visual feedback
          shareBtn.classList.add('copied');
          setTimeout(() => shareBtn.classList.remove('copied'), 1500);
        } catch (e) {
          console.error('Failed to copy:', e);
        }
      }
    });
    
    const saveBtn = el.querySelector('.save-btn');
    if (saveBtn) {
      const saved = JSON.parse(localStorage.getItem('savedProducts') || '[]');
      const isSaved = saved.some(item => (typeof item === 'string' ? item : item.asin) === p.asin);
      if (isSaved) saveBtn.classList.add('active');
      saveBtn.addEventListener('click', () => {
        const items = JSON.parse(localStorage.getItem('savedProducts') || '[]');
        const existingIndex = items.findIndex(item => (typeof item === 'string' ? item : item.asin) === p.asin);
        if (existingIndex !== -1) {
          items.splice(existingIndex, 1);
          localStorage.setItem('savedProducts', JSON.stringify(items));
          saveBtn.classList.remove('active');
        } else {
          // Save full product object
          items.push({
            asin: p.asin,
            title: p.title,
            brand: p.brand || '',
            image: p.featuredImage?.url || '',
            price: p.formattedPrice || '',
            affiliateUrl: p.affiliateUrl
          });
          localStorage.setItem('savedProducts', JSON.stringify(items));
          saveBtn.classList.add('active');
        }
      });
    }
    
    // See more button for description
    const seeMoreBtn = el.querySelector('.see-more');
    const descEl = el.querySelector('.description');
    if (seeMoreBtn && descEl) {
      const fullDesc = p.shortDescription || p.description || '';
      seeMoreBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const descText = el.querySelector('.desc-text');
        if (descText) {
          descText.textContent = fullDesc;
          descEl.dataset.expanded = 'true';
          seeMoreBtn.style.display = 'none';
        }
      });
    }
  }
  
  truncateTitle(title) {
    if (title.length <= 60) return title;
    return title.substring(0, 60).trim() + '...';
  }
  
  // Check if description is meaningfully different from title
  isDescriptionUnique(title, desc) {
    if (!desc) return false;
    const normTitle = title.toLowerCase().replace(/[^a-z0-9]/g, '').slice(0, 50);
    const normDesc = desc.toLowerCase().replace(/[^a-z0-9]/g, '').slice(0, 50);
    // If description starts the same as title, it's not unique
    if (normDesc.startsWith(normTitle.slice(0, 30))) return false;
    if (normTitle.startsWith(normDesc.slice(0, 30))) return false;
    return true;
  }
  
  getDescriptionHtml(p) {
    const desc = p.shortDescription || p.description;
    if (!desc || !this.isDescriptionUnique(p.title, desc)) return '';
    
    const isLong = desc.length > 100;
    const truncated = isLong ? desc.substring(0, 100).trim() + '...' : desc;
    const seeMoreText = this.lang === 'es' ? 'Ver más' : 'See more';
    
    return `
      <p class="description" data-expanded="false">
        <span class="desc-text">${truncated}</span>
        ${isLong ? `<button class="see-more">${seeMoreText}</button>` : ''}
      </p>
    `;
  }
  
  checkPreload() {
    if (this.loading || !this.hasMore) return;
    const slides = this.scroll?.querySelectorAll('.slide:not(.skeleton-slide)');
    if (!slides?.length) return;
    
    const scrollTop = this.scroll.scrollTop;
    const slideHeight = this.scroll.clientHeight;
    const currentIndex = Math.round(scrollTop / slideHeight);
    
    if (currentIndex >= slides.length - 2) {
      this.load();
    }
  }
  
}

let feed = null;

function initFeed() {
  const container = document.getElementById('reel-feed');
  if (!container) return;
  
  const view = container.closest('.view');
  
  // Initialize immediately if no view wrapper or view is active
  if (!view || view.classList.contains('active')) {
    if (!feed) {
      feed = new Feed();
    }
  }
  
  // Also listen for activation event
  view?.addEventListener('feed:activated', () => {
    if (!feed) feed = new Feed();
  });
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initFeed);
} else {
  initFeed();
}
document.addEventListener('astro:page-load', () => { feed = null; initFeed(); });
</script>

