      const tapArea = el.querySelector('.video-tap-area');
      const iframe = el.querySelector('.video-iframe');
      const soundBtn = el.querySelector('.video-sound-btn');
      let controlsHideTimeout = null;

      // Show controls temporarily
      const showControls = () => {
        el.classList.add('controls-visible');
        clearTimeout(controlsHideTimeout);
        controlsHideTimeout = setTimeout(() => {
          el.classList.remove('controls-visible');
        }, 3000); // Hide after 3 seconds
      };

      // Tap area for play/pause (tap anywhere on video)
      if (tapArea && iframe) {
        tapArea.addEventListener('click', (e) => {
          e.stopPropagation();
          showControls(); // Show controls on tap
          this.togglePlayPause(el, iframe);
        });
      }

      // Desktop: show controls on mouse movement
      el.addEventListener('mousemove', () => {
        showControls();
      });

      // Sound button to toggle mute
      if (soundBtn && iframe) {
        soundBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          showControls(); // Keep controls visible when interacting
          const isMuted = soundBtn.dataset.muted === 'true';

          if (isMuted) {
            // Unmute
            this.sendYouTubeCommand(iframe, 'unMute');
            this.globalMuted = false; // Save preference globally
            this.updateSoundButtonUI(el, true);
          } else {
            // Mute
            this.sendYouTubeCommand(iframe, 'mute');
            this.globalMuted = true; // Save preference globally
            this.updateSoundButtonUI(el, false);
          }
        });
      }

      // Don't load iframe yet - will be loaded when slide becomes visible
      el.dataset.playing = 'false';
    }
    
    this.setupSlide(el, p);
    return el;
  }
  
  setupSlide(el, p) {
    const shareBtn = el.querySelector('.share-btn');
    shareBtn?.addEventListener('click', async () => {
      const url = shareBtn.dataset.url;
      // Track share engagement
      this.trackEngagement(p.asin, 'share', { category: p.category });

      if (navigator.share) {
        try { await navigator.share({ url }); } catch (e) {}
      } else {
        try {
          await navigator.clipboard.writeText(url);
          // Visual feedback
          shareBtn.classList.add('copied');
          setTimeout(() => shareBtn.classList.remove('copied'), 1500);
        } catch (e) {
          console.error('Failed to copy:', e);
        }
      }
    });

    const saveBtn = el.querySelector('.save-btn');
    if (saveBtn) {
      const saved = JSON.parse(localStorage.getItem('savedProducts') || '[]');
      const isSaved = saved.some(item => (typeof item === 'string' ? item : item.asin) === p.asin);
      if (isSaved) saveBtn.classList.add('active');
      saveBtn.addEventListener('click', () => {
        const items = JSON.parse(localStorage.getItem('savedProducts') || '[]');
        const existingIndex = items.findIndex(item => (typeof item === 'string' ? item : item.asin) === p.asin);
        if (existingIndex !== -1) {
          items.splice(existingIndex, 1);
          localStorage.setItem('savedProducts', JSON.stringify(items));
          saveBtn.classList.remove('active');
        } else {
          // Track save engagement (high-value signal)
          this.trackEngagement(p.asin, 'save', { category: p.category });

          // Save full product object
          items.push({
            asin: p.asin,
            title: p.title,
            brand: p.brand || '',
            image: p.featuredImage?.url || '',
            price: p.formattedPrice || '',
            affiliateUrl: p.affiliateUrl
          });
          localStorage.setItem('savedProducts', JSON.stringify(items));
          saveBtn.classList.add('active');
        }
      });
    }

    // Track affiliate link clicks (highest value signal)
    const ctaLink = el.querySelector('.cta');
    ctaLink?.addEventListener('click', () => {
      this.trackEngagement(p.asin, 'affiliate_click', { category: p.category });
    });

    // Add to Cart button
    const addCartBtn = el.querySelector('.add-cart-btn');
    addCartBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      e.preventDefault();

      // Check if cart API is available
      if (!window.cart) {
        console.warn('Cart API not available');
        return;
      }

      // Get product data from data attributes
      const btn = e.currentTarget;
      const product = {
        asin: btn.dataset.asin || '',
        productId: btn.dataset.productId || '',
        title: btn.dataset.title || '',
        brand: btn.dataset.brand || '',
        image: btn.dataset.image || '',
        price: parseFloat(btn.dataset.price || '0'),
        currency: btn.dataset.currency || 'EUR',
        affiliateUrl: btn.dataset.affiliateUrl || '',
      };

      // Add to cart
      window.cart.add(product);

      // Show toast notification
      this.showCartToast(product);

      // Visual feedback
      addCartBtn.classList.add('added');
      setTimeout(() => {
        addCartBtn.classList.remove('added');
      }, 1500);

      // Track engagement
      this.trackEngagement(p.asin, 'add_to_cart', { category: p.category });
    });

    // Rating row click to expand reviews panel
    const ratingRow = el.querySelector('[data-expandable-rating]');
    const reviewsPanel = el.querySelector('[data-reviews-panel]');

    if (ratingRow && reviewsPanel) {
      ratingRow.addEventListener('click', (e) => {
        e.stopPropagation();
        reviewsPanel.classList.toggle('open');
        ratingRow.classList.toggle('expanded');
      });

      // Close button
      const closeBtn = el.querySelector('[data-close-reviews]');
      if (closeBtn) {
        closeBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          reviewsPanel.classList.remove('open');
          ratingRow.classList.remove('expanded');
        });
      }
    }
  }

  truncateTitle(title) {
    if (title.length <= 60) return title;
    return title.substring(0, 60).trim() + '...';
  }

  getRatingHtml(p) {
    if (!p.rating) return '';
    const stars = Math.round(p.rating);
    const reviewsText = this.lang === 'es' ? 'opiniones' : 'reviews';
    const hasReviews = p.topReviews && p.topReviews.reviews && p.topReviews.reviews.length > 0;

    return `
      <div class="rating-row ${hasReviews ? 'has-reviews' : ''}" ${hasReviews ? 'data-expandable-rating' : ''}>
        <div class="rating-main">
          <div class="stars">
            ${[1,2,3,4,5].map(s => `<svg class="star ${s <= stars ? 'filled' : ''}" viewBox="0 0 24 24" fill="${s <= stars ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2"><path d="M12 2l2.4 7.4h7.6l-6 4.6 2.3 7-6.3-4.6-6.3 4.6 2.3-7-6-4.6h7.6z"/></svg>`).join('')}
          </div>
          <span class="rating-text">${p.rating.toFixed(1)}</span>
          ${p.totalReviews ? `<span class="reviews-count">(${p.totalReviews.toLocaleString()} ${reviewsText})</span>` : ''}
          ${hasReviews ? `<span class="rating-expand-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="m6 9 6 6 6-6"/></svg></span>` : ''}
        </div>
      </div>
    `;
  }

  getPriceContextHtml(p) {
    if (!p.priceContext) return '';
    // Short labels for mobile-friendly display
    const lowestText = this.lang === 'es' ? 'Mín. 30d' : 'Low 30d';
    const belowText = this.lang === 'es' ? 'bajo avg' : 'below avg';
    const dropText = this.lang === 'es' ? 'bajó' : 'dropped';

    const { isLowestIn30Days, percentBelowAvg, priceDrop7Days, priceHistory } = p.priceContext;
    const hasPriceRange = priceHistory && priceHistory.length >= 3;

    // Calculate min/max from price history
    const minPrice30d = hasPriceRange ? Math.min(...priceHistory) : 0;
    const maxPrice30d = hasPriceRange ? Math.max(...priceHistory) : 0;

    // Generate price range bar
    let priceRangeHtml = '';
    if (hasPriceRange && minPrice30d && maxPrice30d && maxPrice30d > minPrice30d) {
      const currentPrice = p.price;
      const range = maxPrice30d - minPrice30d;
      const position = Math.max(0, Math.min(100, ((currentPrice - minPrice30d) / range) * 100));
      const isGoodDeal = position <= 30; // In lower 30% of range

      const currency = p.currency || 'USD';
      const formatPrice = (val) => new Intl.NumberFormat(this.lang === 'es' ? 'es-ES' : 'en-US', {
        style: 'currency', currency, minimumFractionDigits: 0, maximumFractionDigits: 0
      }).format(val);

      const rangeLabel = this.lang === 'es' ? 'Rango 30d' : '30d range';

      priceRangeHtml = `
        <div class="price-range-bar" title="${rangeLabel}: ${formatPrice(minPrice30d)} - ${formatPrice(maxPrice30d)}">
          <div class="range-labels">
            <span class="range-min">${formatPrice(minPrice30d)}</span>
            <span class="range-label">${rangeLabel}</span>
            <span class="range-max">${formatPrice(maxPrice30d)}</span>
          </div>
          <div class="range-track">
            <div class="range-fill" style="width: ${position}%"></div>
            <div class="range-marker ${isGoodDeal ? 'good-deal' : ''}" style="left: ${position}%">
              <span class="marker-dot"></span>
            </div>
          </div>
        </div>
      `;
    }

    return `
      <div class="price-context">
        ${priceDrop7Days && priceDrop7Days >= 10 ? `
          <span class="context-badge price-drop">
            <svg viewBox="0 0 24 24" fill="currentColor" width="10" height="10"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
            -${priceDrop7Days}%
          </span>
        ` : ''}
        ${isLowestIn30Days && !(priceDrop7Days && priceDrop7Days >= 10) ? `
          <span class="context-badge lowest">
            <svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12"><path d="M12 2l-1 9h-9l7 5-3 9 6-5 6 5-3-9 7-5h-9z"/></svg>
            ${lowestText}
          </span>
        ` : ''}
        ${percentBelowAvg > 0 ? `
          <span class="context-badge below-avg">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
            ${percentBelowAvg}% ${belowText}
          </span>
        ` : ''}
      </div>
      ${priceRangeHtml}
    `;
  }

  getReviewsHtml(p) {
    if (!p.topReviews || !p.topReviews.reviews || p.topReviews.reviews.length === 0) {
      return '';
    }

    const verifiedText = this.lang === 'es' ? 'Verificada' : 'Verified';
    const closeText = this.lang === 'es' ? 'Cerrar' : 'Close';

    const reviewsHtml = p.topReviews.reviews.slice(0, 2).map((review, idx) => {
      const stars = Math.round(review.rating);
      const starsHtml = [1,2,3,4,5].map(s =>
        `<svg class="review-star ${s <= stars ? 'filled' : ''}" viewBox="0 0 24 24" fill="${s <= stars ? '#FF9900' : 'none'}" stroke="#FF9900" stroke-width="1.5" width="10" height="10"><path d="M12 2l2.4 7.4h7.6l-6 4.6 2.3 7-6.3-4.6-6.3 4.6 2.3-7-6-4.6h7.6z"/></svg>`
      ).join('');

      const contentEscaped = (review.content || '').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      const titleEscaped = review.title ? review.title.replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;') : '';

      return `
        <div class="review-item">
          <div class="review-item-header">
            <div class="review-stars">${starsHtml}</div>
            ${review.isVerifiedPurchase ? `<span class="verified-mini">✓ ${verifiedText}</span>` : ''}
            ${review.reviewerName ? `<span class="reviewer-mini">— ${review.reviewerName}</span>` : ''}
          </div>
          ${titleEscaped ? `<p class="review-item-title">${titleEscaped}</p>` : ''}
          <p class="review-item-content">${contentEscaped}</p>
        </div>
      `;
    }).join('');

    return `
      <div class="reviews-panel" data-reviews-panel>
        <div class="reviews-panel-scroll">
          ${reviewsHtml}
        </div>
        <button type="button" class="reviews-panel-close" data-close-reviews>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="m6 9 6 6 6-6"/></svg>
          ${closeText}
        </button>
      </div>
    `;
  }

  checkPreload() {
    if (this.loading || !this.hasMore) return;
    const slides = this.scroll?.querySelectorAll('.slide:not(.skeleton-slide)');
    if (!slides?.length) return;

    const scrollTop = this.scroll.scrollTop;
    const scrollHeight = this.scroll.scrollHeight;
    const clientHeight = this.scroll.clientHeight;

    // Calculate how close we are to the bottom
    // Load more when we're within 2 viewport heights of the end
    const distanceFromBottom = scrollHeight - scrollTop - clientHeight;
    const threshold = clientHeight * 2;

    // Debug logging
    console.log(`[Feed] checkPreload: distanceFromBottom=${Math.round(distanceFromBottom)}, threshold=${Math.round(threshold)}, slides=${slides.length}, hasMore=${this.hasMore}, loading=${this.loading}`);

    if (distanceFromBottom <= threshold) {
      console.log('[Feed] Loading more products...');
      this.load();
    }
  }
  
}

let feed = null;

function initFeed() {
  const container = document.getElementById('reel-feed');
  if (!container) return;
  
  const view = container.closest('.view');
  
  // Initialize immediately if no view wrapper or view is active
  if (!view || view.classList.contains('active')) {
    if (!feed) {
      feed = new Feed();
    }
  }
  
  // Also listen for activation event
  view?.addEventListener('feed:activated', () => {
    if (!feed) feed = new Feed();
  });
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initFeed);
} else {
  initFeed();
}
document.addEventListener('astro:page-load', () => { feed = null; initFeed(); });
</script>
