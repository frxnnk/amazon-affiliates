          ${this.lang === 'es' ? 'Top Ventas' : 'Best Seller'}
        </span>` : ''}
        ${p.isAmazonChoice ? `<span class="badge badge-choice" title="${this.lang === 'es' ? 'Selección de Amazon' : "Amazon's Choice"}">
