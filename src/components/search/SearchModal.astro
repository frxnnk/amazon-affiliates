---
import { type Lang, getTranslation } from '@i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslation(lang);

const placeholderText = lang === 'es' ? 'Buscar productos...' : 'Search products...';
const noResultsText = lang === 'es' ? 'No se encontraron resultados' : 'No results found';
const searchingText = lang === 'es' ? 'Buscando...' : 'Searching...';
---

<div
  id="search-modal"
  class="search-modal"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  aria-labelledby="search-modal-title"
>
  <div class="search-backdrop"></div>
  <div class="search-container">
    <div class="search-header">
      <h2 id="search-modal-title" class="sr-only">
        {lang === 'es' ? 'Buscar productos' : 'Search products'}
      </h2>
      <div class="search-input-wrapper">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <circle cx="11" cy="11" r="8" />
          <path d="M21 21l-4.35-4.35" />
        </svg>
        <label for="search-input" class="sr-only">
          {lang === 'es' ? 'Buscar productos' : 'Search products'}
        </label>
        <input
          type="search"
          id="search-input"
          class="search-input"
          placeholder={placeholderText}
          autocomplete="off"
          autofocus
          aria-describedby="search-status"
        />
        <button
          type="button"
          id="search-close"
          class="search-close"
          aria-label={lang === 'es' ? 'Cerrar búsqueda' : 'Close search'}
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M18 6L6 18M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Live region for screen reader announcements -->
    <div
      id="search-status"
      class="sr-only"
      role="status"
      aria-live="polite"
      aria-atomic="true"
    ></div>

    <div id="search-results" class="search-results" role="region" aria-label={lang === 'es' ? 'Resultados de búsqueda' : 'Search results'}>
      <div class="search-empty" id="search-empty">
        <p>{lang === 'es' ? 'Escribe para buscar productos o pega un link de Amazon' : 'Type to search products or paste an Amazon link'}</p>
      </div>
      <div class="search-loading hidden" id="search-loading" aria-hidden="true">
        <div class="spinner" aria-hidden="true"></div>
        <p>{searchingText}</p>
      </div>
      <div class="search-no-results hidden" id="search-no-results">
        <p>{noResultsText}</p>
      </div>
      <!-- Amazon Link Generator Result -->
      <div class="amazon-link-result hidden" id="amazon-link-result">
        <div class="amazon-link-header">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
          </svg>
          <h3>{lang === 'es' ? 'Link de Referido Generado' : 'Affiliate Link Generated'}</h3>
        </div>
        <div class="amazon-link-info">
          <span class="amazon-link-label">ASIN:</span>
          <code class="amazon-link-asin" id="amazon-link-asin"></code>
        </div>
        <div class="amazon-link-box">
          <input type="text" id="amazon-link-url" class="amazon-link-input" readonly />
          <button type="button" id="amazon-link-copy" class="amazon-link-copy">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
            </svg>
            {lang === 'es' ? 'Copiar' : 'Copy'}
          </button>
        </div>
        <div class="amazon-link-actions">
          <a href="#" id="amazon-link-open" class="amazon-link-open" target="_blank" rel="nofollow noopener sponsored">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
              <polyline points="15 3 21 3 21 9" />
              <line x1="10" y1="14" x2="21" y2="3" />
            </svg>
            {lang === 'es' ? 'Abrir en Amazon' : 'Open on Amazon'}
          </a>
          <button type="button" id="amazon-link-cart" class="amazon-link-cart">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
              <line x1="3" y1="6" x2="21" y2="6" />
              <path d="M16 10a4 4 0 0 1-8 0" />
            </svg>
            {lang === 'es' ? 'Agregar al carrito' : 'Add to cart'}
          </button>
        </div>
        <p class="amazon-link-disclaimer">{lang === 'es' ? 'Este link incluye nuestro tag de afiliado. ¡Gracias por apoyarnos!' : 'This link includes our affiliate tag. Thanks for supporting us!'}</p>
      </div>
      <div id="search-results-list" class="search-results-list" role="list"></div>
    </div>
  </div>
</div>

<style>
  /* Neo-Brutalist Search Modal */
  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 10vh;
    opacity: 0;
    visibility: hidden;
    transition: opacity 150ms, visibility 150ms;
  }

  .search-modal[aria-hidden="false"] {
    opacity: 1;
    visibility: visible;
  }

  .search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(26, 26, 26, 0.8);
  }

  .search-container {
    position: relative;
    width: 100%;
    max-width: 600px;
    margin: 0 1rem;
    background: var(--color-cream, #FFFEF9);
    border: 4px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 12px 12px 0 var(--color-brutal-black, #1A1A1A);
    overflow: hidden;
    transform: translateY(-20px) rotate(-1deg);
    transition: transform 200ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  .search-modal[aria-hidden="false"] .search-container {
    transform: translateY(0) rotate(0deg);
  }

  .search-header {
    padding: 1rem 1.25rem;
    border-bottom: 3px solid var(--color-brutal-black, #1A1A1A);
    background: var(--color-brutal-yellow, #FFE14D);
  }

  .search-input-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .search-icon {
    width: 1.5rem;
    height: 1.5rem;
    color: var(--color-brutal-black, #1A1A1A);
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    border: none;
    outline: none;
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-brutal-black, #1A1A1A);
    background: transparent;
  }

  .search-input::placeholder {
    color: var(--color-brutal-black, #1A1A1A);
    opacity: 0.5;
  }

  .search-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    background: var(--color-cream, #FFFEF9);
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-black, #1A1A1A);
    cursor: pointer;
    box-shadow: 3px 3px 0 var(--color-brutal-black, #1A1A1A);
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
    flex-shrink: 0;
  }

  .search-close:hover {
    background: var(--color-brutal-orange, #FF6B35);
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 var(--color-brutal-black, #1A1A1A);
  }

  .search-close:active {
    transform: translate(1px, 1px);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
  }

  .search-close:focus-visible {
    outline: 3px solid var(--color-brutal-orange, #FF6B35);
    outline-offset: 2px;
  }

  .search-close svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .search-results {
    max-height: 60vh;
    overflow-y: auto;
    background: var(--color-cream, #FFFEF9);
  }

  .search-empty,
  .search-loading,
  .search-no-results {
    padding: 3rem 2rem;
    text-align: center;
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-weight: 600;
    color: var(--color-brutal-black, #1A1A1A);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .search-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .spinner {
    width: 2rem;
    height: 2rem;
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    border-top-color: var(--color-brutal-yellow, #FFE14D);
    animation: spin 0.6s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .hidden {
    display: none !important;
  }

  .search-results-list {
    padding: 0.75rem;
  }

  .search-results-list:empty {
    display: none;
  }

  /* Amazon Link Generator Styles */
  .amazon-link-result {
    padding: 1.5rem;
    background: var(--color-brutal-yellow, #FFE14D);
    border-bottom: 3px solid var(--color-brutal-black, #1A1A1A);
  }

  .amazon-link-result.hidden {
    display: none;
  }

  .amazon-link-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .amazon-link-header svg {
    width: 1.5rem;
    height: 1.5rem;
    color: var(--color-brutal-orange, #FF6B35);
  }

  .amazon-link-header h3 {
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    margin: 0;
  }

  .amazon-link-info {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .amazon-link-label {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.75rem;
    font-weight: 600;
    opacity: 0.7;
  }

  .amazon-link-asin {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.875rem;
    font-weight: 700;
    background: var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-yellow, #FFE14D);
    padding: 0.25rem 0.5rem;
  }

  .amazon-link-box {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .amazon-link-input {
    flex: 1;
    padding: 0.75rem 1rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.75rem;
    background: var(--color-cream, #FFFEF9);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 3px 3px 0 var(--color-brutal-black, #1A1A1A);
    outline: none;
  }

  .amazon-link-copy {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: var(--color-brutal-black, #1A1A1A);
    color: var(--color-cream, #FFFEF9);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    cursor: pointer;
    box-shadow: 3px 3px 0 var(--color-brutal-black, #1A1A1A);
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  .amazon-link-copy:hover {
    background: var(--color-brutal-orange, #FF6B35);
    color: var(--color-brutal-black, #1A1A1A);
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 var(--color-brutal-black, #1A1A1A);
  }

  .amazon-link-copy svg {
    width: 1rem;
    height: 1rem;
  }

  .amazon-link-copy[data-copied="true"] {
    background: #22c55e;
  }

  .amazon-link-actions {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .amazon-link-open,
  .amazon-link-cart {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    cursor: pointer;
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 3px 3px 0 var(--color-brutal-black, #1A1A1A);
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  .amazon-link-open {
    background: var(--color-brutal-orange, #FF6B35);
    color: var(--color-brutal-black, #1A1A1A);
    text-decoration: none;
  }

  .amazon-link-open:hover {
    background: var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-orange, #FF6B35);
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 var(--color-brutal-black, #1A1A1A);
  }

  .amazon-link-cart {
    background: var(--color-cream, #FFFEF9);
    color: var(--color-brutal-black, #1A1A1A);
  }

  .amazon-link-cart:hover {
    background: var(--color-brutal-yellow, #FFE14D);
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 var(--color-brutal-black, #1A1A1A);
  }

  .amazon-link-open svg,
  .amazon-link-cart svg {
    width: 1rem;
    height: 1rem;
  }

  .amazon-link-disclaimer {
    font-size: 0.6875rem;
    color: var(--color-brutal-black, #1A1A1A);
    opacity: 0.6;
    margin: 0;
    text-align: center;
  }

  /* Result item styles - will be added dynamically */
  :global(.search-result-item) {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem;
    text-decoration: none;
    border: 2px solid transparent;
    margin-bottom: 0.5rem;
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  :global(.search-result-item:hover) {
    background: var(--color-brutal-yellow, #FFE14D);
    border-color: var(--color-brutal-black, #1A1A1A);
    box-shadow: 4px 4px 0 var(--color-brutal-black, #1A1A1A);
    transform: translate(-2px, -2px);
  }

  :global(.search-result-image) {
    width: 3.5rem;
    height: 3.5rem;
    background: var(--color-white, #FFFFFF);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    object-fit: contain;
    padding: 0.25rem;
  }

  :global(.search-result-content) {
    flex: 1;
    min-width: 0;
  }

  :global(.search-result-brand) {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.625rem;
    font-weight: 700;
    color: var(--color-brutal-black, #1A1A1A);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  :global(.search-result-title) {
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-brutal-black, #1A1A1A);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.search-result-price) {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-brutal-black, #1A1A1A);
    background: var(--color-brutal-yellow, #FFE14D);
    padding: 0.25rem 0.5rem;
    border: 2px solid var(--color-brutal-black, #1A1A1A);
  }
</style>

<script>
  import Fuse from 'fuse.js';

  interface Product {
    productId: string;
    title: string;
    brand: string;
    price: number;
    currency: string;
    featuredImage: { url: string; alt: string };
    lang: string;
  }

  let fuse: Fuse<Product> | null = null;
  let products: Product[] = [];
  let currentLang = document.documentElement.lang || 'es';
  let previousActiveElement: HTMLElement | null = null;

  const modal = document.getElementById('search-modal');
  const triggerDesktop = document.getElementById('search-trigger-desktop');
  const triggerMobile = document.getElementById('search-trigger-mobile');
  const closeBtn = document.getElementById('search-close');
  const input = document.getElementById('search-input') as HTMLInputElement;
  const resultsContainer = document.getElementById('search-results-list');
  const emptyState = document.getElementById('search-empty');
  const loadingState = document.getElementById('search-loading');
  const noResultsState = document.getElementById('search-no-results');
  const statusRegion = document.getElementById('search-status');
  const searchContainer = modal?.querySelector('.search-container');

  // Amazon link generator elements
  const amazonLinkResult = document.getElementById('amazon-link-result');
  const amazonLinkAsin = document.getElementById('amazon-link-asin');
  const amazonLinkUrl = document.getElementById('amazon-link-url') as HTMLInputElement;
  const amazonLinkCopy = document.getElementById('amazon-link-copy');
  const amazonLinkOpen = document.getElementById('amazon-link-open') as HTMLAnchorElement;
  const amazonLinkCart = document.getElementById('amazon-link-cart');

  // Affiliate tag configuration
  const AFFILIATE_TAG = 'bestdeal0ee40-20';

  // Announce to screen readers
  function announce(message: string) {
    if (statusRegion) {
      statusRegion.textContent = message;
    }
  }

  // Amazon URL detection and parsing
  function isAmazonUrl(text: string): boolean {
    const amazonPattern = /amazon\.(com|es|co\.uk|de|fr|it|ca|com\.mx|com\.br|co\.jp|in|com\.au)/i;
    return amazonPattern.test(text);
  }

  function extractAsinFromUrl(url: string): string | null {
    // Multiple patterns to match ASIN in Amazon URLs
    const patterns = [
      /\/dp\/([A-Z0-9]{10})/i,
      /\/gp\/product\/([A-Z0-9]{10})/i,
      /\/gp\/aw\/d\/([A-Z0-9]{10})/i,
      /\/product\/([A-Z0-9]{10})/i,
      /\/ASIN\/([A-Z0-9]{10})/i,
      /\/?([A-Z0-9]{10})(?:\/|\?|$)/i,
    ];

    for (const pattern of patterns) {
      const match = url.match(pattern);
      if (match && match[1]) {
        // Validate it looks like an ASIN (starts with B0 typically or is alphanumeric)
        const potentialAsin = match[1].toUpperCase();
        if (/^[A-Z0-9]{10}$/.test(potentialAsin)) {
          return potentialAsin;
        }
      }
    }
    return null;
  }

  function getMarketplaceFromUrl(url: string): string {
    const marketplaceMap: { [key: string]: string } = {
      'amazon.com': 'amazon.com',
      'amazon.es': 'amazon.es',
      'amazon.co.uk': 'amazon.co.uk',
      'amazon.de': 'amazon.de',
      'amazon.fr': 'amazon.fr',
      'amazon.it': 'amazon.it',
      'amazon.ca': 'amazon.ca',
      'amazon.com.mx': 'amazon.com.mx',
      'amazon.com.br': 'amazon.com.br',
      'amazon.co.jp': 'amazon.co.jp',
      'amazon.in': 'amazon.in',
      'amazon.com.au': 'amazon.com.au',
    };

    for (const [pattern, marketplace] of Object.entries(marketplaceMap)) {
      if (url.includes(pattern)) {
        return marketplace;
      }
    }
    return 'amazon.com';
  }

  function generateAffiliateUrl(asin: string, marketplace: string): string {
    return `https://www.${marketplace}/dp/${asin}?tag=${AFFILIATE_TAG}&linkCode=ogi&th=1&psc=1`;
  }

  function showAmazonLinkResult(asin: string, affiliateUrl: string) {
    // Hide other states
    emptyState?.classList.add('hidden');
    loadingState?.classList.add('hidden');
    noResultsState?.classList.add('hidden');
    if (resultsContainer) resultsContainer.innerHTML = '';

    // Show amazon link result
    amazonLinkResult?.classList.remove('hidden');

    // Populate data
    if (amazonLinkAsin) amazonLinkAsin.textContent = asin;
    if (amazonLinkUrl) amazonLinkUrl.value = affiliateUrl;
    if (amazonLinkOpen) amazonLinkOpen.href = affiliateUrl;

    // Store ASIN for cart functionality
    if (amazonLinkCart) {
      amazonLinkCart.dataset.asin = asin;
      amazonLinkCart.dataset.affiliateUrl = affiliateUrl;
    }

    announce(currentLang === 'es' ? 'Link de referido generado' : 'Affiliate link generated');
  }

  function hideAmazonLinkResult() {
    amazonLinkResult?.classList.add('hidden');
  }

  // Get focusable elements within container
  function getFocusableElements(container: Element): HTMLElement[] {
    const selector = 'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])';
    return Array.from(container.querySelectorAll(selector)) as HTMLElement[];
  }

  // Focus trap handler
  function handleFocusTrap(e: KeyboardEvent) {
    if (e.key !== 'Tab' || !searchContainer) return;

    const focusable = getFocusableElements(searchContainer);
    if (focusable.length === 0) return;

    const firstFocusable = focusable[0];
    const lastFocusable = focusable[focusable.length - 1];

    if (e.shiftKey) {
      if (document.activeElement === firstFocusable) {
        e.preventDefault();
        lastFocusable.focus();
      }
    } else {
      if (document.activeElement === lastFocusable) {
        e.preventDefault();
        firstFocusable.focus();
      }
    }
  }

  // Fetch products and initialize Fuse
  async function initSearch() {
    try {
      announce(currentLang === 'es' ? 'Cargando búsqueda...' : 'Loading search...');
      const response = await fetch(`/api/search/products?lang=${currentLang}`);
      products = await response.json();

      fuse = new Fuse(products, {
        keys: ['title', 'brand'],
        threshold: 0.4,
        includeScore: true,
      });
      announce(currentLang === 'es' ? 'Búsqueda lista' : 'Search ready');
    } catch (error) {
      console.error('Failed to load search index:', error);
      announce(currentLang === 'es' ? 'Error al cargar búsqueda' : 'Failed to load search');
    }
  }

  function openModal() {
    // Store reference to element that triggered the modal
    previousActiveElement = document.activeElement as HTMLElement;

    modal?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';

    // Add focus trap listener
    document.addEventListener('keydown', handleFocusTrap);

    // Focus the input after a brief delay for animation
    setTimeout(() => input?.focus(), 100);

    if (!fuse) {
      initSearch();
    }
  }

  function closeModal() {
    modal?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    if (input) input.value = '';
    showState('empty');
    if (resultsContainer) resultsContainer.innerHTML = '';

    // Remove focus trap listener
    document.removeEventListener('keydown', handleFocusTrap);

    // Restore focus to the element that opened the modal
    if (previousActiveElement && previousActiveElement.focus) {
      previousActiveElement.focus();
    }
  }

  function showState(state: 'empty' | 'loading' | 'no-results' | 'results') {
    emptyState?.classList.toggle('hidden', state !== 'empty');
    loadingState?.classList.toggle('hidden', state !== 'loading');
    loadingState?.setAttribute('aria-hidden', state === 'loading' ? 'false' : 'true');
    noResultsState?.classList.toggle('hidden', state !== 'no-results');
  }

  function formatPrice(price: number, currency: string): string {
    return new Intl.NumberFormat(currentLang === 'es' ? 'es-ES' : 'en-US', {
      style: 'currency',
      currency,
    }).format(price);
  }

  function performSearch(query: string) {
    if (!query.trim()) {
      showState('empty');
      hideAmazonLinkResult();
      if (resultsContainer) resultsContainer.innerHTML = '';
      announce('');
      return;
    }

    // Check if the query is an Amazon URL
    if (isAmazonUrl(query)) {
      const asin = extractAsinFromUrl(query);
      if (asin) {
        const marketplace = getMarketplaceFromUrl(query);
        const affiliateUrl = generateAffiliateUrl(asin, marketplace);
        showAmazonLinkResult(asin, affiliateUrl);
        return;
      }
    }

    // Hide amazon link result if doing normal search
    hideAmazonLinkResult();

    if (!fuse) {
      showState('loading');
      announce(currentLang === 'es' ? 'Cargando...' : 'Loading...');
      return;
    }

    const results = fuse.search(query, { limit: 8 });

    if (results.length === 0) {
      showState('no-results');
      if (resultsContainer) resultsContainer.innerHTML = '';
      announce(currentLang === 'es' ? 'No se encontraron resultados' : 'No results found');
      return;
    }

    showState('results');

    // Announce results count
    const resultsMessage = currentLang === 'es'
      ? `${results.length} resultado${results.length !== 1 ? 's' : ''} encontrado${results.length !== 1 ? 's' : ''}`
      : `${results.length} result${results.length !== 1 ? 's' : ''} found`;
    announce(resultsMessage);

    if (resultsContainer) {
      resultsContainer.innerHTML = results
        .map(({ item }, index) => `
          <a
            href="/${item.lang}/products/${item.productId}"
            class="search-result-item"
            role="listitem"
            aria-label="${item.brand} ${item.title}, ${formatPrice(item.price, item.currency)}"
          >
            <img
              src="${item.featuredImage?.url || '/placeholder.jpg'}"
              alt=""
              class="search-result-image"
              loading="lazy"
              aria-hidden="true"
            />
            <div class="search-result-content">
              <span class="search-result-brand">${item.brand}</span>
              <h4 class="search-result-title">${item.title}</h4>
            </div>
            <span class="search-result-price" aria-hidden="true">${formatPrice(item.price, item.currency)}</span>
          </a>
        `)
        .join('');
    }
  }

  // Event listeners
  triggerDesktop?.addEventListener('click', openModal);
  triggerMobile?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);

  modal?.querySelector('.search-backdrop')?.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal?.getAttribute('aria-hidden') === 'false') {
      closeModal();
    }
    // Cmd/Ctrl + K to open search
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      openModal();
    }
  });

  let debounceTimer: ReturnType<typeof setTimeout>;
  input?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value;
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => performSearch(query), 150);
  });

  // Handle navigation from search results
  resultsContainer?.addEventListener('click', (e) => {
    const link = (e.target as HTMLElement).closest('a');
    if (link) {
      closeModal();
    }
  });

  // Amazon link copy button
  amazonLinkCopy?.addEventListener('click', async () => {
    if (!amazonLinkUrl?.value) return;

    try {
      await navigator.clipboard.writeText(amazonLinkUrl.value);
      amazonLinkCopy.dataset.copied = 'true';
      const originalText = amazonLinkCopy.innerHTML;
      amazonLinkCopy.innerHTML = `
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="20 6 9 17 4 12" />
        </svg>
        ${currentLang === 'es' ? 'Copiado!' : 'Copied!'}
      `;

      setTimeout(() => {
        amazonLinkCopy.dataset.copied = 'false';
        amazonLinkCopy.innerHTML = originalText;
      }, 2000);
    } catch (err) {
      console.error('Failed to copy:', err);
    }
  });

  // Amazon link add to cart button
  amazonLinkCart?.addEventListener('click', () => {
    const asin = amazonLinkCart.dataset.asin;
    const affiliateUrl = amazonLinkCart.dataset.affiliateUrl;

    if (asin && affiliateUrl && (window as any).cart?.add) {
      (window as any).cart.add({
        asin,
        productId: `amazon-${asin}`,
        title: `Amazon Product ${asin}`,
        brand: 'Amazon',
        image: '',
        price: 0,
        currency: 'USD',
        affiliateUrl
      });

      // Visual feedback
      const originalText = amazonLinkCart.innerHTML;
      amazonLinkCart.innerHTML = `
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="20 6 9 17 4 12" />
        </svg>
        ${currentLang === 'es' ? 'Agregado!' : 'Added!'}
      `;

      setTimeout(() => {
        amazonLinkCart.innerHTML = originalText;
      }, 2000);
    }
  });
</script>
