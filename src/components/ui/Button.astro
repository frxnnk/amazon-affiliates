---
interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost' | 'amazon';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  fullWidth?: boolean;
  class?: string;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  disabled = false,
  fullWidth = false,
  class: className
} = Astro.props;
---

{href ? (
  <a href={href} class:list={['btn', `btn-${variant}`, `btn-${size}`, fullWidth && 'btn-full', className]}>
    <slot />
  </a>
) : (
  <button type={type} disabled={disabled} class:list={['btn', `btn-${variant}`, `btn-${size}`, fullWidth && 'btn-full', className]}>
    <slot />
  </button>
)}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-sans, 'DM Sans', sans-serif);
    font-weight: 500;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* Sizes */
  .btn-sm {
    padding: 0.5rem 1rem;
    font-size: 0.8125rem;
  }

  .btn-md {
    padding: 0.75rem 1.5rem;
    font-size: 0.9375rem;
  }

  .btn-lg {
    padding: 1rem 2rem;
    font-size: 1rem;
  }

  .btn-full {
    width: 100%;
  }

  /* Primary - Dark ink button */
  .btn-primary {
    background: var(--color-ink, #1A1815);
    color: var(--color-cream, #FDFBF7);
  }

  .btn-primary:hover:not(:disabled) {
    background: var(--color-ink-light, #2D2926);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(26, 24, 21, 0.2);
  }

  /* Secondary - Warm honey button */
  .btn-secondary {
    background: var(--color-honey, #C8956C);
    color: white;
  }

  .btn-secondary:hover:not(:disabled) {
    background: var(--color-honey-dark, #A67B5B);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(200, 149, 108, 0.3);
  }

  /* Outline */
  .btn-outline {
    background: transparent;
    border: 2px solid var(--color-ink, #1A1815);
    color: var(--color-ink, #1A1815);
  }

  .btn-outline:hover:not(:disabled) {
    background: var(--color-ink, #1A1815);
    color: var(--color-cream, #FDFBF7);
    transform: translateY(-2px);
  }

  /* Ghost */
  .btn-ghost {
    background: transparent;
    color: var(--color-stone, #6B6560);
    padding-left: 0.75rem;
    padding-right: 0.75rem;
  }

  .btn-ghost:hover:not(:disabled) {
    color: var(--color-ink, #1A1815);
    background: var(--color-sand, #E8E4DD);
  }

  /* Amazon - Orange CTA */
  .btn-amazon {
    background: #FF9900;
    color: #0F1111;
    font-weight: 600;
  }

  .btn-amazon:hover:not(:disabled) {
    background: #FFB030;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(255, 153, 0, 0.35);
  }
</style>
