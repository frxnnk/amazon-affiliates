---
interface Props {
  variant?: 'default' | 'featured' | 'sale' | 'new' | 'bestseller' | 'cashback';
  size?: 'sm' | 'md';
  class?: string;
}

const { variant = 'default', size = 'sm', class: className } = Astro.props;
---

<span class:list={['badge', `badge-${variant}`, `badge-${size}`, className]}>
  <slot />
</span>

<style>
  /* Neo-Brutalist Badge System */
  .badge {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
  }

  /* Sizes */
  .badge-sm {
    padding: 0.25rem 0.5rem;
    font-size: 0.625rem;
  }

  .badge-md {
    padding: 0.375rem 0.75rem;
    font-size: 0.75rem;
  }

  /* Variants */
  .badge-default {
    background: var(--color-cream, #FFFEF9);
    color: var(--color-brutal-black, #1A1A1A);
  }

  .badge-featured {
    background: var(--color-brutal-yellow, #FFE14D);
    color: var(--color-brutal-black, #1A1A1A);
  }

  .badge-sale {
    background: var(--color-brutal-orange, #FF6B35);
    color: var(--color-brutal-black, #1A1A1A);
  }

  .badge-new {
    background: var(--color-brutal-blue, #4A90D9);
    color: var(--color-brutal-black, #1A1A1A);
  }

  .badge-bestseller {
    background: var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-yellow, #FFE14D);
  }

  .badge-cashback {
    background: var(--color-brutal-green, #2D9D4E);
    color: var(--color-brutal-black, #1A1A1A);
  }
</style>
