---
import { formatCurrency, TIER_BONUSES, type UserTier } from '@lib/db';

interface Props {
  balance: number;
  pendingCashback: number;
  tier: UserTier;
  lang: string;
}

const { balance, pendingCashback, tier, lang } = Astro.props;

const tierConfig: Record<UserTier, { icon: string; gradient: string }> = {
  bronze: { icon: '●', gradient: 'tier-bronze' },
  silver: { icon: '◆', gradient: 'tier-silver' },
  gold: { icon: '★', gradient: 'tier-gold' },
};

const tierBonus = TIER_BONUSES[tier] * 100;
const config = tierConfig[tier];

const labels = {
  en: {
    availableBalance: 'Available Balance',
    pendingCashback: 'Pending Cashback',
    tier: 'Your Tier',
    bonus: 'bonus',
    requestPayout: 'Request Payout',
    minPayout: 'Minimum payout: $15.00',
    claimsToSilver: 'claims to Silver',
    claimsToGold: 'claims to Gold',
    topTier: 'Top tier reached!',
  },
  es: {
    availableBalance: 'Balance Disponible',
    pendingCashback: 'Cashback Pendiente',
    tier: 'Tu Nivel',
    bonus: 'extra',
    requestPayout: 'Solicitar Pago',
    minPayout: 'Pago minimo: $15.00',
    claimsToSilver: 'pedidos para Plata',
    claimsToGold: 'pedidos para Oro',
    topTier: 'Nivel maximo alcanzado!',
  },
};

const t = labels[lang as keyof typeof labels] || labels.en;
const canRequestPayout = balance >= 1500; // $15.00 in cents
---

<div class="balance-card">
  <!-- Balance Stats -->
  <div class="balance-stats">
    <div class="stat-block primary">
      <span class="stat-label">{t.availableBalance}</span>
      <span class="stat-value">{formatCurrency(balance)}</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-block">
      <span class="stat-label">{t.pendingCashback}</span>
      <span class="stat-value pending">{formatCurrency(pendingCashback)}</span>
    </div>
  </div>

  <!-- Tier & Payout -->
  <div class="balance-footer">
    <div class={`tier-badge ${config.gradient}`}>
      <span class="tier-icon">{config.icon}</span>
      <div class="tier-info">
        <span class="tier-name">{tier.charAt(0).toUpperCase() + tier.slice(1)}</span>
        {tierBonus > 0 && <span class="tier-bonus">+{tierBonus}% {t.bonus}</span>}
      </div>
    </div>

    <div class="payout-section">
      <a
        href={canRequestPayout ? `/${lang}/dashboard/payout` : undefined}
        class:list={['payout-btn', { disabled: !canRequestPayout }]}
        aria-disabled={!canRequestPayout}
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
          <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
        </svg>
        {t.requestPayout}
      </a>
      {!canRequestPayout && <span class="payout-hint">{t.minPayout}</span>}
    </div>
  </div>
</div>

<style>
  .balance-card {
    background: var(--color-white, #FFFFFF);
    border: 1px solid var(--color-sand, #E8E4DD);
    border-radius: 20px;
    padding: 2rem;
    position: relative;
    overflow: hidden;
  }

  .balance-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--color-honey, #C8956C), var(--color-sage, #7D8B6A));
  }

  /* Stats */
  .balance-stats {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-sand, #E8E4DD);
  }

  .stat-block {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .stat-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-stone, #6B6560);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .stat-value {
    font-family: var(--font-display, 'Fraunces', Georgia, serif);
    font-size: 2.5rem;
    font-weight: 500;
    color: var(--color-sage, #7D8B6A);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .stat-value.pending {
    color: var(--color-honey, #C8956C);
    font-size: 1.75rem;
  }

  .stat-divider {
    width: 1px;
    height: 3.5rem;
    background: var(--color-sand, #E8E4DD);
  }

  /* Footer */
  .balance-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  /* Tier Badge */
  .tier-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.25rem;
    border-radius: 100px;
    font-weight: 500;
  }

  .tier-bronze {
    background: linear-gradient(135deg, #E8D5C4 0%, #D4C4B5 100%);
    color: #8B7355;
  }

  .tier-silver {
    background: linear-gradient(135deg, #E8E8E8 0%, #C0C0C0 100%);
    color: #5A5A5A;
  }

  .tier-gold {
    background: linear-gradient(135deg, #FFE4B5 0%, #FFD700 100%);
    color: #8B6914;
  }

  .tier-icon {
    font-size: 1.25rem;
    line-height: 1;
  }

  .tier-info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .tier-name {
    font-size: 0.9375rem;
    font-weight: 600;
  }

  .tier-bonus {
    font-size: 0.6875rem;
    opacity: 0.8;
  }

  /* Payout */
  .payout-section {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.375rem;
  }

  .payout-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--color-sage, #7D8B6A);
    color: white;
    font-family: var(--font-sans, 'DM Sans', sans-serif);
    font-size: 0.9375rem;
    font-weight: 500;
    border-radius: 10px;
    text-decoration: none;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .payout-btn:hover:not(.disabled) {
    background: #6B7A5A;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(125, 139, 106, 0.3);
  }

  .payout-btn.disabled {
    background: var(--color-sand, #E8E4DD);
    color: var(--color-mist, #C4BFB8);
    cursor: not-allowed;
  }

  .payout-hint {
    font-size: 0.75rem;
    color: var(--color-stone-light, #9C9690);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .balance-card {
      padding: 1.5rem;
    }

    .balance-stats {
      flex-direction: column;
      gap: 1.5rem;
    }

    .stat-divider {
      width: 100%;
      height: 1px;
    }

    .stat-value {
      font-size: 2rem;
    }

    .balance-footer {
      flex-direction: column;
      align-items: stretch;
    }

    .tier-badge {
      justify-content: center;
    }

    .payout-section {
      align-items: stretch;
    }

    .payout-btn {
      justify-content: center;
    }
  }
</style>
