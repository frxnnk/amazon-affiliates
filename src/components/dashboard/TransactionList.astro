---
import { formatCurrency } from '@lib/db';

interface Transaction {
  id: number;
  type: string;
  amount: number;
  description: string;
  balanceAfter: number;
  createdAt: Date;
}

interface Props {
  transactions: Transaction[];
  lang: string;
}

const { transactions, lang } = Astro.props;

const labels = {
  en: {
    title: 'Recent Activity',
    empty: 'No transactions yet',
    credit: 'Credit',
    debit: 'Debit',
    balance: 'Balance',
  },
  es: {
    title: 'Actividad Reciente',
    empty: 'Sin transacciones aun',
    credit: 'Credito',
    debit: 'Debito',
    balance: 'Balance',
  },
};

const t = labels[lang as keyof typeof labels] || labels.en;

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat(lang === 'es' ? 'es-ES' : 'en-US', {
    month: 'short',
    day: 'numeric',
  }).format(new Date(date));
}
---

<div class="transactions-card">
  <h3 class="transactions-title">{t.title}</h3>

  {transactions.length === 0 ? (
    <div class="transactions-empty">
      <div class="empty-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
      </div>
      <p>{t.empty}</p>
    </div>
  ) : (
    <div class="transactions-list">
      {transactions.map((tx) => (
        <div class="transaction-item">
          <div class="transaction-info">
            <span class:list={['transaction-icon', tx.type]}>
              {tx.type === 'credit' ? (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 19V5M5 12l7-7 7 7"/>
                </svg>
              ) : (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 5v14M19 12l-7 7-7-7"/>
                </svg>
              )}
            </span>
            <div class="transaction-details">
              <span class="transaction-desc">{tx.description}</span>
              <span class="transaction-date">{formatDate(tx.createdAt)}</span>
            </div>
          </div>
          <div class="transaction-amounts">
            <span class:list={['transaction-amount', tx.type]}>
              {tx.type === 'credit' ? '+' : '-'}{formatCurrency(tx.amount)}
            </span>
          </div>
        </div>
      ))}
    </div>
  )}
</div>

<style>
  .transactions-card {
    background: var(--color-white, #FFFFFF);
    border: 1px solid var(--color-sand, #E8E4DD);
    border-radius: 20px;
    padding: 1.5rem;
  }

  .transactions-title {
    font-family: var(--font-sans, 'DM Sans', sans-serif);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-ink, #1A1815);
    margin: 0 0 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-sand, #E8E4DD);
  }

  .transactions-empty {
    text-align: center;
    padding: 2rem 1rem;
    color: var(--color-stone-light, #9C9690);
  }

  .empty-icon {
    width: 3rem;
    height: 3rem;
    margin: 0 auto 0.75rem;
    color: var(--color-mist, #C4BFB8);
  }

  .empty-icon svg {
    width: 100%;
    height: 100%;
  }

  .transactions-empty p {
    margin: 0;
    font-size: 0.875rem;
  }

  .transactions-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .transaction-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.875rem 1rem;
    background: var(--color-cream, #FDFBF7);
    border-radius: 12px;
    transition: background 0.2s;
  }

  .transaction-item:hover {
    background: var(--color-cream-dark, #F7F4EE);
  }

  .transaction-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .transaction-icon {
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
  }

  .transaction-icon svg {
    width: 1rem;
    height: 1rem;
  }

  .transaction-icon.credit {
    background: rgba(125, 139, 106, 0.15);
    color: var(--color-sage, #7D8B6A);
  }

  .transaction-icon.debit {
    background: rgba(193, 123, 94, 0.15);
    color: var(--color-terra, #C17B5E);
  }

  .transaction-details {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .transaction-desc {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink, #1A1815);
  }

  .transaction-date {
    font-size: 0.6875rem;
    color: var(--color-stone-light, #9C9690);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .transaction-amounts {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .transaction-amount {
    font-family: var(--font-display, 'Fraunces', Georgia, serif);
    font-size: 1rem;
    font-weight: 500;
  }

  .transaction-amount.credit {
    color: var(--color-sage, #7D8B6A);
  }

  .transaction-amount.debit {
    color: var(--color-terra, #C17B5E);
  }
</style>
