---
/**
 * StarRating Component
 * Interactive or readonly star rating display
 *
 * @props rating - Current rating value (0-5)
 * @props readonly - If true, shows display-only stars
 * @props size - Size variant: 'sm', 'md', 'lg'
 * @props showNumber - Show numeric rating next to stars
 * @props name - Form input name (for interactive mode)
 * @props lang - Language for accessibility labels
 */

import { type Lang } from '@i18n/utils';

interface Props {
  rating?: number;
  readonly?: boolean;
  size?: 'sm' | 'md' | 'lg';
  showNumber?: boolean;
  name?: string;
  lang?: Lang;
  class?: string;
}

const {
  rating = 0,
  readonly = false,
  size = 'md',
  showNumber = false,
  name = 'rating',
  lang = 'en',
  class: className = ''
} = Astro.props;

const sizeClasses = {
  sm: 'star-sm',
  md: 'star-md',
  lg: 'star-lg'
};

const labels = {
  en: {
    star: 'star',
    stars: 'stars',
    rating: 'Rating',
    select: 'Select rating'
  },
  es: {
    star: 'estrella',
    stars: 'estrellas',
    rating: 'Valoracion',
    select: 'Seleccionar valoracion'
  }
};

const t = labels[lang] || labels.en;
const clampedRating = Math.min(5, Math.max(0, rating));
---

<div
  class:list={['star-rating', sizeClasses[size], { 'interactive': !readonly }, className]}
  role={readonly ? 'img' : 'radiogroup'}
  aria-label={readonly ? `${t.rating}: ${clampedRating.toFixed(1)} ${clampedRating === 1 ? t.star : t.stars}` : t.select}
  data-star-rating
  data-readonly={readonly.toString()}
  data-current={clampedRating}
>
  {!readonly && <input type="hidden" name={name} value={Math.round(clampedRating)} data-rating-input />}

  {[1, 2, 3, 4, 5].map((star) => {
    const fillPercent = Math.min(100, Math.max(0, (clampedRating - star + 1) * 100));
    const isFull = fillPercent >= 100;
    const isPartial = fillPercent > 0 && fillPercent < 100;
    const isEmpty = fillPercent === 0;

    return (
      <button
        type="button"
        class:list={['star', { 'full': isFull, 'partial': isPartial, 'empty': isEmpty }]}
        data-star={star}
        aria-label={`${star} ${star === 1 ? t.star : t.stars}`}
        disabled={readonly}
        tabindex={readonly ? -1 : 0}
      >
        <svg viewBox="0 0 24 24" class="star-icon">
          {/* Background (empty) star */}
          <path
            class="star-bg"
            d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          />
          {/* Filled star with clip for partial */}
          <defs>
            <clipPath id={`star-clip-${star}-${Math.random().toString(36).slice(2, 8)}`}>
              <rect x="0" y="0" width={`${fillPercent}%`} height="100%" />
            </clipPath>
          </defs>
          <path
            class="star-fill"
            d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
            fill="currentColor"
            style={isPartial ? `clip-path: inset(0 ${100 - fillPercent}% 0 0)` : ''}
          />
        </svg>
      </button>
    );
  })}

  {showNumber && (
    <span class="rating-number" data-rating-display>
      {clampedRating.toFixed(1)}
    </span>
  )}
</div>

<style>
  .star-rating {
    display: inline-flex;
    align-items: center;
    gap: 0.125rem;
  }

  .star {
    background: none;
    border: none;
    padding: 0;
    cursor: default;
    color: var(--color-brutal-black, #1A1A1A);
    transition: transform 100ms ease-out;
  }

  .star-rating.interactive .star {
    cursor: pointer;
  }

  .star-rating.interactive .star:hover {
    transform: scale(1.15);
  }

  .star-rating.interactive .star:focus-visible {
    outline: 2px solid var(--color-brutal-orange, #FF6B35);
    outline-offset: 2px;
  }

  .star-icon {
    display: block;
  }

  /* Sizes */
  .star-sm .star-icon {
    width: 14px;
    height: 14px;
  }

  .star-md .star-icon {
    width: 20px;
    height: 20px;
  }

  .star-lg .star-icon {
    width: 28px;
    height: 28px;
  }

  /* Star states */
  .star-bg {
    color: var(--color-brutal-black, #1A1A1A);
    opacity: 0.2;
  }

  .star-fill {
    color: var(--color-brutal-yellow, #FFE14D);
  }

  .star.empty .star-fill {
    opacity: 0;
  }

  /* Hover preview for interactive */
  .star-rating.interactive[data-hover] .star .star-fill {
    opacity: 0.4;
  }

  .star-rating.interactive[data-hover] .star[data-highlighted="true"] .star-fill {
    opacity: 1;
  }

  /* Rating number */
  .rating-number {
    margin-left: 0.5rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-weight: 700;
    color: var(--color-brutal-black, #1A1A1A);
  }

  .star-sm .rating-number {
    font-size: 0.75rem;
  }

  .star-md .rating-number {
    font-size: 0.875rem;
  }

  .star-lg .rating-number {
    font-size: 1.125rem;
  }
</style>

<script>
  function initStarRatings() {
    document.querySelectorAll('[data-star-rating]').forEach((container) => {
      const isReadonly = container.getAttribute('data-readonly') === 'true';
      if (isReadonly) return;

      const input = container.querySelector('[data-rating-input]') as HTMLInputElement;
      const display = container.querySelector('[data-rating-display]') as HTMLElement;
      const stars = container.querySelectorAll('[data-star]') as NodeListOf<HTMLButtonElement>;

      let currentRating = parseInt(container.getAttribute('data-current') || '0');

      function updateDisplay(rating: number, isPreview = false) {
        stars.forEach((star) => {
          const starValue = parseInt(star.getAttribute('data-star') || '0');
          const fillPath = star.querySelector('.star-fill') as SVGPathElement;

          if (starValue <= rating) {
            fillPath.style.clipPath = '';
            fillPath.style.opacity = isPreview ? '0.7' : '1';
          } else {
            fillPath.style.opacity = '0';
          }

          star.setAttribute('data-highlighted', (starValue <= rating).toString());
        });

        if (display && !isPreview) {
          display.textContent = rating.toFixed(1);
        }
      }

      // Hover preview
      stars.forEach((star) => {
        star.addEventListener('mouseenter', () => {
          const value = parseInt(star.getAttribute('data-star') || '0');
          container.setAttribute('data-hover', 'true');
          updateDisplay(value, true);
        });

        star.addEventListener('mouseleave', () => {
          container.removeAttribute('data-hover');
          updateDisplay(currentRating);
        });

        // Click to select
        star.addEventListener('click', () => {
          const value = parseInt(star.getAttribute('data-star') || '0');
          currentRating = value;
          container.setAttribute('data-current', value.toString());
          if (input) input.value = value.toString();
          updateDisplay(value);

          // Dispatch change event
          container.dispatchEvent(new CustomEvent('ratingchange', {
            detail: { rating: value },
            bubbles: true
          }));
        });

        // Keyboard support
        star.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            star.click();
          }
        });
      });

      // Initial display
      updateDisplay(currentRating);
    });
  }

  initStarRatings();
  document.addEventListener('astro:after-swap', initStarRatings);
</script>
