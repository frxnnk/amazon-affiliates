---
/**
 * ReviewStats Component
 * Displays average rating and distribution bars
 */

import StarRating from './StarRating.astro';
import { type Lang } from '@i18n/utils';

interface ReviewStats {
  averageRating: number;
  totalReviews: number;
  distribution: { 1: number; 2: number; 3: number; 4: number; 5: number };
  verifiedPurchaseCount: number;
}

interface Props {
  stats: ReviewStats;
  lang: Lang;
}

const { stats, lang } = Astro.props;

const labels = {
  en: {
    basedOn: 'Based on',
    reviews: 'reviews',
    review: 'review',
    verified: 'verified purchases',
    stars: 'stars',
    star: 'star'
  },
  es: {
    basedOn: 'Basado en',
    reviews: 'opiniones',
    review: 'opinion',
    verified: 'compras verificadas',
    stars: 'estrellas',
    star: 'estrella'
  }
};

const t = labels[lang] || labels.en;

// Calculate percentages for bars
const maxCount = Math.max(...Object.values(stats.distribution), 1);
const getBarWidth = (count: number) => Math.round((count / maxCount) * 100);
---

<div class="review-stats">
  <!-- Average Rating -->
  <div class="stats-summary">
    <div class="average-rating">
      <span class="average-number">{stats.averageRating.toFixed(1)}</span>
      <StarRating rating={stats.averageRating} readonly size="lg" lang={lang} />
    </div>
    <div class="stats-meta">
      <span class="total-reviews">
        {t.basedOn} {stats.totalReviews} {stats.totalReviews === 1 ? t.review : t.reviews}
      </span>
      {stats.verifiedPurchaseCount > 0 && (
        <span class="verified-count">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
            <path d="M9 12l2 2 4-4" />
            <circle cx="12" cy="12" r="10" />
          </svg>
          {stats.verifiedPurchaseCount} {t.verified}
        </span>
      )}
    </div>
  </div>

  <!-- Distribution Bars -->
  <div class="distribution">
    {[5, 4, 3, 2, 1].map((stars) => {
      const count = stats.distribution[stars as keyof typeof stats.distribution];
      const percentage = getBarWidth(count);
      const percentOfTotal = stats.totalReviews > 0
        ? Math.round((count / stats.totalReviews) * 100)
        : 0;

      return (
        <button
          type="button"
          class="distribution-row"
          data-filter-stars={stars}
          aria-label={`${lang === 'es' ? 'Filtrar por' : 'Filter by'} ${stars} ${stars === 1 ? t.star : t.stars}`}
        >
          <span class="star-label">
            {stars} {stars === 1 ? t.star : t.stars}
          </span>
          <div class="bar-container">
            <div
              class="bar-fill"
              style={`width: ${percentage}%`}
              role="progressbar"
              aria-valuenow={count}
              aria-valuemin={0}
              aria-valuemax={maxCount}
            />
          </div>
          <span class="count-label">
            {percentOfTotal}%
          </span>
        </button>
      );
    })}
  </div>
</div>

<style>
  .review-stats {
    background: var(--color-cream, #FFFEF9);
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    padding: 1.5rem;
    box-shadow: 6px 6px 0 var(--color-brutal-black, #1A1A1A);
  }

  .stats-summary {
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 3px solid var(--color-brutal-black, #1A1A1A);
  }

  .average-rating {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .average-number {
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 3rem;
    font-weight: 800;
    line-height: 1;
    color: var(--color-brutal-black, #1A1A1A);
  }

  .stats-meta {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .total-reviews {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.8125rem;
    color: var(--color-brutal-black, #1A1A1A);
  }

  .verified-count {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.75rem;
    color: var(--color-brutal-black, #1A1A1A);
    opacity: 0.7;
  }

  .distribution {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .distribution-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    padding: 0.375rem;
    background: transparent;
    border: none;
    cursor: pointer;
    transition: all 100ms ease-out;
  }

  .distribution-row:hover {
    background: var(--color-brutal-yellow, #FFE14D);
  }

  .distribution-row:focus-visible {
    outline: 2px solid var(--color-brutal-orange, #FF6B35);
    outline-offset: 2px;
  }

  .star-label {
    flex: 0 0 70px;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.75rem;
    font-weight: 600;
    text-align: left;
    color: var(--color-brutal-black, #1A1A1A);
  }

  .bar-container {
    flex: 1;
    height: 12px;
    background: var(--color-brutal-black, #1A1A1A);
    opacity: 0.1;
    position: relative;
  }

  .bar-fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    background: var(--color-brutal-yellow, #FFE14D);
    opacity: 1;
    transition: width 300ms ease-out;
  }

  .distribution-row:hover .bar-container {
    opacity: 1;
  }

  .distribution-row:hover .bar-fill {
    background: var(--color-brutal-orange, #FF6B35);
  }

  .count-label {
    flex: 0 0 40px;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.75rem;
    font-weight: 700;
    text-align: right;
    color: var(--color-brutal-black, #1A1A1A);
  }

  @media (max-width: 480px) {
    .average-rating {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .average-number {
      font-size: 2.5rem;
    }

    .star-label {
      flex: 0 0 60px;
      font-size: 0.6875rem;
    }
  }
</style>

<script>
  function initReviewStats() {
    document.querySelectorAll('[data-filter-stars]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const stars = btn.getAttribute('data-filter-stars');
        // Dispatch filter event
        document.dispatchEvent(new CustomEvent('reviewfilter', {
          detail: { stars: parseInt(stars || '0') }
        }));
      });
    });
  }

  initReviewStats();
  document.addEventListener('astro:after-swap', initReviewStats);
</script>
