---
/**
 * ReviewSection Component
 * Main container that orchestrates ReviewStats, ReviewForm, and ReviewList
 * Shows both Amazon reviews and user reviews
 */

import ReviewStats from './ReviewStats.astro';
import ReviewForm from './ReviewForm.astro';
import ReviewList from './ReviewList.astro';
import { type Lang, getTranslation } from '@i18n/utils';
import { getProductReviews, getReviewStats, getUserReview, getAmazonReviews, hasAmazonReviews } from '@lib/db';

interface Props {
  asin: string;
  productId?: string;
  lang: Lang;
}

const { asin, productId, lang } = Astro.props;

// Get auth state
const auth = Astro.locals.auth?.();
const isAuthenticated = !!auth?.userId;
const currentUserId = auth?.userId;

// Fetch initial data (user reviews + Amazon reviews)
const [reviews, stats, userReview, amazonData] = await Promise.all([
  getProductReviews(asin, { limit: 10, sortBy: 'recent' }),
  getReviewStats(asin),
  currentUserId ? getUserReview(currentUserId, asin) : null,
  getAmazonReviews(asin, { limit: 10, sortBy: 'helpful' }),
]);

const hasMore = reviews.length > 10;
const displayReviews = reviews.slice(0, 10);
const amazonReviews = amazonData.reviews;
const amazonStats = amazonData.stats;
const hasAmazon = amazonReviews.length > 0;

const labels = {
  en: {
    title: 'Customer Reviews',
    writeYourReview: 'Your Review',
    amazonReviews: 'Amazon Reviews',
    userReviews: 'Community Reviews',
    fromAmazon: 'From Amazon',
    verifiedPurchase: 'Verified Purchase',
    helpful: 'helpful',
    loadAmazon: 'Load Amazon Reviews',
    loading: 'Loading...',
  },
  es: {
    title: 'Opiniones de Clientes',
    writeYourReview: 'Tu Opinion',
    amazonReviews: 'Reviews de Amazon',
    userReviews: 'Reviews de la Comunidad',
    fromAmazon: 'De Amazon',
    verifiedPurchase: 'Compra Verificada',
    helpful: 'util',
    loadAmazon: 'Cargar Reviews de Amazon',
    loading: 'Cargando...',
  }
};

const t = labels[lang] || labels.en;
---

<section class="review-section" id="reviews" data-asin={asin}>
  <h2 class="section-title">{t.title}</h2>

  <!-- Review Tabs -->
  <div class="review-tabs">
    <button type="button" class="tab-btn active" data-tab="amazon">
      <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
      </svg>
      {t.amazonReviews}
      {hasAmazon && <span class="tab-count">{amazonStats.totalReviews}</span>}
    </button>
    <button type="button" class="tab-btn" data-tab="community">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
        <circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
      {t.userReviews}
      {stats.totalReviews > 0 && <span class="tab-count">{stats.totalReviews}</span>}
    </button>
  </div>

  <!-- Amazon Reviews Tab -->
  <div class="tab-content active" data-tab-content="amazon">
    {hasAmazon ? (
      <div class="amazon-reviews-grid">
        <!-- Amazon Stats -->
        <div class="amazon-sidebar">
          <div class="amazon-stats-card">
            <div class="amazon-rating-big">
              <span class="rating-value">{amazonStats.averageRating.toFixed(1)}</span>
              <div class="rating-stars">
                {[1,2,3,4,5].map((star) => (
                  <svg class={`star ${star <= Math.round(amazonStats.averageRating) ? 'filled' : ''}`} viewBox="0 0 24 24" width="20" height="20">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                ))}
              </div>
              <span class="rating-count">{amazonStats.totalReviews} {t.fromAmazon}</span>
            </div>
            <div class="rating-bars">
              {[5,4,3,2,1].map((stars) => (
                <div class="rating-bar-row">
                  <span class="bar-label">{stars}</span>
                  <div class="bar-track">
                    <div class="bar-fill" style={`width: ${amazonStats.totalReviews > 0 ? (amazonStats.ratingBreakdown[stars] / amazonStats.totalReviews * 100) : 0}%`}></div>
                  </div>
                  <span class="bar-count">{amazonStats.ratingBreakdown[stars]}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Amazon Reviews List -->
        <div class="amazon-reviews-list">
          {amazonReviews.map((review: any) => (
            <article class="amazon-review-card">
              <div class="amazon-review-header">
                <div class="reviewer-info">
                  <span class="reviewer-name">{review.reviewerName || 'Amazon Customer'}</span>
                  {review.isVerifiedPurchase && (
                    <span class="verified-badge">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12">
                        <path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/>
                      </svg>
                      {t.verifiedPurchase}
                    </span>
                  )}
                </div>
                <div class="amazon-rating">
                  {[1,2,3,4,5].map((star) => (
                    <svg class={`star-sm ${star <= review.rating ? 'filled' : ''}`} viewBox="0 0 24 24" width="14" height="14">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  ))}
                </div>
              </div>
              {review.title && <h4 class="amazon-review-title">{review.title}</h4>}
              <div class="amazon-review-content-wrapper" data-expandable>
                <p class="amazon-review-content">{review.content}</p>
                {review.content && review.content.length > 300 && (
                  <button type="button" class="btn-expand" data-expand-btn>
                    {lang === 'es' ? 'Leer más' : 'Read more'}
                  </button>
                )}
              </div>
              <div class="amazon-review-footer">
                <span class="review-date">{review.reviewDate}</span>
                {review.helpfulCount > 0 && (
                  <span class="helpful-count">{review.helpfulCount} {t.helpful}</span>
                )}
              </div>
            </article>
          ))}

          <!-- Load More Amazon -->
          {amazonStats.totalReviews > amazonReviews.length && (
            <button type="button" class="btn-load-amazon" data-load-amazon>
              {t.loadAmazon}
            </button>
          )}
        </div>
      </div>
    ) : (
      <div class="no-amazon-reviews">
        <button type="button" class="btn-fetch-amazon" data-fetch-amazon>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
            <path d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            <path d="M9 12l2 2 4-4"/>
          </svg>
          {t.loadAmazon}
        </button>
      </div>
    )}
  </div>

  <!-- Community Reviews Tab -->
  <div class="tab-content" data-tab-content="community">
    <div class="review-section-grid">
      <!-- Left Column: Stats + Form -->
      <div class="review-sidebar">
        <ReviewStats stats={stats} lang={lang} />

        {!userReview && (
          <div class="form-wrapper">
            <h3 class="form-section-title">{t.writeYourReview}</h3>
            <ReviewForm
              asin={asin}
              productId={productId}
              lang={lang}
              isAuthenticated={isAuthenticated}
            />
          </div>
        )}

        {userReview && (
          <div class="form-wrapper user-review-notice">
            <p class="notice-text">
              {lang === 'es'
                ? 'Ya has dejado tu opinion. Puedes editarla o eliminarla desde la lista.'
                : 'You have already left a review. You can edit or delete it from the list.'}
            </p>
          </div>
        )}
      </div>

      <!-- Right Column: Review List -->
      <div class="review-main">
        <ReviewList
          asin={asin}
          reviews={displayReviews}
          lang={lang}
          currentUserId={currentUserId}
          hasMore={hasMore}
        />
      </div>
    </div>
  </div>
</section>

<style>
  .review-section {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 4px solid var(--color-brutal-black, #1A1A1A);
  }

  .section-title {
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-brutal-black, #1A1A1A);
    margin: 0 0 1.5rem 0;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .section-title::before {
    content: '';
    display: block;
    width: 8px;
    height: 32px;
    background: var(--color-brutal-orange, #FF6B35);
  }

  /* Tabs */
  .review-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 1.5rem;
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    background: var(--color-cream, #FFFEF9);
  }

  .tab-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem;
    background: transparent;
    border: none;
    border-right: 3px solid var(--color-brutal-black, #1A1A1A);
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-brutal-black, #1A1A1A);
    cursor: pointer;
    transition: all 150ms ease;
  }

  .tab-btn:last-child {
    border-right: none;
  }

  .tab-btn:hover {
    background: var(--color-brutal-yellow, #FFE14D);
  }

  .tab-btn.active {
    background: var(--color-brutal-black, #1A1A1A);
    color: var(--color-cream, #FFFEF9);
  }

  .tab-btn svg {
    flex-shrink: 0;
  }

  .tab-count {
    background: var(--color-brutal-orange, #FF6B35);
    color: white;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 0.75rem;
  }

  .tab-btn.active .tab-count {
    background: var(--color-brutal-yellow, #FFE14D);
    color: var(--color-brutal-black, #1A1A1A);
  }

  .tab-content {
    display: none;
  }

  .tab-content.active {
    display: block;
  }

  /* Amazon Reviews Grid */
  .amazon-reviews-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 2rem;
    align-items: start;
  }

  .amazon-sidebar {
    position: sticky;
    top: 2rem;
  }

  .amazon-stats-card {
    background: var(--color-cream, #FFFEF9);
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    padding: 1.5rem;
    box-shadow: 4px 4px 0 var(--color-brutal-black, #1A1A1A);
  }

  .amazon-rating-big {
    text-align: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid var(--color-brutal-black, #1A1A1A);
  }

  .rating-value {
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-brutal-black, #1A1A1A);
  }

  .rating-stars {
    display: flex;
    justify-content: center;
    gap: 4px;
    margin: 0.5rem 0;
  }

  .star {
    fill: none;
    stroke: var(--color-brutal-black, #1A1A1A);
    stroke-width: 2;
  }

  .star.filled {
    fill: var(--color-brutal-yellow, #FFE14D);
  }

  .rating-count {
    font-size: 0.875rem;
    color: var(--color-brutal-black, #1A1A1A);
    opacity: 0.7;
  }

  .rating-bars {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .rating-bar-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .bar-label {
    font-size: 0.75rem;
    font-weight: 700;
    width: 1rem;
    text-align: center;
  }

  .bar-track {
    flex: 1;
    height: 12px;
    background: var(--color-white, #FFFFFF);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
  }

  .bar-fill {
    height: 100%;
    background: var(--color-brutal-yellow, #FFE14D);
    transition: width 300ms ease;
  }

  .bar-count {
    font-size: 0.75rem;
    font-weight: 600;
    width: 2rem;
    text-align: right;
  }

  /* Amazon Reviews List */
  .amazon-reviews-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .amazon-review-card {
    background: var(--color-cream, #FFFEF9);
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    padding: 1.25rem;
    box-shadow: 4px 4px 0 var(--color-brutal-black, #1A1A1A);
  }

  .amazon-review-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .reviewer-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .reviewer-name {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--color-brutal-black, #1A1A1A);
  }

  .verified-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 8px;
    background: var(--color-brutal-green, #4ADE80);
    color: var(--color-brutal-black, #1A1A1A);
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    border-radius: 999px;
  }

  .amazon-rating {
    display: flex;
    gap: 2px;
  }

  .star-sm {
    fill: none;
    stroke: var(--color-brutal-black, #1A1A1A);
    stroke-width: 2;
  }

  .star-sm.filled {
    fill: var(--color-brutal-yellow, #FFE14D);
  }

  .amazon-review-title {
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-brutal-black, #1A1A1A);
    margin: 0 0 0.5rem 0;
  }

  .amazon-review-content-wrapper {
    position: relative;
  }

  .amazon-review-content-wrapper:not(.expanded) .amazon-review-content {
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    max-height: 6.4em; /* 4 lines * 1.6 line-height */
  }

  .amazon-review-content-wrapper.expanded .amazon-review-content {
    display: block;
    max-height: none;
  }

  .amazon-review-content {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-brutal-black, #1A1A1A);
    margin: 0;
  }

  .btn-expand {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-top: 0.5rem;
    padding: 0.25rem 0.5rem;
    background: transparent;
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-brutal-black, #1A1A1A);
    cursor: pointer;
    transition: all 150ms ease;
  }

  .btn-expand:hover {
    background: var(--color-brutal-yellow, #FFE14D);
  }

  .amazon-review-content-wrapper.expanded .btn-expand {
    display: none;
  }

  .amazon-review-footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1rem;
    padding-top: 0.75rem;
    border-top: 2px dashed var(--color-brutal-black, #1A1A1A);
    font-size: 0.75rem;
    color: var(--color-brutal-black, #1A1A1A);
    opacity: 0.7;
  }

  .helpful-count {
    font-weight: 600;
  }

  .btn-load-amazon,
  .btn-fetch-amazon {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 1rem;
    background: var(--color-brutal-yellow, #FFE14D);
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    cursor: pointer;
    box-shadow: 4px 4px 0 var(--color-brutal-black, #1A1A1A);
    transition: all 150ms ease;
  }

  .btn-load-amazon:hover,
  .btn-fetch-amazon:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-brutal-black, #1A1A1A);
  }

  .no-amazon-reviews {
    padding: 2rem;
    text-align: center;
  }

  /* Community Reviews Grid */
  .review-section-grid {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: 2rem;
    align-items: start;
  }

  .review-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: sticky;
    top: 2rem;
  }

  .form-wrapper {
    margin-top: 0.5rem;
  }

  .form-section-title {
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-brutal-black, #1A1A1A);
    margin: 0 0 1rem 0;
  }

  .user-review-notice {
    background: var(--color-brutal-yellow, #FFE14D);
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    padding: 1rem;
    box-shadow: 4px 4px 0 var(--color-brutal-black, #1A1A1A);
  }

  .notice-text {
    font-size: 0.875rem;
    color: var(--color-brutal-black, #1A1A1A);
    margin: 0;
  }

  .review-main {
    min-width: 0;
  }

  @media (max-width: 960px) {
    .review-section-grid,
    .amazon-reviews-grid {
      grid-template-columns: 1fr;
    }

    .review-sidebar,
    .amazon-sidebar {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .section-title {
      font-size: 1.5rem;
    }

    .section-title::before {
      width: 6px;
      height: 24px;
    }

    .tab-btn {
      font-size: 0.75rem;
      padding: 0.75rem 0.5rem;
    }

    .tab-btn span:not(.tab-count) {
      display: none;
    }
  }
</style>

<script>
  function initReviewTabs() {
    document.querySelectorAll('.review-section').forEach((section) => {
      const tabs = section.querySelectorAll('.tab-btn');
      const contents = section.querySelectorAll('.tab-content');
      const asin = section.getAttribute('data-asin');

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const targetTab = tab.getAttribute('data-tab');

          // Update tabs
          tabs.forEach((t) => t.classList.remove('active'));
          tab.classList.add('active');

          // Update content
          contents.forEach((content) => {
            if (content.getAttribute('data-tab-content') === targetTab) {
              content.classList.add('active');
            } else {
              content.classList.remove('active');
            }
          });
        });
      });

      // Fetch Amazon reviews button
      const fetchBtn = section.querySelector('[data-fetch-amazon]');
      if (fetchBtn) {
        fetchBtn.addEventListener('click', async () => {
          fetchBtn.textContent = 'Loading...';
          fetchBtn.disabled = true;

          try {
            const response = await fetch(`/api/products/amazon-reviews?asin=${asin}&refresh=true`);
            const data = await response.json();

            if (data.success) {
              window.location.reload();
            } else {
              alert('Failed to fetch reviews');
            }
          } catch (error) {
            console.error('Fetch error:', error);
            alert('Error fetching reviews');
          } finally {
            fetchBtn.disabled = false;
          }
        });
      }

      // Expand review content buttons
      section.querySelectorAll('[data-expand-btn]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const wrapper = btn.closest('[data-expandable]');
          if (wrapper) {
            wrapper.classList.add('expanded');
          }
        });
      });
    });
  }

  initReviewTabs();
  document.addEventListener('astro:after-swap', initReviewTabs);
</script>
