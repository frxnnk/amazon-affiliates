---
/**
 * ReviewCard Component
 * Displays a single product review with rating, content, and helpful votes
 */

import StarRating from './StarRating.astro';
import { type Lang, getTranslation } from '@i18n/utils';

interface Review {
  id: number;
  userId: string;
  rating: number;
  title?: string;
  content: string;
  isVerifiedPurchase: boolean;
  helpfulCount: number;
  createdAt: Date;
}

interface Props {
  review: Review;
  lang: Lang;
  currentUserId?: string;
  userVote?: boolean | null;
}

const { review, lang, currentUserId, userVote } = Astro.props;
const t = getTranslation(lang);

const isOwner = currentUserId === review.userId;
const createdDate = new Date(review.createdAt);
const dateStr = createdDate.toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});

// Get relative time
function getRelativeTime(date: Date): string {
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

  if (diffDays === 0) return lang === 'es' ? 'Hoy' : 'Today';
  if (diffDays === 1) return lang === 'es' ? 'Ayer' : 'Yesterday';
  if (diffDays < 7) return lang === 'es' ? `Hace ${diffDays} dias` : `${diffDays} days ago`;
  if (diffDays < 30) {
    const weeks = Math.floor(diffDays / 7);
    return lang === 'es' ? `Hace ${weeks} semana${weeks > 1 ? 's' : ''}` : `${weeks} week${weeks > 1 ? 's' : ''} ago`;
  }
  return dateStr;
}
---

<article class="review-card" data-review-id={review.id}>
  <!-- Header -->
  <div class="review-header">
    <div class="review-rating">
      <StarRating rating={review.rating} readonly size="sm" lang={lang} />
      {review.title && <span class="review-title">{review.title}</span>}
    </div>
    <div class="review-meta">
      {review.isVerifiedPurchase && (
        <span class="verified-badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
            <path d="M9 12l2 2 4-4" />
            <circle cx="12" cy="12" r="10" />
          </svg>
          {lang === 'es' ? 'Compra Verificada' : 'Verified Purchase'}
        </span>
      )}
      <time datetime={createdDate.toISOString()} class="review-date">
        {getRelativeTime(createdDate)}
      </time>
    </div>
  </div>

  <!-- Content -->
  <div class="review-content" data-review-content>
    <p>{review.content}</p>
  </div>

  <!-- Footer -->
  <div class="review-footer">
    <div class="helpful-section">
      <span class="helpful-label">
        {lang === 'es' ? 'Util?' : 'Helpful?'}
      </span>
      <div class="helpful-buttons">
        <button
          type="button"
          class:list={['btn-helpful', { 'active': userVote === true }]}
          data-vote-helpful="true"
          data-review-id={review.id}
          aria-label={lang === 'es' ? 'Marcar como util' : 'Mark as helpful'}
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3" />
          </svg>
          <span>{lang === 'es' ? 'Si' : 'Yes'}</span>
        </button>
        <button
          type="button"
          class:list={['btn-helpful', { 'active': userVote === false }]}
          data-vote-helpful="false"
          data-review-id={review.id}
          aria-label={lang === 'es' ? 'Marcar como no util' : 'Mark as not helpful'}
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3zm7-13h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17" />
          </svg>
          <span>{lang === 'es' ? 'No' : 'No'}</span>
        </button>
      </div>
      <span class="helpful-count" data-helpful-count={review.id}>
        {review.helpfulCount > 0 && (
          lang === 'es'
            ? `${review.helpfulCount} encontraron esto util`
            : `${review.helpfulCount} found this helpful`
        )}
      </span>
    </div>

    {isOwner && (
      <div class="owner-actions">
        <button
          type="button"
          class="btn-edit"
          data-edit-review={review.id}
          aria-label={lang === 'es' ? 'Editar resena' : 'Edit review'}
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
          </svg>
        </button>
        <button
          type="button"
          class="btn-delete"
          data-delete-review={review.id}
          aria-label={lang === 'es' ? 'Eliminar resena' : 'Delete review'}
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <polyline points="3,6 5,6 21,6" />
            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
          </svg>
        </button>
      </div>
    )}
  </div>
</article>

<style>
  .review-card {
    background: var(--color-cream, #FFFEF9);
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    padding: 1.25rem;
    box-shadow: 4px 4px 0 var(--color-brutal-black, #1A1A1A);
  }

  .review-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .review-rating {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .review-title {
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-brutal-black, #1A1A1A);
  }

  .review-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .verified-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.5rem;
    background: var(--color-brutal-yellow, #FFE14D);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .review-date {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.75rem;
    color: var(--color-brutal-black, #1A1A1A);
    opacity: 0.6;
  }

  .review-content {
    margin-bottom: 1rem;
  }

  .review-content p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-brutal-black, #1A1A1A);
    margin: 0;
    white-space: pre-wrap;
  }

  .review-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 0.75rem;
    border-top: 2px dashed var(--color-brutal-black, #1A1A1A);
  }

  .helpful-section {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .helpful-label {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .helpful-buttons {
    display: flex;
    gap: 0.25rem;
  }

  .btn-helpful {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.375rem 0.625rem;
    background: var(--color-cream, #FFFEF9);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 100ms ease-out;
  }

  .btn-helpful:hover {
    background: var(--color-brutal-yellow, #FFE14D);
    transform: translate(-1px, -1px);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
  }

  .btn-helpful.active {
    background: var(--color-brutal-yellow, #FFE14D);
    box-shadow: inset 2px 2px 0 var(--color-brutal-black, #1A1A1A);
  }

  .helpful-count {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.6875rem;
    color: var(--color-brutal-black, #1A1A1A);
    opacity: 0.7;
  }

  .owner-actions {
    display: flex;
    gap: 0.5rem;
  }

  .btn-edit,
  .btn-delete {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: var(--color-cream, #FFFEF9);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    cursor: pointer;
    transition: all 100ms ease-out;
  }

  .btn-edit:hover {
    background: var(--color-brutal-yellow, #FFE14D);
    transform: translate(-1px, -1px);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
  }

  .btn-delete:hover {
    background: var(--color-brutal-orange, #FF6B35);
    transform: translate(-1px, -1px);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
  }

  @media (max-width: 480px) {
    .review-footer {
      flex-direction: column;
      align-items: flex-start;
    }

    .helpful-section {
      width: 100%;
    }
  }
</style>

<script>
  function initReviewCards() {
    // Helpful vote buttons
    document.querySelectorAll('[data-vote-helpful]').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const reviewId = target.getAttribute('data-review-id');
        const isHelpful = target.getAttribute('data-vote-helpful') === 'true';

        try {
          const response = await fetch('/api/user/review-vote', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reviewId: parseInt(reviewId || '0'), isHelpful })
          });

          const data = await response.json();

          if (data.success) {
            // Update UI
            const card = target.closest('.review-card');
            if (card) {
              // Update active states
              card.querySelectorAll('[data-vote-helpful]').forEach((b) => {
                b.classList.remove('active');
              });
              target.classList.add('active');

              // Update count
              const countEl = card.querySelector(`[data-helpful-count="${reviewId}"]`);
              if (countEl && data.helpfulCount > 0) {
                const lang = document.documentElement.lang || 'en';
                countEl.textContent = lang === 'es'
                  ? `${data.helpfulCount} encontraron esto util`
                  : `${data.helpfulCount} found this helpful`;
              }
            }
          } else if (data.error === 'Authentication required') {
            // Redirect to login
            window.location.href = `/${document.documentElement.lang || 'en'}/login`;
          }
        } catch (error) {
          console.error('Vote error:', error);
        }
      });
    });

    // Delete button
    document.querySelectorAll('[data-delete-review]').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const reviewId = target.getAttribute('data-delete-review');
        const lang = document.documentElement.lang || 'en';

        const confirmMsg = lang === 'es'
          ? 'Estas seguro de que quieres eliminar esta resena?'
          : 'Are you sure you want to delete this review?';

        if (!confirm(confirmMsg)) return;

        try {
          const response = await fetch(`/api/user/review?id=${reviewId}`, {
            method: 'DELETE'
          });

          const data = await response.json();

          if (data.success) {
            // Remove card from DOM
            const card = target.closest('.review-card');
            if (card) {
              card.remove();
            }
            // Reload to update stats
            window.location.reload();
          } else {
            alert(data.error || 'Failed to delete review');
          }
        } catch (error) {
          console.error('Delete error:', error);
          alert('Failed to delete review');
        }
      });
    });
  }

  initReviewCards();
  document.addEventListener('astro:after-swap', initReviewCards);
</script>
