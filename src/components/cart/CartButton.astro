---
import { type Lang } from '@i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<button
  type="button"
  class="cart-btn"
  id="cart-trigger"
  aria-label={lang === 'es' ? 'Carrito de compras' : 'Shopping cart'}
>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
    <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
    <line x1="3" y1="6" x2="21" y2="6" />
    <path d="M16 10a4 4 0 0 1-8 0" />
  </svg>
  <span class="cart-badge" id="cart-badge" aria-live="polite">0</span>
  <span class="cart-label">{lang === 'es' ? 'Carrito' : 'Cart'}</span>
</button>

<style>
  .cart-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: var(--color-cream, #FFFEF9);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-black, #1A1A1A);
    cursor: pointer;
    box-shadow: 3px 3px 0 var(--color-brutal-black, #1A1A1A);
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    position: relative;
  }

  .cart-btn:hover {
    background: var(--color-brutal-yellow, #FFE14D);
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 var(--color-brutal-black, #1A1A1A);
  }

  .cart-btn:active {
    transform: translate(1px, 1px);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
  }

  .cart-btn svg {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
  }

  .cart-badge {
    position: absolute;
    top: -6px;
    right: -6px;
    min-width: 1.25rem;
    height: 1.25rem;
    padding: 0 0.375rem;
    background: var(--color-brutal-orange, #FF6B35);
    color: var(--color-brutal-black, #1A1A1A);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.625rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  /* Hide badge when empty */
  .cart-badge:empty,
  .cart-badge[data-count="0"] {
    display: none;
  }

  /* Bounce animation when count changes */
  .cart-badge.bounce {
    animation: badge-bounce 300ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  @keyframes badge-bounce {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.3); }
  }

  .cart-label {
    display: none;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  @media (min-width: 768px) {
    .cart-label {
      display: inline;
    }

    .cart-badge {
      top: -8px;
      right: -8px;
    }
  }
</style>

<script>
  // Cart state management
  interface CartItem {
    asin: string;
    productId: string;
    title: string;
    brand: string;
    image: string;
    price: number;
    currency: string;
    affiliateUrl: string;
    marketplace: string; // 'amazon.com' | 'amazon.es'
    quantity: number;
    addedAt: number;
  }

  const CART_KEY = 'shoppingCart';

  // Get cart items from localStorage
  function getCartItems(): CartItem[] {
    try {
      return JSON.parse(localStorage.getItem(CART_KEY) || '[]');
    } catch {
      return [];
    }
  }

  // Save cart items to localStorage
  function saveCartItems(items: CartItem[]) {
    localStorage.setItem(CART_KEY, JSON.stringify(items));
    updateBadge();
    // Dispatch event for other components
    window.dispatchEvent(new CustomEvent('cart:updated', { detail: { items } }));
  }

  // Get cart count
  function getCartCount(): number {
    return getCartItems().reduce((sum, item) => sum + item.quantity, 0);
  }

  // Update badge display
  function updateBadge() {
    const badge = document.getElementById('cart-badge');
    if (!badge) return;

    const count = getCartCount();
    badge.textContent = String(count);
    badge.dataset.count = String(count);

    // Bounce animation
    badge.classList.remove('bounce');
    requestAnimationFrame(() => {
      badge.classList.add('bounce');
    });
  }

  // Get current cart marketplace
  function getCartMarketplace(): string | null {
    const items = getCartItems();
    return items.length > 0 ? items[0].marketplace : null;
  }

  // Add to cart
  function addToCart(product: Omit<CartItem, 'quantity' | 'addedAt'>): boolean {
    const items = getCartItems();
    const cartMarketplace = getCartMarketplace();

    // Check if mixing regions
    if (cartMarketplace && product.marketplace && cartMarketplace !== product.marketplace) {
      const currentLang = document.documentElement.lang || 'en';
      const message = currentLang === 'es'
        ? `Tu carrito tiene productos de ${cartMarketplace}. ¿Quieres vaciar el carrito y agregar este producto de ${product.marketplace}?`
        : `Your cart has products from ${cartMarketplace}. Do you want to clear the cart and add this product from ${product.marketplace}?`;

      if (confirm(message)) {
        // Clear cart and add new product
        const newItems: CartItem[] = [{
          ...product,
          quantity: 1,
          addedAt: Date.now()
        }];
        saveCartItems(newItems);
        return true;
      }
      return false;
    }

    const existing = items.find(item => item.asin === product.asin);

    if (existing) {
      existing.quantity += 1;
    } else {
      items.push({
        ...product,
        quantity: 1,
        addedAt: Date.now()
      });
    }

    saveCartItems(items);
    return true;
  }

  // Remove from cart
  function removeFromCart(asin: string) {
    const items = getCartItems().filter(item => item.asin !== asin);
    saveCartItems(items);
  }

  // Update quantity
  function updateQuantity(asin: string, quantity: number) {
    const items = getCartItems();
    const item = items.find(i => i.asin === asin);
    if (item) {
      if (quantity <= 0) {
        removeFromCart(asin);
      } else {
        item.quantity = quantity;
        saveCartItems(items);
      }
    }
  }

  // Clear cart
  function clearCart() {
    saveCartItems([]);
  }

  // Expose cart functions globally
  (window as any).cart = {
    getItems: getCartItems,
    add: addToCart,
    remove: removeFromCart,
    updateQuantity,
    clear: clearCart,
    getCount: getCartCount,
    getMarketplace: getCartMarketplace
  };

  // Initialize badge on load
  updateBadge();

  // Listen for cart updates from other tabs
  window.addEventListener('storage', (e) => {
    if (e.key === CART_KEY) {
      updateBadge();
    }
  });

  // Open cart modal
  const cartTrigger = document.getElementById('cart-trigger');
  cartTrigger?.addEventListener('click', () => {
    const modal = document.getElementById('cart-modal');
    if (modal) {
      modal.setAttribute('aria-hidden', 'false');
      window.dispatchEvent(new CustomEvent('cart:open'));
    }
  });
</script>
