---
import { type Lang, getTranslation } from '@i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import siteConfig from '@data/site-config.json';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = getTranslation(lang);

const navItems = [
  { href: `/${lang}`, label: t('nav.home'), exact: true },
  { href: `/${lang}/products`, label: t('nav.products') },
  { href: `/${lang}/reviews`, label: t('nav.reviews') },
  { href: `/${lang}/lists`, label: t('nav.lists') },
  { href: `/${lang}/deals`, label: t('nav.deals') },
];

function isActive(href: string, exact?: boolean) {
  if (exact) return currentPath === href || currentPath === href + '/';
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<header class="header">
  <div class="header-inner">
    <!-- Logo -->
    <a href={`/${lang}`} class="logo">
      <span class="logo-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
        </svg>
      </span>
      <span class="logo-text">{siteConfig.site.name}</span>
    </a>

    <!-- Navigation -->
    <nav class="nav-desktop">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={['nav-link', { active: isActive(item.href, item.exact) }]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Right side -->
    <div class="header-actions">
      <!-- Search -->
      <button
        type="button"
        class="search-btn"
        aria-label={t('nav.search')}
        id="search-trigger"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8" />
          <path d="M21 21l-4.35-4.35" />
        </svg>
        <span class="search-text">Buscar...</span>
        <kbd class="search-kbd">Ctrl K</kbd>
      </button>

      <LanguageSwitcher currentLang={lang} currentPath={currentPath} />

      <!-- Mobile menu button -->
      <button
        type="button"
        class="mobile-menu-btn"
        aria-label="Menu"
        id="mobile-menu-button"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <nav id="mobile-menu" class="nav-mobile hidden">
    {navItems.map((item) => (
      <a
        href={item.href}
        class:list={['nav-mobile-link', { active: isActive(item.href, item.exact) }]}
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>

<style>
  .header {
    background: white;
    border-bottom: 1px solid #e5e5e5;
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .header-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1rem;
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  /* Logo */
  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
  }

  .logo-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
    border-radius: 0.5rem;
    color: white;
  }

  .logo-icon svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .logo-text {
    font-size: 1.25rem;
    font-weight: 700;
    color: #171717;
  }

  /* Desktop Navigation */
  .nav-desktop {
    display: none;
    align-items: center;
    gap: 0.25rem;
  }

  @media (min-width: 768px) {
    .nav-desktop {
      display: flex;
    }
  }

  .nav-link {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #525252;
    text-decoration: none;
    border-radius: 0.375rem;
    transition: all 0.15s ease;
  }

  .nav-link:hover {
    color: #171717;
    background: #f5f5f5;
  }

  .nav-link.active {
    color: #ea580c;
    background: #fff7ed;
  }

  /* Header Actions */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* Search Button */
  .search-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: #f5f5f5;
    border: 1px solid #e5e5e5;
    border-radius: 0.5rem;
    color: #737373;
    font-size: 0.875rem;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .search-btn:hover {
    background: #e5e5e5;
    border-color: #d4d4d4;
  }

  .search-btn svg {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  .search-text {
    display: none;
  }

  @media (min-width: 640px) {
    .search-text {
      display: block;
    }
  }

  .search-kbd {
    display: none;
    padding: 0.125rem 0.375rem;
    background: white;
    border: 1px solid #d4d4d4;
    border-radius: 0.25rem;
    font-size: 0.75rem;
    font-family: inherit;
    color: #737373;
  }

  @media (min-width: 768px) {
    .search-kbd {
      display: block;
    }
  }

  /* Mobile Menu Button */
  .mobile-menu-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: transparent;
    border: none;
    color: #525252;
    cursor: pointer;
    border-radius: 0.375rem;
    transition: all 0.15s ease;
  }

  .mobile-menu-btn:hover {
    background: #f5f5f5;
    color: #171717;
  }

  .mobile-menu-btn svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  @media (min-width: 768px) {
    .mobile-menu-btn {
      display: none;
    }
  }

  /* Mobile Navigation */
  .nav-mobile {
    padding: 0.5rem 1rem 1rem;
    border-top: 1px solid #e5e5e5;
  }

  .nav-mobile.hidden {
    display: none;
  }

  @media (min-width: 768px) {
    .nav-mobile {
      display: none !important;
    }
  }

  .nav-mobile-link {
    display: block;
    padding: 0.75rem 1rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #525252;
    text-decoration: none;
    border-radius: 0.375rem;
    transition: all 0.15s ease;
  }

  .nav-mobile-link:hover {
    color: #171717;
    background: #f5f5f5;
  }

  .nav-mobile-link.active {
    color: #ea580c;
    background: #fff7ed;
  }
</style>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');

  button?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Keyboard shortcut for search
  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      // TODO: Open search modal
      console.log('Search triggered');
    }
  });
</script>
