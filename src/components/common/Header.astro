---
import { type Lang, getTranslation } from '@i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import CartButton from '@components/cart/CartButton.astro';
import siteConfig from '@data/site-config.json';
import { SignedIn, SignedOut, UserButton } from '@clerk/astro/components';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = getTranslation(lang);

const navItems = [
  { href: `/${lang}`, label: t('nav.home'), exact: true },
  { href: `/${lang}/products`, label: t('nav.products') },
  { href: `/${lang}/categories`, label: t('nav.categories') },
];

function isActive(href: string, exact?: boolean) {
  if (exact) return currentPath === href || currentPath === href + '/';
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<header class="header">
  <div class="header-inner">
    <!-- Logo -->
    <a href={`/${lang}`} class="logo">
      <span class="logo-mark">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2L2 7l10 5 10-5-10-5z" fill="currentColor" opacity="0.9"/>
          <path d="M2 17l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
      <span class="logo-text">{siteConfig.site.name}</span>
    </a>

    <!-- Navigation -->
    <nav class="nav-desktop">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={['nav-link', { active: isActive(item.href, item.exact) }]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Right side -->
    <div class="header-actions">
      <!-- Search Bar (Desktop) -->
      <button
        type="button"
        class="search-bar-desktop"
        aria-label={t('nav.search')}
        id="search-trigger-desktop"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="11" cy="11" r="8" />
          <path d="M21 21l-4.35-4.35" />
        </svg>
        <span class="search-placeholder">{t('common.searchPlaceholder')}</span>
        <kbd class="search-shortcut">⌘K</kbd>
      </button>

      <!-- Search Button (Mobile) -->
      <button
        type="button"
        class="search-btn-mobile"
        aria-label={t('nav.search')}
        id="search-trigger-mobile"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="11" cy="11" r="8" />
          <path d="M21 21l-4.35-4.35" />
        </svg>
      </button>

      <!-- Cart -->
      <CartButton lang={lang} />

      <!-- Auth (hidden on desktop - redundant with PROFILE nav) -->
      <div class="auth-section hide-on-desktop">
        <SignedOut>
          <a href={`/${lang}/login`} class="btn-login">
            <svg class="auth-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
              <circle cx="12" cy="7" r="4" />
            </svg>
            <span class="auth-label">{t('nav.login')}</span>
          </a>
        </SignedOut>
        <SignedIn>
          <div class="user-section">
            <UserButton />
            <span class="auth-label user-label">{lang === 'es' ? 'Mi cuenta' : 'Account'}</span>
          </div>
        </SignedIn>
      </div>

      <!-- Language Switcher (hidden on desktop - redundant with RegionSelector in feed) -->
      <div class="hide-on-desktop">
        <LanguageSwitcher currentLang={lang} currentPath={currentPath} />
      </div>

      <!-- Mobile menu button -->
      <button
        type="button"
        class="mobile-menu-btn"
        aria-label="Menu"
        id="mobile-menu-button"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <nav id="mobile-menu" class="nav-mobile hidden">
    {navItems.map((item) => (
      <a
        href={item.href}
        class:list={['nav-mobile-link', { active: isActive(item.href, item.exact) }]}
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>

<style>
  /* Neo-Brutalist Header */
  .header {
    background: var(--color-cream, #FFFEF9);
    border-bottom: 3px solid var(--color-brutal-black, #1A1A1A);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 4.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  @media (min-width: 1024px) {
    .header-inner {
      gap: 2rem;
    }
  }

  /* Logo */
  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
    transition: transform 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  .logo:hover {
    transform: translate(-2px, -2px);
  }

  .logo-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    color: var(--color-brutal-orange, #FF6B35);
  }

  .logo-mark svg {
    width: 100%;
    height: 100%;
  }

  .logo-text {
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-brutal-black, #1A1A1A);
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  /* Desktop Navigation */
  .nav-desktop {
    display: none;
    align-items: center;
    gap: 0.5rem;
  }

  @media (min-width: 768px) {
    .nav-desktop {
      display: flex;
    }
  }

  .nav-link {
    padding: 0.625rem 1rem;
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-brutal-black, #1A1A1A);
    text-decoration: none;
    border: 2px solid transparent;
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
    position: relative;
  }

  .nav-link:hover {
    border-color: var(--color-brutal-black, #1A1A1A);
    box-shadow: 3px 3px 0 var(--color-brutal-black, #1A1A1A);
    transform: translate(-2px, -2px);
  }

  .nav-link.active {
    background: var(--color-brutal-yellow, #FFE14D);
    border-color: var(--color-brutal-black, #1A1A1A);
    box-shadow: 3px 3px 0 var(--color-brutal-black, #1A1A1A);
  }

  .nav-link.active::after {
    display: none;
  }

  /* Header Actions */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  /* Search Bar Desktop - Hidden on large screens (redundant with search modal) */
  .search-bar-desktop {
    display: none;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 1rem;
    min-width: 180px;
    background: var(--color-cream, #FFFEF9);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-black, #1A1A1A);
    cursor: pointer;
    box-shadow: 3px 3px 0 var(--color-brutal-black, #1A1A1A);
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
    font-family: var(--font-sans, 'DM Sans', sans-serif);
  }

  /* Show on tablet, hide on large desktop */
  @media (min-width: 768px) and (max-width: 1023px) {
    .search-bar-desktop {
      display: flex;
    }
  }

  .search-bar-desktop:hover {
    background: var(--color-brutal-yellow, #FFE14D);
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 var(--color-brutal-black, #1A1A1A);
  }

  .search-bar-desktop:active {
    transform: translate(1px, 1px);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
  }

  .search-bar-desktop svg {
    width: 1.125rem;
    height: 1.125rem;
    flex-shrink: 0;
    opacity: 0.6;
  }

  .search-placeholder {
    flex: 1;
    text-align: left;
    font-size: 0.875rem;
    color: var(--color-brutal-black, #1A1A1A);
    opacity: 0.5;
  }

  .search-shortcut {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.625rem;
    padding: 0.25rem 0.5rem;
    background: var(--color-brutal-black, #1A1A1A);
    color: var(--color-cream, #FFFEF9);
    border-radius: 3px;
    opacity: 0.8;
  }

  /* Search Button Mobile */
  .search-btn-mobile {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: var(--color-cream, #FFFEF9);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-black, #1A1A1A);
    cursor: pointer;
    box-shadow: 3px 3px 0 var(--color-brutal-black, #1A1A1A);
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  @media (min-width: 768px) {
    .search-btn-mobile {
      display: none;
    }
  }

  .search-btn-mobile:hover {
    background: var(--color-brutal-yellow, #FFE14D);
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 var(--color-brutal-black, #1A1A1A);
  }

  .search-btn-mobile:active {
    transform: translate(1px, 1px);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
  }

  .search-btn-mobile svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  /* Auth Section */
  .auth-section {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .btn-login {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-cream, #FFFEF9);
    background: var(--color-brutal-black, #1A1A1A);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    text-decoration: none;
    cursor: pointer;
    box-shadow: 3px 3px 0 var(--color-brutal-black, #1A1A1A);
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  .btn-login:hover {
    background: var(--color-brutal-orange, #FF6B35);
    color: var(--color-brutal-black, #1A1A1A);
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 var(--color-brutal-black, #1A1A1A);
  }

  .btn-login:active {
    transform: translate(1px, 1px);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
  }

  .auth-icon {
    width: 1rem;
    height: 1rem;
    display: none;
  }

  .auth-label {
    display: none;
  }

  @media (min-width: 768px) {
    .auth-label {
      display: inline;
    }
  }

  /* User Section (signed in) */
  .user-section {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.75rem;
    background: var(--color-cream, #FFFEF9);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 3px 3px 0 var(--color-brutal-black, #1A1A1A);
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  .user-section:hover {
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 var(--color-brutal-black, #1A1A1A);
  }

  .user-label {
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-brutal-black, #1A1A1A);
  }

  /* Mobile Menu Button */
  .mobile-menu-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: var(--color-cream, #FFFEF9);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-black, #1A1A1A);
    cursor: pointer;
    box-shadow: 3px 3px 0 var(--color-brutal-black, #1A1A1A);
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  .mobile-menu-btn:hover {
    background: var(--color-brutal-yellow, #FFE14D);
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 var(--color-brutal-black, #1A1A1A);
  }

  .mobile-menu-btn:active {
    transform: translate(1px, 1px);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
  }

  .mobile-menu-btn svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  @media (min-width: 768px) {
    .mobile-menu-btn {
      display: none;
    }
  }


  /* Mobile Navigation */
  .nav-mobile {
    padding: 0.75rem 1.5rem 1.5rem;
    border-top: 3px solid var(--color-brutal-black, #1A1A1A);
    background: var(--color-cream, #FFFEF9);
  }

  .nav-mobile.hidden {
    display: none;
  }

  @media (min-width: 768px) {
    .nav-mobile {
      display: none !important;
    }
  }

  .nav-mobile-link {
    display: block;
    padding: 0.875rem 1rem;
    margin-bottom: 0.5rem;
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-brutal-black, #1A1A1A);
    text-decoration: none;
    border: 2px solid transparent;
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  .nav-mobile-link:hover {
    border-color: var(--color-brutal-black, #1A1A1A);
    box-shadow: 3px 3px 0 var(--color-brutal-black, #1A1A1A);
    transform: translate(-2px, -2px);
  }

  .nav-mobile-link.active {
    background: var(--color-brutal-yellow, #FFE14D);
    border-color: var(--color-brutal-black, #1A1A1A);
    box-shadow: 3px 3px 0 var(--color-brutal-black, #1A1A1A);
  }
</style>

<style is:global>
  /* Hide auth and language switcher on desktop - they are redundant */
  @media (min-width: 768px) {
    .header .hide-on-desktop {
      display: none !important;
    }
  }
</style>

<script>
  // Mobile menu toggle
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');

  button?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Search triggers - both open the search modal
  const searchTriggerDesktop = document.getElementById('search-trigger-desktop');
  const searchTriggerMobile = document.getElementById('search-trigger-mobile');
  const searchModal = document.getElementById('search-modal');

  function openSearchModal() {
    if (searchModal) {
      searchModal.setAttribute('aria-hidden', 'false');
      const searchInput = searchModal.querySelector('#search-input') as HTMLInputElement;
      searchInput?.focus();
    }
  }

  searchTriggerDesktop?.addEventListener('click', openSearchModal);
  searchTriggerMobile?.addEventListener('click', openSearchModal);
</script>
