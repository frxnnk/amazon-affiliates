---
import { type Lang, getTranslation } from '@i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import siteConfig from '@data/site-config.json';
import { SignedIn, SignedOut, UserButton, SignInButton } from '@clerk/astro/components';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = getTranslation(lang);

const navItems = [
  { href: `/${lang}`, label: t('nav.home'), exact: true },
  { href: `/${lang}/products`, label: t('nav.products') },
  { href: `/${lang}/categories`, label: t('nav.categories') },
  { href: `/${lang}/lists`, label: t('nav.lists') },
];

function isActive(href: string, exact?: boolean) {
  if (exact) return currentPath === href || currentPath === href + '/';
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<header class="header">
  <div class="header-inner">
    <!-- Logo -->
    <a href={`/${lang}`} class="logo">
      <span class="logo-mark">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2L2 7l10 5 10-5-10-5z" fill="currentColor" opacity="0.9"/>
          <path d="M2 17l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
      <span class="logo-text">{siteConfig.site.name}</span>
    </a>

    <!-- Navigation -->
    <nav class="nav-desktop">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={['nav-link', { active: isActive(item.href, item.exact) }]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Right side -->
    <div class="header-actions">
      <!-- Search -->
      <button
        type="button"
        class="search-btn"
        aria-label={t('nav.search')}
        id="search-trigger"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="11" cy="11" r="8" />
          <path d="M21 21l-4.35-4.35" />
        </svg>
      </button>

      <!-- Auth -->
      <div class="auth-section">
        <SignedOut>
          <SignInButton mode="modal">
            <button class="btn-login">{t('nav.login')}</button>
          </SignInButton>
        </SignedOut>
        <SignedIn>
          <a href={`/${lang}/dashboard`} class="btn-dashboard">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="3" width="7" height="7" rx="1"/>
              <rect x="14" y="3" width="7" height="7" rx="1"/>
              <rect x="3" y="14" width="7" height="7" rx="1"/>
              <rect x="14" y="14" width="7" height="7" rx="1"/>
            </svg>
            <span>{t('nav.dashboard')}</span>
          </a>
          <UserButton />
        </SignedIn>
      </div>

      <LanguageSwitcher currentLang={lang} currentPath={currentPath} />

      <!-- Mobile menu button -->
      <button
        type="button"
        class="mobile-menu-btn"
        aria-label="Menu"
        id="mobile-menu-button"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <nav id="mobile-menu" class="nav-mobile hidden">
    {navItems.map((item) => (
      <a
        href={item.href}
        class:list={['nav-mobile-link', { active: isActive(item.href, item.exact) }]}
      >
        {item.label}
      </a>
    ))}
    <SignedIn>
      <a href={`/${lang}/dashboard`} class="nav-mobile-link">
        {t('nav.dashboard')}
      </a>
    </SignedIn>
  </nav>
</header>

<style>
  .header {
    background: rgba(253, 251, 247, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-sand, #E8E4DD);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 4.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  /* Logo */
  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
  }

  .logo-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    color: var(--color-honey, #C8956C);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .logo:hover .logo-mark {
    transform: scale(1.05);
  }

  .logo-mark svg {
    width: 100%;
    height: 100%;
  }

  .logo-text {
    font-family: var(--font-display, 'Fraunces', Georgia, serif);
    font-size: 1.375rem;
    font-weight: 500;
    color: var(--color-ink, #1A1815);
    letter-spacing: -0.02em;
  }

  /* Desktop Navigation */
  .nav-desktop {
    display: none;
    align-items: center;
    gap: 0.25rem;
  }

  @media (min-width: 768px) {
    .nav-desktop {
      display: flex;
    }
  }

  .nav-link {
    padding: 0.625rem 1rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-stone, #6B6560);
    text-decoration: none;
    border-radius: 8px;
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
  }

  .nav-link:hover {
    color: var(--color-ink, #1A1815);
    background: var(--color-sand, #E8E4DD);
  }

  .nav-link.active {
    color: var(--color-ink, #1A1815);
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: 0.375rem;
    left: 1rem;
    right: 1rem;
    height: 2px;
    background: var(--color-honey, #C8956C);
    border-radius: 1px;
  }

  /* Header Actions */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Search Button */
  .search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: transparent;
    border: none;
    color: var(--color-stone, #6B6560);
    cursor: pointer;
    border-radius: 8px;
    transition: all 0.2s;
  }

  .search-btn:hover {
    background: var(--color-sand, #E8E4DD);
    color: var(--color-ink, #1A1815);
  }

  .search-btn svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  /* Auth Section */
  .auth-section {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .btn-login {
    padding: 0.625rem 1.25rem;
    font-family: var(--font-sans, 'DM Sans', sans-serif);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-cream, #FDFBF7);
    background: var(--color-ink, #1A1815);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .btn-login:hover {
    background: var(--color-ink-light, #2D2926);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(26, 24, 21, 0.15);
  }

  .btn-dashboard {
    display: none;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-stone, #6B6560);
    text-decoration: none;
    border-radius: 8px;
    transition: all 0.2s;
  }

  @media (min-width: 640px) {
    .btn-dashboard {
      display: flex;
    }
  }

  .btn-dashboard:hover {
    background: var(--color-sand, #E8E4DD);
    color: var(--color-ink, #1A1815);
  }

  .btn-dashboard svg {
    width: 1rem;
    height: 1rem;
  }

  /* Mobile Menu Button */
  .mobile-menu-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: transparent;
    border: none;
    color: var(--color-stone, #6B6560);
    cursor: pointer;
    border-radius: 8px;
    transition: all 0.2s;
  }

  .mobile-menu-btn:hover {
    background: var(--color-sand, #E8E4DD);
    color: var(--color-ink, #1A1815);
  }

  .mobile-menu-btn svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  @media (min-width: 768px) {
    .mobile-menu-btn {
      display: none;
    }
  }

  /* Mobile Navigation */
  .nav-mobile {
    padding: 0.75rem 1.5rem 1.5rem;
    border-top: 1px solid var(--color-sand, #E8E4DD);
    background: var(--color-cream, #FDFBF7);
  }

  .nav-mobile.hidden {
    display: none;
  }

  @media (min-width: 768px) {
    .nav-mobile {
      display: none !important;
    }
  }

  .nav-mobile-link {
    display: block;
    padding: 0.875rem 1rem;
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-stone, #6B6560);
    text-decoration: none;
    border-radius: 8px;
    transition: all 0.2s;
  }

  .nav-mobile-link:hover {
    color: var(--color-ink, #1A1815);
    background: var(--color-sand, #E8E4DD);
  }

  .nav-mobile-link.active {
    color: var(--color-ink, #1A1815);
    background: var(--color-honey-muted, #E8D5C4);
  }
</style>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');

  button?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
