---
import PriceDisplay from '@components/affiliate/PriceDisplay.astro';
import AffiliateLink from '@components/affiliate/AffiliateLink.astro';
import ProductRating from './ProductRating.astro';
import { type Lang, getTranslation } from '@i18n/utils';

interface Props {
  product: {
    productId: string;
    asin: string;
    title: string;
    brand: string;
    price: number;
    originalPrice?: number;
    currency: string;
    rating: number;
    ourRating?: number;
    featuredImage: { url: string; alt: string };
    images?: string[]; // All product images for carousel
    affiliateUrl: string;
    isOnSale?: boolean;
    isFeatured?: boolean;
    shortDescription?: string;
    category?: string;
  };
  lang: Lang;
  variant?: 'default' | 'featured' | 'compact';
  showCashback?: boolean;
}

const { product, lang, variant = 'default', showCashback = true } = Astro.props;
const t = getTranslation(lang);

const discount = product.originalPrice
  ? Math.round(((product.originalPrice - product.price) / product.originalPrice) * 100)
  : 0;

// Estimated cashback (2% of price as example)
const estimatedCashback = (product.price * 0.02).toFixed(2);

// Get all images for carousel (fallback to featured image)
const productImages = product.images && product.images.length > 0
  ? product.images
  : [product.featuredImage?.url].filter(Boolean) as string[];
const hasMultipleImages = productImages.length > 1;

// Truncate description for "see more" functionality
const MAX_DESC_LENGTH = 20;
const fullDescription = product.shortDescription || '';
const shouldTruncate = fullDescription.length > MAX_DESC_LENGTH;
const truncatedDescription = shouldTruncate
  ? fullDescription.slice(0, MAX_DESC_LENGTH) + '...'
  : fullDescription;
---

<article class:list={['product-card', `variant-${variant}`]}>
  <!-- Badge -->
  {product.isFeatured && (
    <span class="card-badge badge-featured">
      <svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
      {t('common.featured')}
    </span>
  )}
  {!product.isFeatured && product.isOnSale && discount > 0 && (
    <span class="card-badge badge-sale">-{discount}%</span>
  )}

  <!-- Image -->
  <a href={`/${lang}/products/${product.productId}`} class="card-image-link">
    {hasMultipleImages ? (
      <!-- Image carousel -->
      <div class="card-image card-carousel" data-card-carousel>
        <div class="card-carousel-track" data-card-carousel-track>
          {productImages.map((imgUrl, imgIndex) => (
            <div class="card-carousel-slide">
              <img
                src={imgUrl}
                alt={`${product.title} - ${imgIndex + 1}`}
                loading="lazy"
                decoding="async"
              />
            </div>
          ))}
        </div>
        <!-- Carousel dots -->
        <div class="card-carousel-dots">
          {productImages.map((_, imgIndex) => (
            <button
              class:list={['card-carousel-dot', { active: imgIndex === 0 }]}
              data-card-dot={imgIndex}
              aria-label={`${lang === 'es' ? 'Imagen' : 'Image'} ${imgIndex + 1}`}
            />
          ))}
        </div>
        <!-- Nav arrows -->
        <button class="card-carousel-nav card-carousel-prev" data-card-prev aria-label={lang === 'es' ? 'Anterior' : 'Previous'}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </button>
        <button class="card-carousel-nav card-carousel-next" data-card-next aria-label={lang === 'es' ? 'Siguiente' : 'Next'}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </button>
      </div>
    ) : (
      <div class="card-image">
        {product.featuredImage?.url ? (
          <img
            src={product.featuredImage.url}
            alt={product.featuredImage.alt || product.title}
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="image-placeholder">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
              <rect x="3" y="3" width="18" height="18" rx="2" />
              <circle cx="8.5" cy="8.5" r="1.5" />
              <path d="M21 15l-5-5L5 21" />
            </svg>
          </div>
        )}
      </div>
    )}
  </a>

  <!-- Content -->
  <div class="card-content">
    <!-- Brand & Category -->
    <div class="card-meta">
      <span class="meta-brand">{product.brand}</span>
      {product.category && (
        <>
          <span class="meta-separator">/</span>
          <span class="meta-category">{product.category}</span>
        </>
      )}
    </div>

    <!-- Title -->
    <h3 class="card-title">
      <a href={`/${lang}/products/${product.productId}`}>
        {product.title}
      </a>
    </h3>

    <!-- Description with see more (non-compact only) -->
    {variant !== 'compact' && fullDescription && (
      <div class="card-description-wrapper">
        <p class="card-description" data-card-description data-full={fullDescription} data-truncated={truncatedDescription} data-lang={lang}>
          <span class="card-description-text">{truncatedDescription}</span>
          {shouldTruncate && (
            <button class="card-see-more" data-card-see-more type="button">
              {lang === 'es' ? 'ver más' : 'see more'}
            </button>
          )}
        </p>
      </div>
    )}

    <!-- Rating -->
    <div class="card-rating">
      <ProductRating rating={product.rating} size="sm" />
    </div>

    <!-- Price & Cashback -->
    <div class="card-footer">
      <div class="price-section">
        <PriceDisplay
          price={product.price}
          originalPrice={product.originalPrice}
          currency={product.currency}
          lang={lang}
          size="md"
        />
        {showCashback && (
          <span class="cashback-hint">
            +${estimatedCashback} cashback
          </span>
        )}
      </div>

      <AffiliateLink
        productId={product.productId}
        asin={product.asin}
        affiliateUrl={product.affiliateUrl}
        lang={lang}
        variant="card"
        trackingLabel="product-card"
      >
        <span class="cta-text">{t('common.viewOnAmazon')}</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="cta-arrow">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </AffiliateLink>
    </div>
  </div>
</article>

<style>
  /* Neo-Brutalist Product Card */
  .product-card {
    position: relative;
    background: var(--color-cream, #FFFEF9);
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 6px 6px 0 var(--color-brutal-black, #1A1A1A);
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  .product-card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 10px 10px 0 var(--color-brutal-black, #1A1A1A);
  }

  /* Featured variant */
  .variant-featured {
    border-width: 4px;
    background: var(--color-brutal-yellow, #FFE14D);
  }

  .variant-featured .card-content {
    background: var(--color-cream, #FFFEF9);
  }

  .variant-featured:hover {
    box-shadow: 12px 12px 0 var(--color-brutal-black, #1A1A1A);
  }

  /* Compact variant */
  .variant-compact .card-content {
    padding: 1rem;
    gap: 0.375rem;
  }

  .variant-compact .card-title {
    font-size: 0.875rem;
  }

  /* Badge */
  .card-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 10;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
  }

  .badge-featured {
    background: var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-yellow, #FFE14D);
  }

  .badge-sale {
    background: var(--color-brutal-orange, #FF6B35);
    color: var(--color-brutal-black, #1A1A1A);
  }

  /* Image */
  .card-image-link {
    display: block;
  }

  .card-image {
    aspect-ratio: 4/3;
    background: var(--color-white, #FFFFFF);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    border-bottom: 3px solid var(--color-brutal-black, #1A1A1A);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 1.5rem;
    transition: transform 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  .product-card:hover .card-image img {
    transform: scale(1.02);
  }

  .image-placeholder {
    color: var(--color-brutal-black, #1A1A1A);
    opacity: 0.3;
  }

  .image-placeholder svg {
    width: 3rem;
    height: 3rem;
  }

  /* Content */
  .card-content {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    flex: 1;
  }

  /* Meta */
  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.625rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .meta-brand {
    font-weight: 700;
    color: var(--color-brutal-black, #1A1A1A);
  }

  .meta-separator {
    color: var(--color-brutal-black, #1A1A1A);
    opacity: 0.3;
  }

  .meta-category {
    color: var(--color-brutal-black, #1A1A1A);
    opacity: 0.6;
  }

  /* Title */
  .card-title {
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-title a {
    color: var(--color-brutal-black, #1A1A1A);
    text-decoration: none;
  }

  .card-title a:hover {
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 2px;
  }

  /* Description */
  .card-description-wrapper {
    margin-bottom: 0.25rem;
  }

  .card-description {
    font-size: 0.8125rem;
    color: var(--color-brutal-black, #1A1A1A);
    opacity: 0.7;
    line-height: 1.5;
    margin: 0;
    display: inline;
  }

  .card-description-text {
    display: inline;
  }

  .card-see-more {
    display: inline;
    background: none;
    border: none;
    padding: 0;
    margin-left: 0.25rem;
    font-size: 0.8125rem;
    color: var(--color-brutal-orange, #FF6B35);
    cursor: pointer;
    font-weight: 700;
    text-transform: uppercase;
  }

  .card-see-more:hover {
    text-decoration: underline;
    text-decoration-thickness: 2px;
  }

  /* Rating */
  .card-rating {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Footer */
  .card-footer {
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 2px dashed var(--color-brutal-black, #1A1A1A);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .price-section {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .cashback-hint {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-brutal-green, #2D9D4E);
    display: flex;
    align-items: center;
    gap: 0.375rem;
    text-transform: uppercase;
  }

  .cashback-hint::before {
    content: '+';
    font-weight: 800;
  }

  /* CTA Button styling override */
  .card-footer :global(a) {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: var(--color-brutal-orange, #FF6B35);
    color: var(--color-brutal-black, #1A1A1A);
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    text-decoration: none;
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 4px 4px 0 var(--color-brutal-black, #1A1A1A);
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  .card-footer :global(a:hover) {
    background: var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-orange, #FF6B35);
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-brutal-black, #1A1A1A);
  }

  .card-footer :global(a:active) {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
  }

  .cta-arrow {
    width: 1rem;
    height: 1rem;
    transition: transform 150ms;
  }

  .card-footer :global(a:hover) .cta-arrow {
    transform: translateX(4px);
  }

  /* Card Carousel */
  .card-carousel {
    position: relative;
    overflow: hidden;
  }

  .card-carousel-track {
    display: flex;
    height: 100%;
    transition: transform 200ms ease-out;
  }

  .card-carousel-slide {
    flex: 0 0 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  .card-carousel-slide img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .card-carousel-dots {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
    z-index: 2;
  }

  .card-carousel-dot {
    width: 8px;
    height: 8px;
    background: var(--color-cream, #FFFEF9);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    padding: 0;
    cursor: pointer;
    transition: all 150ms;
  }

  .card-carousel-dot.active {
    background: var(--color-brutal-yellow, #FFE14D);
    transform: scale(1.1);
  }

  .card-carousel-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 28px;
    height: 28px;
    background: var(--color-cream, #FFFEF9);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-black, #1A1A1A);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
    opacity: 0;
    z-index: 2;
  }

  .card-carousel:hover .card-carousel-nav {
    opacity: 1;
  }

  .card-carousel-nav:hover {
    background: var(--color-brutal-yellow, #FFE14D);
    transform: translateY(-50%) translate(-2px, -2px);
    box-shadow: 4px 4px 0 var(--color-brutal-black, #1A1A1A);
  }

  .card-carousel-prev {
    left: 8px;
  }

  .card-carousel-next {
    right: 8px;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .card-content {
      padding: 1rem 1.25rem 1.25rem;
    }

    .card-image img {
      padding: 1rem;
    }

    .card-carousel-nav {
      opacity: 1;
      width: 24px;
      height: 24px;
    }
  }
</style>

<script>
  // Initialize card carousels and see more buttons
  function initProductCard() {
    // Card carousel functionality
    document.querySelectorAll('[data-card-carousel]').forEach((carousel) => {
      const track = carousel.querySelector('[data-card-carousel-track]') as HTMLElement;
      const slides = carousel.querySelectorAll('.card-carousel-slide');
      const dots = carousel.querySelectorAll('[data-card-dot]');
      const prevBtn = carousel.querySelector('[data-card-prev]');
      const nextBtn = carousel.querySelector('[data-card-next]');

      if (!track || slides.length === 0) return;

      let currentIndex = 0;
      const totalSlides = slides.length;

      function goToSlide(index: number) {
        currentIndex = Math.max(0, Math.min(index, totalSlides - 1));
        track.style.transform = `translateX(-${currentIndex * 100}%)`;

        dots.forEach((dot, i) => {
          dot.classList.toggle('active', i === currentIndex);
        });
      }

      prevBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        goToSlide(currentIndex - 1);
      });

      nextBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        goToSlide(currentIndex + 1);
      });

      dots.forEach((dot, index) => {
        dot.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          goToSlide(index);
        });
      });
    });

  }

  // See more functionality - use event delegation for dynamic content
  function initCardSeeMore() {
    document.removeEventListener('click', handleCardSeeMoreClick);
    document.addEventListener('click', handleCardSeeMoreClick);
  }

  function handleCardSeeMoreClick(e: Event) {
    const target = e.target as HTMLElement;
    if (!target.matches('[data-card-see-more]')) return;

    e.preventDefault();
    e.stopPropagation();

    const btn = target;
    const description = btn.closest('[data-card-description]') as HTMLElement;
    if (!description) return;

    const fullText = description.dataset.full || '';
    const truncatedText = description.dataset.truncated || '';
    const textSpan = description.querySelector('.card-description-text');
    const isSpanish = description.dataset.lang === 'es';

    if (!textSpan) return;

    const isExpanded = description.dataset.expanded === 'true';

    if (isExpanded) {
      textSpan.textContent = truncatedText;
      btn.textContent = isSpanish ? 'ver más' : 'see more';
      description.dataset.expanded = 'false';
    } else {
      textSpan.textContent = fullText;
      btn.textContent = isSpanish ? 'ver menos' : 'see less';
      description.dataset.expanded = 'true';
    }
  }

  // Run on load and after Astro page transitions
  initProductCard();
  initCardSeeMore();
  document.addEventListener('astro:after-swap', () => {
    initProductCard();
    initCardSeeMore();
  });
</script>
