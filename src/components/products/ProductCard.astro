---
import PriceDisplay from '@components/affiliate/PriceDisplay.astro';
import AffiliateLink from '@components/affiliate/AffiliateLink.astro';
import ProductRating from './ProductRating.astro';
import { type Lang, getTranslation } from '@i18n/utils';

interface Props {
  product: {
    productId: string;
    asin: string;
    title: string;
    brand: string;
    price: number;
    originalPrice?: number;
    currency: string;
    rating: number;
    ourRating?: number;
    featuredImage: { url: string; alt: string };
    images?: string[]; // All product images for carousel
    affiliateUrl: string;
    isOnSale?: boolean;
    isFeatured?: boolean;
    shortDescription?: string;
    category?: string;
    // Text variants (new)
    displayTitle?: string;
    shortTitle?: string;
    cardDescription?: string;
  };
  lang: Lang;
  variant?: 'default' | 'featured' | 'compact';
}

const { product, lang, variant = 'default' } = Astro.props;
const t = getTranslation(lang);

const discount = product.originalPrice
  ? Math.round(((product.originalPrice - product.price) / product.originalPrice) * 100)
  : 0;

// Get all images for carousel (fallback to featured image)
const productImages = product.images && product.images.length > 0
  ? product.images
  : [product.featuredImage?.url].filter(Boolean) as string[];
const hasMultipleImages = productImages.length > 1;

// Use text variants with fallbacks
const displayTitle = variant === 'compact'
  ? (product.shortTitle || product.displayTitle || product.title)
  : (product.displayTitle || product.title);

// Description handling - show preview with expandable full text
const fullDescription = product.cardDescription || product.shortDescription || '';
const hasDescription = fullDescription.length > 0;
---

<article class:list={['product-card', `variant-${variant}`]}>
  <!-- Badge -->
  {product.isFeatured && (
    <span class="card-badge badge-featured">
      <svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
      {t('common.featured')}
    </span>
  )}
  {!product.isFeatured && product.isOnSale && discount > 0 && (
    <span class="card-badge badge-sale">-{discount}%</span>
  )}

  <!-- Image -->
  <a href={`/${lang}/products/${product.productId}`} class="card-image-link">
    {hasMultipleImages ? (
      <!-- Image carousel -->
      <div class="card-image card-carousel" data-card-carousel>
        <div class="card-carousel-track" data-card-carousel-track>
          {productImages.map((imgUrl, imgIndex) => (
            <div class="card-carousel-slide">
              <img
                src={imgUrl}
                alt={`${product.title} - ${imgIndex + 1}`}
                loading="lazy"
                decoding="async"
              />
            </div>
          ))}
        </div>
        <!-- Carousel dots -->
        <div class="card-carousel-dots">
          {productImages.map((_, imgIndex) => (
            <button
              class:list={['card-carousel-dot', { active: imgIndex === 0 }]}
              data-card-dot={imgIndex}
              aria-label={`${lang === 'es' ? 'Imagen' : 'Image'} ${imgIndex + 1}`}
            />
          ))}
        </div>
        <!-- Nav arrows -->
        <button class="card-carousel-nav card-carousel-prev" data-card-prev aria-label={lang === 'es' ? 'Anterior' : 'Previous'}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </button>
        <button class="card-carousel-nav card-carousel-next" data-card-next aria-label={lang === 'es' ? 'Siguiente' : 'Next'}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </button>
      </div>
    ) : (
      <div class="card-image">
        {product.featuredImage?.url ? (
          <img
            src={product.featuredImage.url}
            alt={product.featuredImage.alt || product.title}
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="image-placeholder">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
              <rect x="3" y="3" width="18" height="18" rx="2" />
              <circle cx="8.5" cy="8.5" r="1.5" />
              <path d="M21 15l-5-5L5 21" />
            </svg>
          </div>
        )}
      </div>
    )}
  </a>

  <!-- Content -->
  <div class="card-content">
    <!-- Brand & Category -->
    <div class="card-meta">
      <span class="meta-brand">{product.brand}</span>
      {product.category && (
        <>
          <span class="meta-separator">/</span>
          <span class="meta-category">{product.category}</span>
        </>
      )}
    </div>

    <!-- Title - with tooltip for full title on truncated text -->
    <h3 class="card-title" title={product.title}>
      <a href={`/${lang}/products/${product.productId}`}>
        {displayTitle}
      </a>
    </h3>

    <!-- Description with expandable text (non-compact only) -->
    {variant !== 'compact' && hasDescription && (
      <div class="card-description-wrapper" data-description-wrapper>
        <p class="card-description" data-card-description data-full={fullDescription} data-lang={lang}>
          {fullDescription}
        </p>
        <button class="card-see-more" data-card-see-more type="button">
          {lang === 'es' ? 'ver más' : 'see more'}
        </button>
      </div>
    )}

    <!-- Rating -->
    <div class="card-rating">
      <ProductRating rating={product.rating} size="sm" />
    </div>

    <!-- Price -->
    <div class="card-footer">
      <div class="price-section">
        <PriceDisplay
          price={product.price}
          originalPrice={product.originalPrice}
          currency={product.currency}
          lang={lang}
          size="md"
        />
      </div>

      <div class="card-actions">
        <button
          type="button"
          class="btn-add-cart"
          data-add-to-cart
          data-product={JSON.stringify({
            asin: product.asin,
            productId: product.productId,
            title: product.title,
            brand: product.brand,
            image: product.featuredImage?.url || '',
            price: product.price,
            currency: product.currency,
            affiliateUrl: product.affiliateUrl
          })}
          aria-label={lang === 'es' ? 'Agregar al carrito' : 'Add to cart'}
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
            <line x1="3" y1="6" x2="21" y2="6" />
            <path d="M16 10a4 4 0 0 1-8 0" />
          </svg>
          <span class="btn-add-cart-plus">+</span>
        </button>

        <AffiliateLink
          productId={product.productId}
          asin={product.asin}
          affiliateUrl={product.affiliateUrl}
          lang={lang}
          variant="card"
          trackingLabel="product-card"
        >
          <span class="cta-text">{t('common.viewOnAmazon')}</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="cta-arrow">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </AffiliateLink>
      </div>
    </div>
  </div>
</article>

<style>
  /* Neo-Brutalist Product Card */
  .product-card {
    position: relative;
    background: var(--color-cream, #FFFEF9);
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 6px 6px 0 var(--color-brutal-black, #1A1A1A);
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  .product-card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 10px 10px 0 var(--color-brutal-black, #1A1A1A);
  }

  /* Featured variant */
  .variant-featured {
    border-width: 4px;
    background: var(--color-brutal-yellow, #FFE14D);
  }

  .variant-featured .card-content {
    background: var(--color-cream, #FFFEF9);
  }

  .variant-featured:hover {
    box-shadow: 12px 12px 0 var(--color-brutal-black, #1A1A1A);
  }

  /* Compact variant */
  .variant-compact .card-content {
    padding: 1rem;
    gap: 0.375rem;
  }

  .variant-compact .card-title {
    font-size: 0.875rem;
  }

  /* Badge */
  .card-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 10;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
  }

  .badge-featured {
    background: var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-yellow, #FFE14D);
  }

  .badge-sale {
    background: var(--color-brutal-orange, #FF6B35);
    color: var(--color-brutal-black, #1A1A1A);
  }

  /* Image */
  .card-image-link {
    display: block;
  }

  .card-image {
    aspect-ratio: 4/3;
    background: var(--color-white, #FFFFFF);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    border-bottom: 3px solid var(--color-brutal-black, #1A1A1A);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 1.5rem;
    transition: transform 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  .product-card:hover .card-image img {
    transform: scale(1.02);
  }

  .image-placeholder {
    color: var(--color-brutal-black, #1A1A1A);
    opacity: 0.3;
  }

  .image-placeholder svg {
    width: 3rem;
    height: 3rem;
  }

  /* Content */
  .card-content {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    flex: 1;
  }

  /* Meta */
  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.625rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .meta-brand {
    font-weight: 700;
    color: var(--color-brutal-black, #1A1A1A);
  }

  .meta-separator {
    color: var(--color-brutal-black, #1A1A1A);
    opacity: 0.3;
  }

  .meta-category {
    color: var(--color-brutal-black, #1A1A1A);
    opacity: 0.6;
  }

  /* Title */
  .card-title {
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-title a {
    color: var(--color-brutal-black, #1A1A1A);
    text-decoration: none;
  }

  .card-title a:hover {
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 2px;
  }

  /* Description - Expandable */
  .card-description-wrapper {
    margin-bottom: 0.25rem;
    position: relative;
  }

  .card-description {
    font-size: 0.8125rem;
    color: var(--color-brutal-black, #1A1A1A);
    opacity: 0.7;
    line-height: 1.5;
    margin: 0;
    /* Default: collapsed state with line-clamp */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: all 200ms ease-out;
  }

  /* Expanded state */
  .card-description-wrapper[data-expanded="true"] .card-description {
    -webkit-line-clamp: unset;
    display: block;
  }

  .card-see-more {
    display: inline-block;
    background: none;
    border: none;
    padding: 0;
    margin-top: 0.375rem;
    font-size: 0.75rem;
    color: var(--color-brutal-orange, #FF6B35);
    cursor: pointer;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .card-see-more:hover {
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 2px;
  }

  /* Hide see more button for short descriptions */
  .card-description-wrapper[data-short="true"] .card-see-more {
    display: none;
  }

  /* Rating */
  .card-rating {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Footer */
  .card-footer {
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 2px dashed var(--color-brutal-black, #1A1A1A);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .price-section {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  /* Card Actions Row */
  .card-actions {
    display: flex;
    gap: 0.5rem;
  }

  /* Add to Cart Button */
  .btn-add-cart {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    background: var(--color-cream, #FFFEF9);
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-black, #1A1A1A);
    cursor: pointer;
    box-shadow: 4px 4px 0 var(--color-brutal-black, #1A1A1A);
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
    position: relative;
    flex-shrink: 0;
  }

  .btn-add-cart:hover {
    background: var(--color-brutal-yellow, #FFE14D);
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-brutal-black, #1A1A1A);
  }

  .btn-add-cart:active {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
  }

  .btn-add-cart svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .btn-add-cart-plus {
    position: absolute;
    bottom: 2px;
    right: 2px;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1;
  }

  /* Added state */
  .btn-add-cart[data-added="true"] {
    background: var(--color-brutal-yellow, #FFE14D);
  }

  .btn-add-cart[data-added="true"] .btn-add-cart-plus::after {
    content: '✓';
  }

  /* CTA Button styling override */
  .card-actions :global(a) {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: var(--color-brutal-orange, #FF6B35);
    color: var(--color-brutal-black, #1A1A1A);
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    text-decoration: none;
    border: 3px solid var(--color-brutal-black, #1A1A1A);
    box-shadow: 4px 4px 0 var(--color-brutal-black, #1A1A1A);
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
  }

  .card-actions :global(a:hover) {
    background: var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-orange, #FF6B35);
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-brutal-black, #1A1A1A);
  }

  .card-actions :global(a:active) {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
  }

  .cta-arrow {
    width: 1rem;
    height: 1rem;
    transition: transform 150ms;
  }

  .card-actions :global(a:hover) .cta-arrow {
    transform: translateX(4px);
  }

  /* Card Carousel */
  .card-carousel {
    position: relative;
    overflow: hidden;
  }

  .card-carousel-track {
    display: flex;
    height: 100%;
    transition: transform 200ms ease-out;
  }

  .card-carousel-slide {
    flex: 0 0 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  .card-carousel-slide img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .card-carousel-dots {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
    z-index: 2;
  }

  .card-carousel-dot {
    width: 8px;
    height: 8px;
    background: var(--color-cream, #FFFEF9);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    padding: 0;
    cursor: pointer;
    transition: all 150ms;
  }

  .card-carousel-dot.active {
    background: var(--color-brutal-yellow, #FFE14D);
    transform: scale(1.1);
  }

  .card-carousel-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 28px;
    height: 28px;
    background: var(--color-cream, #FFFEF9);
    border: 2px solid var(--color-brutal-black, #1A1A1A);
    color: var(--color-brutal-black, #1A1A1A);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 2px 2px 0 var(--color-brutal-black, #1A1A1A);
    transition: all 150ms cubic-bezier(0.68, -0.6, 0.32, 1.6);
    opacity: 0;
    z-index: 2;
  }

  .card-carousel:hover .card-carousel-nav {
    opacity: 1;
  }

  .card-carousel-nav:hover {
    background: var(--color-brutal-yellow, #FFE14D);
    transform: translateY(-50%) translate(-2px, -2px);
    box-shadow: 4px 4px 0 var(--color-brutal-black, #1A1A1A);
  }

  .card-carousel-prev {
    left: 8px;
  }

  .card-carousel-next {
    right: 8px;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .card-content {
      padding: 1rem 1.25rem 1.25rem;
    }

    .card-image img {
      padding: 1rem;
    }

    .card-carousel-nav {
      opacity: 1;
      width: 24px;
      height: 24px;
    }
  }
</style>

<script>
  // Initialize card carousels and see more buttons
  function initProductCard() {
    // Card carousel functionality
    document.querySelectorAll('[data-card-carousel]').forEach((carousel) => {
      const track = carousel.querySelector('[data-card-carousel-track]') as HTMLElement;
      const slides = carousel.querySelectorAll('.card-carousel-slide');
      const dots = carousel.querySelectorAll('[data-card-dot]');
      const prevBtn = carousel.querySelector('[data-card-prev]');
      const nextBtn = carousel.querySelector('[data-card-next]');

      if (!track || slides.length === 0) return;

      let currentIndex = 0;
      const totalSlides = slides.length;

      function goToSlide(index: number) {
        currentIndex = Math.max(0, Math.min(index, totalSlides - 1));
        track.style.transform = `translateX(-${currentIndex * 100}%)`;

        dots.forEach((dot, i) => {
          dot.classList.toggle('active', i === currentIndex);
        });
      }

      prevBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        goToSlide(currentIndex - 1);
      });

      nextBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        goToSlide(currentIndex + 1);
      });

      dots.forEach((dot, index) => {
        dot.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          goToSlide(index);
        });
      });
    });

  }

  // See more functionality - use event delegation for dynamic content
  function initCardSeeMore() {
    // Check if descriptions are short enough to hide "see more" button
    document.querySelectorAll('[data-description-wrapper]').forEach((wrapper) => {
      const description = wrapper.querySelector('[data-card-description]') as HTMLElement;
      if (!description) return;

      // Check if content is truncated by comparing scrollHeight to clientHeight
      requestAnimationFrame(() => {
        const isTruncated = description.scrollHeight > description.clientHeight;
        if (!isTruncated) {
          (wrapper as HTMLElement).dataset.short = 'true';
        }
      });
    });

    document.removeEventListener('click', handleCardSeeMoreClick);
    document.addEventListener('click', handleCardSeeMoreClick);
  }

  function handleCardSeeMoreClick(e: Event) {
    const target = e.target as HTMLElement;
    if (!target.matches('[data-card-see-more]')) return;

    e.preventDefault();
    e.stopPropagation();

    const btn = target;
    const wrapper = btn.closest('[data-description-wrapper]') as HTMLElement;
    if (!wrapper) return;

    const description = wrapper.querySelector('[data-card-description]') as HTMLElement;
    if (!description) return;

    const isSpanish = description.dataset.lang === 'es';
    const isExpanded = wrapper.dataset.expanded === 'true';

    if (isExpanded) {
      wrapper.dataset.expanded = 'false';
      btn.textContent = isSpanish ? 'ver más' : 'see more';
    } else {
      wrapper.dataset.expanded = 'true';
      btn.textContent = isSpanish ? 'ver menos' : 'see less';
    }
  }

  // Add to cart functionality - event delegation
  function initAddToCart() {
    document.removeEventListener('click', handleAddToCartClick);
    document.addEventListener('click', handleAddToCartClick);
  }

  function handleAddToCartClick(e: Event) {
    const target = e.target as HTMLElement;
    const btn = target.closest('[data-add-to-cart]') as HTMLElement;
    if (!btn) return;

    e.preventDefault();
    e.stopPropagation();

    try {
      const productData = JSON.parse(btn.dataset.product || '{}');
      if (productData.asin && (window as any).cart?.add) {
        (window as any).cart.add(productData);

        // Visual feedback
        btn.dataset.added = 'true';
        const plusSpan = btn.querySelector('.btn-add-cart-plus');
        if (plusSpan) {
          plusSpan.textContent = '✓';
        }

        // Reset after 2 seconds
        setTimeout(() => {
          btn.dataset.added = 'false';
          if (plusSpan) {
            plusSpan.textContent = '+';
          }
        }, 2000);
      }
    } catch (error) {
      console.error('Failed to add to cart:', error);
    }
  }

  // Run on load and after Astro page transitions
  initProductCard();
  initCardSeeMore();
  initAddToCart();
  document.addEventListener('astro:after-swap', () => {
    initProductCard();
    initCardSeeMore();
    initAddToCart();
  });
</script>
