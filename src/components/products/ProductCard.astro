---
import PriceDisplay from '@components/affiliate/PriceDisplay.astro';
import AffiliateLink from '@components/affiliate/AffiliateLink.astro';
import ProductRating from './ProductRating.astro';
import { type Lang, getTranslation } from '@i18n/utils';

interface Props {
  product: {
    productId: string;
    asin: string;
    title: string;
    brand: string;
    price: number;
    originalPrice?: number;
    currency: string;
    rating: number;
    ourRating?: number;
    featuredImage: { url: string; alt: string };
    affiliateUrl: string;
    isOnSale?: boolean;
    isFeatured?: boolean;
    shortDescription?: string;
    category?: string;
  };
  lang: Lang;
  variant?: 'default' | 'featured' | 'compact';
  showCashback?: boolean;
}

const { product, lang, variant = 'default', showCashback = true } = Astro.props;
const t = getTranslation(lang);

const discount = product.originalPrice
  ? Math.round(((product.originalPrice - product.price) / product.originalPrice) * 100)
  : 0;

// Estimated cashback (2% of price as example)
const estimatedCashback = (product.price * 0.02).toFixed(2);
---

<article class:list={['product-card', `variant-${variant}`]}>
  <!-- Badge -->
  {product.isFeatured && (
    <span class="card-badge badge-featured">
      <svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
      {t('common.featured')}
    </span>
  )}
  {!product.isFeatured && product.isOnSale && discount > 0 && (
    <span class="card-badge badge-sale">-{discount}%</span>
  )}

  <!-- Image -->
  <a href={`/${lang}/products/${product.productId}`} class="card-image-link">
    <div class="card-image">
      {product.featuredImage?.url ? (
        <img
          src={product.featuredImage.url}
          alt={product.featuredImage.alt || product.title}
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="image-placeholder">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
            <rect x="3" y="3" width="18" height="18" rx="2" />
            <circle cx="8.5" cy="8.5" r="1.5" />
            <path d="M21 15l-5-5L5 21" />
          </svg>
        </div>
      )}
    </div>
  </a>

  <!-- Content -->
  <div class="card-content">
    <!-- Brand & Category -->
    <div class="card-meta">
      <span class="meta-brand">{product.brand}</span>
      {product.category && (
        <>
          <span class="meta-separator">/</span>
          <span class="meta-category">{product.category}</span>
        </>
      )}
    </div>

    <!-- Title -->
    <h3 class="card-title">
      <a href={`/${lang}/products/${product.productId}`}>
        {product.title}
      </a>
    </h3>

    <!-- Description (non-compact only) -->
    {variant !== 'compact' && product.shortDescription && (
      <p class="card-description">{product.shortDescription}</p>
    )}

    <!-- Rating -->
    <div class="card-rating">
      <ProductRating rating={product.rating} size="sm" />
    </div>

    <!-- Price & Cashback -->
    <div class="card-footer">
      <div class="price-section">
        <PriceDisplay
          price={product.price}
          originalPrice={product.originalPrice}
          currency={product.currency}
          lang={lang}
          size="md"
        />
        {showCashback && (
          <span class="cashback-hint">
            +${estimatedCashback} cashback
          </span>
        )}
      </div>

      <AffiliateLink
        productId={product.productId}
        asin={product.asin}
        affiliateUrl={product.affiliateUrl}
        lang={lang}
        variant="card"
        trackingLabel="product-card"
      >
        <span class="cta-text">{t('common.viewOnAmazon')}</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="cta-arrow">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </AffiliateLink>
    </div>
  </div>
</article>

<style>
  .product-card {
    position: relative;
    background: var(--color-white, #FFFFFF);
    border: 1px solid var(--color-sand, #E8E4DD);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-card:hover {
    border-color: var(--color-honey-muted, #E8D5C4);
    box-shadow: 0 8px 32px rgba(26, 24, 21, 0.08);
    transform: translateY(-4px);
  }

  /* Featured variant */
  .variant-featured {
    border: 2px solid var(--color-honey, #C8956C);
    background: linear-gradient(180deg, var(--color-honey-muted, #E8D5C4) 0%, var(--color-white, #FFFFFF) 40%);
  }

  .variant-featured:hover {
    box-shadow: 0 12px 40px rgba(200, 149, 108, 0.2);
  }

  /* Compact variant */
  .variant-compact .card-content {
    padding: 1rem;
    gap: 0.375rem;
  }

  .variant-compact .card-title {
    font-size: 0.875rem;
  }

  /* Badge */
  .card-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 10;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: 6px;
  }

  .badge-featured {
    background: var(--color-ink, #1A1815);
    color: var(--color-cream, #FDFBF7);
  }

  .badge-sale {
    background: var(--color-terra, #C17B5E);
    color: white;
  }

  /* Image */
  .card-image-link {
    display: block;
  }

  .card-image {
    aspect-ratio: 4/3;
    background: var(--color-cream-dark, #F7F4EE);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
  }

  .card-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 60%, rgba(26, 24, 21, 0.02) 100%);
    pointer-events: none;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 1.5rem;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-card:hover .card-image img {
    transform: scale(1.05);
  }

  .image-placeholder {
    color: var(--color-mist, #C4BFB8);
  }

  .image-placeholder svg {
    width: 3rem;
    height: 3rem;
  }

  /* Content */
  .card-content {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    flex: 1;
  }

  /* Meta */
  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .meta-brand {
    font-weight: 600;
    color: var(--color-stone, #6B6560);
  }

  .meta-separator {
    color: var(--color-sand-dark, #D4CFC6);
  }

  .meta-category {
    color: var(--color-stone-light, #9C9690);
  }

  /* Title */
  .card-title {
    font-family: var(--font-sans, 'DM Sans', sans-serif);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.4;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-title a {
    color: var(--color-ink, #1A1815);
    text-decoration: none;
    transition: color 0.2s;
  }

  .card-title a:hover {
    color: var(--color-honey-dark, #A67B5B);
  }

  /* Description */
  .card-description {
    font-size: 0.8125rem;
    color: var(--color-stone, #6B6560);
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Rating */
  .card-rating {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Footer */
  .card-footer {
    margin-top: auto;
    padding-top: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .price-section {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .cashback-hint {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-sage, #7D8B6A);
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .cashback-hint::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--color-sage, #7D8B6A);
    border-radius: 50%;
    opacity: 0.6;
  }

  /* CTA Button styling override */
  .card-footer :global(a) {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: #FF9900;
    color: #0F1111;
    font-weight: 600;
    font-size: 0.875rem;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .card-footer :global(a:hover) {
    background: #FFB030;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(255, 153, 0, 0.3);
  }

  .cta-arrow {
    width: 1rem;
    height: 1rem;
    transition: transform 0.2s;
  }

  .card-footer :global(a:hover) .cta-arrow {
    transform: translateX(2px);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .card-content {
      padding: 1rem 1.25rem 1.25rem;
    }

    .card-image img {
      padding: 1rem;
    }
  }
</style>
