---
interface Props {
  rating: number;
  totalReviews?: number;
  size?: 'sm' | 'md' | 'lg';
  showNumber?: boolean;
}

const { rating, totalReviews, size = 'md', showNumber = true } = Astro.props;

const fullStars = Math.floor(rating);
const hasHalfStar = rating % 1 >= 0.5;
const emptyStars = 5 - fullStars - (hasHalfStar ? 1 : 0);
---

<div class:list={['rating-container', `rating-${size}`]}>
  <div class="stars">
    {Array(fullStars).fill(0).map(() => (
      <svg class="star star-full" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}

    {hasHalfStar && (
      <svg class="star star-half" fill="currentColor" viewBox="0 0 20 20">
        <defs>
          <linearGradient id="half-star-brutal">
            <stop offset="50%" stop-color="var(--color-brutal-yellow, #FFE14D)" />
            <stop offset="50%" stop-color="var(--color-brutal-black, #1A1A1A)" stop-opacity="0.2" />
          </linearGradient>
        </defs>
        <path fill="url(#half-star-brutal)" d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    )}

    {Array(emptyStars).fill(0).map(() => (
      <svg class="star star-empty" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>

  {showNumber && (
    <span class="rating-number">{rating.toFixed(1)}</span>
  )}

  {totalReviews !== undefined && (
    <span class="rating-reviews">({totalReviews.toLocaleString()})</span>
  )}
</div>

<style>
  /* Neo-Brutalist Rating */
  .rating-container {
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .stars {
    display: flex;
    align-items: center;
    gap: 1px;
  }

  .star {
    flex-shrink: 0;
  }

  .star-full {
    color: var(--color-brutal-yellow, #FFE14D);
  }

  .star-empty {
    color: var(--color-brutal-black, #1A1A1A);
    opacity: 0.2;
  }

  .rating-number {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-weight: 700;
    color: var(--color-brutal-black, #1A1A1A);
  }

  .rating-reviews {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    color: var(--color-brutal-black, #1A1A1A);
    opacity: 0.5;
  }

  /* Sizes */
  .rating-sm .star {
    width: 0.875rem;
    height: 0.875rem;
  }
  .rating-sm .rating-number,
  .rating-sm .rating-reviews {
    font-size: 0.6875rem;
  }

  .rating-md .star {
    width: 1rem;
    height: 1rem;
  }
  .rating-md .rating-number,
  .rating-md .rating-reviews {
    font-size: 0.75rem;
  }

  .rating-lg .star {
    width: 1.25rem;
    height: 1.25rem;
  }
  .rating-lg .rating-number,
  .rating-lg .rating-reviews {
    font-size: 0.875rem;
  }
</style>
