---
import ProductCard from './ProductCard.astro';
import { type Lang } from '@i18n/utils';

interface Product {
  productId: string;
  asin: string;
  title: string;
  brand: string;
  price: number;
  originalPrice?: number;
  currency: string;
  rating: number;
  featuredImage: { url: string; alt: string };
  affiliateUrl: string;
  isOnSale?: boolean;
  isFeatured?: boolean;
}

interface Props {
  products: Product[];
  lang: Lang;
  columns?: 2 | 3 | 4;
}

const { products, lang, columns = 3 } = Astro.props;

const gridClasses = {
  2: 'grid-cols-1 sm:grid-cols-2',
  3: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3',
  4: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4'
};
---

<div class:list={['grid gap-6', gridClasses[columns]]}>
  {products.map((product) => (
    <ProductCard product={product} lang={lang} />
  ))}
</div>
