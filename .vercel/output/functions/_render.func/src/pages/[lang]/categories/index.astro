---
import BaseLayout from '@layouts/BaseLayout.astro';
import { type Lang, getTranslation } from '@i18n/utils';
import categories from '@data/categories.json';

const { lang } = Astro.params as { lang: Lang };

// Validate lang parameter
const validLangs = ['es', 'en'];
if (!validLangs.includes(lang)) {
  return Astro.redirect('/es/categories/', 302);
}

const t = getTranslation(lang);

const pageContent = {
  es: {
    title: 'Categorias',
    subtitle: 'Explora productos por categoria',
    description: 'Encuentra los mejores productos organizados por categoria. Desde electronica hasta fitness, tenemos todo lo que necesitas.',
    viewProducts: 'Ver productos',
  },
  en: {
    title: 'Categories',
    subtitle: 'Explore products by category',
    description: 'Find the best products organized by category. From electronics to fitness, we have everything you need.',
    viewProducts: 'View products',
  },
};

const content = pageContent[lang];

// Icon mapping
const iconMap: Record<string, string> = {
  laptop: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />`,
  home: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />`,
  gamepad: `<path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 01-.657.643 48.39 48.39 0 01-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 01-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 00-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 01-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 00.657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 01-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.4.604-.4.959v0c0 .333.277.599.61.58a48.1 48.1 0 005.427-.63 48.05 48.05 0 00.582-4.717.532.532 0 00-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.959.401v0a.656.656 0 00.658-.663 48.422 48.422 0 00-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 01-.61-.58v0z" />`,
  dumbbell: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12" />`,
};
---

<BaseLayout
  title={content.title}
  description={content.description}
  lang={lang}
>
  <div class="categories-page">
    <!-- Hero Section -->
    <section class="hero-section">
      <div class="hero-content">
        <span class="hero-eyebrow">{lang === 'es' ? 'Descubre' : 'Discover'}</span>
        <h1 class="hero-title">{content.title}</h1>
        <p class="hero-description">{content.description}</p>
      </div>
    </section>

    <!-- Categories Grid -->
    <section class="categories-section">
      <div class="section-container">
        <div class="categories-grid">
          {categories.categories.map((category, index) => (
            <a
              href={`/${lang}/categories/${category.id}`}
              class="category-card"
              style={`--card-delay: ${index * 100}ms;`}
            >
              <div class="card-image">
                <div class="image-placeholder">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <Fragment set:html={iconMap[category.icon] || iconMap.laptop} />
                  </svg>
                </div>
                <div class="card-overlay"></div>
              </div>
              <div class="card-content">
                <div class="card-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <Fragment set:html={iconMap[category.icon] || iconMap.laptop} />
                  </svg>
                </div>
                <h2 class="card-title">{category.name[lang]}</h2>
                <p class="card-description">{category.description[lang]}</p>
                <span class="card-link">
                  {content.viewProducts}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .categories-page {
    min-height: 100vh;
  }

  /* Hero Section */
  .hero-section {
    background: linear-gradient(180deg, var(--color-cream, #FDFBF7) 0%, var(--color-white, #FFFFFF) 100%);
    padding: 4rem 1.5rem 3rem;
    text-align: center;
  }

  .hero-content {
    max-width: 600px;
    margin: 0 auto;
  }

  .hero-eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-honey, #C8956C);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .hero-title {
    font-family: var(--font-display, 'Fraunces', Georgia, serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 400;
    color: var(--color-ink, #1A1815);
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }

  .hero-description {
    font-size: 1.125rem;
    color: var(--color-stone, #6B6560);
    line-height: 1.6;
    margin: 0;
  }

  /* Categories Section */
  .categories-section {
    background: var(--color-white, #FFFFFF);
  }

  .section-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  /* Category Card */
  .category-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--color-cream, #FDFBF7);
    border: 1px solid var(--color-sand, #E8E4DD);
    border-radius: 20px;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: var(--card-delay, 0ms);
  }

  .category-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(26, 24, 21, 0.1);
    border-color: var(--color-honey-muted, #E8D5C4);
  }

  .card-image {
    position: relative;
    aspect-ratio: 16/9;
    background: linear-gradient(135deg, var(--color-sand, #E8E4DD) 0%, var(--color-cream-dark, #F7F4EE) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .image-placeholder {
    color: var(--color-mist, #C4BFB8);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .image-placeholder svg {
    width: 4rem;
    height: 4rem;
  }

  .category-card:hover .image-placeholder {
    transform: scale(1.1);
    color: var(--color-honey, #C8956C);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(26, 24, 21, 0.02) 100%);
  }

  .card-content {
    padding: 1.5rem 1.75rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-icon {
    display: none;
    width: 2.5rem;
    height: 2.5rem;
    color: var(--color-honey, #C8956C);
    margin-bottom: 0.25rem;
  }

  .card-icon svg {
    width: 100%;
    height: 100%;
  }

  .card-title {
    font-family: var(--font-display, 'Fraunces', Georgia, serif);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--color-ink, #1A1815);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .card-description {
    font-size: 0.9375rem;
    color: var(--color-stone, #6B6560);
    line-height: 1.5;
    margin: 0;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-honey-dark, #A67B5B);
    transition: gap 0.2s;
  }

  .card-link svg {
    width: 1rem;
    height: 1rem;
    transition: transform 0.2s;
  }

  .category-card:hover .card-link {
    gap: 0.75rem;
  }

  .category-card:hover .card-link svg {
    transform: translateX(2px);
  }

  /* Animation */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Responsive */
  @media (min-width: 768px) {
    .hero-section {
      padding: 5rem 1.5rem 4rem;
    }

    .categories-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }

    .card-content {
      padding: 1.75rem 2rem 2rem;
    }

    .card-title {
      font-size: 1.75rem;
    }
  }

  @media (min-width: 1024px) {
    .categories-grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .card-image {
      aspect-ratio: 4/3;
    }

    .card-title {
      font-size: 1.25rem;
    }

    .card-description {
      font-size: 0.875rem;
    }
  }

  @media (max-width: 640px) {
    .categories-grid {
      grid-template-columns: 1fr;
    }

    .hero-section {
      padding: 3rem 1rem 2rem;
    }

    .section-container {
      padding: 2rem 1rem 4rem;
    }
  }
</style>
