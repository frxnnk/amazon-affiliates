---
export const prerender = false;

import AdminLayout from '@components/admin/AdminLayout.astro';
import { getAllProducts } from '@lib/db';

const allProducts = await getAllProducts();
const products = allProducts.sort((a, b) =>
  new Date(b.updatedAt || b.createdAt).getTime() - new Date(a.updatedAt || a.createdAt).getTime()
);
---

<AdminLayout title="Productos">
  <style>
    .products-page {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }

    /* Toolbar */
    .toolbar {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }

    @media (min-width: 480px) {
      .toolbar {
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
      }
    }

    .product-count {
      font-size: 0.875rem;
      color: var(--text-muted);
    }

    .product-count strong {
      color: var(--text-primary);
      font-weight: 600;
    }

    .toolbar-actions {
      display: flex;
      gap: var(--space-sm);
    }

    .toolbar-actions .admin-btn {
      flex: 1;
    }

    @media (min-width: 480px) {
      .toolbar-actions .admin-btn {
        flex: initial;
      }
    }

    /* Product List - Card Layout for Mobile */
    .products-list {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }

    .product-card {
      background: var(--bg-surface);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius);
      padding: var(--space-md);
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }

    .product-main {
      display: flex;
      gap: var(--space-md);
      align-items: flex-start;
    }

    .product-image {
      width: 56px;
      height: 56px;
      border-radius: var(--radius-sm);
      background: var(--bg-hover);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      overflow: hidden;
    }

    .product-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .product-image svg {
      width: 24px;
      height: 24px;
      color: var(--text-muted);
    }

    .product-info {
      flex: 1;
      min-width: 0;
    }

    .product-title {
      font-size: 0.9375rem;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 4px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .product-meta {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: var(--space-sm);
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    .product-asin {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6875rem;
      background: var(--bg-base);
      padding: 2px 6px;
      border-radius: 4px;
    }

    .product-details {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-sm);
      padding-top: var(--space-sm);
      border-top: 1px solid var(--border-subtle);
    }

    .product-tags {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      flex-wrap: wrap;
    }

    .product-price {
      font-size: 1rem;
      font-weight: 700;
      color: var(--text-primary);
      font-feature-settings: 'tnum';
    }

    .product-price-original {
      font-size: 0.75rem;
      color: var(--text-muted);
      text-decoration: line-through;
      margin-left: var(--space-xs);
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 3px 8px;
      border-radius: 999px;
      font-size: 0.625rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }

    .badge-dot {
      width: 5px;
      height: 5px;
      border-radius: 50%;
    }

    .badge-published {
      background: var(--success-muted);
      color: var(--success);
    }

    .badge-published .badge-dot {
      background: var(--success);
    }

    .badge-draft {
      background: var(--warning-muted);
      color: var(--warning);
    }

    .badge-draft .badge-dot {
      background: var(--warning);
    }

    .badge-lang {
      background: rgba(99, 102, 241, 0.12);
      color: #818cf8;
    }

    .product-actions {
      display: flex;
      align-items: center;
      gap: var(--space-xs);
    }

    .action-btn {
      width: 36px;
      height: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: var(--radius-sm);
      color: var(--text-muted);
      background: transparent;
      border: none;
      cursor: pointer;
      transition: all var(--duration) var(--ease);
      text-decoration: none;
    }

    .action-btn:hover {
      background: var(--bg-hover);
      color: var(--text-primary);
    }

    .action-btn.danger:hover {
      background: var(--error-muted);
      color: var(--error);
    }

    .action-btn svg {
      width: 18px;
      height: 18px;
    }

    /* Desktop Table Layout */
    @media (min-width: 769px) {
      .products-list {
        display: block;
        background: var(--bg-surface);
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius);
        overflow: hidden;
      }

      .product-card {
        border: none;
        border-radius: 0;
        padding: 0;
        flex-direction: row;
        align-items: center;
        gap: 0;
        border-bottom: 1px solid var(--border-subtle);
      }

      .product-card:last-child {
        border-bottom: none;
      }

      .product-card:hover {
        background: var(--bg-hover);
      }

      .product-main {
        flex: 1;
        padding: var(--space-md);
        min-width: 0;
      }

      .product-image {
        width: 48px;
        height: 48px;
      }

      .product-title {
        -webkit-line-clamp: 1;
        max-width: 300px;
      }

      .product-details {
        border-top: none;
        padding: var(--space-md);
        padding-left: 0;
        gap: var(--space-lg);
        justify-content: flex-end;
        flex-wrap: nowrap;
      }

      .product-tags {
        flex-wrap: nowrap;
      }

      .product-price {
        min-width: 100px;
        text-align: right;
      }
    }

    /* Empty State */
    .empty-state {
      background: var(--bg-surface);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius);
      padding: var(--space-2xl) var(--space-md);
      text-align: center;
    }

    .empty-icon {
      width: 64px;
      height: 64px;
      margin: 0 auto var(--space-md);
      background: var(--bg-hover);
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .empty-icon svg {
      width: 32px;
      height: 32px;
      color: var(--text-muted);
    }

    .empty-state h3 {
      font-size: 1.125rem;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: var(--space-xs);
    }

    .empty-state p {
      font-size: 0.875rem;
      color: var(--text-muted);
      margin-bottom: var(--space-lg);
      max-width: 280px;
      margin-left: auto;
      margin-right: auto;
    }
  </style>

  <div class="products-page">
    <div class="toolbar">
      <span class="product-count">
        <strong>{products.length}</strong> productos
      </span>
      <div class="toolbar-actions">
        <a href="/admin/products/import" class="admin-btn admin-btn-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="17 8 12 3 7 8"/>
            <line x1="12" y1="3" x2="12" y2="15"/>
          </svg>
          Importar
        </a>
        <a href="/admin/products/new" class="admin-btn admin-btn-secondary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"/>
            <line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
          Nuevo
        </a>
      </div>
    </div>

    {products.length > 0 ? (
      <div class="products-list">
        {products.map((product) => (
          <div class="product-card">
            <div class="product-main">
              <div class="product-image">
                {product.featuredImageUrl ? (
                  <img src={product.featuredImageUrl} alt={product.title} loading="lazy" />
                ) : (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                    <circle cx="8.5" cy="8.5" r="1.5"/>
                    <polyline points="21 15 16 10 5 21"/>
                  </svg>
                )}
              </div>
              <div class="product-info">
                <div class="product-title">{product.title}</div>
                <div class="product-meta">
                  <code class="product-asin">{product.asin}</code>
                  <span>{product.brand}</span>
                </div>
              </div>
            </div>

            <div class="product-details">
              <div class="product-tags">
                <span class="badge badge-lang">{product.lang?.toUpperCase() || 'ES'}</span>
                <span class={`badge badge-${product.status}`}>
                  <span class="badge-dot"></span>
                  {product.status === 'published' ? 'Publicado' : 'Borrador'}
                </span>
              </div>

              <div class="product-price">
                {product.price} {product.currency || 'EUR'}
                {product.originalPrice && product.originalPrice > product.price && (
                  <span class="product-price-original">{product.originalPrice}</span>
                )}
              </div>

              <div class="product-actions">
                <a href={`/admin/products/${product.id}`} class="action-btn" title="Editar">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                  </svg>
                </a>
                <a href={`/${product.lang || 'es'}/products/${product.productId}`} target="_blank" class="action-btn" title="Ver">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                    <polyline points="15 3 21 3 21 9"/>
                    <line x1="10" y1="14" x2="21" y2="3"/>
                  </svg>
                </a>
                <button type="button" class="action-btn danger delete-btn" data-id={product.id} data-title={product.title} title="Eliminar">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="3 6 5 6 21 6"/>
                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <div class="empty-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
            <line x1="12" y1="22.08" x2="12" y2="12"/>
          </svg>
        </div>
        <h3>No hay productos</h3>
        <p>Importa tu primer producto desde Amazon para comenzar</p>
        <a href="/admin/products/import" class="admin-btn admin-btn-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="17 8 12 3 7 8"/>
            <line x1="12" y1="3" x2="12" y2="15"/>
          </svg>
          Importar producto
        </a>
      </div>
    )}
  </div>

  <script>
    document.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-id');
        const title = btn.getAttribute('data-title');

        if (!confirm(`¿Eliminar "${title}"?`)) return;

        try {
          const res = await fetch(`/api/admin/products/${id}`, {
            method: 'DELETE',
            credentials: 'include',
          });

          if (res.ok) {
            window.location.reload();
          } else {
            const data = await res.json();
            alert(data.error || 'Error al eliminar');
          }
        } catch {
          alert('Error de conexion');
        }
      });
    });
  </script>
</AdminLayout>
