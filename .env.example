# ============================================================================
# AMAZON AFFILIATES - Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values
# Required variables are marked with [REQUIRED]
# ============================================================================

# ----------------------------------------------------------------------------
# AUTHENTICATION (Clerk) [REQUIRED]
# Get credentials from https://clerk.com/
# ----------------------------------------------------------------------------
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Admin emails - comma-separated list of emails that have admin access
ADMIN_EMAILS=admin@example.com,owner@example.com

# Clerk redirect URLs
PUBLIC_CLERK_SIGN_IN_URL=/admin/login
PUBLIC_CLERK_SIGN_UP_URL=/admin/login
PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin
PUBLIC_CLERK_AFTER_SIGN_UP_URL=/admin

# ----------------------------------------------------------------------------
# DATABASE (Astro DB / Turso) [REQUIRED for production]
# Get credentials from https://turso.tech/
# ----------------------------------------------------------------------------
ASTRO_DB_REMOTE_URL=libsql://your-db-name.turso.io
ASTRO_DB_APP_TOKEN=your-turso-token

# ----------------------------------------------------------------------------
# GITHUB CMS [REQUIRED]
# Used to create/edit product markdown files
# Create a personal access token at https://github.com/settings/tokens
# ----------------------------------------------------------------------------
GITHUB_TOKEN=ghp_xxx
GITHUB_OWNER=your-username
GITHUB_REPO=amazon-affiliates
GITHUB_BRANCH=main

# ----------------------------------------------------------------------------
# AMAZON PRODUCT DATA APIs
# ----------------------------------------------------------------------------

# Amazon Creators API (OAuth 2.0) - PRIMARY [RECOMMENDED]
# New API that replaces PA-API 5.0. Get credentials from:
# Amazon Associates Central > Tools > Creators API
# Docs: https://developer.amazon.com/docs/creators-api
AMAZON_CREATORS_CREDENTIAL_ID=
AMAZON_CREATORS_CREDENTIAL_SECRET=

# Amazon Affiliate Partner Tag [REQUIRED]
# Your Amazon Associates tracking tag (e.g., mytag-20)
# Get from https://affiliate-program.amazon.com/
AMAZON_PA_API_PARTNER_TAG=your-tag-20

# RapidAPI - Real-Time Amazon Data [RECOMMENDED as fallback]
# Used for product search and as fallback for product details
# 500 free requests/month
# Get key from https://rapidapi.com/letscrape-6bRBa3QguO5/api/real-time-amazon-data
RAPIDAPI_KEY=

# Amazon PA-API 5.0 (DEPRECATED - Remove after Jan 31, 2026)
# Offers V1 endpoint deprecated. Migrate to Creators API above.
# AMAZON_PA_API_ACCESS_KEY=
# AMAZON_PA_API_SECRET_KEY=
# AMAZON_PA_API_MARKETPLACE=com

# ----------------------------------------------------------------------------
# AI FEATURES (OpenAI) [OPTIONAL]
# Used for deal analysis and content generation
# Get key from https://platform.openai.com/api-keys
# ----------------------------------------------------------------------------
OPENAI_API_KEY=

# ----------------------------------------------------------------------------
# VIDEO INTEGRATION (YouTube) [OPTIONAL]
# Used to show product review videos in the feed
# Free tier: 10,000 units/day (~100 video searches)
# Get key from https://console.cloud.google.com/apis/credentials
# Enable: YouTube Data API v3
# ----------------------------------------------------------------------------
YOUTUBE_API_KEY=

# ----------------------------------------------------------------------------
# PRICE HISTORY (Keepa) [OPTIONAL]
# Used to validate deals and show price history
# Get key from https://keepa.com/#!api
# ----------------------------------------------------------------------------
KEEPA_API_KEY=

# ----------------------------------------------------------------------------
# SOCIAL MEDIA & NOTIFICATIONS [OPTIONAL]
# Used by Deal Agent for automated posting
# ----------------------------------------------------------------------------

# Twitter/X API
# Get credentials from https://developer.twitter.com/
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Discord Webhook
# Create webhook in Discord Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=

# Telegram Bot
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# ----------------------------------------------------------------------------
# CRON JOBS [OPTIONAL]
# Secret to protect cron endpoints from unauthorized access
# ----------------------------------------------------------------------------
CRON_SECRET=your-random-secret-here

# ----------------------------------------------------------------------------
# EXPERIMENTAL [OPTIONAL]
# ----------------------------------------------------------------------------

# Tripo3D API - For 3D product models
# TRIPO_API_KEY=
