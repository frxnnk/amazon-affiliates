# Clerk Authentication
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Admin emails (comma-separated list of emails that have admin access)
ADMIN_EMAILS=admin@example.com,owner@example.com
PUBLIC_CLERK_SIGN_IN_URL=/admin/login
PUBLIC_CLERK_SIGN_UP_URL=/admin/login
PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin
PUBLIC_CLERK_AFTER_SIGN_UP_URL=/admin

# GitHub API (para crear/editar archivos Markdown)
GITHUB_TOKEN=ghp_xxx
GITHUB_OWNER=tu-usuario
GITHUB_REPO=amazon-affiliates
GITHUB_BRANCH=main

# Astro DB (Turso) - for production
# Get these from https://turso.tech/
ASTRO_DB_REMOTE_URL=libsql://your-db-name.turso.io
ASTRO_DB_APP_TOKEN=your-turso-token

# Amazon Product Advertising API (PA-API) - Optional
# Get these from Amazon Associates program
# If not configured, product import will fall back to web scraping
AMAZON_PAAPI_ACCESS_KEY=your-access-key
AMAZON_PAAPI_SECRET_KEY=your-secret-key
# Partner tag is optional - uses site-config.json values by default
# AMAZON_PAAPI_PARTNER_TAG=your-tag-20
